                              <td class="px-3 py-2.5 sm:px-5 sm:py-3">
                                  <span class="inline-flex items-center whitespace-nowrap rounded-full bg-amber-50 px-2 py-0.5 text-xs font-medium text-amber-700 dark:bg-amber-900/30 dark:text-amber-300">Late (2m)</span>
                              </td>
                          </tr>
                          <tr>
                              <td class="px-3 py-2.5 text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">Feb 20, 2025</td>
                              <td class="hidden px-3 py-2.5 tabular-nums text-slate-600 dark:text-slate-400 sm:table-cell sm:px-5 sm:py-3">07:58</td>
