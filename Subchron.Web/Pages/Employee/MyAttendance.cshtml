@page
@model Subchron.Web.Pages.Employee.MyAttendanceModel
@{
    ViewData["Title"] = "Attendance & Schedule";
    ViewData["PageTitle"] = "Attendance & Schedule";
    Layout = "/Pages/Employee/Shared/_LayoutEmployee.cshtml";
}

<div class="w-full px-3 sm:px-4">
    <div class="mb-4 flex gap-3 border-b border-slate-200 dark:border-slate-700 sm:mb-6 sm:gap-6">
        <button type="button" id="tabRecord" class="emp-tab border-b-2 border-subgreen-600 pb-2 text-xs font-semibold text-subgreen-600 dark:border-subgreen-400 dark:text-subgreen-400 sm:text-sm">Attendance Record</button>
        <button type="button" id="tabSchedule" class="emp-tab border-b-2 border-transparent pb-2 text-xs font-semibold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300 sm:text-sm">My Schedule</button>
    </div>

      <div id="panelRecord" class="space-y-3 sm:space-y-4">
          <p class="text-xs text-slate-500 dark:text-slate-400 sm:text-sm">Your time in/out history. Use Time In / Out or QR at kiosk to record attendance.</p>
          <div class="flex items-center gap-2 text-xs text-slate-600 dark:text-slate-300 sm:text-sm">
              <label for="hourlyRateInput" class="font-medium">Rate per hour</label>
              <input type="number" id="hourlyRateInput" min="0" step="0.01" value="100" class="h-9 w-28 rounded-lg border border-slate-200 bg-white px-2 text-right text-sm text-slate-800 dark:border-slate-600 dark:bg-slate-700 dark:text-white" />
              <span class="text-slate-500 dark:text-slate-400">Earnings are computed from worked time only.</span>
          </div>
          <div class="flex gap-1 sm:gap-2">
              <input type="date" id="recordFrom" class="flex-1 min-w-0 rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-xs text-slate-900 focus:border-subgreen-500 focus:ring-1 focus:ring-subgreen-500/20 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 sm:px-3 sm:py-2" placeholder="From" />
              <input type="date" id="recordTo" class="flex-1 min-w-0 rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-xs text-slate-900 focus:border-subgreen-500 focus:ring-1 focus:ring-subgreen-500/20 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 sm:px-3 sm:py-2" placeholder="To" />
              <button type="button" id="recordClearBtn" class="flex-shrink-0 rounded-lg bg-slate-200 px-2 py-1.5 text-slate-600 hover:bg-slate-300 dark:bg-slate-700 dark:text-slate-300 dark:hover:bg-slate-600 sm:px-3 sm:py-2" title="Clear filters">
                  <svg class="h-4 w-4 sm:h-5 sm:w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
              </button>
          </div>
         <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:rounded-2xl">
             <div class="overflow-x-auto">
                 <table class="w-full text-left text-xs sm:text-sm">
                      <thead>
                          <tr class="border-y border-slate-100 bg-slate-50/50 dark:border-slate-700 dark:bg-slate-800/50">
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Date</th>
                              <th class="hidden px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:table-cell sm:px-5 sm:py-3">Time in</th>
                              <th class="hidden px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:table-cell sm:px-5 sm:py-3">Time out</th>
                              <th class="hidden px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:table-cell sm:px-5 sm:py-3">Hours</th>
                              <th class="hidden px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:table-cell sm:px-5 sm:py-3">Earnings</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Status</th>
                          </tr>
                      </thead>
                     <tbody id="attendanceTableBody" class="divide-y divide-slate-100 dark:divide-slate-700">
                           <tr><td colspan="6" class="px-3 py-6 text-center text-slate-500 dark:text-slate-400 sm:px-5">Loading attendance records...</td></tr>
                      </tbody>
                  </table>
              </div>
          </div>
     </div>

      <div id="panelSchedule" class="hidden space-y-3 sm:space-y-4">
          <p class="text-xs text-slate-500 dark:text-slate-400 sm:text-sm">Your assigned shift schedule. Contact HR if you need changes.</p>
          <div class="rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:rounded-2xl">
              <div class="border-b border-slate-100 px-3 py-3 dark:border-slate-700 sm:px-5 sm:py-4">
                  <h3 class="text-xs font-semibold text-slate-800 dark:text-slate-200 sm:text-sm">Regular schedule</h3>
                  <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">Mon – Fri (unless on leave or holiday)</p>
              </div>
              <div class="overflow-x-auto">
                  <table class="w-full text-left text-xs sm:text-sm">
                      <thead>
                          <tr class="border-y border-slate-100 bg-slate-50/50 dark:border-slate-700 dark:bg-slate-800/50">
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Department</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Day</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Shift</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Time</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Site Location</th>
                          </tr>
                      </thead>
                      <tbody id="scheduleTableBody" class="divide-y divide-slate-100 dark:divide-slate-700">
                          <tr><td colspan="5" class="px-3 py-6 text-center text-slate-500 dark:text-slate-400 sm:px-5">Loading schedule...</td></tr>
                      </tbody>
                  </table>
              </div>
          </div>
          <div class="rounded-lg border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:rounded-2xl">
              <div class="border-b border-slate-100 px-3 py-3 dark:border-slate-700 sm:px-5 sm:py-4">
                  <h3 class="text-xs font-semibold text-slate-800 dark:text-slate-200 sm:text-sm">Assigned shift schedule</h3>
                  <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">Temporary or manually assigned shifts for specific dates.</p>
              </div>
              <div class="overflow-x-auto">
                  <table class="w-full text-left text-xs sm:text-sm">
                      <thead>
                          <tr class="border-y border-slate-100 bg-slate-50/50 dark:border-slate-700 dark:bg-slate-800/50">
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Date</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Day</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Shift</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Time</th>
                              <th class="px-3 py-2.5 font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300 sm:px-5 sm:py-3">Department</th>
                          </tr>
                      </thead>
                      <tbody id="assignedShiftTableBody" class="divide-y divide-slate-100 dark:divide-slate-700">
                          <tr><td colspan="5" class="px-3 py-6 text-center text-slate-500 dark:text-slate-400 sm:px-5">Loading assigned shifts...</td></tr>
                      </tbody>
                  </table>
              </div>
          </div>
          <div class="rounded-lg border border-sky-200 bg-sky-50/50 p-3 dark:border-sky-800 dark:bg-sky-900/20 sm:rounded-2xl sm:p-4">
              <p class="text-xs font-medium text-sky-800 dark:text-sky-200 sm:text-sm">Need a different shift?</p>
              <p class="mt-0.5 text-xs text-sky-700 dark:text-sky-300 sm:mt-1 sm:text-sm">Contact your supervisor or HR to request schedule changes.</p>
          </div>
      </div>
 </div>

@section Scripts {
<script>
(function () {
    var tabRecord = document.getElementById('tabRecord');
    var tabSchedule = document.getElementById('tabSchedule');
    var panelRecord = document.getElementById('panelRecord');
    var panelSchedule = document.getElementById('panelSchedule');
    var recordFrom = document.getElementById('recordFrom');
    var recordTo = document.getElementById('recordTo');
    var recordClearBtn = document.getElementById('recordClearBtn');
    var hourlyRateInput = document.getElementById('hourlyRateInput');
    var attendanceTableBody = document.getElementById('attendanceTableBody');
    var scheduleTableBody = document.getElementById('scheduleTableBody');
    var assignedShiftTableBody = document.getElementById('assignedShiftTableBody');

    function formatTime(dt) {
        if (!dt) return '—';
        var d = new Date(dt);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
    }

    function formatTimeAmPm(dt) {
        if (!dt) return '—';
        var d = new Date(dt);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true });
    }

    function statusBadge(status) {
        var s = String(status || '').toLowerCase();
        if (s === 'present') return 'bg-subgreen-50 text-subgreen-700 dark:bg-subgreen-900/30 dark:text-subgreen-300';
        if (s === 'timed in') return 'bg-sky-50 text-sky-700 dark:bg-sky-900/30 dark:text-sky-300';
        if (s === 'late-in') return 'bg-orange-50 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300';
        if (s === 'undertime') return 'bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300';
        if (s === 'overtime') return 'bg-violet-50 text-violet-700 dark:bg-violet-900/30 dark:text-violet-300';
        if (s === 'late-in + undertime') return 'bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-300';
        return 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300';
    }

    function parseNumber(value, fallback) {
        var n = Number(value);
        return isFinite(n) ? n : fallback;
    }

    function getHourlyRate() {
        return Math.max(0, parseNumber(hourlyRateInput && hourlyRateInput.value, 100));
    }

    function workedMinutesFromRow(x) {
        var worked = Number(x && x.workedMinutes);
        if (isFinite(worked) && worked > 0) return worked;
        var timeIn = x && x.timeIn ? new Date(x.timeIn) : null;
        var timeOut = x && x.timeOut ? new Date(x.timeOut) : null;
        if (!timeIn || !timeOut || isNaN(timeIn.getTime()) || isNaN(timeOut.getTime())) return 0;
        var diff = Math.floor((timeOut.getTime() - timeIn.getTime()) / 60000);
        return diff > 0 ? diff : 0;
    }

    function fmtCurrency(value) {
        var n = Number(value || 0);
        if (!isFinite(n) || n <= 0) return '—';
        return new Intl.NumberFormat(undefined, { style: 'currency', currency: 'PHP' }).format(n);
    }

    function loadAttendance() {
        var from = recordFrom && recordFrom.value ? recordFrom.value : '';
        var to = recordTo && recordTo.value ? recordTo.value : '';
        var qs = '?handler=Record' + (from ? '&from=' + encodeURIComponent(from) : '') + (to ? '&to=' + encodeURIComponent(to) : '');
        fetch(qs, { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (rows) {
                if (!attendanceTableBody) return;
                if (!rows || !rows.length) {
                    attendanceTableBody.innerHTML = '<tr><td colspan="6" class="px-3 py-6 text-center text-slate-500 dark:text-slate-400 sm:px-5">No attendance record found.</td></tr>';
                    return;
                }
                var hourlyRate = getHourlyRate();
                attendanceTableBody.innerHTML = rows.map(function (x) {
                    var dateText = x.logDate ? new Date(String(x.logDate).substring(0, 10) + 'T00:00:00').toLocaleDateString() : '—';
                    var status = x.status || (x.timeOut ? 'Present' : 'Timed In');
                    var badge = statusBadge(status);
                    var workedMinutes = workedMinutesFromRow(x);
                    var hours = workedMinutes > 0 ? (workedMinutes / 60).toFixed(2) : '—';
                    var earnings = workedMinutes > 0 ? (workedMinutes / 60) * hourlyRate : 0;
                    return '<tr>' +
                        '<td class="px-3 py-2.5 text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">' + dateText + '</td>' +
                        '<td class="hidden px-3 py-2.5 tabular-nums text-slate-600 dark:text-slate-400 sm:table-cell sm:px-5 sm:py-3">' + formatTime(x.timeIn) + '</td>' +
                        '<td class="hidden px-3 py-2.5 tabular-nums text-slate-600 dark:text-slate-400 sm:table-cell sm:px-5 sm:py-3">' + formatTime(x.timeOut) + '</td>' +
                        '<td class="hidden px-3 py-2.5 tabular-nums text-slate-600 dark:text-slate-400 sm:table-cell sm:px-5 sm:py-3">' + hours + '</td>' +
                        '<td class="hidden px-3 py-2.5 tabular-nums font-medium text-subgreen-700 dark:text-subgreen-300 sm:table-cell sm:px-5 sm:py-3">' + fmtCurrency(earnings) + '</td>' +
                        '<td class="px-3 py-2.5 sm:px-5 sm:py-3"><span class="inline-flex items-center whitespace-nowrap rounded-full px-2 py-0.5 text-xs font-medium ' + badge + '">' + status + '</span></td>' +
                        '</tr>';
                }).join('');
            });
    }

    function loadSchedule() {
        fetch('?handler=Schedule', { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (rows) {
                if (!scheduleTableBody) return;
                if (!rows || !rows.length) {
                    scheduleTableBody.innerHTML = '<tr><td colspan="5" class="px-3 py-6 text-center text-slate-500 dark:text-slate-400 sm:px-5">No schedule assigned.</td></tr>';
                    return;
                }

                var order = { monday: 1, tuesday: 2, wednesday: 3, thursday: 4, friday: 5, saturday: 6, sunday: 7 };
                rows = rows.slice().sort(function (a, b) {
                    var da = String(a.dayName || '').toLowerCase();
                    var db = String(b.dayName || '').toLowerCase();
                    var oa = order[da] || 99;
                    var ob = order[db] || 99;
                    return oa - ob;
                });

                scheduleTableBody.innerHTML = rows.map(function (x) {
                    var day = x.dayName || new Date(x.date).toLocaleDateString(undefined, { weekday: 'long' });
                    var shiftName = x.shiftName || 'No shift assigned';
                    var dept = x.departmentName || '—';
                    var site = x.siteName || '—';
                    var timeText = x.shiftStart && x.shiftEnd
                        ? (formatTimeAmPm(x.shiftStart) + ' - ' + formatTimeAmPm(x.shiftEnd))
                        : '—';
                    return '<tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50">' +
                        '<td class="px-3 py-2.5 font-medium text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">' + dept + '</td>' +
                        '<td class="px-3 py-2.5 font-medium text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">' + day + '</td>' +
                        '<td class="px-3 py-2.5 text-slate-600 dark:text-slate-400 sm:px-5 sm:py-3">' + shiftName + '</td>' +
                        '<td class="px-3 py-2.5 tabular-nums font-medium text-subgreen-600 dark:text-subgreen-400 sm:px-5 sm:py-3">' + timeText + '</td>' +
                        '<td class="px-3 py-2.5 text-slate-500 dark:text-slate-400 sm:px-5 sm:py-3">' + site + '</td>' +
                        '</tr>';
                }).join('');
            });
    }

    function loadAssignedShifts() {
        fetch('?handler=AssignedShifts', { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (rows) {
                if (!assignedShiftTableBody) return;
                if (!rows || !rows.length) {
                    assignedShiftTableBody.innerHTML = '<tr><td colspan="5" class="px-3 py-6 text-center text-slate-500 dark:text-slate-400 sm:px-5">No assigned shifts found.</td></tr>';
                    return;
                }

                assignedShiftTableBody.innerHTML = rows.map(function (x) {
                    var dateText = x.date ? new Date(String(x.date).substring(0, 10) + 'T00:00:00').toLocaleDateString() : '—';
                    var day = x.dayName || (x.date ? new Date(x.date).toLocaleDateString(undefined, { weekday: 'long' }) : '—');
                    var shiftName = x.shiftName || 'Assigned Shift';
                    var dept = x.departmentName || '—';
                    var timeText = x.shiftStart && x.shiftEnd
                        ? (formatTimeAmPm(x.shiftStart) + ' - ' + formatTimeAmPm(x.shiftEnd))
                        : '—';
                    return '<tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50">' +
                        '<td class="px-3 py-2.5 text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">' + dateText + '</td>' +
                        '<td class="px-3 py-2.5 text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">' + day + '</td>' +
                        '<td class="px-3 py-2.5 font-medium text-slate-700 dark:text-slate-300 sm:px-5 sm:py-3">' + shiftName + '</td>' +
                        '<td class="px-3 py-2.5 tabular-nums font-medium text-subgreen-600 dark:text-subgreen-400 sm:px-5 sm:py-3">' + timeText + '</td>' +
                        '<td class="px-3 py-2.5 text-slate-500 dark:text-slate-400 sm:px-5 sm:py-3">' + dept + '</td>' +
                        '</tr>';
                }).join('');
            });
    }

    function setActiveTab(active) {
        var isRecord = active === 'record';
        panelRecord.classList.toggle('hidden', !isRecord);
        panelSchedule.classList.toggle('hidden', isRecord);
        tabRecord.classList.toggle('border-subgreen-600', isRecord);
        tabRecord.classList.toggle('text-subgreen-600', isRecord);
        tabRecord.classList.toggle('dark:border-subgreen-400', isRecord);
        tabRecord.classList.toggle('dark:text-subgreen-400', isRecord);
        tabRecord.classList.toggle('border-transparent', !isRecord);
        tabSchedule.classList.toggle('border-subgreen-600', !isRecord);
        tabSchedule.classList.toggle('text-subgreen-600', !isRecord);
        tabSchedule.classList.toggle('dark:border-subgreen-400', !isRecord);
        tabSchedule.classList.toggle('dark:text-subgreen-400', !isRecord);
        tabSchedule.classList.toggle('border-transparent', isRecord);
    }

    tabRecord && tabRecord.addEventListener('click', function () { setActiveTab('record'); });
    tabSchedule && tabSchedule.addEventListener('click', function () { setActiveTab('schedule'); });

    if (recordFrom && recordTo) {
        var today = new Date();
        var weekAgo = new Date(today);
        weekAgo.setDate(weekAgo.getDate() - 14);
        recordTo.value = today.toISOString().slice(0, 10);
        recordFrom.value = weekAgo.toISOString().slice(0, 10);
    }
    recordClearBtn && recordClearBtn.addEventListener('click', function () {
        if (recordFrom && recordTo) {
            recordFrom.value = '';
            recordTo.value = '';
        }
        loadAttendance();
    });

    recordFrom && recordFrom.addEventListener('change', loadAttendance);
    recordTo && recordTo.addEventListener('change', loadAttendance);
    hourlyRateInput && hourlyRateInput.addEventListener('change', loadAttendance);

    loadAttendance();
    loadSchedule();
    loadAssignedShifts();

    setInterval(function () {
        if (document.hidden) return;
        loadAttendance();
    }, 10000);

    window.addEventListener('storage', function (e) {
        if (!e || e.key !== 'attendance:lastUpdate') return;
        loadAttendance();
    });
})();
</script>
}
