    <div role="dialog" aria-modal="true" aria-labelledby="payslipTitle" class="relative w-full max-w-2xl rounded-lg bg-white shadow-2xl dark:bg-slate-800 sm:rounded-xl max-h-[90vh] overflow-y-auto">
