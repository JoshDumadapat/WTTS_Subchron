@page
@model Subchron.Web.Pages.Employee.PayHistoryModel
@{
    ViewData["Title"] = "Pay History";
    ViewData["PageTitle"] = "Pay History";
    Layout = "/Pages/Employee/Shared/_LayoutEmployee.cshtml";
}

<div class="w-full space-y-4 px-3 sm:px-4 sm:space-y-6">
    <section class="grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
            <p class="text-xs text-slate-500 dark:text-slate-400">Total Earnings</p>
            <p id="sumGross" class="mt-1 text-2xl font-bold text-emerald-600 dark:text-emerald-400">₱0.00</p>
            <p class="text-xs text-slate-500">Processed periods</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
            <p class="text-xs text-slate-500 dark:text-slate-400">Total Deductions</p>
            <p id="sumDed" class="mt-1 text-2xl font-bold text-orange-600 dark:text-orange-400">₱0.00</p>
            <p class="text-xs text-slate-500">Processed periods</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
            <p class="text-xs text-slate-500 dark:text-slate-400">Net Pay</p>
            <p id="sumNet" class="mt-1 text-2xl font-bold text-blue-600 dark:text-blue-400">₱0.00</p>
            <p class="text-xs text-slate-500">Processed periods</p>
        </div>
    </section>

    <section class="rounded-xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-900/50">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Period</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Gross</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Deductions</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Net</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Status</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Actions</th>
                    </tr>
                </thead>
                <tbody id="payHistoryBody" class="divide-y divide-slate-200 dark:divide-slate-700">
                    <tr><td colspan="6" class="px-4 py-8 text-center text-slate-500">Loading pay history...</td></tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<div id="payslipModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 p-4">
    <div class="w-full max-w-2xl rounded-xl bg-white shadow-2xl dark:bg-slate-800">
        <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4 dark:border-slate-700">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Payslip Details</h2>
            <button id="closePayslipModal" class="rounded-lg p-1.5 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700">✕</button>
        </div>
        <div id="payslipContent" class="space-y-3 p-5 text-sm text-slate-700 dark:text-slate-200"></div>
        <div class="flex justify-end gap-2 border-t border-slate-200 bg-slate-50 px-5 py-4 dark:border-slate-700 dark:bg-slate-900/40">
            <button id="downloadPayslipPdf" class="btn-primary px-4 py-2">Download PDF</button>
            <button id="closePayslipFooter" class="btn-secondary px-4 py-2">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var payHistoryBody = document.getElementById('payHistoryBody');
    var sumGross = document.getElementById('sumGross');
    var sumDed = document.getElementById('sumDed');
    var sumNet = document.getElementById('sumNet');
    var modal = document.getElementById('payslipModal');
    var payslipContent = document.getElementById('payslipContent');
    var closePayslipModal = document.getElementById('closePayslipModal');
    var closePayslipFooter = document.getElementById('closePayslipFooter');
    var downloadPayslipPdf = document.getElementById('downloadPayslipPdf');

    var historyRows = [];
    var currentRunId = null;

    function currency(n) {
        return new Intl.NumberFormat(undefined, { style: 'currency', currency: 'PHP' }).format(Number(n || 0));
    }

    function showModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function hideModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    function renderHistory(rows) {
        if (!rows || !rows.length) {
            payHistoryBody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-slate-500">No processed payroll history yet.</td></tr>';
            sumGross.textContent = currency(0);
            sumDed.textContent = currency(0);
            sumNet.textContent = currency(0);
            return;
        }

        var grossTotal = rows.reduce(function (s, x) { return s + Number(x.grossPay || 0); }, 0);
        var dedTotal = rows.reduce(function (s, x) { return s + Number(x.deductions || 0); }, 0);
        var netTotal = rows.reduce(function (s, x) { return s + Number(x.netPay || 0); }, 0);
        sumGross.textContent = currency(grossTotal);
        sumDed.textContent = currency(dedTotal);
        sumNet.textContent = currency(netTotal);

        payHistoryBody.innerHTML = rows.map(function (x, i) {
            var ps = String(x.periodStart).slice(0, 10);
            var pe = String(x.periodEnd).slice(0, 10);
            var status = x.status || 'Processed';
            return '<tr>' +
                '<td class="px-4 py-3 text-slate-900 dark:text-slate-100">' + ps + ' to ' + pe + '</td>' +
                '<td class="px-4 py-3 text-emerald-600 dark:text-emerald-400">' + currency(x.grossPay) + '</td>' +
                '<td class="px-4 py-3 text-orange-600 dark:text-orange-400">' + currency(x.deductions) + '</td>' +
                '<td class="px-4 py-3 font-semibold text-slate-900 dark:text-slate-100">' + currency(x.netPay) + '</td>' +
                '<td class="px-4 py-3"><span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300">' + status + '</span></td>' +
                '<td class="px-4 py-3"><button data-view="' + i + '" class="rounded-lg px-2 py-1 text-xs font-medium text-blue-600 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/20">View Payslip</button></td>' +
                '</tr>';
        }).join('');

        payHistoryBody.querySelectorAll('[data-view]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var item = rows[Number(btn.getAttribute('data-view'))];
                currentRunId = item.payrollRunID;
                payslipContent.innerHTML =
                    '<p><strong>Period:</strong> ' + String(item.periodStart).slice(0, 10) + ' to ' + String(item.periodEnd).slice(0, 10) + '</p>' +
                    '<p><strong>Worked Hours:</strong> ' + Number(item.workedHours || 0).toFixed(2) + '</p>' +
                    '<p><strong>Overtime Hours:</strong> ' + Number(item.overtimeHours || 0).toFixed(2) + '</p>' +
                    '<p><strong>Base Pay:</strong> ' + currency(item.basePay) + '</p>' +
                    '<p><strong>Overtime Pay:</strong> ' + currency(item.overtimePay) + '</p>' +
                    '<p><strong>Allowances:</strong> ' + currency(item.allowances) + '</p>' +
                    '<p><strong>Gross Pay:</strong> ' + currency(item.grossPay) + '</p>' +
                    '<p><strong>Deductions:</strong> ' + currency(item.deductions) + '</p>' +
                    '<p><strong>Tax:</strong> ' + currency(item.tax) + '</p>' +
                    '<p><strong>Net Pay:</strong> <span class="font-semibold">' + currency(item.netPay) + '</span></p>' +
                    '<p class="text-xs text-slate-500">' + (item.formulaSummary || 'Net = (Base + OT + Allowances) - Deductions') + '</p>';
                showModal();
            });
        });
    }

    function loadHistory() {
        fetch('?handler=History', { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(function (rows) {
                historyRows = rows || [];
                renderHistory(historyRows);
            })
            .catch(function () {
                payHistoryBody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-red-500">Failed to load pay history.</td></tr>';
            });
    }

    downloadPayslipPdf.addEventListener('click', function () {
        if (!currentRunId) return;
        window.location.href = '?handler=PayslipPdf&runId=' + currentRunId;
    });
    closePayslipModal.addEventListener('click', hideModal);
    closePayslipFooter.addEventListener('click', hideModal);
    modal.addEventListener('click', function (e) { if (e.target === modal) hideModal(); });

    loadHistory();
})();
</script>
}
