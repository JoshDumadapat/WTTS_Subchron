@page
@model Subchron.Web.Pages.Employee.PayHistoryModel
@{
    ViewData["Title"] = "Pay History";
    ViewData["PageTitle"] = "Pay History";
    Layout = "/Pages/Employee/Shared/_LayoutEmployee.cshtml";
}

<div class="mx-auto max-w-7xl space-y-6">
    <!-- Summary Cards -->
    <section>
        <div class="grid gap-4 grid-cols-1 sm:grid-cols-3">
            <!-- Total Earnings -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Total Earnings</p>
                        <p class="mt-1 text-3xl font-bold text-emerald-600 dark:text-emerald-400">₱45,500.00</p>
                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-500">This year</p>
                    </div>
                    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" /></svg>
                    </div>
                </div>
            </div>

            <!-- Total Deductions -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Total Deductions</p>
                        <p class="mt-1 text-3xl font-bold text-orange-600 dark:text-orange-400">₱8,200.00</p>
                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-500">This year</p>
                    </div>
                    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" /></svg>
                    </div>
                </div>
            </div>

            <!-- Net Pay -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Net Pay</p>
                        <p class="mt-1 text-3xl font-bold text-blue-600 dark:text-blue-400">₱37,300.00</p>
                        <p class="mt-1 text-xs text-slate-500 dark:text-slate-500">This year</p>
                    </div>
                    <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" /></svg>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Filters and Actions Section -->
    <section class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
            <!-- Filters -->
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                <!-- Month Filter -->
                <div>
                    <label for="monthFilter" class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Month</label>
                    <select id="monthFilter" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 dark:border-slate-600 dark:bg-slate-700 dark:text-white">
                        <option>All Months</option>
                        <option>January 2024</option>
                        <option>February 2024</option>
                        <option>March 2024</option>
                        <option>April 2024</option>
                        <option>May 2024</option>
                        <option>June 2024</option>
                    </select>
                </div>

                <!-- Year Filter -->
                <div>
                    <label for="yearFilter" class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Year</label>
                    <select id="yearFilter" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 dark:border-slate-600 dark:bg-slate-700 dark:text-white">
                        <option>2024</option>
                        <option>2023</option>
                        <option>2022</option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div>
                    <label for="statusFilter" class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1">Status</label>
                    <select id="statusFilter" class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm text-slate-900 dark:border-slate-600 dark:bg-slate-700 dark:text-white">
                        <option>All Status</option>
                        <option>Paid</option>
                        <option>Pending</option>
                        <option>Cancelled</option>
                    </select>
                </div>
            </div>

            <!-- Cash Advance Button -->
            <button id="cashAdvanceBtn" type="button" class="flex items-center justify-center gap-2 rounded-lg bg-subgreen-500 px-4 py-2 text-sm font-semibold text-white shadow-md transition hover:bg-subgreen-600 dark:bg-subgreen-500 dark:hover:bg-subgreen-600">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Cash Advance
            </button>
        </div>
    </section>

    <!-- Pay History Table -->
    <section class="rounded-xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-slate-200 bg-slate-50 dark:border-slate-700 dark:bg-slate-900/50">
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Period</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Gross Pay</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Deductions</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Net Pay</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Status</th>
                        <th class="px-4 py-3 text-left text-xs font-semibold text-slate-700 dark:text-slate-300">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                    <!-- Sample Row 1 -->
                    <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50">
                        <td class="px-4 py-3 text-sm text-slate-900 dark:text-slate-100">June 2024</td>
                        <td class="px-4 py-3 text-sm font-medium text-emerald-600 dark:text-emerald-400">₱18,000.00</td>
                        <td class="px-4 py-3 text-sm font-medium text-orange-600 dark:text-orange-400">₱2,050.00</td>
                        <td class="px-4 py-3 text-sm font-bold text-slate-900 dark:text-slate-100">₱15,950.00</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400">
                                Paid
                            </span>
                        </td>
                        <td class="px-4 py-3 text-sm">
                            <button type="button" onclick="openPayslipModal('June 2024')" class="inline-flex items-center gap-1 rounded-lg px-2 py-1 text-xs font-medium text-blue-600 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/20">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                View Payslip
                            </button>
                        </td>
                    </tr>

                    <!-- Sample Row 2 -->
                    <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50">
                        <td class="px-4 py-3 text-sm text-slate-900 dark:text-slate-100">May 2024</td>
                        <td class="px-4 py-3 text-sm font-medium text-emerald-600 dark:text-emerald-400">₱18,000.00</td>
                        <td class="px-4 py-3 text-sm font-medium text-orange-600 dark:text-orange-400">₱1,950.00</td>
                        <td class="px-4 py-3 text-sm font-bold text-slate-900 dark:text-slate-100">₱16,050.00</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400">
                                Paid
                            </span>
                        </td>
                        <td class="px-4 py-3 text-sm">
                            <button type="button" onclick="openPayslipModal('May 2024')" class="inline-flex items-center gap-1 rounded-lg px-2 py-1 text-xs font-medium text-blue-600 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/20">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                View Payslip
                            </button>
                        </td>
                    </tr>

                    <!-- Sample Row 3 -->
                    <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50">
                        <td class="px-4 py-3 text-sm text-slate-900 dark:text-slate-100">April 2024</td>
                        <td class="px-4 py-3 text-sm font-medium text-emerald-600 dark:text-emerald-400">₱18,000.00</td>
                        <td class="px-4 py-3 text-sm font-medium text-orange-600 dark:text-orange-400">₱2,100.00</td>
                        <td class="px-4 py-3 text-sm font-bold text-slate-900 dark:text-slate-100">₱15,900.00</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">
                                Pending
                            </span>
                        </td>
                        <td class="px-4 py-3 text-sm">
                            <button type="button" onclick="openPayslipModal('April 2024')" class="inline-flex items-center gap-1 rounded-lg px-2 py-1 text-xs font-medium text-blue-600 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/20">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                View Payslip
                            </button>
                        </td>
                    </tr>

                    <!-- Sample Row 4 -->
                    <tr class="transition-colors hover:bg-slate-50 dark:hover:bg-slate-700/50">
                        <td class="px-4 py-3 text-sm text-slate-900 dark:text-slate-100">March 2024</td>
                        <td class="px-4 py-3 text-sm font-medium text-emerald-600 dark:text-emerald-400">₱18,000.00</td>
                        <td class="px-4 py-3 text-sm font-medium text-orange-600 dark:text-orange-400">₱2,000.00</td>
                        <td class="px-4 py-3 text-sm font-bold text-slate-900 dark:text-slate-100">₱16,000.00</td>
                        <td class="px-4 py-3">
                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400">
                                Paid
                            </span>
                        </td>
                        <td class="px-4 py-3 text-sm">
                            <button type="button" onclick="openPayslipModal('March 2024')" class="inline-flex items-center gap-1 rounded-lg px-2 py-1 text-xs font-medium text-blue-600 hover:bg-blue-50 dark:text-blue-400 dark:hover:bg-blue-900/20">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                                View Payslip
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>
</div>

<!-- Payslip Modal -->
<div id="payslipModal" class="fixed inset-0 z-[9999] hidden items-center justify-center">
    <div id="payslipBackdrop" class="backdrop-blur-[1px] absolute inset-0 bg-slate-900/40" aria-hidden="true"></div>

    <div role="dialog" aria-modal="true" aria-labelledby="payslipTitle" class="relative mx-4 w-full max-w-2xl rounded-xl bg-white shadow-2xl dark:bg-slate-800">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
            <div class="flex items-center justify-between">
                <h2 id="payslipTitle" class="text-lg font-semibold text-slate-900 dark:text-white">Payslip Details</h2>
                <button type="button" onclick="closePayslipModal()" class="rounded-lg p-1.5 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
        </div>

        <div class="p-6 space-y-6">
            <!-- Period Header -->
            <div>
                <p id="payslipPeriod" class="text-xl font-bold text-slate-900 dark:text-white">June 2024</p>
                <p class="text-sm text-slate-600 dark:text-slate-400 mt-1">Payroll Details and Breakdown</p>
            </div>

            <!-- Earnings Section -->
            <div>
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Earnings</h3>
                <div class="space-y-2 bg-slate-50 rounded-lg p-4 dark:bg-slate-700/50">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">Basic Salary</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱15,000.00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">Overtime</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱2,000.00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">Allowances</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱1,000.00</span>
                    </div>
                    <div class="border-t border-slate-200 dark:border-slate-600 pt-2 mt-2 flex justify-between text-sm">
                        <span class="font-semibold text-slate-900 dark:text-white">Gross Pay</span>
                        <span class="font-bold text-emerald-600 dark:text-emerald-400">₱18,000.00</span>
                    </div>
                </div>
            </div>

            <!-- Deductions Section -->
            <div>
                <h3 class="text-sm font-semibold text-slate-900 dark:text-white mb-3">Deductions</h3>
                <div class="space-y-2 bg-slate-50 rounded-lg p-4 dark:bg-slate-700/50">
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">SSS</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱600.00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">PhilHealth</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱500.00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">Pag-IBIG</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱300.00</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-slate-600 dark:text-slate-300">Withholding Tax</span>
                        <span class="font-medium text-slate-900 dark:text-white">₱550.00</span>
                    </div>
                    <div class="border-t border-slate-200 dark:border-slate-600 pt-2 mt-2 flex justify-between text-sm">
                        <span class="font-semibold text-slate-900 dark:text-white">Total Deductions</span>
                        <span class="font-bold text-orange-600 dark:text-orange-400">₱1,950.00</span>
                    </div>
                </div>
            </div>

            <!-- Net Pay Section -->
            <div class="rounded-lg border-2 border-emerald-200 bg-emerald-50 p-4 dark:border-emerald-900/50 dark:bg-emerald-900/20">
                <div class="flex justify-between items-center">
                    <span class="text-lg font-bold text-emerald-900 dark:text-emerald-100">Net Pay</span>
                    <span class="text-2xl font-bold text-emerald-600 dark:text-emerald-400">₱16,050.00</span>
                </div>
            </div>
        </div>

        <!-- Modal Footer -->
        <div class="border-t border-slate-200 bg-slate-50 px-6 py-4 dark:border-slate-700 dark:bg-slate-900/50 flex items-center justify-end gap-3">
            <button type="button" onclick="closePayslipModal()" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700">
                Close
            </button>
            <button type="button" class="flex items-center gap-2 rounded-lg bg-subgreen-500 px-4 py-2 text-sm font-medium text-white hover:bg-subgreen-600">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                Download PDF
            </button>
        </div>
    </div>
</div>

<!-- Cash Advance Modal -->
<div id="cashAdvanceModal" class="fixed inset-0 z-[9999] hidden items-center justify-center">
    <div id="cashAdvanceBackdrop" class="backdrop-blur-[1px] absolute inset-0 bg-slate-900/40" aria-hidden="true"></div>

    <div role="dialog" aria-modal="true" aria-labelledby="cashAdvanceTitle" class="relative mx-4 w-full max-w-md rounded-xl bg-white shadow-2xl dark:bg-slate-800">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
            <div class="flex items-center justify-between">
                <h2 id="cashAdvanceTitle" class="text-lg font-semibold text-slate-900 dark:text-white">Request Cash Advance</h2>
                <button type="button" onclick="closeCashAdvanceModal()" class="rounded-lg p-1.5 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-700">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
        </div>

        <form id="cashAdvanceForm" class="space-y-4 p-6">
            <!-- Amount Input -->
            <div>
                <label for="advanceAmount" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Amount to Advance</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500 dark:text-slate-400">₱</span>
                    <input type="number" id="advanceAmount" name="amount" placeholder="0.00" min="0" step="0.01"
                           class="w-full rounded-lg border border-slate-300 bg-white pl-7 pr-4 py-2 text-sm text-slate-900 placeholder-slate-500 dark:border-slate-600 dark:bg-slate-700 dark:text-white dark:placeholder-slate-400" />
                </div>
                <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Available Balance: ₱5,000.00</p>
            </div>

            <!-- Purpose Input -->
            <div>
                <label for="advancePurpose" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Purpose</label>
                <select id="advancePurpose" name="purpose"
                        class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm text-slate-900 dark:border-slate-600 dark:bg-slate-700 dark:text-white">
                    <option value="">Select purpose</option>
                    <option value="emergency">Emergency</option>
                    <option value="medical">Medical</option>
                    <option value="personal">Personal</option>
                    <option value="loan">Loan Payment</option>
                    <option value="other">Other</option>
                </select>
            </div>

            <!-- Reason Input -->
            <div>
                <label for="advanceReason" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Reason (Optional)</label>
                <textarea id="advanceReason" name="reason" rows="3" placeholder="Please provide details about your request..."
                          class="w-full rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm text-slate-900 placeholder-slate-500 dark:border-slate-600 dark:bg-slate-700 dark:text-white dark:placeholder-slate-400"></textarea>
            </div>

            <!-- Deduction Schedule -->
            <div class="rounded-lg bg-slate-50 p-3 dark:bg-slate-700/50">
                <p class="text-xs font-medium text-slate-700 dark:text-slate-300 mb-2">Deduction Schedule</p>
                <div class="space-y-1 text-xs text-slate-600 dark:text-slate-400">
                    <p>• Amount: ₱<span id="scheduleAmount">0.00</span></p>
                    <p>• Monthly Deduction: ₱<span id="scheduleMonthly">0.00</span></p>
                    <p>• Number of Months: <span id="scheduleMonths">3</span></p>
                </div>
            </div>
        </form>

        <!-- Modal Footer -->
        <div class="border-t border-slate-200 bg-slate-50 px-6 py-4 dark:border-slate-700 dark:bg-slate-900/50 flex items-center justify-end gap-3">
            <button type="button" onclick="closeCashAdvanceModal()" class="rounded-lg px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-700">
                Cancel
            </button>
            <button type="button" onclick="submitCashAdvance()" class="flex items-center gap-2 rounded-lg bg-subgreen-500 px-4 py-2 text-sm font-medium text-white hover:bg-subgreen-600">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Submit Request
            </button>
        </div>
    </div>
</div>

<script>
    // Payslip Modal Functions
    function openPayslipModal(period) {
        const modal = document.getElementById('payslipModal');
        const periodElement = document.getElementById('payslipPeriod');
        if (modal && periodElement) {
            periodElement.textContent = period;
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.addEventListener('keydown', onPayslipKeyDown);
        }
    }

    function closePayslipModal() {
        const modal = document.getElementById('payslipModal');
        if (modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.removeEventListener('keydown', onPayslipKeyDown);
        }
    }

    function onPayslipKeyDown(e) {
        if (e.key === 'Escape') closePayslipModal();
    }

    const payslipBackdrop = document.getElementById('payslipBackdrop');
    const payslipModal = document.getElementById('payslipModal');
    if (payslipBackdrop && payslipModal) {
        payslipBackdrop.addEventListener('click', closePayslipModal);
        payslipModal.addEventListener('click', (e) => {
            if (e.target === payslipModal) closePayslipModal();
        });
    }

    // Cash Advance Modal Functions
    function openCashAdvanceModal() {
        const modal = document.getElementById('cashAdvanceModal');
        if (modal) {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.getElementById('advanceAmount')?.focus();
            document.addEventListener('keydown', onCashAdvanceKeyDown);
        }
    }

    function closeCashAdvanceModal() {
        const modal = document.getElementById('cashAdvanceModal');
        if (modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.getElementById('cashAdvanceForm')?.reset();
            document.removeEventListener('keydown', onCashAdvanceKeyDown);
        }
    }

    function onCashAdvanceKeyDown(e) {
        if (e.key === 'Escape') closeCashAdvanceModal();
    }

    const cashAdvanceBackdrop = document.getElementById('cashAdvanceBackdrop');
    const cashAdvanceModal = document.getElementById('cashAdvanceModal');
    if (cashAdvanceBackdrop && cashAdvanceModal) {
        cashAdvanceBackdrop.addEventListener('click', closeCashAdvanceModal);
        cashAdvanceModal.addEventListener('click', (e) => {
            if (e.target === cashAdvanceModal) closeCashAdvanceModal();
        });
    }

    const cashAdvanceBtn = document.getElementById('cashAdvanceBtn');
    if (cashAdvanceBtn) {
        cashAdvanceBtn.addEventListener('click', openCashAdvanceModal);
    }

    // Cash Advance Amount Calculation
    const advanceAmountInput = document.getElementById('advanceAmount');
    if (advanceAmountInput) {
        advanceAmountInput.addEventListener('input', () => {
            const amount = parseFloat(advanceAmountInput.value) || 0;
            const monthlyDeduction = (amount / 3).toFixed(2);
            document.getElementById('scheduleAmount').textContent = amount.toFixed(2);
            document.getElementById('scheduleMonthly').textContent = monthlyDeduction;
        });
    }

    // Submit Cash Advance
    function submitCashAdvance() {
        const amount = document.getElementById('advanceAmount').value;
        const purpose = document.getElementById('advancePurpose').value;
        const reason = document.getElementById('advanceReason').value;

        if (!amount || !purpose) {
            alert('Please fill in all required fields');
            return;
        }

        // TODO: Submit to API
        console.log('Cash Advance Request:', { amount, purpose, reason });
        alert('Cash advance request submitted successfully!');
        closeCashAdvanceModal();
    }
</script>
