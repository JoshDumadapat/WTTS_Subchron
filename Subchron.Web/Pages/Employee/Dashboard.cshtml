@page
@model Subchron.Web.Pages.Employee.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageTitle"] = "Dashboard";
    Layout = "/Pages/Employee/Shared/_LayoutEmployee.cshtml";
}

<div class="mx-auto max-w-6xl space-y-6">
    <!-- Quick Actions Section -->
    <section>
        <p class="mb-4 text-sm text-slate-500 dark:text-slate-400">Quick actions for attendance and overtime.</p>

        <!-- Quick Action Cards - Single Row on Desktop, Grid on Mobile -->
        <div class="grid gap-3 grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 xl:gap-4">
            <!-- Show My QR -->
            <a href="/Employee/MyQr" class="flex flex-col items-center justify-center gap-2 sm:gap-3 rounded-2xl border border-slate-200 bg-white p-3 sm:p-5 lg:p-6 shadow-sm transition-all hover:border-subgreen-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-subgreen-600">
                <div class="flex h-10 w-10 sm:h-12 sm:w-12 lg:h-14 lg:w-14 items-center justify-center rounded-2xl bg-sky-100 text-sky-600 dark:bg-sky-900/40 dark:text-sky-400">
                    <svg class="h-5 w-5 sm:h-6 sm:w-6 lg:h-8 lg:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z" /></svg>
                </div>
                <span class="text-center text-xs sm:text-sm lg:text-base font-semibold text-slate-900 dark:text-white">QR Code</span>
            </a>

            <!-- Time In / Out -->
            <a href="/Employee/Attendance" class="flex flex-col items-center justify-center gap-2 sm:gap-3 rounded-2xl border border-slate-200 bg-white p-3 sm:p-5 lg:p-6 shadow-sm transition-all hover:border-subgreen-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-subgreen-600">
                <div class="flex h-10 w-10 sm:h-12 sm:w-12 lg:h-14 lg:w-14 items-center justify-center rounded-2xl bg-subgreen-100 text-subgreen-600 dark:bg-subgreen-900/40 dark:text-subgreen-400">
                    <svg class="h-5 w-5 sm:h-6 sm:w-6 lg:h-8 lg:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
                </div>
                <span class="text-center text-xs sm:text-sm lg:text-base font-semibold text-slate-900 dark:text-white">Time In/Out</span>
            </a>

            <!-- Overtime -->
            <a href="/Employee/Overtime" class="flex flex-col items-center justify-center gap-2 sm:gap-3 rounded-2xl border border-slate-200 bg-white p-3 sm:p-5 lg:p-6 shadow-sm transition-all hover:border-subgreen-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-subgreen-600">
                <div class="flex h-10 w-10 sm:h-12 sm:w-12 lg:h-14 lg:w-14 items-center justify-center rounded-2xl bg-violet-100 text-violet-600 dark:bg-violet-900/40 dark:text-violet-400">
                    <svg class="h-5 w-5 sm:h-6 sm:w-6 lg:h-8 lg:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <span class="text-center text-xs sm:text-sm lg:text-base font-semibold text-slate-900 dark:text-white">Overtime</span>
            </a>

            <!-- Leave -->
            <a href="/Employee/Leave" class="flex flex-col items-center justify-center gap-2 sm:gap-3 rounded-2xl border border-slate-200 bg-white p-3 sm:p-5 lg:p-6 shadow-sm transition-all hover:border-subgreen-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-subgreen-600">
                <div class="flex h-10 w-10 sm:h-12 sm:w-12 lg:h-14 lg:w-14 items-center justify-center rounded-2xl bg-teal-100 text-teal-600 dark:bg-teal-900/40 dark:text-teal-400">
                    <svg class="h-5 w-5 sm:h-6 sm:w-6 lg:h-8 lg:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                </div>
                <span class="text-center text-xs sm:text-sm lg:text-base font-semibold text-slate-900 dark:text-white">Leave</span>
            </a>

            <!-- Attendance & Schedule -->
            <a href="/Employee/MyAttendance" class="flex flex-col items-center justify-center gap-2 sm:gap-3 rounded-2xl border border-slate-200 bg-white p-3 sm:p-5 lg:p-6 shadow-sm transition-all hover:border-subgreen-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-subgreen-600">
                <div class="flex h-10 w-10 sm:h-12 sm:w-12 lg:h-14 lg:w-14 items-center justify-center rounded-2xl bg-indigo-100 text-indigo-600 dark:bg-indigo-900/40 dark:text-indigo-400">
                    <svg class="h-5 w-5 sm:h-6 sm:w-6 lg:h-8 lg:w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
                </div>
                <span class="text-center text-xs sm:text-sm lg:text-base font-semibold text-slate-900 dark:text-white">Schedule</span>
            </a>
        </div>
    </section>

    <!-- Statistics Section -->
    <section class="pt-4">
        <h2 class="mb-4 text-sm font-semibold text-slate-700 dark:text-slate-300">Quick Stats</h2>

        <!-- Stats Grid - 4 columns on desktop, 2 on mobile -->
        <div class="grid gap-4 grid-cols-2 lg:grid-cols-4">
            <!-- Present Days -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between gap-2">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" /></svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Present</p>
                        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-500">days</p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-bold text-emerald-600 dark:text-emerald-400">18</p>
                    </div>
                </div>
            </div>

            <!-- Absences -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between gap-2">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41z" /></svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Absences</p>
                        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-500">this month</p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-bold text-orange-600 dark:text-orange-400">2</p>
                    </div>
                </div>
            </div>

            <!-- Lates -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between gap-2">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-amber-100 text-amber-600 dark:bg-amber-900/30 dark:text-amber-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" /></svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Lates</p>
                        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-500">this month</p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-bold text-amber-600 dark:text-amber-400">1</p>
                    </div>
                </div>
            </div>

            <!-- Leave Balance -->
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800">
                <div class="flex items-start justify-between gap-2">
                    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z" /></svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-slate-600 dark:text-slate-400">Leave Balance</p>
                        <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-500">days</p>
                    </div>
                    <div class="text-right">
                        <p class="text-3xl font-bold text-blue-600 dark:text-blue-400">8</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Access Notifications Section -->
    <section class="pt-6">
        <h2 class="mb-4 text-sm font-semibold text-slate-700 dark:text-slate-300">Updates & Notifications</h2>

        <!-- Notification Cards Grid - 3 columns on desktop, 2 on mobile -->
        <div class="grid gap-4 grid-cols-2 lg:grid-cols-3">
            <!-- Leave Updates -->
            <a href="/Employee/Leave" class="group rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-blue-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-blue-600">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <div class="flex items-center gap-2">
                            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z" /></svg>
                            </div>
                            <h3 class="font-semibold text-slate-900 dark:text-white">Leave</h3>
                        </div>
                        <p class="mt-2 text-xs text-slate-600 dark:text-slate-400">1 pending request</p>
                        <p class="mt-1 text-xs text-blue-600 dark:text-blue-400 font-medium">View details →</p>
                    </div>
                    <div class="flex h-6 w-6 items-center justify-center rounded-full bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400">
                        <span class="text-xs font-bold">1</span>
                    </div>
                </div>
            </a>

            <!-- Overtime Updates -->
            <a href="/Employee/Overtime" class="group rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-violet-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-violet-600">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <div class="flex items-center gap-2">
                            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-violet-100 text-violet-600 dark:bg-violet-900/30 dark:text-violet-400">
                                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" /></svg>
                            </div>
                            <h3 class="font-semibold text-slate-900 dark:text-white">Overtime</h3>
                        </div>
                        <p class="mt-2 text-xs text-slate-600 dark:text-slate-400">Approved this month</p>
                        <p class="mt-1 text-xs text-violet-600 dark:text-violet-400 font-medium">6.5 hours →</p>
                    </div>
                    <div class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" /></svg>
                    </div>
                </div>
            </a>

            <!-- Payroll Updates -->
            <a href="/Employee/Settings" class="group rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-emerald-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-emerald-600">
                <div class="flex items-start justify-between">
                    <div class="flex-1">
                        <div class="flex items-center gap-2">
                            <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                                <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" /></svg>
                            </div>
                            <h3 class="font-semibold text-slate-900 dark:text-white">Payroll</h3>
                        </div>
                        <p class="mt-2 text-xs text-slate-600 dark:text-slate-400">Latest update available</p>
                        <p class="mt-1 text-xs text-emerald-600 dark:text-emerald-400 font-medium">Dec 15, 2024 →</p>
                    </div>
                    <div class="flex h-6 w-6 items-center justify-center rounded-full bg-emerald-100 text-emerald-600 dark:bg-emerald-900/30 dark:text-emerald-400">
                        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z" /></svg>
                    </div>
                </div>
            </a>
        </div>
    </section>
</div>
