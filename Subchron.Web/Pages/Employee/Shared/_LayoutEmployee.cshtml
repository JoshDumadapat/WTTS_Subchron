@using System.Security.Claims
@using Subchron.Web.Rbac
@using Subchron.Web.Services
@using Subchron.Web.Pages.Auth
@inject IConfiguration Config
@inject LayoutBrandingService LayoutBrandingService
@{
    var displayName = User.FindFirst(ClaimTypes.Name)?.Value ?? User.Identity?.Name ?? "Employee";
    var canAccessBackoffice = RoleModuleAccess.CanAccessBackoffice(User);
    var token = User.FindFirst(CompleteLoginModel.AccessTokenClaimType)?.Value;

    var branding = await LayoutBrandingService.GetAsync(User);
    if (!string.IsNullOrWhiteSpace(branding.ProfileName))
        displayName = branding.ProfileName!.Trim();

    var orgSidebarName = !string.IsNullOrWhiteSpace(branding.OrgName)
        ? branding.OrgName!.Trim()
        : "Employee Portal";

    var orgLogoUrl = string.IsNullOrWhiteSpace(branding.OrgLogoUrl)
        ? null
        : branding.OrgLogoUrl!.Trim();
    var orgLogoResolved = orgLogoUrl;
    if (!string.IsNullOrWhiteSpace(orgLogoResolved) && orgLogoResolved.StartsWith("~/", StringComparison.Ordinal))
        orgLogoResolved = Url.Content(orgLogoResolved);

    var orgLogoSrc = !string.IsNullOrWhiteSpace(orgLogoResolved)
        ? orgLogoResolved + (orgLogoResolved.Contains("?") ? "&" : "?") + "v=" + DateTimeOffset.UtcNow.ToUnixTimeSeconds()
        : Url.Content("~/images/logo/logo.png");

    var profileAvatarSrc = branding.ProfileAvatarUrl;
    if (!string.IsNullOrWhiteSpace(profileAvatarSrc) && profileAvatarSrc.StartsWith("~/", StringComparison.Ordinal))
        profileAvatarSrc = Url.Content(profileAvatarSrc);
    if (string.IsNullOrWhiteSpace(profileAvatarSrc))
        profileAvatarSrc = "https://ui-avatars.com/api/?name=" + Uri.EscapeDataString(displayName) + "&background=209030&color=fff&bold=true";
}
<!DOCTYPE html>
<html lang="en" class="scroll-smooth" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Employee Portal - Subchron</title>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true" />
    <script>
        (function () { var stored = localStorage.getItem("subchron-theme"); var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches; document.documentElement.classList.toggle("dark", stored === "dark" || (!stored && prefersDark)); })();
    </script>
    <style>
        #sidebar { transition: width 0.3s ease-in-out; }
        #sidebar nav { scrollbar-width: none; -ms-overflow-style: none; }
        #sidebar nav::-webkit-scrollbar { display: none; }
        .nav-item { position: relative; }
        .nav-item.active { background-color: rgba(22, 163, 74, 0.10); color: #16a34a; font-weight: 700; }
        .dark .nav-item.active { background-color: rgba(34, 197, 94, 0.14); color: #22c55e; }
        .nav-item:hover { background-color: rgba(22, 163, 74, 0.10); color: #16a34a; }
        .dark .nav-item:hover { background-color: rgba(34, 197, 94, 0.14); color: #22c55e; }
        .nav-indicator { position: absolute; right: -14px; top: 50%; transform: translate(50%, -50%); width: 6px; height: 35px; border-radius: 9999px; background: #16a34a; opacity: 0; transition: opacity 0.2s; z-index: 5; }
        .dark .nav-indicator { background: #22c55e; }
        .nav-item.active .nav-indicator { opacity: 1; }
        .profile-dropdown.open #profileDropdownMenu { display: block; }
        .toggle-wrap { position: absolute; right: -17px; top: 50px; transform: translateY(-50%); width: 34px; height: 34px; border-radius: 9999px; background: #f8fafc; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 18px rgba(15, 23, 42, 0.08); border: 1px solid rgba(226, 232, 240, 0.9); z-index: 25; }
        .dark .toggle-wrap { background: #0f172a; border-color: rgba(51, 65, 85, 0.9); box-shadow: 0 10px 24px rgba(0, 0, 0, 0.25); }
        .toggle-btn { width: 26px; height: 26px; background: #16a34a; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 0; transition: background 0.2s ease; }
        .toggle-btn:hover { background: #15803d; }
        .dark .toggle-btn { background: #22c55e; }
        .dark .toggle-btn:hover { background: #16a34a; }
        #sidebarToggle svg { transition: transform 0.25s ease; }
        .sidebar-collapsed #sidebarToggle svg { transform: rotate(180deg); }
        .sidebar-collapsed #sidebar { width: 82px !important; }
        .sidebar-collapsed .sidebar-label, .sidebar-collapsed .company-name { opacity: 0; width: 0; overflow: hidden; pointer-events: none; }
        .sidebar-collapsed .profile-header { justify-content: center; gap: 0; }
        .sidebar-label, .company-name { white-space: nowrap; flex: 1 1 auto; min-width: 0; }
        @@media (max-width: 767px) {
            #sidebar { position: fixed; top: 0; left: 0; bottom: 0; width: 260px !important; transform: translateX(-110%); transition: transform 0.25s; z-index: 20; }
            .sidebar-mobile-open #sidebar { transform: translateX(0); }
            .sidebar-collapsed #sidebar { width: 260px !important; }
            .sidebar-collapsed .sidebar-label, .sidebar-collapsed .company-name { opacity: 1; width: auto; pointer-events: auto; }
            .toggle-wrap { right: -17px; top: 50px; transform: translateY(-50%); }
            .layout-header { margin: 12px !important; padding: 12px 16px !important; }
            .layout-header h1 { font-size: 0.95rem !important; font-weight: 600; }
            .layout-header #mobileSidebarOpen { padding: 0.375rem !important; }
            .layout-header #mobileSidebarOpen svg { height: 1.25rem !important; width: 1.25rem !important; }
            .layout-header #themeToggle { width: 32px !important; height: 32px !important; }
            .layout-header #themeToggle svg { height: 1.125rem !important; width: 1.125rem !important; }
            .layout-header #profileDropdownTrigger { padding: 0.375rem 0.5rem !important; gap: 0.375rem !important; }
            .layout-header #profileDropdownTrigger img { height: 2rem !important; width: 2rem !important; }
            .layout-header #profileDropdownTrigger span { font-size: 0.75rem !important; }
            .layout-header #profileDropdownTrigger svg { height: 0.875rem !important; width: 0.875rem !important; }
        }
    </style>
</head>
