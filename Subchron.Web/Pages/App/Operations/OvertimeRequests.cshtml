@page
@model Subchron.Web.Pages.App.Operations.OvertimeRequestsModel
@{
    ViewData["Title"] = "Overtime Requests";
    ViewData["PageTitle"] = "Overtime Requests";
    Layout = "/Pages/App/Shared/_LayoutAdmin.cshtml";
}

<div class="mx-auto">
    @Html.AntiForgeryToken()
    <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-xl font-bold tracking-tight text-subgreen-500 dark:text-white sm:text-2xl">Overtime Requests</h1>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="border-b border-slate-100 bg-slate-50/50 px-5 py-4 dark:border-slate-700 dark:bg-slate-800/50">
            <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Review queue (Pending)</p>
            <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">Click a request to view details and approve or reject.</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="border-y border-slate-100 bg-slate-50/50 dark:border-slate-700 dark:bg-slate-800/50">
                        <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Employee</th>
                        <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Date</th>
                        <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Start – End</th>
                        <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Reason</th>
                        <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Status</th>
                        <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Actions</th>
                    </tr>
                </thead>
                <tbody id="otTableBody" class="divide-y divide-slate-100 dark:divide-slate-700">
                    <tr><td colspan="6" class="px-5 py-8 text-center text-sm text-slate-500 dark:text-slate-400">Loading overtime requests...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    function statusBadge(status) {
        var s = (status || '').toLowerCase();
        if (s === 'approved') return 'bg-subgreen-50 text-subgreen-700 dark:bg-subgreen-900/30 dark:text-subgreen-300';
        if (s === 'rejected') return 'bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-300';
        if (s === 'systemgenerated' || s === 'needsreview') return 'bg-sky-50 text-sky-700 dark:bg-sky-900/30 dark:text-sky-300';
        return 'bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300';
    }

    function formatTime(dt) {
        var d = new Date(dt);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
    }

    function renderRows(list) {
        var body = document.getElementById('otTableBody');
        if (!body) return;
        if (!list || !list.length) {
            body.innerHTML = '<tr><td colspan="6" class="px-5 py-8 text-center text-sm text-slate-500 dark:text-slate-400">No overtime requests found.</td></tr>';
            return;
        }

        body.innerHTML = list.map(function (r) {
            var dateText = r.otDate ? new Date(String(r.otDate).substring(0, 10) + 'T00:00:00').toLocaleDateString() : '—';
            var badge = statusBadge(r.status);
            var canAction = (r.status || '').toLowerCase() === 'pending' || (r.status || '').toLowerCase() === 'systemgenerated' || (r.status || '').toLowerCase() === 'needsreview';
            return '<tr class="ot-row transition-colors hover:bg-subgreen-50/30 dark:hover:bg-subgreen-900/10" data-id="' + r.otRequestID + '">' +
                '<td class="px-5 py-3"><span class="text-sm font-medium text-slate-900 dark:text-white">' + (r.employeeName || '—') + '</span></td>' +
                '<td class="px-5 py-3 text-sm text-slate-700 dark:text-slate-300">' + dateText + '</td>' +
                '<td class="px-5 py-3 text-sm tabular-nums text-slate-600 dark:text-slate-400">' + formatTime(r.startTime) + ' – ' + formatTime(r.endTime) + '</td>' +
                '<td class="px-5 py-3 text-sm text-slate-600 dark:text-slate-400">' + (r.reason || '—') + '</td>' +
                '<td class="px-5 py-3"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ' + badge + '">' + (r.status || 'Pending') + '</span></td>' +
                '<td class="px-5 py-3 text-right">' + (canAction ? ('<button data-action="approve" class="mr-2 rounded-lg bg-subgreen-100 px-2 py-1 text-xs font-medium text-subgreen-700 hover:bg-subgreen-200">Approve</button><button data-action="reject" class="rounded-lg bg-rose-100 px-2 py-1 text-xs font-medium text-rose-700 hover:bg-rose-200">Reject</button>') : '') + '</td>' +
                '</tr>';
        }).join('');
    }

    function loadQueue() {
        fetch('?handler=Queue', { headers: { 'Accept': 'application/json' } })
            .then(function (r) { return r.json(); })
            .then(renderRows)
            .catch(function () { renderRows([]); });
    }

    function submitAction(id, action) {
        var fd = new FormData();
        fd.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]')?.value || '');
        fd.append('id', id);
        fd.append('action', action);
        fetch('?handler=Action', { method: 'POST', body: fd })
            .then(function (r) { return r.json(); })
            .then(function (x) { if (x && x.ok) loadQueue(); })
            .catch(function () { });
    }

    document.getElementById('otTableBody')?.addEventListener('click', function (e) {
        var row = e.target.closest('tr.ot-row');
        if (!row) return;
        var btn = e.target.closest('button[data-action]');
        if (!btn) return;
        submitAction(row.getAttribute('data-id'), btn.getAttribute('data-action'));
    });

    loadQueue();
})();
</script>
}
