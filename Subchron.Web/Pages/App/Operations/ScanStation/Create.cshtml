@page
@model Subchron.Web.Pages.App.Operations.ScanStation.CreateModel
@{
    ViewData["Title"] = "Create Station";
    ViewData["PageTitle"] = "Create Station";
    Layout = "/Pages/App/Shared/_LayoutAdmin.cshtml";
}

<div class="mx-auto max-w-2xl">
    <div class="mb-6 flex items-center gap-3">
        <a asp-page="/App/Operations/ScanStation" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-700">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </a>
        <div>
            <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Create Station</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Configure a new scan station for attendance kiosks.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Error))
    {
        <div class="mb-4 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 dark:border-red-500/40 dark:bg-red-900/20 dark:text-red-200">@Model.Error</div>
    }

    <form method="post" class="space-y-6 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <!-- Choose Site -->
        <div>
            <label for="site" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Choose Site</label>
            <select id="site" asp-for="LocationID" class="mt-1.5 block w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 shadow-sm focus:border-subgreen-500 focus:ring-2 focus:ring-subgreen-500/20 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 dark:focus:border-subgreen-400" required>
                <option value="">Select a site</option>
                @foreach (var site in Model.Sites.Where(s => s.IsActive))
                {
                    <option value="@site.LocationId">@site.LocationName</option>
                }
            </select>
        </div>

        <!-- Station Name -->
        <div>
            <label for="stationName" class="block text-sm font-medium text-slate-700 dark:text-slate-300">Station Name</label>
            <input type="text" id="stationName" asp-for="StationName" placeholder="e.g. Main Lobby Kiosk" required
                   class="mt-1.5 block w-full rounded-xl border border-slate-300 bg-white px-4 py-2.5 text-slate-900 placeholder-slate-400 shadow-sm focus:border-subgreen-500 focus:ring-2 focus:ring-subgreen-500/20 dark:border-slate-600 dark:bg-slate-700 dark:text-slate-100 dark:placeholder-slate-500 dark:focus:border-subgreen-400" />
        </div>

        <!-- Toggles -->
        <div class="space-y-4 rounded-xl border border-slate-100 bg-slate-50/50 p-4 dark:border-slate-700 dark:bg-slate-800/50">
            <p class="text-sm font-medium text-slate-700 dark:text-slate-300">Attendance mode</p>
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-600 dark:text-slate-400">QR Scan</span>
                <input type="checkbox" asp-for="QrEnabled" class="h-4 w-4 rounded border-slate-300 text-subgreen-600 focus:ring-subgreen-500" />
            </div>
            <div class="flex items-center justify-between">
                <span class="text-sm text-slate-600 dark:text-slate-400">ID Entry (organization-controlled)</span>
                <div class="inline-flex items-center gap-2">
                    <span class="text-xs font-medium @(Model.AllowManualEntry ? "text-subgreen-600 dark:text-subgreen-400" : "text-slate-500 dark:text-slate-400")">@(Model.AllowManualEntry ? "ON" : "OFF")</span>
                    <input type="checkbox" @(Model.AllowManualEntry ? "checked" : null) disabled class="h-4 w-4 rounded border-slate-300 text-subgreen-600 opacity-70" />
                </div>
            </div>
            <p class="text-xs text-slate-500 dark:text-slate-400">ID entry is forced by Organization Attendance Settings and cannot be changed per station.</p>
        </div>

        <!-- Schedule (Optional) -->
        <div>
            <label class="block text-sm font-medium text-slate-700 dark:text-slate-300">Schedule (optional)</label>
            <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">When this station is available for scanning.</p>
            <div class="mt-3 space-y-2">
                <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-slate-200 bg-white p-3 transition dark:border-slate-600 dark:bg-slate-700">
                    <input type="radio" name="ScheduleMode" value="Always" checked class="h-4 w-4 border-slate-300 text-subgreen-600 focus:ring-subgreen-500 dark:border-slate-500" />
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Always Open</span>
                </label>
                <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-slate-200 bg-white p-3 transition dark:border-slate-600 dark:bg-slate-700">
                    <input type="radio" name="ScheduleMode" value="Scheduled" class="h-4 w-4 border-slate-300 text-subgreen-600 focus:ring-subgreen-500 dark:border-slate-500" />
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Scheduled</span>
                    <span class="text-xs text-slate-500 dark:text-slate-400">Set opening hours</span>
                </label>
                <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-slate-200 bg-white p-3 transition dark:border-slate-600 dark:bg-slate-700">
                    <input type="radio" name="ScheduleMode" value="Manual" class="h-4 w-4 border-slate-300 text-subgreen-600 focus:ring-subgreen-500 dark:border-slate-500" />
                    <span class="text-sm font-medium text-slate-700 dark:text-slate-200">Manual</span>
                    <span class="text-xs text-slate-500 dark:text-slate-400">Enable/disable from admin</span>
                </label>
            </div>
        </div>

        <div class="flex gap-3 pt-2">
            <a asp-page="/App/Operations/ScanStation" class="btn-secondary flex-1 text-center">
                Cancel
            </a>
            <button type="submit" class="btn-primary flex-1">
                Save
            </button>
        </div>
    </form>
</div>
