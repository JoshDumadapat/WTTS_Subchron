@page
@model Subchron.Web.Pages.App.Operations.AttendanceLogs.DetailsModel
@{
    ViewData["Title"] = "Log Details";
    ViewData["PageTitle"] = "Log Details";
    Layout = "/Pages/App/Shared/_LayoutAdmin.cshtml";
}

<div class="mx-auto max-w-5xl space-y-6">
    <div class="flex items-center gap-3">
        <a asp-page="/App/Operations/AttendanceLogs" class="rounded-lg p-2 text-slate-500 hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-700">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        </a>
        <div>
            <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Daily Attendance Details</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400">Log #@Model.LogId</p>
        </div>
    </div>

    <div id="detailsState" class="rounded-2xl border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm dark:border-slate-700 dark:bg-slate-800 dark:text-slate-300">
        Loading attendance details...
    </div>

    <div id="detailsContent" class="hidden space-y-6">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800"><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Worked</p><p id="metricWorked" class="mt-2 text-lg font-semibold text-slate-900 dark:text-white">—</p></div>
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800"><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Late</p><p id="metricLate" class="mt-2 text-lg font-semibold text-orange-700 dark:text-orange-300">—</p></div>
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800"><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Undertime</p><p id="metricUndertime" class="mt-2 text-lg font-semibold text-amber-700 dark:text-amber-300">—</p></div>
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-700 dark:bg-slate-800"><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Overtime</p><p id="metricOvertime" class="mt-2 text-lg font-semibold text-violet-700 dark:text-violet-300">—</p></div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
            <div class="flex flex-wrap items-center justify-between gap-3">
                <div>
                    <p id="employeeName" class="text-lg font-semibold text-slate-900 dark:text-white">—</p>
                    <p id="employeeMeta" class="text-sm text-slate-500 dark:text-slate-400">—</p>
                </div>
                <span id="dayStatus" class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700 dark:bg-slate-700 dark:text-slate-200">—</span>
            </div>
            <div class="mt-4 grid gap-3 text-sm sm:grid-cols-3">
                <div><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Date</p><p id="dayDate" class="mt-1 font-medium text-slate-900 dark:text-white">—</p></div>
                <div><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Final Time In</p><p id="dayIn" class="mt-1 font-medium text-slate-900 dark:text-white">—</p></div>
                <div><p class="text-xs uppercase tracking-wide text-slate-500 dark:text-slate-400">Final Time Out</p><p id="dayOut" class="mt-1 font-medium text-slate-900 dark:text-white">—</p></div>
            </div>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
            <div class="border-b border-slate-100 px-5 py-4 dark:border-slate-700">
                <h3 class="text-sm font-semibold text-slate-800 dark:text-slate-200">Recorded Entries for the Day</h3>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="border-y border-slate-100 bg-slate-50/50 dark:border-slate-700 dark:bg-slate-800/50">
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Log ID</th>
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Time In</th>
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Time Out</th>
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Method</th>
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Station</th>
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Status</th>
                            <th class="px-5 py-3 text-xs font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Remarks</th>
                        </tr>
                    </thead>
                    <tbody id="entriesTableBody" class="divide-y divide-slate-100 dark:divide-slate-700">
                        <tr><td colspan="7" class="px-5 py-6 text-center text-sm text-slate-500 dark:text-slate-400">Loading entries...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var detailsState = document.getElementById('detailsState');
    var detailsContent = document.getElementById('detailsContent');
    var entriesTableBody = document.getElementById('entriesTableBody');
    var logId = @Model.LogId;

    function fmtDate(d) {
        var date = new Date(d);
        if (isNaN(date.getTime())) return '—';
        return date.toLocaleDateString();
    }

    function fmtTime(d) {
        var date = new Date(d);
        if (isNaN(date.getTime())) return '—';
        return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true });
    }

    function fmtMinutes(m) {
        var n = Number(m || 0);
        if (!isFinite(n) || n <= 0) return '—';
        return n + 'm';
    }

    function fmtWorked(m) {
        var n = Number(m || 0);
        if (!isFinite(n) || n <= 0) return '—';
        return (n / 60).toFixed(2) + 'h';
    }

    function statusBadgeClass(status) {
        var s = String(status || '').toLowerCase();
        if (s === 'present') return 'bg-subgreen-50 text-subgreen-700 dark:bg-subgreen-900/30 dark:text-subgreen-300';
        if (s === 'timed in') return 'bg-sky-50 text-sky-700 dark:bg-sky-900/30 dark:text-sky-300';
        if (s === 'late-in') return 'bg-orange-50 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300';
        if (s === 'undertime') return 'bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-300';
        if (s === 'overtime') return 'bg-violet-50 text-violet-700 dark:bg-violet-900/30 dark:text-violet-300';
        if (s === 'late-in + undertime') return 'bg-rose-50 text-rose-700 dark:bg-rose-900/30 dark:text-rose-300';
        return 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300';
    }

    function render(data) {
        document.getElementById('metricWorked').textContent = fmtWorked(data.workedMinutes);
        document.getElementById('metricLate').textContent = fmtMinutes(data.lateMinutes);
        document.getElementById('metricUndertime').textContent = fmtMinutes(data.undertimeMinutes);
        document.getElementById('metricOvertime').textContent = fmtMinutes(data.overtimeMinutes);
        document.getElementById('employeeName').textContent = data.employeeName || '—';
        document.getElementById('employeeMeta').textContent = ((data.empNumber || '—') + ' • ' + (data.departmentName || '—'));
        document.getElementById('dayDate').textContent = fmtDate(data.logDate);
        document.getElementById('dayIn').textContent = fmtTime(data.timeIn);
        document.getElementById('dayOut').textContent = fmtTime(data.timeOut);

        var statusEl = document.getElementById('dayStatus');
        statusEl.textContent = data.status || '—';
        statusEl.className = 'inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ' + statusBadgeClass(data.status);

        var entries = data.entries || [];
        if (!entries.length) {
            entriesTableBody.innerHTML = '<tr><td colspan="7" class="px-5 py-6 text-center text-sm text-slate-500 dark:text-slate-400">No entries found for this day.</td></tr>';
        } else {
            entriesTableBody.innerHTML = entries.map(function (e) {
                var method = (e.methodOut || e.methodIn || '—');
                return '<tr>' +
                    '<td class="px-5 py-3 text-sm font-medium text-slate-900 dark:text-white">#' + e.attendanceID + '</td>' +
                    '<td class="px-5 py-3 text-sm tabular-nums text-slate-600 dark:text-slate-400">' + fmtTime(e.timeIn) + '</td>' +
                    '<td class="px-5 py-3 text-sm tabular-nums text-slate-600 dark:text-slate-400">' + fmtTime(e.timeOut) + '</td>' +
                    '<td class="px-5 py-3 text-sm text-slate-600 dark:text-slate-400">' + method + '</td>' +
                    '<td class="px-5 py-3 text-sm text-slate-600 dark:text-slate-400">' + (e.station || '—') + '</td>' +
                    '<td class="px-5 py-3"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ' + statusBadgeClass(e.status) + '">' + (e.status || '—') + '</span></td>' +
                    '<td class="px-5 py-3 text-sm text-slate-500 dark:text-slate-400">' + (e.remarks || '—') + '</td>' +
                    '</tr>';
            }).join('');
        }

        detailsState.classList.add('hidden');
        detailsContent.classList.remove('hidden');
    }

    function fail(message) {
        detailsState.textContent = message || 'Unable to load attendance details.';
        detailsState.classList.remove('hidden');
        detailsContent.classList.add('hidden');
    }

    fetch('?handler=Item&id=' + encodeURIComponent(logId), { headers: { 'Accept': 'application/json' } })
        .then(function (r) {
            return r.json().then(function (data) {
                return { ok: r.ok, data: data || {} };
            });
        })
        .then(function (resp) {
            if (!resp.ok) {
                fail(resp.data.message || 'Attendance details not found.');
                return;
            }
            render(resp.data);
        })
        .catch(function () { fail('Unable to load attendance details.'); });
})();
</script>
}
