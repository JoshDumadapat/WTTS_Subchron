                            <button type="button"
                                    class="accordion-trigger"
                                    data-accordion-target="attendanceBucketsBody"
                                    aria-expanded="false"
                                    aria-controls="attendanceBucketsBody">
                                <div class="accordion-trigger__content flex flex-col items-start text-left">
                                    <span class="text-xs uppercase tracking-[0.35em] text-slate-400 dark:text-slate-500">Overtime Day Types</span>
                                    <p class="mt-1 text-lg font-semibold text-slate-900 dark:text-white">Customize Each Day Type</p>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">Turn day types on/off and optionally override their thresholds, caps, and minimum blocks.</p>
                                </div>
                                <svg class="h-5 w-5 text-slate-500 transition-transform" data-accordion-icon viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.25a.75.75 0 01-1.06 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                </svg>
                            </button>

                            <div id="attendanceBucketsBody" class="accordion-body hidden border-t border-slate-200 pt-4 dark:border-gray-700/60">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Leave a field blank if you want that day type to inherit the global value.</p>

                                <div class="mt-4 overflow-x-auto">
                                    <table class="min-w-full divide-y divide-slate-200 text-sm dark:divide-gray-700">
                                        <thead class="bg-slate-100 text-xs uppercase text-gray-500 dark:bg-gray-800/60 dark:text-gray-400">
                                            <tr>
                                                <th class="px-3 py-2 text-left">Day Type</th>
                                                <th class="px-3 py-2 text-left">Enabled</th>
                                                <th class="px-3 py-2 text-left">OT Threshold (hrs)</th>
                                                <th class="px-3 py-2 text-left">Maximum OT (hrs)</th>
                                                <th class="px-3 py-2 text-left">Minimum OT Block (mins)</th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-slate-200 dark:divide-gray-800">
                                            @{
                                                var buckets = new[]
                                                {
                                                                                         new { Key = "RegularDay", Label = "Regular Day", Detail = "Standard workday" },
                                                                                         new { Key = "RestDay", Label = "Rest Day", Detail = "Company rest day" },
                                                                                         new { Key = "SpecialWorkingHoliday", Label = "Special Working Holiday", Detail = "Special holiday (working)" },
                                                                                         new { Key = "SpecialNonWorkingHoliday", Label = "Special Non-Working Holiday", Detail = "Special holiday rest" },
                                                                                         new { Key = "RegularHoliday", Label = "Regular Holiday", Detail = "Regular national holiday" },
                                                                                         new { Key = "RestDaySpecialWorkingHoliday", Label = "Rest Day + Special Working Holiday", Detail = "Rest day overlaps special working holiday" },
                                                                                         new { Key = "RestDaySpecialNonWorkingHoliday", Label = "Rest Day + Special Non-Working Holiday", Detail = "Rest day overlaps special non-working holiday" },
                                                                                         new { Key = "RestDayRegularHoliday", Label = "Rest Day + Regular Holiday", Detail = "Rest day overlaps regular holiday" }
                                                                                         };
                                            }
                                            @foreach (var bucket in buckets)
                                            {
                                                var enableId = $"bucketEnabled-{bucket.Key}";
                                                var thresholdId = $"bucketThreshold-{bucket.Key}";
                                                var maxId = $"bucketMax-{bucket.Key}";
                                                var minBlockId = $"bucketMinBlock-{bucket.Key}";
                                                <tr>
                                                    <td class="px-3 py-3">
                                                        <span class="text-sm font-semibold text-gray-800 dark:text-white">@bucket.Label</span>
                                                        <p class="text-xs text-gray-500 dark:text-gray-400">@bucket.Detail</p>
                                                    </td>
                                                    <td class="px-3 py-3">
                                                        <span class="sr-only" id="@enableId-help">Toggle overtime for @bucket.Label</span>
                                                        <label class="relative inline-flex cursor-pointer items-center" aria-labelledby="@enableId-help">
                                                            <input type="checkbox" id="@enableId" class="peer sr-only" data-bucket-switch role="switch" aria-checked="false" @(bucket.Key == "RegularDay" ? "checked" : string.Empty)>
                                                            <div class="h-6 w-11 rounded-full bg-gray-300 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-400 after:bg-white after:transition-all after:content-['']
                                                                            peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                                                            peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-emerald-500
                                                                            dark:bg-gray-600 dark:border-gray-500"></div>
                                                        </label>
                                                    </td>
                                                    <td class="px-3 py-3">
                                                        <div class="flex items-center gap-2">
                                                            <input type="number" id="@thresholdId" min="0" max="24" step="0.25"
                                                                   class="w-24 rounded-lg border-0 px-2 py-1.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700"
                                                                   placeholder="optional" aria-label="@bucket.Label OT threshold in hours">
                                                            <span class="text-xs text-gray-500 dark:text-gray-400">hrs</span>
                                                        </div>
                                                    </td>
                                                    <td class="px-3 py-3">
                                                        <div class="flex items-center gap-2">
                                                            <input type="number" id="@maxId" min="0" max="24" step="0.25"
                                                                   class="w-24 rounded-lg border-0 px-2 py-1.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700"
                                                                   placeholder="optional" aria-label="@bucket.Label maximum OT in hours">
                                                            <span class="text-xs text-gray-500 dark:text-gray-400">hrs</span>
                                                        </div>
                                                    </td>
                                                    <td class="px-3 py-3">
                                                        <div class="flex items-center gap-2">
                                            <input type="number" id="@minBlockId" min="0" max="720" step="5" data-whole-number
                                                                   class="w-28 rounded-lg border-0 px-2 py-1.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700"
                                                                   placeholder="optional" aria-label="@bucket.Label minimum OT block in minutes">
                                                            <span class="text-xs text-gray-500 dark:text-gray-400">mins</span>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Scope (Accordion) -->
                        <div class="rounded-xl border border-slate-200 bg-white dark:border-gray-700 dark:bg-gray-900/20">
                            <button type="button"
                                    class="accordion-trigger"
                                    data-accordion-target="scopeRulesBody"
                                    aria-expanded="false"
                                    aria-controls="scopeRulesBody">
                                <div class="accordion-trigger__content flex flex-col items-start text-left">
                                    <span class="text-xs uppercase tracking-[0.35em] text-slate-400 dark:text-slate-500">Scope</span>
                                    <p class="mt-1 text-lg font-semibold text-slate-900 dark:text-white">Eligibility Controls</p>
                                    <p class="text-xs text-slate-500 dark:text-slate-400">Choose who these overtime rules cover.</p>
                                </div>
                                <svg class="h-5 w-5 text-slate-500 transition-transform" data-accordion-icon viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.25a.75.75 0 01-1.06 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                </svg>
                            </button>

                            <div id="scopeRulesBody" class="accordion-body hidden border-t border-slate-200 pt-4 dark:border-gray-700/60">
                                <p class="text-xs text-gray-500 dark:text-gray-400">Select “Limit to Selected Groups” to scope OT rules.</p>

                                <div class="mt-4 space-y-4">
                                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-6">
                                    <div class="flex items-center gap-2">
                                        <input type="radio" id="scopeAll" name="otScopeMode" value="ALL" class="h-4 w-4 text-emerald-600 focus:ring-emerald-500" checked>
                                        <label for="scopeAll" class="text-sm font-medium text-gray-800 dark:text-white">Applies to All Employees</label>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <input type="radio" id="scopeSelected" name="otScopeMode" value="SELECTED" class="h-4 w-4 text-emerald-600 focus:ring-emerald-500">
                                        <label for="scopeSelected" class="text-sm font-medium text-gray-800 dark:text-white">Limit to Selected Groups</label>
                                    </div>
                                </div>

                                <p class="text-xs text-gray-500 dark:text-gray-400">Filters support Departments, Sites, Roles, and Employment Types.</p>

                                <div id="scopeDisabledNotice" class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-gray-600 dark:border-gray-700 dark:bg-gray-900/30 dark:text-gray-300">
                                    Filtering is off. Switch to "Limit to Selected Groups" to choose departments, sites, roles, or employment types.
                                </div>

                                <div id="scopeEntryControls" class="hidden space-y-4">
                                        <div class="grid gap-4 md:grid-cols-[210px_minmax(0,1fr)_140px]">
                                            <div>
                                                <label for="scopeEntryType" class="text-sm font-semibold text-gray-800 dark:text-white">Group Type</label>
                                                <select id="scopeEntryType"
                                                        class="mt-2 w-full rounded-xl border-0 bg-slate-100 px-3 py-2 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700">
                                                    <option value="DEPARTMENT">Department</option>
                                                    <option value="SITE">Site / Location</option>
                                                    <option value="ROLE">Role</option>
                                                    <option value="EMPLOYMENT_TYPE">Employment Type</option>
                                                </select>
                                            </div>

                                            <div>
                                                <label for="scopeEntryValue" class="text-sm font-semibold text-gray-800 dark:text-white">Select Value</label>
                                                <select id="scopeEntryValue"
                                                        class="mt-2 w-full rounded-xl border-0 bg-slate-100 px-3 py-2 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700"></select>
                                            </div>

                                            <div class="flex items-end">
                                                <button type="button" id="addScopeEntryBtn" class="btn-secondary w-full">Add Group</button>
                                            </div>
                                        </div>

                                        <p id="scopeEntryError" class="hidden text-sm font-medium text-red-600 dark:text-red-400">Select a value to add.</p>

                                        <div class="overflow-x-auto">
                                            <table class="min-w-full divide-y divide-slate-200 text-sm dark:divide-gray-800" aria-label="Scope groups table">
                                                <thead class="bg-slate-100 text-xs uppercase text-gray-500 dark:bg-gray-800/60 dark:text-gray-400">
                                                    <tr>
                                                        <th class="px-3 py-2 text-left">Group Type</th>
                                                        <th class="px-3 py-2 text-left">Value</th>
                                                        <th class="px-3 py-2 text-left">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="scopeEntriesTableBody" class="divide-y divide-slate-200 bg-white dark:divide-gray-800 dark:bg-gray-900/30">
                                                    <tr data-empty-row>
                                                        <td colspan="3" class="px-3 py-4 text-sm text-gray-500 dark:text-gray-400">No groups added yet.</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="border-slate-200 dark:border-gray-700" />

                        <!-- Night Differential (stays inside same card) -->
                        <div class="rounded-xl border border-slate-200 bg-white dark:border-gray-700 dark:bg-gray-900/20">
                            <div class="flex flex-wrap items-start justify-between gap-4 border-b border-slate-200 px-5 py-4 dark:border-gray-700">
                                <div>
                                    <p class="text-xs uppercase tracking-[0.35em] text-slate-400 dark:text-slate-500">Night Ops</p>
                                    <p class="mt-1 text-lg font-semibold text-slate-900 dark:text-white">Night Differential</p>
                                    <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">Attendance tags ND minutes; payroll computes ND pay.</p>
                                </div>

                                <div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 dark:border-gray-700 dark:bg-gray-900/60">
                                    <div>
                                        <label for="ndEnabledToggle" class="text-sm font-semibold text-gray-800 dark:text-white">Enabled</label>
                                        <p id="nd-enabled-help" class="text-xs text-gray-500 dark:text-gray-400">When off, ND tagging is skipped.</p>
                                    </div>
                                    <label class="relative inline-flex cursor-pointer items-center">
                                        <input type="checkbox" id="ndEnabledToggle" class="peer sr-only" role="switch" aria-checked="true" aria-describedby="nd-enabled-help" checked>
                                        <div class="h-6 w-11 rounded-full bg-gray-300 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-400 after:bg-white after:transition-all after:content-['']
                                                    peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                                    peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-emerald-500
                                                    dark:bg-gray-600 dark:border-gray-500"></div>
                                    </label>
                                </div>
                            </div>

                            <div id="nightDiffFields" class="space-y-6 p-5">
                                <div class="grid gap-5 md:grid-cols-3">
                                    <div>
                                        <label for="ndStartTime" class="text-sm font-semibold text-gray-800 dark:text-white">ND Window Start Time</label>
                                        <p id="nd-start-help" class="text-xs text-gray-500 dark:text-gray-400">Default 22:00 (10 PM).</p>
                                        <input type="time" id="ndStartTime" value="22:00" aria-describedby="nd-start-help"
                                               class="mt-2 block w-full rounded-xl border-0 bg-slate-100 px-3 py-2.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700">
                                    </div>

                                    <div>
                                        <label for="ndEndTime" class="text-sm font-semibold text-gray-800 dark:text-white">ND Window End Time</label>
                                        <p id="nd-end-help" class="text-xs text-gray-500 dark:text-gray-400">End earlier than start rolls to next day.</p>
                                        <input type="time" id="ndEndTime" value="06:00" aria-describedby="nd-end-help"
                                               class="mt-2 block w-full rounded-xl border-0 bg-slate-100 px-3 py-2.5 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700">
                                    </div>

                                    <div>
                                        <label for="ndMinimumMinutes" class="text-sm font-semibold text-gray-800 dark:text-white">Minimum Consecutive Minutes</label>
                                        <p id="nd-min-help" class="text-xs text-gray-500 dark:text-gray-400">ND minutes count after hitting this duration.</p>
                                        <div class="mt-2 flex items-center gap-2">
                        <input type="number" id="ndMinimumMinutes" min="0" max="720" step="5" value="30" aria-describedby="nd-min-help" data-whole-number
                                                   class="w-32 rounded-lg border-0 px-3 py-2 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700">
                                            <span class="text-sm text-gray-500 dark:text-gray-400">minutes</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="rounded-xl border border-slate-200 p-4 dark:border-gray-700">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <label for="ndExcludeBreaksToggle" class="text-sm font-semibold text-gray-800 dark:text-white">Exclude Breaks from ND</label>
                                            <p id="nd-breaks-help" class="text-xs text-gray-500 dark:text-gray-400">Unpaid breaks are removed from ND calculation.</p>
                                        </div>
                                        <label class="relative inline-flex cursor-pointer items-center">
                                            <input type="checkbox" id="ndExcludeBreaksToggle" class="peer sr-only" role="switch" aria-checked="true" aria-describedby="nd-breaks-help" checked>
                                            <div class="h-6 w-11 rounded-full bg-gray-300 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-400 after:bg-white after:transition-all after:content-['']
                                                        peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                                        peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-offset-2 peer-focus-visible:outline-emerald-500
                                                        dark:bg-gray-600 dark:border-gray-500"></div>
                                        </label>
                                    </div>
                                </div>

                                <div class="rounded-xl border border-dashed border-slate-300 dark:border-gray-700">
                                    <button type="button"
                                            class="flex w-full items-center justify-between px-4 py-3 text-left"
                                            data-accordion-target="ndExclusionsBody"
                                            aria-expanded="false"
                                            aria-controls="ndExclusionsBody">
                                        <span class="text-sm font-semibold text-gray-800 dark:text-white">Optional Exclusions</span>
                                        <svg class="h-5 w-5 text-gray-500 transition-transform" data-accordion-icon viewBox="0 0 20 20" fill="currentColor">
                                            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.06 1.06l-4.24 4.25a.75.75 0 01-1.06 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                        </svg>
                                    </button>

                                    <div id="ndExclusionsBody" class="hidden border-t border-slate-200 px-4 pb-4 pt-3 dark:border-gray-700/60">
                                        <p class="text-xs text-gray-500 dark:text-gray-400">Exclude ND tagging for selected scopes.</p>

                                        <div class="mt-4 space-y-4">
                                            <p class="text-xs text-slate-500 dark:text-gray-400">Choose a Department, Site, and Role combination, then add it below. Each row represents a scoped exclusion.</p>

                                            <div class="grid gap-4 md:grid-cols-3">
