        background: #f8fafc;
        cursor: pointer;
        transition: border-color .2s ease, background .2s ease;
        display: block;
        position: relative;
    }

    .dark #tab-attendance .basis-card {
        border-color: rgba(148,163,184,.35);
        background: rgba(15,23,42,.75);
        backdrop-filter: blur(6px);
    }

        #tab-attendance .basis-card input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

    #tab-attendance .basis-card__body {
        display: flex;
        flex-direction: column;
        gap: .35rem;
    }

    #tab-attendance .basis-card__title {
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
    }

    .dark #tab-attendance .basis-card__title {
        color: #f8fafc;
    }

    #tab-attendance .basis-card__description {
        font-size: .9rem;
        color: #475569;
    }

    .dark #tab-attendance .basis-card__description {
        color: rgba(226,232,240,.8);
    }

    #tab-attendance .basis-card--selected {
        border-color: #10b981;
        background: #ecfdf5;
        box-shadow: 0 0 0 1px rgba(16,185,129,.3);
    }

    .dark #tab-attendance .basis-card--selected {
        border-color: rgba(16,185,129,.65);
        background: rgba(5,86,69,.6);
        box-shadow: 0 0 0 1px rgba(16,185,129,.35);
    }

    #tab-attendance .accordion-trigger {
        width: 100%;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1.5rem;
        padding: 1.1rem 1.5rem;
        border-radius: 1.25rem;
        text-align: left;
        transition: background .2s ease, color .2s ease;
    }

    #tab-attendance .accordion-trigger__content {
        flex: 1;
        min-width: 0;
    }

    #tab-attendance .accordion-trigger svg {
        flex-shrink: 0;
        align-self: center;
    }

    #tab-attendance fieldset.is-readonly {
        opacity: 0.85;
    }

    #tab-attendance select[data-readonly-select="true"] {
        cursor: not-allowed;
    }

        #tab-attendance .accordion-trigger:hover {
            background: rgba(16,185,129,.12);
        }

    #tab-attendance .accordion-body {
        padding: 0 1.5rem 1.5rem;
    }

    #tab-attendance .scope-entry-disabled {
        opacity: .6;
    }

    /* Avoid accidental vertical overflow from tables */
    #tab-attendance table {
        border-collapse: separate;
        border-spacing: 0;
    }
</style>

<script>
    function openInstructionModal(modalId) {
        const modal = document.getElementById(modalId);
        if (!modal) return;
        modal.classList.remove('hidden');
        modal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('overflow-hidden');
    }

    function closeInstructionModal(modalId) {
        const modal = document.getElementById(modalId);
        if (!modal) return;
        modal.classList.add('hidden');
        modal.setAttribute('aria-hidden', 'true');
        if (!document.querySelector('.instruction-modal:not(.hidden)')) {
            document.body.classList.remove('overflow-hidden');
        }
    }

    function toggleManualOptions(checkbox) {
        const opts = document.getElementById('manualEntryOptions');
        if (!opts || !checkbox) return;
        opts.classList.toggle('hidden', !checkbox.checked);
    }

    function toggleAutoClockOut(checkbox) {
        const wrapper = document.getElementById('autoClockOutInput');
        const input = document.getElementById('autoClockOutHours');
        if (!wrapper || !checkbox) return;

        if (checkbox.checked) {
            wrapper.classList.remove('hidden');
            input?.removeAttribute('disabled');
        } else {
            wrapper.classList.add('hidden');
            input?.setAttribute('disabled', 'true');
        }
    }

    (function initAttendanceSettings() {
        const attendanceForm = document.getElementById('org-attendance-settings-form');
        const otForm = document.getElementById('org-ot-settings-form');
        if (!attendanceForm && !otForm) return;

        const appRoot = document.getElementById('appRoot');
        const apiBase = (appRoot?.getAttribute('data-api-base') || '').trim().replace(/\/$/, '');
        const token = appRoot?.getAttribute('data-access-token') || '';
        if (!apiBase || !token) return;

        const manualToggle = document.getElementById('manualEntryToggle');
        const requireGeofenceToggle = document.getElementById('requireGeofenceToggle');
        const restrictByIpToggle = document.getElementById('restrictByIpToggle');
        const preventDoubleClockInToggle = document.getElementById('preventDoubleClockInToggle');
        const autoClockOutToggle = document.getElementById('autoClockOutToggle');
        const autoClockOutHours = document.getElementById('autoClockOutHours');
        const defaultShiftInput = document.getElementById('defaultShiftTemplateCode');
        const attendanceSaveBtn = document.getElementById('attendanceSettingsSaveBtn');
        const attendanceErrorBox = document.getElementById('attendanceSettingsError');
        const otSaveBtn = document.getElementById('otSettingsSaveBtn');
        const otErrorBox = document.getElementById('otSettingsError');
        const attendanceButtonDefault = attendanceSaveBtn?.innerHTML || '';
        const otButtonDefault = otSaveBtn?.innerHTML || '';

        const attendanceFieldset = document.getElementById('attendanceSettingsFieldset');
        const attendanceActions = document.getElementById('attendanceFormActions');
        const attendanceEditBtn = document.getElementById('attendanceEditBtn');
        const attendanceCancelBtn = document.getElementById('attendanceCancelBtn');

        const otFieldset = document.getElementById('otSettingsFieldset');
        const otActions = document.getElementById('otFormActions');
        const otEditBtn = document.getElementById('otEditBtn');
        const otCancelBtn = document.getElementById('otCancelBtn');
        const readonlySelectHandlers = new WeakMap();

        const otEnabledToggle = document.getElementById('otEnabledToggle');
        const otSections = document.querySelectorAll('[data-ot-section]');

        const otBasisRadios = otForm?.querySelectorAll('input[name="otBasisOption"]') || [];
        const basisDailyInputRow = document.getElementById('basisDailyInputRow');
        const basisWeeklyInputRow = document.getElementById('basisWeeklyInputRow');
        const otBasisDailyHours = document.getElementById('otBasisDailyHours');
        const otBasisWeeklyHours = document.getElementById('otBasisWeeklyHours');

        const restHolidayOverrideToggle = document.getElementById('restHolidayOverrideToggle');
        const earlyOtToggle = document.getElementById('earlyOtToggle');
        const microOtBuffer = document.getElementById('microOtBuffer');
        const requireHoursMetToggle = document.getElementById('requireHoursMetToggle');

        const otFilingMode = document.getElementById('otFilingMode');
        const preApprovalToggle = document.getElementById('preApprovalToggle');
        const postFilingToggle = document.getElementById('postFilingToggle');
        const approvalFlowSelect = document.getElementById('approvalFlowSelect');
        const approvalStepsList = document.getElementById('approvalStepsList');
        const addApprovalStepBtn = document.getElementById('addApprovalStepBtn');
        const autoApproveToggle = document.getElementById('autoApproveToggle');

        const roundOtMinutes = document.getElementById('roundOtMinutes');
        const roundingDirection = document.getElementById('roundingDirection');
        const minimumOtBlock = document.getElementById('minimumOtBlock');

        const maxOtPerDay = document.getElementById('maxOtPerDay');
        const maxOtPerWeek = document.getElementById('maxOtPerWeek');
        const limitModeSelect = document.getElementById('limitModeSelect');
        const overrideRoleWrap = document.getElementById('overrideRoleWrap');
        const overrideRoleSelect = document.getElementById('overrideRoleSelect');

        const scopeEntryType = document.getElementById('scopeEntryType');
        const scopeEntryValue = document.getElementById('scopeEntryValue');
        const addScopeEntryBtn = document.getElementById('addScopeEntryBtn');
        const scopeEntryError = document.getElementById('scopeEntryError');
        const scopeEntriesTableBody = document.getElementById('scopeEntriesTableBody');
        const scopeRadios = otForm?.querySelectorAll('input[name="otScopeMode"]') || [];

        const nightDiffFields = document.getElementById('nightDiffFields');
        const ndEnabledToggle = document.getElementById('ndEnabledToggle');
        const ndStartTime = document.getElementById('ndStartTime');
        const ndEndTime = document.getElementById('ndEndTime');
        const ndMinimumMinutes = document.getElementById('ndMinimumMinutes');
        const ndExcludeBreaksToggle = document.getElementById('ndExcludeBreaksToggle');
        const ndComboDepartment = document.getElementById('ndComboDepartment');
        const ndComboSite = document.getElementById('ndComboSite');
        const ndComboRole = document.getElementById('ndComboRole');
        const ndAddExclusionBtn = document.getElementById('ndAddExclusionBtn');
        const ndCancelExclusionEditBtn = document.getElementById('ndCancelExclusionEditBtn');
        const ndComboError = document.getElementById('ndComboError');
        const ndCombosTableBody = document.getElementById('ndCombosTableBody');

        const accordionButtons = document.querySelectorAll('[data-accordion-target]');

        const bucketKeys = [
            'RegularDay',
            'RestDay',
            'SpecialWorkingHoliday',
            'SpecialNonWorkingHoliday',
            'RegularHoliday',
            'RestDaySpecialWorkingHoliday',
            'RestDaySpecialNonWorkingHoliday',
            'RestDayRegularHoliday'
        ];

        const approvalRoleOptions = [
            { value: 'SUPERVISOR', label: 'Supervisor' },
            { value: 'DEPARTMENT_HEAD', label: 'Department Head' },
            { value: 'HR_MANAGER', label: 'HR Manager' },
            { value: 'PAYROLL_ADMIN', label: 'Payroll Admin' },
            { value: 'OPERATIONS_HEAD', label: 'Operations Head' }
        ];

        const scopeOptionMap = {
            DEPARTMENT: ['Operations', 'Warehouse', 'Finance', 'Customer Success'],
            SITE: ['Metro Manila HQ', 'Cebu Hub', 'Davao Site', 'Clark Satellite'],
            ROLE: ['Supervisor', 'Shift Lead', 'HR Partner', 'Finance Reviewer'],
            EMPLOYMENT_TYPE: ['Regular', 'Project-based', 'Seasonal', 'Probationary']
        };

        const ndScopedOptions = {
            DEPARTMENT: ['Support', 'Sales', 'Field Ops', 'Warehouse'],
            SITE: ['Baguio Site', 'Iloilo Hub', 'Remote-only'],
            ROLE: ['Executives', 'Supervisors', 'Apprentices']
        };
        const ndAddExclusionBtnDefault = ndAddExclusionBtn?.innerHTML || 'Add Exclusion';

        let scopeEntries = [];
        let ndExclusionCombos = [];
        let ndComboEditingIndex = null;
        let isAttendanceSaving = false;
        let isOtSaving = false;
        let attendanceEditing = false;
        let otEditing = false;
        let lastAttendanceSettings = null;
        let lastOvertimeSettings = null;

        const defaultOvertimeSettings = {
            enabled: false,
            basis: 'SHIFT_END',
            restHolidayOverride: false,
            dailyThresholdHours: 8,
            weeklyThresholdHours: null,
            earlyOtAllowed: false,
            microOtBufferMinutes: 0,
            requireHoursMet: false,
            filingMode: 'AUTO',
            preApprovalRequired: false,
            allowPostFiling: true,
            approvalFlowType: 'SINGLE',
            approvalSteps: [{ role: 'SUPERVISOR', required: true }],
            autoApprove: false,
            roundingMinutes: 15,
            roundingDirection: 'NEAREST',
            minimumBlockMinutes: 30,
            maxPerDayHours: null,
            maxPerWeekHours: null,
            limitMode: 'SOFT',
            overrideRole: '',
            buckets: bucketKeys.map(key => ({
                key,
                enabled: key === 'RegularDay',
                thresholdHours: null,
                maxHours: null,
                minimumBlockMinutes: null
            })),
            scopeMode: 'ALL',
            scopeFilters: { departments: [], sites: [], employmentTypes: [], roles: [] }
        };

        const defaultNightDiffSettings = {
            enabled: true,
            windowStart: '22:00',
            windowEnd: '06:00',
            minimumMinutes: 30,
            excludeBreaks: true,
            excludeDepartments: [],
            excludeSites: [],
            excludeRoles: [],
            scopedExclusions: []
        };

        const deepClone = (value) => (value == null ? null : JSON.parse(JSON.stringify(value)));

        const numericOnlyInputs = document.querySelectorAll('[data-whole-number]');
        numericOnlyInputs.forEach(input => {
            input.addEventListener('input', () => {
                const sanitized = (input.value || '').replace(/[^0-9]/g, '');
                if (sanitized !== input.value) input.value = sanitized;
            });
        });

        const switchInputs = [
            otEnabledToggle,
            restHolidayOverrideToggle,
            earlyOtToggle,
            requireHoursMetToggle,
            preApprovalToggle,
            postFilingToggle,
            autoApproveToggle,
            ndEnabledToggle,
            ndExcludeBreaksToggle
        ];

        document.querySelectorAll('[data-bucket-switch]').forEach(input => switchInputs.push(input));

        switchInputs.forEach(input => {
            if (!input) return;
            syncSwitchAria(input);
            input.addEventListener('change', () => syncSwitchAria(input));
        });

        setOtSectionsDisabled(!(otEnabledToggle?.checked ?? false));
        handleBasisSelection();
        handleLimitModeChange();
        ensureApprovalStepsInitialized();
        handleScopeModeChange();
        setNightDiffDisabled(!(ndEnabledToggle?.checked ?? true));
        handleScopeEntryTypeChange();
        renderScopeEntries();
        populateNdComboSelects();
        setNdScopedExclusions(defaultNightDiffSettings.scopedExclusions || []);
        setAttendanceEditMode(false);
        setOtEditMode(false);

        otEnabledToggle?.addEventListener('change', () => setOtSectionsDisabled(!otEnabledToggle.checked));
        otBasisRadios.forEach(radio => radio.addEventListener('change', handleBasisSelection));
        limitModeSelect?.addEventListener('change', handleLimitModeChange);
        scopeRadios.forEach(radio => radio.addEventListener('change', handleScopeModeChange));
        ndEnabledToggle?.addEventListener('change', () => setNightDiffDisabled(!ndEnabledToggle.checked));

        scopeEntryType?.addEventListener('change', handleScopeEntryTypeChange);
        addScopeEntryBtn?.addEventListener('click', handleAddScopeEntry);
        scopeEntriesTableBody?.addEventListener('click', handleScopeEntryTableClick);
        ndAddExclusionBtn?.addEventListener('click', handleNdAddCombo);
        ndCancelExclusionEditBtn?.addEventListener('click', () => resetNdComboForm());
        ndCombosTableBody?.addEventListener('click', handleNdCombosTableClick);
        attendanceEditBtn?.addEventListener('click', () => {
            if (isAttendanceSaving) return;
            setAttendanceEditMode(true);
        });
        attendanceCancelBtn?.addEventListener('click', () => {
            if (isAttendanceSaving) return;
            if (lastAttendanceSettings) hydrateAttendanceSettings(deepClone(lastAttendanceSettings));
            setAttendanceEditMode(false);
            showAttendanceError('');
        });
        otEditBtn?.addEventListener('click', () => {
            if (isOtSaving) return;
            setOtEditMode(true);
        });
        otCancelBtn?.addEventListener('click', () => {
            if (isOtSaving) return;
            if (lastOvertimeSettings) hydrateOvertimeSettings(deepClone(lastOvertimeSettings));
            setOtEditMode(false);
            showOtError('');
        });

        accordionButtons.forEach(btn => {
            const targetId = btn.getAttribute('data-accordion-target');
            const target = document.getElementById(targetId);
            if (!target) return;
            btn.addEventListener('click', () => toggleAccordion(btn, target));
        });

        approvalFlowSelect?.addEventListener('change', updateApprovalFlowState);
        addApprovalStepBtn?.addEventListener('click', () => {
            if (!approvalStepsList) return;
            approvalStepsList.appendChild(createApprovalStepRow());
            updateApprovalFlowState();
        });

        approvalStepsList?.addEventListener('click', evt => {
            const row = evt.target.closest('[data-approval-step]');
            if (!row) return;

            if (evt.target.closest('[data-remove-step]')) {
                row.remove();
                updateApprovalFlowState();
                return;
            }
            if (evt.target.closest('[data-move-up]')) {
                moveApprovalStep(row, -1);
                return;
            }
            if (evt.target.closest('[data-move-down]')) {
                moveApprovalStep(row, 1);
            }
        });

        function showAttendanceError(message) {
            if (!attendanceErrorBox) return;
            if (message) {
                attendanceErrorBox.textContent = message;
                attendanceErrorBox.classList.remove('hidden');
            } else {
                attendanceErrorBox.textContent = '';
                attendanceErrorBox.classList.add('hidden');
            }
        }

        function showOtError(message) {
            if (!otErrorBox) return;
            if (message) {
                otErrorBox.textContent = message;
                otErrorBox.classList.remove('hidden');
            } else {
                otErrorBox.textContent = '';
                otErrorBox.classList.add('hidden');
            }
        }

        function setAttendanceSaving(state) {
            isAttendanceSaving = state;
            if (!attendanceSaveBtn) return;
            attendanceSaveBtn.disabled = state;
            attendanceSaveBtn.innerHTML = state ? 'Saving...' : attendanceButtonDefault;
        }

        function setOtSaving(state) {
            isOtSaving = state;
            if (!otSaveBtn) return;
            otSaveBtn.disabled = state;
            otSaveBtn.innerHTML = state ? 'Saving...' : otButtonDefault;
        }

        function setAttendanceEditMode(enabled) {
            attendanceEditing = !!enabled;
            toggleFieldsetInteractivity(attendanceFieldset, enabled);
            attendanceActions?.classList.toggle('hidden', !enabled);
            attendanceEditBtn?.classList.toggle('hidden', enabled);
        }

        function setOtEditMode(enabled) {
            otEditing = !!enabled;
            toggleFieldsetInteractivity(otFieldset, enabled, { readOnlySelects: true });
            otActions?.classList.toggle('hidden', !enabled);
            otEditBtn?.classList.toggle('hidden', enabled);
        }

        function syncSwitchAria(input) {
            if (!input) return;
            input.setAttribute('aria-checked', input.checked ? 'true' : 'false');
        }

        function setOtSectionsDisabled(disabled) {
            otSections.forEach(section => {
                section.setAttribute('aria-disabled', disabled ? 'true' : 'false');
                section.classList.toggle('opacity-50', disabled);
                section.classList.toggle('pointer-events-none', disabled);
                section.querySelectorAll('input, select, textarea, button').forEach(el => el.disabled = disabled);
            });
        }

        function setNightDiffDisabled(disabled) {
            if (!nightDiffFields) return;
            nightDiffFields.setAttribute('aria-disabled', disabled ? 'true' : 'false');
            nightDiffFields.classList.toggle('opacity-50', disabled);
            nightDiffFields.classList.toggle('pointer-events-none', disabled);
            nightDiffFields.querySelectorAll('input, select, textarea, button').forEach(el => el.disabled = disabled);
        }

        function getSelectedBasisValue() {
            const selected = Array.from(otBasisRadios || []).find(radio => radio.checked);
            return selected ? selected.value : 'SHIFT_END';
        }

        function handleBasisSelection() {
            const basis = getSelectedBasisValue();
            otBasisRadios.forEach(radio => {
                const card = radio.closest('[data-basis-card]');
                if (!card) return;
                card.classList.toggle('basis-card--selected', radio.checked);
            });

            const needsDaily = basis === 'DAILY_HOURS' || basis === 'LATER_OF_BOTH';
            const needsWeekly = basis === 'WEEKLY_HOURS' || basis === 'LATER_OF_BOTH';
            basisDailyInputRow?.classList.toggle('hidden', !needsDaily);
            basisWeeklyInputRow?.classList.toggle('hidden', !needsWeekly);

            toggleThresholdRequired(basisDailyInputRow, needsDaily);
            toggleThresholdRequired(basisWeeklyInputRow, needsWeekly);
        }

        function toggleThresholdRequired(wrapper, required) {
            if (!wrapper) return;
            const input = wrapper.querySelector('input[type="number"]');
            if (!input) return;
            if (required) {
                input.setAttribute('required', 'required');
                input.setAttribute('aria-required', 'true');
            } else {
                input.removeAttribute('required');
                input.removeAttribute('aria-required');
                input.value = input.value;
            }
        }

        function handleLimitModeChange() {
            const mode = limitModeSelect?.value || 'SOFT';
            const isSoft = mode === 'SOFT';
            overrideRoleWrap?.classList.toggle('hidden', !isSoft);
            if (overrideRoleSelect) overrideRoleSelect.disabled = !isSoft;
        }

        function toggleAccordion(btn, target) {
            const expanded = btn.getAttribute('aria-expanded') === 'true';
            const next = !expanded;
            btn.setAttribute('aria-expanded', String(next));
            target.classList.toggle('hidden', !next);
            const icon = btn.querySelector('[data-accordion-icon]');
            if (icon) icon.classList.toggle('rotate-180', next);
        }

        function createApprovalStepRow(step = {}) {
            const row = document.createElement('tr');
            row.dataset.approvalStep = 'true';

            const optionsHtml = approvalRoleOptions.map(opt => `<option value="${opt.value}">${opt.label}</option>`).join('');
            const selectId = `approver-role-${Date.now()}-${Math.random().toString(16).slice(2)}`;

            row.innerHTML = `
                <td class="px-3 py-3 text-sm font-semibold text-gray-800 dark:text-white" data-step-order>1</td>
                <td class="px-3 py-3">
                    <label class="sr-only" for="${selectId}">Approver Role</label>
                    <select id="${selectId}" class="mt-1 block w-full rounded-lg border-0 bg-slate-100 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-700">
                        ${optionsHtml}
                    </select>
                </td>
                <td class="px-3 py-3">
                    <label class="inline-flex items-center gap-2 text-sm text-gray-700 dark:text-gray-200">
                        <input type="checkbox" class="h-4 w-4 rounded border-gray-300 text-emerald-600 focus:ring-emerald-500 dark:border-gray-600">
                        <span>Required</span>
                    </label>
                </td>
                <td class="px-3 py-3">
                    <div class="flex flex-wrap gap-2">
                        <button type="button" class="rounded-lg border border-slate-300 px-2 py-1 text-xs font-semibold text-gray-700 hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-800" data-move-up>Move Up</button>
                        <button type="button" class="rounded-lg border border-slate-300 px-2 py-1 text-xs font-semibold text-gray-700 hover:bg-slate-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-emerald-500 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-800" data-move-down>Move Down</button>
                        <button type="button" class="rounded-lg border border-red-300 px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-500 dark:border-red-500/60 dark:text-red-300 dark:hover:bg-red-500/10" data-remove-step>Remove</button>
                    </div>
                </td>
            `;

            const select = row.querySelector('select');
            if (select) select.value = step.role || approvalRoleOptions[0].value;
            const checkbox = row.querySelector('input[type="checkbox"]');
            if (checkbox) checkbox.checked = step.required ?? true;

            return row;
        }

        function ensureApprovalStepsInitialized() {
            if (!approvalStepsList) return;
            if (!approvalStepsList.children.length) approvalStepsList.appendChild(createApprovalStepRow());
            updateApprovalFlowState();
        }

        function updateApprovalFlowState() {
            if (!approvalStepsList) return;
            const isMulti = (approvalFlowSelect?.value || 'SINGLE') === 'MULTI';

            if (addApprovalStepBtn) addApprovalStepBtn.disabled = !isMulti;

            const rows = Array.from(approvalStepsList.querySelectorAll('[data-approval-step]'));
            if (!rows.length) approvalStepsList.appendChild(createApprovalStepRow());

            rows.forEach((row, index) => {
                row.querySelector('[data-step-order]')?.replaceChildren(document.createTextNode(String(index + 1)));

                const removeBtn = row.querySelector('[data-remove-step]');
                if (!removeBtn) return;

                const hide = !isMulti || rows.length <= 1;
                removeBtn.classList.toggle('invisible', hide);
                removeBtn.setAttribute('aria-hidden', hide ? 'true' : 'false');
                removeBtn.tabIndex = hide ? -1 : 0;
            });
        }

        function moveApprovalStep(row, direction) {
            if (!approvalStepsList || !row) return;

            if (direction < 0) {
                const prev = row.previousElementSibling;
                if (prev) approvalStepsList.insertBefore(row, prev);
                updateApprovalFlowState();
                return;
            }

            if (direction > 0) {
                const next = row.nextElementSibling;
                if (next) approvalStepsList.insertBefore(row, next.nextElementSibling);
                updateApprovalFlowState();
            }
        }

        function handleScopeModeChange() {
            const onlySelected = getScopeMode() === 'SELECTED';
            toggleScopeEntryControls(!onlySelected);
        }

        function getScopeMode() {
            const selected = otForm?.querySelector('input[name="otScopeMode"]:checked');
            return selected ? selected.value : 'ALL';
        }

        function handleScopeEntryTypeChange() {
            if (!scopeEntryType || !scopeEntryValue) return;
            const type = scopeEntryType.value || 'DEPARTMENT';
            const options = scopeOptionMap[type] || [];
            scopeEntryValue.innerHTML = options.map(val => `<option value="${val}">${val}</option>`).join('');
            if (scopeEntryValue.options.length) scopeEntryValue.selectedIndex = 0;
        }

        function showScopeEntryError(message) {
            if (!scopeEntryError) return;
            scopeEntryError.textContent = message || '';
            scopeEntryError.classList.toggle('hidden', !message);
        }

        function handleAddScopeEntry() {
            if (!scopeEntryType || !scopeEntryValue) return;
            const type = scopeEntryType.value;
            const value = scopeEntryValue.value;

            if (!value) {
                showScopeEntryError('Select a value to add.');
                return;
            }
            if (scopeEntries.some(entry => entry.type === type && entry.value === value)) {
                showScopeEntryError('This group is already added.');
                return;
            }
            scopeEntries.push({ type, value });
            showScopeEntryError('');
            renderScopeEntries();
        }

        function handleScopeEntryTableClick(evt) {
            const removeBtn = evt.target.closest('[data-remove-scope]');
            if (!removeBtn) return;
            const index = Number(removeBtn.getAttribute('data-index'));
            if (Number.isNaN(index)) return;
            scopeEntries.splice(index, 1);
            renderScopeEntries();
        }

        function toggleScopeEntryControls(disabled) {
            const controls = document.getElementById('scopeEntryControls');
            const notice = document.getElementById('scopeDisabledNotice');
            controls?.classList.toggle('scope-entry-disabled', disabled);
            controls?.classList.toggle('hidden', disabled);
            controls?.setAttribute('aria-hidden', disabled ? 'true' : 'false');
            notice?.classList.toggle('hidden', !disabled);

            if (addScopeEntryBtn) addScopeEntryBtn.disabled = disabled;
            if (scopeEntryType) scopeEntryType.disabled = disabled;
            if (scopeEntryValue) scopeEntryValue.disabled = disabled;

            scopeEntriesTableBody?.querySelectorAll('[data-remove-scope]')?.forEach(btn => btn.disabled = disabled);
        }

        function formatScopeType(type) {
            const labels = {
                DEPARTMENT: 'Department',
                SITE: 'Site / Location',
                ROLE: 'Role',
                EMPLOYMENT_TYPE: 'Employment Type'
            };
            return labels[type] || type;
        }

        function renderScopeEntries() {
            if (!scopeEntriesTableBody) return;
            scopeEntriesTableBody.innerHTML = '';

            if (!scopeEntries.length) {
                const row = document.createElement('tr');
                row.setAttribute('data-empty-row', 'true');
                row.innerHTML = '<td colspan="3" class="px-3 py-4 text-sm text-gray-500 dark:text-gray-400">No groups added yet.</td>';
                scopeEntriesTableBody.appendChild(row);
                toggleScopeEntryControls(getScopeMode() !== 'SELECTED');
                return;
            }

            scopeEntries.forEach((entry, index) => {
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="px-3 py-3 text-sm font-medium text-gray-800 dark:text-gray-200">${formatScopeType(entry.type)}</td>
                    <td class="px-3 py-3 text-sm text-gray-700 dark:text-gray-300">${entry.value}</td>
                    <td class="px-3 py-3">
                        <button type="button"
                                class="rounded-lg border border-red-300 px-3 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-500 dark:border-red-500/60 dark:text-red-300 dark:hover:bg-red-500/10"
                                data-remove-scope data-index="${index}">
                            Remove
                        </button>
                    </td>
                `;
                scopeEntriesTableBody.appendChild(row);
            });

            toggleScopeEntryControls(getScopeMode() !== 'SELECTED');
        }

        function populateNdComboSelects() {
            populateNdComboSelect(ndComboDepartment, ndScopedOptions.DEPARTMENT, 'Select department');
            populateNdComboSelect(ndComboSite, ndScopedOptions.SITE, 'Select site');
            populateNdComboSelect(ndComboRole, ndScopedOptions.ROLE, 'Select role');
        }

        function populateNdComboSelect(selectEl, options, placeholder) {
            if (!selectEl) return;
            const opts = Array.isArray(options) ? options : [];
            const html = ['<option value="">' + placeholder + '</option>', ...opts.map(opt => `<option value="${opt}">${opt}</option>`)].join('');
            selectEl.innerHTML = html;
            selectEl.selectedIndex = 0;
        }

        function ensureOption(selectEl, value) {
            if (!selectEl) return;
            if (!value) return;
            const exists = Array.from(selectEl.options).some(opt => (opt.value || opt.textContent) === value);
            if (!exists) {
                const option = document.createElement('option');
                option.value = value;
                option.textContent = value;
                selectEl.appendChild(option);
            }
            selectEl.value = value;
        }

        function setNdComboError(message) {
            if (!ndComboError) return;
            ndComboError.textContent = message || '';
            ndComboError.classList.toggle('hidden', !message);
        }

        function resetNdComboForm() {
            ndComboEditingIndex = null;
            ndComboDepartment && (ndComboDepartment.selectedIndex = 0);
            ndComboSite && (ndComboSite.selectedIndex = 0);
            ndComboRole && (ndComboRole.selectedIndex = 0);
            ndCancelExclusionEditBtn?.classList.add('hidden');
            if (ndAddExclusionBtn) ndAddExclusionBtn.innerHTML = ndAddExclusionBtnDefault;
            setNdComboError('');
        }

        function handleNdAddCombo() {
            if (!ndComboDepartment || !ndComboSite || !ndComboRole) return;
            const department = (ndComboDepartment.value || '').trim();
            const site = (ndComboSite.value || '').trim();
            const role = (ndComboRole.value || '').trim();

            if (!department || !site || !role) {
                setNdComboError('Select a department, site, and role.');
                return;
            }

            const normalized = {
                department,
                site,
                role
            };

            const duplicateIndex = ndExclusionCombos.findIndex((combo, index) => {
                if (ndComboEditingIndex !== null && index === ndComboEditingIndex) return false;
                return combo.department?.toLowerCase() === department.toLowerCase()
                    && combo.site?.toLowerCase() === site.toLowerCase()
                    && combo.role?.toLowerCase() === role.toLowerCase();
            });

            if (duplicateIndex >= 0) {
                setNdComboError('That exclusion already exists.');
                return;
            }

            if (ndComboEditingIndex !== null) {
                ndExclusionCombos[ndComboEditingIndex] = normalized;
            } else {
                ndExclusionCombos.push(normalized);
            }

            renderNdCombosTable();
            resetNdComboForm();
        }

        function handleNdCombosTableClick(evt) {
            const editBtn = evt.target.closest('[data-edit-nd-combo]');
            if (editBtn) {
                const index = Number(editBtn.dataset.index);
                if (!Number.isNaN(index)) startNdComboEdit(index);
                return;
            }

            const removeBtn = evt.target.closest('[data-remove-nd-combo]');
            if (removeBtn) {
                const index = Number(removeBtn.dataset.index);
                if (Number.isNaN(index)) return;
                ndExclusionCombos.splice(index, 1);
                renderNdCombosTable();
                if (ndComboEditingIndex === index) resetNdComboForm();
                return;
            }
        }

        function startNdComboEdit(index) {
            if (!ndComboDepartment || !ndComboSite || !ndComboRole) return;
            const target = ndExclusionCombos[index];
            if (!target) return;
            ndComboEditingIndex = index;
            ensureOption(ndComboDepartment, target.department);
            ensureOption(ndComboSite, target.site);
            ensureOption(ndComboRole, target.role);
            if (ndAddExclusionBtn) ndAddExclusionBtn.innerHTML = 'Save Changes';
            ndCancelExclusionEditBtn?.classList.remove('hidden');
            setNdComboError('');
        }

        function setNdScopedExclusions(entries) {
            const list = Array.isArray(entries) ? entries : [];
            ndExclusionCombos = list.map(entry => ({
                department: (entry.department ?? entry.Department ?? '').trim(),
                site: (entry.site ?? entry.Site ?? '').trim(),
                role: (entry.role ?? entry.Role ?? '').trim()
            })).filter(entry => entry.department && entry.site && entry.role);
            renderNdCombosTable();
            resetNdComboForm();
        }

        function renderNdCombosTable() {
            if (!ndCombosTableBody) return;
            if (!ndExclusionCombos.length) {
                ndCombosTableBody.innerHTML = '<tr data-empty-row><td colspan="4" class="px-3 py-4 text-sm text-gray-500 dark:text-gray-400">No scoped exclusions added yet.</td></tr>';
                return;
            }

            ndCombosTableBody.innerHTML = ndExclusionCombos.map((combo, index) => `
                <tr>
                    <td class="px-3 py-3 text-sm font-medium text-gray-800 dark:text-gray-200">${combo.department || '—'}</td>
                    <td class="px-3 py-3 text-sm text-gray-700 dark:text-gray-300">${combo.site || '—'}</td>
                    <td class="px-3 py-3 text-sm text-gray-700 dark:text-gray-300">${combo.role || '—'}</td>
                    <td class="px-3 py-3">
                        <div class="flex flex-wrap gap-2">
                            <button type="button" class="btn-secondary h-9 px-3 text-xs" data-edit-nd-combo data-index="${index}">Edit</button>
                            <button type="button" class="rounded-lg border border-red-300 px-3 py-1.5 text-xs font-semibold text-red-600 hover:bg-red-50 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red-500 dark:border-red-500/60 dark:text-red-300 dark:hover:bg-red-500/10" data-remove-nd-combo data-index="${index}">Remove</button>
                        </div>
                    </td>
                </tr>
            `).join('');
        }

        function dedupeStrings(values) {
            if (!Array.isArray(values)) return [];
            const seen = new Set();
            const result = [];
            values.forEach(value => {
                const trimmed = (value ?? '').toString().trim();
                if (!trimmed || seen.has(trimmed.toLowerCase())) return;
                seen.add(trimmed.toLowerCase());
                result.push(trimmed);
            });
            return result;
        }

        function toggleFieldsetInteractivity(fieldset, enabled, options = {}) {
            if (!fieldset) return;
            const controls = fieldset.querySelectorAll('input, select, textarea, button, [contenteditable="true"]');
            controls.forEach(control => {
                if (control.tagName === 'SELECT' && options.readOnlySelects) {
                    if (!enabled) {
                        lockSelect(control);
                    } else {
                        unlockSelect(control);
                    }
                } else {
                    control.disabled = !enabled;
                    if (control.tagName === 'SELECT') unlockSelect(control);
                }
            });
            fieldset.classList.toggle('is-readonly', !enabled);
        }

        function lockSelect(select) {
            if (!select) return;
            select.disabled = false;
            select.dataset.readonlySelect = 'true';
            select.dataset.lockedValue = select.value;
            if (readonlySelectHandlers.has(select)) return;
            const handler = evt => {
                if (select.dataset.readonlySelect !== 'true') return;
                select.value = select.dataset.lockedValue ?? select.value;
                evt.preventDefault();
                evt.stopImmediatePropagation();
            };
            select.addEventListener('change', handler, true);
            select.addEventListener('input', handler, true);
            readonlySelectHandlers.set(select, handler);
        }

        function unlockSelect(select) {
            if (!select) return;
            const handler = readonlySelectHandlers.get(select);
            if (handler) {
                select.removeEventListener('change', handler, true);
                select.removeEventListener('input', handler, true);
                readonlySelectHandlers.delete(select);
            }
            delete select.dataset.readonlySelect;
            delete select.dataset.lockedValue;
        }

        function getSelectedMode() {
            const selected = attendanceForm?.querySelector('input[name="primaryMode"]:checked');
            return selected ? selected.value : null;
        }

        function parseHours() {
            if (!autoClockOutHours) return null;
            const value = autoClockOutHours.value.trim();
            if (!value) return null;
            const parsed = parseFloat(value);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function normalizeDecimal(input) {
            if (!input) return null;
            const value = (input.value || '').trim();
            if (!value) return null;
            const parsed = parseFloat(value);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function normalizeInt(input) {
            if (!input) return null;
            const value = (input.value || '').trim();
            if (!value) return null;
            const parsed = parseInt(value, 10);
            return Number.isFinite(parsed) ? parsed : null;
        }

        function collectApprovalSteps() {
            if (!approvalStepsList) return [];
            return Array.from(approvalStepsList.querySelectorAll('[data-approval-step]')).map(row => {
                const select = row.querySelector('select');
                const checkbox = row.querySelector('input[type="checkbox"]');
                return {
                    role: select?.value || approvalRoleOptions[0].value,
                    required: checkbox?.checked ?? true
                };
            });
        }

        function collectBucketSettings() {
            return bucketKeys.map(key => ({
                key,
                enabled: document.getElementById(`bucketEnabled-${key}`)?.checked ?? false,
                thresholdHours: normalizeDecimal(document.getElementById(`bucketThreshold-${key}`)),
                maxHours: normalizeDecimal(document.getElementById(`bucketMax-${key}`)),
                minimumBlockMinutes: normalizeInt(document.getElementById(`bucketMinBlock-${key}`))
            }));
        }

        function collectAttendancePayload() {
            const payload = {
                primaryMode: getSelectedMode(),
                allowManualEntry: manualToggle?.checked ?? false,
                requireGeo: requireGeofenceToggle?.checked ?? false,
                enforceGeofence: requireGeofenceToggle?.checked ?? false,
                restrictByIp: restrictByIpToggle?.checked ?? false,
                preventDoubleClockIn: preventDoubleClockInToggle?.checked ?? false,
                autoClockOutEnabled: autoClockOutToggle?.checked ?? false,
                autoClockOutMaxHours: null,
                defaultShiftTemplateCode: defaultShiftInput?.value?.trim() || null
            };

            if (!payload.primaryMode) {
                throw new Error('Select a primary attendance mode.');
            }

            if (payload.autoClockOutEnabled) {
                const parsedHours = parseHours();
                if (parsedHours == null) {
                    const err = new Error('Enter the number of hours before auto clock-out.');
                    err.code = 'AUTO_CLOCK_OUT';
                    throw err;
                }

                payload.autoClockOutMaxHours = parsedHours;
            } else {
                payload.autoClockOutMaxHours = null;
            }

            return payload;
        }

        function getScopePayload() {
            const mode = getScopeMode();
            if (mode !== 'SELECTED') {
                return { mode: 'ALL', filters: { departments: [], sites: [], employmentTypes: [], roles: [] } };
            }
            if (!scopeEntries.length) {
                throw new Error('Add at least one eligibility group when limiting scope.');
            }
            const filters = { departments: [], sites: [], roles: [], employmentTypes: [] };
            scopeEntries.forEach(entry => {
                if (entry.type === 'DEPARTMENT') filters.departments.push(entry.value);
                if (entry.type === 'SITE') filters.sites.push(entry.value);
                if (entry.type === 'ROLE') filters.roles.push(entry.value);
                if (entry.type === 'EMPLOYMENT_TYPE') filters.employmentTypes.push(entry.value);
            });
            return { mode: 'SELECTED', filters };
        }

        function collectOvertimeSettings() {
            const basis = getSelectedBasisValue() || defaultOvertimeSettings.basis;
            const dailyThreshold = normalizeDecimal(otBasisDailyHours);
            const weeklyThreshold = normalizeDecimal(otBasisWeeklyHours);

            const needsDaily = basis === 'DAILY_HOURS' || basis === 'LATER_OF_BOTH';
            const needsWeekly = basis === 'WEEKLY_HOURS' || basis === 'LATER_OF_BOTH';

            if (needsDaily && dailyThreshold == null) {
                throw new Error('Enter the daily OT threshold in hours.');
            }
            if (needsWeekly && weeklyThreshold == null) {
                throw new Error('Enter the weekly OT threshold in hours.');
            }

            const scopePayload = getScopePayload();
            const maxPerDay = normalizeDecimal(maxOtPerDay);
            const maxPerWeek = normalizeDecimal(maxOtPerWeek);

            if (maxPerDay != null && maxPerDay <= 0) {
                throw new Error('Enter a positive number of hours for Max OT Per Day or leave it blank for unlimited.');
            }

            if (maxPerWeek != null && maxPerWeek <= 0) {
                throw new Error('Enter a positive number of hours for Max OT Per Week or leave it blank for unlimited.');
            }

            return {
                enabled: otEnabledToggle?.checked ?? false,
                basis,
                restHolidayOverride: restHolidayOverrideToggle?.checked ?? false,
                dailyThresholdHours: needsDaily ? dailyThreshold : null,
                weeklyThresholdHours: needsWeekly ? weeklyThreshold : null,
                earlyOtAllowed: earlyOtToggle?.checked ?? false,
                microOtBufferMinutes: normalizeInt(microOtBuffer) ?? defaultOvertimeSettings.microOtBufferMinutes,
                requireHoursMet: requireHoursMetToggle?.checked ?? false,

                filingMode: otFilingMode?.value || 'AUTO',
                preApprovalRequired: preApprovalToggle?.checked ?? false,
                allowPostFiling: postFilingToggle?.checked ?? true,
                approvalFlowType: approvalFlowSelect?.value || 'SINGLE',
                approvalSteps: collectApprovalSteps(),
                autoApprove: autoApproveToggle?.checked ?? false,

                roundingMinutes: parseInt(roundOtMinutes?.value || defaultOvertimeSettings.roundingMinutes, 10) || defaultOvertimeSettings.roundingMinutes,
                roundingDirection: roundingDirection?.value || defaultOvertimeSettings.roundingDirection,
                minimumBlockMinutes: normalizeInt(minimumOtBlock) ?? defaultOvertimeSettings.minimumBlockMinutes,

                maxPerDayHours: maxPerDay,
                maxPerWeekHours: maxPerWeek,
                limitMode: limitModeSelect?.value || 'SOFT',
                overrideRole: (limitModeSelect?.value || 'SOFT') === 'SOFT' ? (overrideRoleSelect?.value || '') : '',

                buckets: collectBucketSettings(),
                scopeMode: scopePayload.mode,
                scopeFilters: scopePayload.filters
            };
        }

        function collectNightDiffSettings() {
            const departments = dedupeStrings(ndExclusionCombos.map(combo => combo.department));
            const sites = dedupeStrings(ndExclusionCombos.map(combo => combo.site));
            const roles = dedupeStrings(ndExclusionCombos.map(combo => combo.role));

            return {
                enabled: ndEnabledToggle?.checked ?? true,
                windowStart: ndStartTime?.value || defaultNightDiffSettings.windowStart,
                windowEnd: ndEndTime?.value || defaultNightDiffSettings.windowEnd,
                minimumMinutes: normalizeInt(ndMinimumMinutes) ?? defaultNightDiffSettings.minimumMinutes,
                excludeBreaks: ndExcludeBreaksToggle?.checked ?? true,
                excludeDepartments: departments,
                excludeSites: sites,
                excludeRoles: roles,
                scopedExclusions: ndExclusionCombos.map(combo => ({
                    department: combo.department,
                    site: combo.site,
                    role: combo.role
                }))
            };
        }

        function setBasisSelection(value) {
            let matched = false;
            otBasisRadios.forEach(radio => {
                if (radio.value === value) {
                    radio.checked = true;
                    matched = true;
                }
            });
            if (!matched && otBasisRadios.length) otBasisRadios[0].checked = true;
            handleBasisSelection();
        }

        function setScopeEntriesFromFilters(filters) {
            const normalized = normalizeScopeFilters(filters);
            scopeEntries = [];
            (normalized.departments || []).forEach(value => scopeEntries.push({ type: 'DEPARTMENT', value }));
            (normalized.sites || []).forEach(value => scopeEntries.push({ type: 'SITE', value }));
            (normalized.roles || []).forEach(value => scopeEntries.push({ type: 'ROLE', value }));
            (normalized.employmentTypes || []).forEach(value => scopeEntries.push({ type: 'EMPLOYMENT_TYPE', value }));
            renderScopeEntries();
        }

        function normalizeScopeFilters(filters) {
            if (!filters) return { departments: [], sites: [], roles: [], employmentTypes: [] };

            if (Array.isArray(filters)) {
                const grouped = { departments: [], sites: [], roles: [], employmentTypes: [] };
                filters.forEach(item => {
                    const type = (item?.scopeType || item?.type || '').toUpperCase();
                    const values = item?.values || item?.include || [];
                    if (type.includes('DEPARTMENT')) grouped.departments.push(...values);
                    if (type.includes('SITE') || type.includes('LOCATION')) grouped.sites.push(...values);
                    if (type.includes('ROLE')) grouped.roles.push(...values);
                    if (type.includes('EMPLOYMENT')) grouped.employmentTypes.push(...values);
                });
                return grouped;
            }

            return {
                departments: filters.departments || filters?.scopeFilters?.departments || [],
                sites: filters.sites || filters?.scopeFilters?.sites || [],
                roles: filters.roles || filters?.scopeFilters?.roles || [],
                employmentTypes: filters.employmentTypes || filters?.scopeFilters?.employmentTypes || []
            };
        }

        function applyOvertimeSettings(settings) {
            const merged = {
                ...defaultOvertimeSettings,
                ...(settings || {}),
                scopeFilters: { ...defaultOvertimeSettings.scopeFilters, ...(settings?.scopeFilters || {}) }
            };

            if (otEnabledToggle) {
                otEnabledToggle.checked = !!merged.enabled;
                syncSwitchAria(otEnabledToggle);
                setOtSectionsDisabled(!otEnabledToggle.checked);
            }

            setBasisSelection(merged.basis || defaultOvertimeSettings.basis);

            if (otBasisDailyHours) otBasisDailyHours.value = merged.dailyThresholdHours != null ? merged.dailyThresholdHours : '';
            if (otBasisWeeklyHours) otBasisWeeklyHours.value = merged.weeklyThresholdHours != null ? merged.weeklyThresholdHours : '';

            if (restHolidayOverrideToggle) { restHolidayOverrideToggle.checked = !!merged.restHolidayOverride; syncSwitchAria(restHolidayOverrideToggle); }
            if (earlyOtToggle) { earlyOtToggle.checked = !!merged.earlyOtAllowed; syncSwitchAria(earlyOtToggle); }
            if (microOtBuffer) microOtBuffer.value = merged.microOtBufferMinutes ?? defaultOvertimeSettings.microOtBufferMinutes;
            if (requireHoursMetToggle) { requireHoursMetToggle.checked = !!merged.requireHoursMet; syncSwitchAria(requireHoursMetToggle); }

            if (otFilingMode) otFilingMode.value = merged.filingMode || 'AUTO';
            if (preApprovalToggle) { preApprovalToggle.checked = !!merged.preApprovalRequired; syncSwitchAria(preApprovalToggle); }
            if (postFilingToggle) { postFilingToggle.checked = merged.allowPostFiling ?? true; syncSwitchAria(postFilingToggle); }
            if (autoApproveToggle) { autoApproveToggle.checked = !!merged.autoApprove; syncSwitchAria(autoApproveToggle); }

            if (approvalFlowSelect) approvalFlowSelect.value = merged.approvalFlowType || 'SINGLE';

            if (approvalStepsList) {
                approvalStepsList.innerHTML = '';
                const steps = merged.approvalSteps?.length ? merged.approvalSteps : defaultOvertimeSettings.approvalSteps;
                steps.forEach(step => approvalStepsList.appendChild(createApprovalStepRow(step)));
                updateApprovalFlowState();
            }

            if (roundOtMinutes) roundOtMinutes.value = (merged.roundingMinutes ?? 15).toString();
            if (roundingDirection) roundingDirection.value = merged.roundingDirection || 'NEAREST';
            if (minimumOtBlock) minimumOtBlock.value = merged.minimumBlockMinutes ?? defaultOvertimeSettings.minimumBlockMinutes;

            if (maxOtPerDay) maxOtPerDay.value = merged.maxPerDayHours != null ? merged.maxPerDayHours : '';
            if (maxOtPerWeek) maxOtPerWeek.value = merged.maxPerWeekHours != null ? merged.maxPerWeekHours : '';

            if (limitModeSelect) limitModeSelect.value = merged.limitMode || 'SOFT';
            if (overrideRoleSelect) overrideRoleSelect.value = merged.overrideRole || '';
            handleLimitModeChange();

            const bucketMap = new Map((merged.buckets || []).map(b => [b.key, b]));
            bucketKeys.forEach(key => {
                const bucket = bucketMap.get(key) || {};
                const enabledInput = document.getElementById(`bucketEnabled-${key}`);
                if (enabledInput) { enabledInput.checked = bucket.enabled ?? (key === 'RegularDay'); syncSwitchAria(enabledInput); }
                const thresholdInput = document.getElementById(`bucketThreshold-${key}`);
                if (thresholdInput) thresholdInput.value = bucket.thresholdHours != null ? bucket.thresholdHours : '';
                const maxInput = document.getElementById(`bucketMax-${key}`);
                if (maxInput) maxInput.value = bucket.maxHours != null ? bucket.maxHours : '';
                const minInput = document.getElementById(`bucketMinBlock-${key}`);
                if (minInput) minInput.value = bucket.minimumBlockMinutes != null ? bucket.minimumBlockMinutes : '';
            });

            const scopeMode = merged.scopeMode === 'SELECTED' ? 'SELECTED' : 'ALL';
            otForm?.querySelector(`input[name="otScopeMode"][value="${scopeMode}"]`)?.click();
            setScopeEntriesFromFilters(merged.scopeFilters || merged.scopeRules);
            handleScopeModeChange();
        }

        function applyNightDiffSettings(settings) {
            const merged = { ...defaultNightDiffSettings, ...(settings || {}) };

            if (ndEnabledToggle) {
                ndEnabledToggle.checked = !!merged.enabled;
                syncSwitchAria(ndEnabledToggle);
                setNightDiffDisabled(!ndEnabledToggle.checked);
            }

            if (ndStartTime) ndStartTime.value = merged.windowStart || defaultNightDiffSettings.windowStart;
            if (ndEndTime) ndEndTime.value = merged.windowEnd || defaultNightDiffSettings.windowEnd;
            if (ndMinimumMinutes) ndMinimumMinutes.value = merged.minimumMinutes ?? defaultNightDiffSettings.minimumMinutes;

            if (ndExcludeBreaksToggle) { ndExcludeBreaksToggle.checked = !!merged.excludeBreaks; syncSwitchAria(ndExcludeBreaksToggle); }
            setNdScopedExclusions(merged.scopedExclusions || []);
        }

        function selectPrimaryMode(value) {
            const radios = attendanceForm?.querySelectorAll('input[name="primaryMode"]') || [];
            let matched = false;
            radios.forEach(radio => {
                if (value && radio.value === value) { radio.checked = true; matched = true; }
            });
            if (!matched && radios[0]) radios[0].checked = true;
        }

        function hydrateAttendanceSettings(data) {
            selectPrimaryMode(data?.primaryMode || 'QR');

            if (manualToggle) {
                manualToggle.checked = !!data?.allowManualEntry;
                toggleManualOptions(manualToggle);
            }

            if (requireGeofenceToggle) {
                const requireValue = (data?.enforceGeofence ?? data?.requireGeo) || false;
                requireGeofenceToggle.checked = requireValue;
            }

            if (restrictByIpToggle) restrictByIpToggle.checked = !!data?.restrictByIp;
            if (preventDoubleClockInToggle) preventDoubleClockInToggle.checked = data?.preventDoubleClockIn ?? true;

            if (autoClockOutToggle) {
                autoClockOutToggle.checked = !!data?.autoClockOutEnabled;
                toggleAutoClockOut(autoClockOutToggle);
            }

            if (autoClockOutHours) {
                if (data?.autoClockOutMaxHours != null) autoClockOutHours.value = Number(data.autoClockOutMaxHours).toString();
                else autoClockOutHours.value = '';
            }

            if (defaultShiftInput) defaultShiftInput.value = data?.defaultShiftTemplateCode || '';
        }

        function hydrateOvertimeSettings(data) {
            applyOvertimeSettings(data);
            applyNightDiffSettings(data?.nightDifferential);
        }

        async function loadAttendanceSettings() {
            try {
                const resp = await fetch(`${apiBase}/api/org-attendance-settings/current`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const text = await resp.text();
                const data = text ? JSON.parse(text) : null;

                if (!resp.ok) {
                    showAttendanceError(data?.message || 'Unable to load attendance settings.');
                    return;
                }

                lastAttendanceSettings = deepClone(data);
                hydrateAttendanceSettings(deepClone(lastAttendanceSettings));
                showAttendanceError('');
                setAttendanceEditMode(false);
            } catch {
                showAttendanceError('Unable to load attendance settings.');
            }
        }

        async function loadOvertimeSettings() {
            try {
                const resp = await fetch(`${apiBase}/api/org-attendance-overtime/current`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const text = await resp.text();
                const data = text ? JSON.parse(text) : null;

                if (!resp.ok) {
                    showOtError(data?.message || 'Unable to load overtime rules.');
                    return;
                }

                lastOvertimeSettings = deepClone(data);
                hydrateOvertimeSettings(deepClone(lastOvertimeSettings));
                showOtError('');
                setOtEditMode(false);
            } catch {
                showOtError('Unable to load overtime rules.');
            }
        }

        const instructionBindings = [
            { el: manualToggle, modalId: 'manualEntryInstructionModal' },
            { el: requireGeofenceToggle, modalId: 'geofenceInstructionModal' },
            { el: restrictByIpToggle, modalId: 'ipRestrictionInstructionModal' },
            { el: preventDoubleClockInToggle, modalId: 'doubleClockInstructionModal' },
            { el: autoClockOutToggle, modalId: 'autoClockInstructionModal' }
        ];

        instructionBindings.forEach(binding => {
            if (!binding.el) return;
            binding.el.addEventListener('change', (evt) => {
                if (evt.target.checked) openInstructionModal(binding.modalId);
            });
        });

        async function saveAttendanceSettings() {
            if (isAttendanceSaving || !attendanceForm) return;
            if (!attendanceEditing) return;

            let payload;
            try {
                payload = collectAttendancePayload();
            } catch (err) {
                showAttendanceError(err?.message || 'Unable to save attendance settings.');
                if (err?.code === 'AUTO_CLOCK_OUT') autoClockOutHours?.focus();
                return;
            }

            showAttendanceError('');
            setAttendanceSaving(true);

            try {
                const resp = await fetch(`${apiBase}/api/org-attendance-settings/current`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const text = await resp.text();
                let data = null;
                if (text) { try { data = JSON.parse(text); } catch { } }

                if (!resp.ok) throw new Error(data?.message || 'Failed to save attendance settings.');

                await loadAttendanceSettings();
                setAttendanceEditMode(false);

                const persisted = data?.persisted !== false;
                const toastMessage = data?.message
                    || (persisted ? 'Attendance settings updated.' : 'Attendance settings saved locally and will sync once reconnected.');
                window.showToast?.(toastMessage, persisted);
            } catch (err) {
                showAttendanceError(err?.message || 'Failed to save attendance settings.');
                window.showToast?.('Unable to save attendance settings.', false);
            } finally {
                setAttendanceSaving(false);
            }
        }

        async function saveOvertimeSettings() {
            if (isOtSaving || !otForm) return;
            if (!otEditing) return;

            let overtimeRules;
            try {
                overtimeRules = collectOvertimeSettings();
            } catch (err) {
                showOtError(err?.message || 'Fix the errors in overtime rules before saving.');
                return;
            }

            const nightDifferential = collectNightDiffSettings();

            const payload = { ...overtimeRules, nightDifferential };

            showOtError('');
            setOtSaving(true);

            try {
                const resp = await fetch(`${apiBase}/api/org-attendance-overtime/current`, {
                    method: 'PUT',
                    headers: {
                        'Authorization': `Bearer ${token}`,
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const text = await resp.text();
                let data = null;
                if (text) { try { data = JSON.parse(text); } catch { } }

                if (!resp.ok) throw new Error(data?.message || 'Failed to save overtime settings.');

                await loadOvertimeSettings();
                setOtEditMode(false);

                const persisted = data?.persisted !== false;
                const toastMessage = data?.message
                    || (persisted ? 'Overtime rules updated.' : 'Overtime rules saved locally and will sync once reconnected.');
                window.showToast?.(toastMessage, persisted);
            } catch (err) {
                showOtError(err?.message || 'Failed to save overtime settings.');
                window.showToast?.('Unable to save overtime settings.', false);
            } finally {
                setOtSaving(false);
            }
        }

        attendanceForm?.addEventListener('submit', (evt) => {
            evt.preventDefault();
            saveAttendanceSettings();
        });

        otForm?.addEventListener('submit', (evt) => {
            evt.preventDefault();
            saveOvertimeSettings();
        });

        Promise.all([loadAttendanceSettings(), loadOvertimeSettings()]);
    })();
</script>
