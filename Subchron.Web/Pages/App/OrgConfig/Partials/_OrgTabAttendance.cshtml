                                                    </thead>
                                                    <tbody id="ndCombosTableBody" class="divide-y divide-slate-200 bg-white dark:divide-gray-800 dark:bg-gray-900/30">
                                                        <tr data-empty-row>
                                                            <td colspan="4" class="px-3 py-4 text-sm text-gray-500 dark:text-gray-400">No scoped exclusions added yet.</td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div><!-- /data-ot-section -->
                </div><!-- /one OT card -->
            </section>

            </fieldset>

            <div class="mt-6 flex flex-wrap items-center justify-end gap-3 hidden" id="otFormActions">
                <button type="button" id="otCancelBtn" class="btn-secondary h-11 px-5 text-sm">Cancel</button>
                <button type="submit" id="otSettingsSaveBtn" class="btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
