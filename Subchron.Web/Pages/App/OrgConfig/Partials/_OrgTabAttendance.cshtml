                                                    <select id="ndComboRole" size="4"
                                                            class="mt-2 w-full rounded-xl border-0 bg-slate-100 px-3 py-2 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:outline-none focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-700"></select>
                                                </div>
                                            </div>

                                            <div class="flex flex-wrap items-center gap-3 justify-end">
                                                <button type="button" id="ndAddExclusionBtn" class="btn-primary">
                                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
                                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                                                    </svg>
                                                    Add Exclusion
                                                </button>
                                                <button type="button" id="ndCancelExclusionEditBtn" class="btn-secondary h-10 px-4 text-sm hidden">Cancel Edit</button>
                                                <p id="ndComboError" class="text-sm font-medium text-red-600 dark:text-red-400 hidden"></p>
                                            </div>

                                            <div class="overflow-x-auto">
                                                <table class="min-w-full divide-y divide-slate-200 text-sm dark:divide-gray-800" aria-label="Night differential scoped exclusions table">
                                                    <thead class="bg-slate-100 text-xs uppercase text-gray-500 dark:bg-gray-800/60 dark:text-gray-400">
                                                        <tr>
                                                            <th class="px-3 py-2 text-left">Department</th>
                                                            <th class="px-3 py-2 text-left">Site</th>
                                                            <th class="px-3 py-2 text-left">Role</th>
                                                            <th class="px-3 py-2 text-left">Actions</th>
