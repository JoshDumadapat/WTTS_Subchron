        function saveEarningRule(button) {
            var id = document.getElementById('earningRuleId').value;
            var name = (document.getElementById('earningRuleName').value || '').trim();
            if (!name) {
                notify('error', 'Earning rule name is required.');
                document.getElementById('earningRuleName').focus();
                return;
            }

            var rateType = document.getElementById('earningRuleRateType').value;
            if (!rateType) {
                notify('error', 'Rate type is required.');
                document.getElementById('earningRuleRateType').focus();
                return;
            }

            var rateValue = parseFloat(document.getElementById('earningRuleRateValue').value);
            if (!Number.isFinite(rateValue) || rateValue <= 0) {
                notify('error', 'Rate value must be greater than zero.');
                document.getElementById('earningRuleRateValue').focus();
                return;
            }

            var payload = {
                name: name,
                appliesTo: document.getElementById('earningRuleAppliesTo').value,
                dayType: document.getElementById('earningRuleDayType').value,
                holidayCombo: document.getElementById('earningRuleHolidayCombo').value,
                restDayHandling: document.getElementById('earningRuleRestDayHandling').value,
                scope: document.getElementById('earningRuleScope').value,
                effectiveFrom: document.getElementById('earningRuleEffectiveFrom').value || null,
                rateType: rateType,
                rateValue: rateValue,
                isTaxable: document.getElementById('earningRuleTaxable').checked,
                includeInBenefitBase: document.getElementById('earningRuleBenefitBase').checked,
                requiresApproval: document.getElementById('earningRuleRequiresApproval').checked,
                scopeTags: parseTags(document.getElementById('earningRuleScopeTags').value),
                notes: document.getElementById('earningRuleNotes').value || ''
            };

            var oid = getOrgId();
            if (!oid) {
                notify('error', 'No organization id found for pay components.');
                return;
            }

            var url = buildApiUrl('/api/organizations/' + oid + '/pay-components/earnings');
            var method = 'POST';
            if (id) {
                url += '/' + id;
                method = 'PUT';
            }

            setButtonLoading(button, true, 'Save Earning Rule');

            fetch(url, {
                method: method,
                headers: getJsonHeaders(),
                body: JSON.stringify(payload)
            })
            .then(function (r) {
                if (!r.ok) {
                    return r.json().then(function (e) { throw new Error(e.message || 'Failed to save earning rule.'); })
                        .catch(function () { throw new Error('Failed to save earning rule.'); });
                }
                return r.json();
            })
            .then(function (data) {
                if (data.ok !== false) {
                    closeEarningRuleModal();
                    loadEarnings();
                    notify('success', 'Earning rule saved.');
                }
            })
            .catch(function (err) { notify('error', err.message || 'Failed to save earning rule.'); })
            .finally(function () { setButtonLoading(button, false); });
        }

