                <label class="inline-flex cursor-pointer items-center gap-2">
                    <input type="checkbox" id="deductionRuleActive" checked class="rounded border-gray-300 text-emerald-600 focus:ring-emerald-500 dark:bg-gray-700 dark:border-gray-600" />
                    <span class="text-sm text-gray-700 dark:text-gray-300">Active?</span>
