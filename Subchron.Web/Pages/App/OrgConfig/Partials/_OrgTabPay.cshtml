                    tbody.querySelectorAll('.allowances-row').forEach(function (el) { el.remove(); });

                    var ph = tbody.querySelector('.allowances-placeholder');
                    if (ph) ph.remove();

                    if (!_allowancesList.length) {
                        tbody.innerHTML = '<tr class="allowances-placeholder text-center text-sm text-gray-400 dark:text-gray-500"><td colspan="10" class="px-5 py-8">No allowances yet. Click <strong>Add Allowance</strong> to create one.</td></tr>';
                        return;
                    }

                    _allowancesList.forEach(function (r) {
                        var tr = document.createElement('tr');
                        tr.className = 'allowances-row';
                        tr.innerHTML =
                            '<td class="px-5 py-3 text-sm font-medium text-gray-900 dark:text-white">' + safeText(r.name) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.category) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.allowanceType) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + safeText(r.amount) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.isTaxable) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.attendanceDependent) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.prorateIfPartialPeriod) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.effectiveFrom ? String(r.effectiveFrom).substring(0, 10) : '') + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.isActive !== false) + '</td>' +
                            '<td class="px-5 py-3 text-right">' + renderActionButtons('window.editAllowanceRule(' + r.allowanceRuleID + ')', 'window.deleteAllowanceRule(' + r.allowanceRuleID + ')') + '</td>';

                        tbody.appendChild(tr);
                    });
                })
                .catch(function () { });
        }

        function loadDeductions() {
            var oid = getOrgId();
            if (!oid) return;

            fetch(buildApiUrl('/api/organizations/' + oid + '/pay-components/deductions'), { headers: getAcceptHeaders() })
                .then(function (r) { return r.json(); })
                .then(function (list) {
                    _deductionsList = Array.isArray(list) ? list : [];
                    var tbody = document.getElementById('deductionsRulesBody');
                    tbody.querySelectorAll('.deductions-row').forEach(function (el) { el.remove(); });

                    var ph = tbody.querySelector('.deductions-placeholder');
                    if (ph) ph.remove();

                    if (!_deductionsList.length) {
                        tbody.innerHTML = '<tr class="deductions-placeholder text-center text-sm text-gray-400 dark:text-gray-500"><td colspan="12" class="px-5 py-8">No deductions yet. Click <strong>Add Deduction</strong> to create one.</td></tr>';
                        return;
                    }

                    _deductionsList.forEach(function (r) {
                        var amountText = r.deductionType === 'Formula'
                            ? (r.formulaExpression || '—')
                            : (r.amount != null ? r.amount : '—');

                        var tr = document.createElement('tr');
                        tr.className = 'deductions-row';
                        tr.innerHTML =
                            '<td class="px-5 py-3 text-sm font-medium text-gray-900 dark:text-white">' + safeText(r.name) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.category) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.deductionType) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.computeBasedOn) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + safeText(amountText) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.hasEmployerShare) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.hasEmployeeShare) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + safeText(r.maxDeductionAmount) + '</td>' +
                            '<td class="px-5 py-3 text-xs text-gray-500 dark:text-gray-400">' + safeText(r.effectiveFrom ? String(r.effectiveFrom).substring(0, 10) : '') + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + boolText(r.isActive !== false) + '</td>' +
                            '<td class="px-5 py-3 text-xs">' + (r.autoCompute ? 'Auto' : 'Manual') + '</td>' +
                            '<td class="px-5 py-3 text-right">' + renderActionButtons('window.editDeductionRule(' + r.deductionRuleID + ')', 'window.deleteDeductionRule(' + r.deductionRuleID + ')') + '</td>';

                        tbody.appendChild(tr);
                    });
                })
                .catch(function () { });
        }

        window.editEarningRule = function (id) { openEarningRuleModal(id); };
        window.editAllowanceRule = function (id) { openAllowanceModal(id); };
        window.editDeductionRule = function (id) { openDeductionModal(id); };

        window.deleteEarningRule = function (id) {
            if (confirm('Remove this earning rule?')) {
                fetch(buildApiUrl('/api/organizations/' + getOrgId() + '/pay-components/earnings/' + id), { method: 'DELETE', headers: getAuthHeaders() })
                    .then(function () { loadEarnings(); });
            }
        };

        window.deleteAllowanceRule = function (id) {
            if (confirm('Remove this allowance?')) {
                fetch(buildApiUrl('/api/organizations/' + getOrgId() + '/pay-components/allowances/' + id), { method: 'DELETE', headers: getAuthHeaders() })
                    .then(function () { loadAllowances(); });
            }
        };

        window.deleteDeductionRule = function (id) {
            if (confirm('Remove this deduction?')) {
                fetch(buildApiUrl('/api/organizations/' + getOrgId() + '/pay-components/deductions/' + id), { method: 'DELETE', headers: getAuthHeaders() })
                    .then(function () { loadDeductions(); });
            }
        };

        window.toggleCustomCompensationFields = function () {
            var basis = document.getElementById('compensation-basis').value;
            var customFields = document.getElementById('custom-compensation-fields');
            customFields.classList.toggle('hidden', basis !== 'Custom');

            if (basis !== 'Custom') {
                customFields.classList.remove('sm:grid', 'sm:grid-cols-2', 'sm:gap-5', 'sm:col-span-2');
            } else {
                customFields.classList.add('sm:grid', 'sm:grid-cols-2', 'sm:gap-5', 'sm:col-span-2');
            }
        };

        document.addEventListener('DOMContentLoaded', function () {
            if (document.getElementById('tab-pay')) {
                initializePaySectionLocking();
                loadOrgPayConfig();
                loadEarnings();
                loadAllowances();
                loadDeductions();
                window.toggleSecondCutoff();
                window.toggleCustomCompensationFields();
            }

        });

        document.getElementById('earningRuleModal')?.addEventListener('click', function (e) {
            if (e.target === this) closeEarningRuleModal();
        });

        document.getElementById('allowanceModal')?.addEventListener('click', function (e) {
            if (e.target === this) closeAllowanceModal();
        });

        document.getElementById('deductionModal')?.addEventListener('click', function (e) {
            if (e.target === this) closeDeductionModal();
        });
    })();
</script>
