        function parseTags(value) {
            if (!value) return [];
            return value.split(',').map(function (tag) { return tag.trim(); }).filter(function (tag) { return tag.length > 0; });
        }

        function joinTags(values) {
            if (!values || !values.length) return '';
            return values.join(', ');
        }

