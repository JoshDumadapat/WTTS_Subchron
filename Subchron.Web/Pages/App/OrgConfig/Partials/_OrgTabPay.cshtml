@* Pay Components Engine - Payroll Configuration Tab *@
<style>
    .pay-section-heading {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
    }

    .pay-step-badge {
        font-size: 0.9rem;
        font-weight: 700;
        color: rgb(16 185 129);
        background: rgba(16, 185, 129, 0.15);
        border-radius: 9999px;
        width: 1.9rem;
        height: 1.9rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .pay-hint {
        font-size: 11px;
        color: rgb(100 116 139);
    }

    .dark .pay-hint {
        color: rgb(148 163 184);
    }

    .pay-modal-scroll {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .pay-modal-scroll::-webkit-scrollbar {
        width: 0;
        height: 0;
    }
</style>

<div id="tab-pay" class="tab-content hidden h-full flex-col">

    <div class="flex items-center justify-between border-b border-slate-300 px-8 py-5 dark:border-gray-700">
        <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Payroll Configuration</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Define earnings rules, allowances, tax, and deductions. No hardcoding — build exactly what your organisation needs.</p>
        </div>
    </div>

    <div class="flex-1 overflow-y-auto p-8">
        <div class="flex flex-col gap-3">

            @* ── Financial Basis ──────────────────────────────────────────── *@
            <div id="pay-section-financial" class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <div class="pay-section-heading">
                        <span class="pay-step-badge">1</span>
                        <div>
                            <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Financial Basis</h3>
                            <p class="pay-hint">Currency, pay frequency, cutoff rules, and 13th-month handling aligned with DOLE guidance.</p>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-1 gap-5 p-6 sm:grid-cols-3">
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Currency <span class="text-red-500">*</span></label>
                        <input type="hidden" id="pay-currency" value="PHP" />
                        <input type="text" value="PHP (&#8369;)" readonly class="block w-full rounded-lg border-0 bg-slate-100 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                    </div>

                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Pay Cycle <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <select id="pay-cycle" class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                <option value="Weekly">Weekly</option>
                                <option value="BiWeekly">Bi-Weekly</option>
                                <option value="SemiMonthly" selected>Semi-Monthly</option>
                                <option value="Monthly">Monthly</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                            </div>
                        </div>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Work Hours Per Day <span class="text-red-500">*</span></label>
                        <div class="flex items-center gap-2">
                            <input id="pay-hours-per-day" type="number" min="1" max="24" value="8"
                                   class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                            <span class="whitespace-nowrap text-xs text-gray-400">hrs / day</span>
                        </div>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Cutoff Start Day <span class="text-red-500">*</span></label>
                        <input id="pay-cutoff-start-day" type="number" min="1" max="31" value="1"
                               class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                    </div>

                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Cutoff End Day <span class="text-red-500">*</span></label>
                        <input id="pay-cutoff-end-day" type="number" min="1" max="31" value="15"
                               class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                    </div>

                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Add Second Cutoff Window</label>
                        <div class="flex items-center gap-3">
                            <input type="checkbox" id="pay-enable-second-cutoff" class="rounded border-gray-300 text-emerald-600 focus:ring-emerald-500 dark:bg-gray-700 dark:border-gray-600" onchange="window.toggleSecondCutoff()" />
                            <span class="pay-hint">Enable if you run 1–15 and 16–EOM or weekly cycles.</span>
                        </div>
                    </div>

                    <div id="pay-second-cutoff-fields" class="hidden col-span-3 grid gap-5 sm:grid-cols-3">
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Second Cutoff Start Day <span class="text-red-500">*</span></label>
                            <input id="pay-second-cutoff-start" type="number" min="1" max="31" value="16" class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Second Cutoff End Day <span class="text-red-500">*</span></label>
                            <input id="pay-second-cutoff-end" type="number" min="1" max="31" value="30" class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Payroll Release Lag (days) <span class="text-red-500">*</span></label>
                            <input id="pay-release-lag" type="number" min="0" max="30" value="0" class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>
                    </div>

                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Lock Attendance After Cutoff</label>
                        <div class="relative">
                            <select id="pay-lock-attendance-after-cutoff" class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                <option value="true">Yes</option>
                                <option value="false" selected>No</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                            </div>
                        </div>
                        <p class="pay-hint mt-1">If enabled, supervisors must approve corrections before payroll cut.</p>
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">13th Month Calculation <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <select id="pay-thirteenth-basis" class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                <option value="basic" selected>Basic pay only</option>
                                <option value="basic_plus_allowances">Basic + selected allowances</option>
                                <option value="custom">Custom formula</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                            </div>
                        </div>
                        <p class="pay-hint mt-1">Aligns with DOLE rules; choose "Custom" if you grant prorated or project-based 13th month.</p>
                    </div>
                </div>
                <div class="flex items-center justify-end border-t border-slate-300 bg-slate-100 px-6 py-4 dark:border-gray-700 dark:bg-gray-700/40">
                    <button type="button" onclick="handlePaySectionAction('financial', this)" class="btn-secondary">Edit Financial Basis</button>
                </div>
            </div>

            <div class="h-[3px] w-full"></div>

            @* ── Compensation Basis ───────────────────────────────────────── *@
            <div id="pay-section-compensation" class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <div class="pay-section-heading">
                        <span class="pay-step-badge">2</span>
                        <div>
                            <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Compensation Basis</h3>
                            <p class="pay-hint">Define your base unit (monthly/daily/hourly/custom) and how custom units map to hours.</p>
                        </div>
                    </div>
                </div>
                <div class="grid grid-cols-1 gap-5 p-6 sm:grid-cols-2">
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Compensation Basis <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <select id="compensation-basis" onchange="toggleCustomCompensationFields()" style="color-scheme: light dark;" class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                <option value="Monthly" selected>Monthly</option>
                                <option value="Daily">Daily</option>
                                <option value="Hourly">Hourly</option>
                                <option value="Custom">Custom</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                            </div>
                        </div>
                    </div>

                    <div id="custom-compensation-fields" class="hidden sm:grid sm:grid-cols-2 sm:gap-5 sm:col-span-2">
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Custom Unit Label <span class="text-red-500">*</span></label>
                            <input id="custom-unit-label" type="text" placeholder="e.g. Project, Task"
                                   class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Custom Work Hours Per Unit <span class="text-red-500">*</span></label>
                            <input id="custom-work-hours" type="number" min="0" placeholder="e.g. 160"
                                   class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>
                    </div>
                </div>
                <div class="flex items-center justify-end border-t border-slate-300 bg-slate-100 px-6 py-4 dark:border-gray-700 dark:bg-gray-700/40">
                    <button type="button" onclick="handlePaySectionAction('compensation', this)" class="btn-secondary">Edit Compensation Basis</button>
                </div>
            </div>
            <div class="h-[3px] w-full"></div>

            @* ── Earnings Rules ───────────────────────────────────────────── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="flex items-center justify-between border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <div class="pay-section-heading">
                        <span class="pay-step-badge">3</span>
                        <div>
                            <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Earnings Rules</h3>
                            <p class="pay-hint">Configure OT, rest-day, night diff, and holiday premiums per DOLE classification.</p>
                        </div>
                    </div>
                    <button type="button" onclick="openEarningRuleModal()" class="btn-primary gap-1.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        Add Earning Rule
                    </button>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-300 dark:divide-gray-700">
                        <thead class="bg-slate-100 dark:bg-gray-700/40">
                            <tr>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Name</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Applies To</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Day Type</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Scope</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Rate</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Taxable</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Benefit Base</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Approval</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Effective From</th>
                                <th class="px-5 py-3 text-right text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="earningsRulesBody" class="divide-y divide-slate-300 bg-slate-50 dark:divide-gray-700 dark:bg-gray-800">
                            <tr class="earnings-placeholder text-center text-sm text-gray-400 dark:text-gray-500">
                                <td colspan="10" class="px-5 py-8">No earning rules yet. Click <strong>Add Earning Rule</strong> to create one.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="h-[3px] w-full"></div>

            @* ── Allowances ───────────────────────────────────────────────── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="flex items-center justify-between border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <div class="pay-section-heading">
                        <span class="pay-step-badge">4</span>
                        <div>
                            <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Allowances</h3>
                            <p class="pay-hint">Capture non-taxable allowances, hazard pay, or sector-specific grants with scopes per site/role.</p>
                        </div>
                    </div>
                    <button type="button" onclick="openAllowanceModal()" class="btn-primary gap-1.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                        Add Allowance
                    </button>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-300 dark:divide-gray-700">
                        <thead class="bg-slate-100 dark:bg-gray-700/40">
                            <tr>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Allowance Name</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Category</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Type</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Amount</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Taxable</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Attendance Dependent</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Prorate Partial Period</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Effective From</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Active</th>
                                <th class="px-5 py-3 text-right text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="allowancesRulesBody" class="divide-y divide-slate-300 bg-slate-50 dark:divide-gray-700 dark:bg-gray-800">
                            <tr class="allowances-placeholder text-center text-sm text-gray-400 dark:text-gray-500">
                                <td colspan="9" class="px-5 py-8">No allowances yet. Click <strong>Add Allowance</strong> to create one.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="h-[3px] w-full"></div>

            @* ── Tax Toggle ───────────────────────────────────────────────── *@
            <div id="pay-section-statutory" class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <div class="pay-section-heading">
                        <span class="pay-step-badge">5</span>
                        <div>
                            <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Statutory & Tax Settings</h3>
                            <p class="pay-hint">Toggle PH statutory computations (BIR, SSS, PhilHealth, Pag-IBIG) and who bears each contribution.</p>
                        </div>
                    </div>
                </div>
                <div class="p-6">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">BIR Withholding Tax</label>
                            <div class="space-y-2 rounded-lg border border-slate-200 p-3 dark:border-gray-700">
                                <label class="inline-flex items-center gap-2">
                                    <input type="checkbox" id="pay-enable-bir" class="rounded border-gray-300 text-emerald-600 focus:ring-emerald-500 dark:bg-gray-700 dark:border-gray-600" checked>
                                    <span class="text-sm text-gray-700 dark:text-gray-200">Apply BIR tax table (Manual of Allowances)</span>
                                </label>
                                <div class="grid grid-cols-2 gap-3">
                                    <div>
                                        <label class="pay-hint">Payroll Period <span class="text-red-500">*</span></label>
                                        <select id="pay-bir-period" class="mt-1 block w-full rounded-lg border-0 bg-slate-100 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-200 focus:ring-2 focus:ring-emerald-500 dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                            <option value="semi-monthly" selected>Semi-Monthly</option>
                                            <option value="monthly">Monthly</option>
                                            <option value="weekly">Weekly</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="pay-hint">Tax Table Version <span class="text-red-500">*</span></label>
