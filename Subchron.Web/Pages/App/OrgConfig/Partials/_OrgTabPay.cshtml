        function loadOrgPayConfig() {
            fetch(buildApiUrl('/api/orgconfig/pay'), { headers: getAcceptHeaders() })
                .then(function (r) {
                    if (!r.ok) throw new Error('Failed to load pay config');
                    return r.json();
                })
                .then(function (config) {
                    applyPayConfigToForm(config);
                })
                .catch(function () {
                    notify('warning', 'Unable to load saved pay settings.');
                });
        }

        function saveOrgPayConfig(sectionName, button) {
            var validationError = validatePayConfigForm();
            if (validationError) {
                notify('error', validationError.message);
                if (validationError.focusId) {
                    var field = document.getElementById(validationError.focusId);
                    if (field && typeof field.focus === 'function') field.focus();
                }
                return Promise.resolve(false);
            }

            setButtonLoading(button, true, sectionName ? 'Save ' + sectionName : 'Save Pay Settings');

            return fetch(buildApiUrl('/api/orgconfig/pay'), {
                method: 'PUT',
                headers: getJsonHeaders(),
                body: JSON.stringify(collectPayConfigPayload())
            })
                .then(function (r) {
                    if (!r.ok) {
                        return r.json().then(function (e) {
                            throw new Error(e.message || 'Failed to save pay settings');
                        }).catch(function () {
                            throw new Error('Failed to save pay settings');
                        });
                    }
                    return r.json();
                })
                .then(function () {
                    notify('success', (sectionName ? sectionName + ' saved.' : 'Pay settings saved.'));
                    return true;
                })
                .catch(function (err) {
                    notify('error', err.message || (sectionName ? 'Failed to save ' + sectionName + '.' : 'Failed to save pay settings.'));
                    return false;
                })
                .finally(function () {
                    setButtonLoading(button, false);
                });
        }

        function handlePaySectionAction(sectionKey, button) {
            var meta = paySectionMeta[sectionKey];
            if (!meta || !button) return;

            if (!paySectionState[sectionKey]) {
                setPaySectionEditable(sectionKey, true);
                button.textContent = 'Save ' + meta.label;
                button.classList.remove('btn-secondary');
                button.classList.add('btn-primary');
                return;
            }

            saveOrgPayConfig(meta.label, button).then(function (ok) {
                if (!ok) return;
                setPaySectionEditable(sectionKey, false);
                button.textContent = 'Edit ' + meta.label;
                button.classList.remove('btn-primary');
                button.classList.add('btn-secondary');
            });
        }

