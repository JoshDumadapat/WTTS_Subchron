            <button type="button" onclick="closeDeductionModal()" class="btn-secondary">Cancel</button>
            <button type="button" onclick="saveDeductionRule(this)" class="btn-primary gap-1.5">Save Deduction</button>
        </div>
    </div>
</div>

<script>
    (function () {
        var appRoot = document.getElementById('appRoot');
        var apiBase = (appRoot && appRoot.getAttribute('data-api-base') || '').trim().replace(/\/$/, '');
        var accessToken = (appRoot && appRoot.getAttribute('data-access-token') || '').trim();
        var resolvedApiBase = apiBase || window.location.origin;

        function buildApiUrl(path) {
            if (!path) return resolvedApiBase;
            return resolvedApiBase + (path.startsWith('/') ? path : '/' + path);
        }

        function parseJwtPayload(token) {
            try {
                if (!token) return null;
                var parts = token.split('.');
                if (parts.length < 2) return null;
                var payload = parts[1].replace(/-/g, '+').replace(/_/g, '/');
                var normalized = payload + '='.repeat((4 - payload.length % 4) % 4);
                var decoded = atob(normalized);
                return JSON.parse(decoded);
            } catch (_) {
                return null;
            }
        }

        var tokenPayload = parseJwtPayload(accessToken);
        var tokenOrgId = tokenPayload && (tokenPayload.orgId || tokenPayload.orgID || tokenPayload.OrgID || tokenPayload['http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier']);
        var parsedTokenOrgId = parseInt(tokenOrgId || '0', 10);
        var orgId = window.__orgIdForPay || (Number.isFinite(parsedTokenOrgId) ? parsedTokenOrgId : 0);

        function getOrgId() {
            if (orgId) return orgId;
            var m = document.cookie.match(/orgId=(\d+)/);
            if (m) return parseInt(m[1], 10);
            var queryOrg = parseInt(new URLSearchParams(window.location.search).get('orgId') || '0', 10);
            if (Number.isFinite(queryOrg) && queryOrg > 0) return queryOrg;
            return 0;
        }

        function getJsonHeaders() {
            var headers = { 'Content-Type': 'application/json' };
            if (accessToken) headers['Authorization'] = 'Bearer ' + accessToken;
            return headers;
        }

        function getAcceptHeaders() {
            var headers = { 'Accept': 'application/json' };
            if (accessToken) headers['Authorization'] = 'Bearer ' + accessToken;
            return headers;
        }

        function getAuthHeaders() {
            if (!accessToken) return {};
            return { 'Authorization': 'Bearer ' + accessToken };
        }

        var _earningsList = [];
        var _deductionsList = [];
        var _allowancesList = [];
        var paySectionState = {
            financial: false,
            compensation: false,
            statutory: false
        };
        var paySectionMeta = {
            financial: { id: 'pay-section-financial', label: 'Financial Basis' },
            compensation: { id: 'pay-section-compensation', label: 'Compensation Basis' },
            statutory: { id: 'pay-section-statutory', label: 'Statutory and Tax Settings' }
        };

        function notify(type, message) {
            if (window.showToast) {
                var success = type === 'success';
                window.showToast(message, success, type);
                return;
            }
            console.log(type + ': ' + message);
        }

        function setButtonLoading(button, isLoading, idleText) {
            if (!button) return;
            if (!button.dataset.idleText) button.dataset.idleText = idleText || button.textContent.trim();
            if (isLoading) {
                button.disabled = true;
                button.innerHTML = '<span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-white/60 border-t-white"></span><span>Saving...</span>';
                button.classList.add('inline-flex', 'items-center', 'gap-2');
            } else {
                button.disabled = false;
                button.textContent = button.dataset.idleText;
                button.classList.remove('inline-flex', 'items-center', 'gap-2');
            }
        }

        function setPaySectionEditable(sectionKey, editable) {
            var meta = paySectionMeta[sectionKey];
            if (!meta) return;
            var section = document.getElementById(meta.id);
            if (!section) return;
            section.querySelectorAll('input, select, textarea').forEach(function (field) {
                if (field.type === 'hidden') return;
                field.disabled = !editable;
            });
            paySectionState[sectionKey] = editable;
        }

        function initializePaySectionLocking() {
            Object.keys(paySectionMeta).forEach(function (key) {
                setPaySectionEditable(key, false);
            });
        }

        function toDecimal(value, fallback) {
            var parsed = parseFloat(value);
            return Number.isFinite(parsed) ? parsed : fallback;
        }

        function parseCutoffWindowsFromForm() {
            var windows = [];
            windows.push({
                startDay: Math.max(1, Math.min(31, parseInt(document.getElementById('pay-cutoff-start-day').value || '1', 10))),
                endDay: Math.max(1, Math.min(31, parseInt(document.getElementById('pay-cutoff-end-day').value || '15', 10))),
                releaseLagDays: 0
            });

            var hasSecond = document.getElementById('pay-enable-second-cutoff').checked;
            if (hasSecond) {
                windows.push({
                    startDay: Math.max(1, Math.min(31, parseInt(document.getElementById('pay-second-cutoff-start').value || '16', 10))),
                    endDay: Math.max(1, Math.min(31, parseInt(document.getElementById('pay-second-cutoff-end').value || '30', 10))),
                    releaseLagDays: Math.max(0, Math.min(30, parseInt(document.getElementById('pay-release-lag').value || '0', 10)))
                });
            }

            return windows;
        }

        function applyCutoffWindowsToForm(cutoffJson) {
            var windows = [];
            try {
                windows = JSON.parse(cutoffJson || '[]');
            } catch (_) {
                windows = [];
            }

            var first = windows[0] || { startDay: 1, endDay: 15 };
            document.getElementById('pay-cutoff-start-day').value = first.startDay || 1;
            document.getElementById('pay-cutoff-end-day').value = first.endDay || 15;

            var second = windows[1] || null;
            document.getElementById('pay-enable-second-cutoff').checked = !!second;
            if (second) {
                document.getElementById('pay-second-cutoff-start').value = second.startDay || 16;
                document.getElementById('pay-second-cutoff-end').value = second.endDay || 30;
                document.getElementById('pay-release-lag').value = second.releaseLagDays || 0;
            }

            window.toggleSecondCutoff();
        }

        function collectPayConfigPayload() {
            return {
                currency: 'PHP',
                payCycle: document.getElementById('pay-cycle').value,
                compensationBasis: document.getElementById('compensation-basis').value,
                customUnitLabel: (document.getElementById('custom-unit-label').value || '').trim(),
                customWorkHours: toDecimal(document.getElementById('custom-work-hours').value, null),
                hoursPerDay: toDecimal(document.getElementById('pay-hours-per-day').value, 8),
                cutoffWindowsJson: JSON.stringify(parseCutoffWindowsFromForm()),
                lockAttendanceAfterCutoff: document.getElementById('pay-lock-attendance-after-cutoff').value === 'true',
                thirteenthMonthBasis: document.getElementById('pay-thirteenth-basis').value,
                thirteenthMonthNotes: '',
                enableBIR: document.getElementById('pay-enable-bir').checked,
                birPeriod: document.getElementById('pay-bir-period').value,
                birTableVersion: parseInt(document.getElementById('pay-bir-table-version').value || String(new Date().getFullYear()), 10),
                enableSSS: document.getElementById('pay-enable-sss').checked,
                sssEmployerPercent: toDecimal(document.getElementById('pay-sss-employer').value, 8.5),
                enablePhilHealth: document.getElementById('pay-enable-phic').checked,
                philHealthRate: toDecimal(document.getElementById('pay-phic-rate').value, 3),
                enablePagIbig: document.getElementById('pay-enable-hdmf').checked,
                pagIbigRate: toDecimal(document.getElementById('pay-hdmf-rate').value, 2),
                enableIncomeTax: document.getElementById('pay-tax-apply').checked,
                prorateNewHires: document.getElementById('pay-tax-prorate-new-hire').checked,
                applyTaxThreshold: document.getElementById('pay-tax-apply-threshold').checked
            };
        }

        function validatePayConfigForm() {
            var payCycle = document.getElementById('pay-cycle').value;
            if (!payCycle) {
                return { message: 'Pay cycle is required.', focusId: 'pay-cycle' };
            }

            var hoursPerDay = toDecimal(document.getElementById('pay-hours-per-day').value, null);
            if (hoursPerDay == null || hoursPerDay <= 0 || hoursPerDay > 24) {
                return { message: 'Work hours per day must be between 0.01 and 24.', focusId: 'pay-hours-per-day' };
            }

            var cutoffStart = parseInt(document.getElementById('pay-cutoff-start-day').value || '0', 10);
            var cutoffEnd = parseInt(document.getElementById('pay-cutoff-end-day').value || '0', 10);
            if (!Number.isInteger(cutoffStart) || cutoffStart < 1 || cutoffStart > 31) {
                return { message: 'Cutoff start day must be from 1 to 31.', focusId: 'pay-cutoff-start-day' };
            }
            if (!Number.isInteger(cutoffEnd) || cutoffEnd < 1 || cutoffEnd > 31) {
                return { message: 'Cutoff end day must be from 1 to 31.', focusId: 'pay-cutoff-end-day' };
            }
            if (cutoffStart > cutoffEnd) {
                return { message: 'Cutoff start day must be less than or equal to cutoff end day.', focusId: 'pay-cutoff-start-day' };
            }

            if (document.getElementById('pay-enable-second-cutoff').checked) {
                var secondStart = parseInt(document.getElementById('pay-second-cutoff-start').value || '0', 10);
                var secondEnd = parseInt(document.getElementById('pay-second-cutoff-end').value || '0', 10);
                var releaseLag = parseInt(document.getElementById('pay-release-lag').value || '0', 10);
                if (!Number.isInteger(secondStart) || secondStart < 1 || secondStart > 31) {
                    return { message: 'Second cutoff start day must be from 1 to 31.', focusId: 'pay-second-cutoff-start' };
                }
                if (!Number.isInteger(secondEnd) || secondEnd < 1 || secondEnd > 31) {
                    return { message: 'Second cutoff end day must be from 1 to 31.', focusId: 'pay-second-cutoff-end' };
                }
                if (secondStart > secondEnd) {
                    return { message: 'Second cutoff start day must be less than or equal to second cutoff end day.', focusId: 'pay-second-cutoff-start' };
                }
                if (!Number.isInteger(releaseLag) || releaseLag < 0 || releaseLag > 30) {
                    return { message: 'Payroll release lag must be from 0 to 30 days.', focusId: 'pay-release-lag' };
                }
            }

            var compensationBasis = document.getElementById('compensation-basis').value;
            if (!compensationBasis) {
                return { message: 'Compensation basis is required.', focusId: 'compensation-basis' };
            }

            if (compensationBasis === 'Custom') {
                var customLabel = (document.getElementById('custom-unit-label').value || '').trim();
                var customHours = toDecimal(document.getElementById('custom-work-hours').value, null);
                if (!customLabel) {
                    return { message: 'Custom unit label is required.', focusId: 'custom-unit-label' };
                }
                if (customHours == null || customHours <= 0) {
                    return { message: 'Custom work hours must be greater than zero.', focusId: 'custom-work-hours' };
                }
            }

            if (!document.getElementById('pay-thirteenth-basis').value) {
                return { message: '13th month calculation is required.', focusId: 'pay-thirteenth-basis' };
            }

            if (document.getElementById('pay-enable-bir').checked) {
                if (!document.getElementById('pay-bir-period').value) {
                    return { message: 'Payroll period is required when BIR withholding is enabled.', focusId: 'pay-bir-period' };
                }
                var birYear = parseInt(document.getElementById('pay-bir-table-version').value || '0', 10);
                if (!Number.isInteger(birYear) || birYear < 2000 || birYear > 2100) {
                    return { message: 'Tax table version must be a valid year between 2000 and 2100.', focusId: 'pay-bir-table-version' };
                }
            }

            if (document.getElementById('pay-enable-sss').checked) {
                var sssRate = toDecimal(document.getElementById('pay-sss-employer').value, null);
                if (sssRate == null || sssRate < 0 || sssRate > 100) {
                    return { message: 'SSS employer rate must be between 0 and 100.', focusId: 'pay-sss-employer' };
                }
            }

            if (document.getElementById('pay-enable-phic').checked) {
                var phicRate = toDecimal(document.getElementById('pay-phic-rate').value, null);
                if (phicRate == null || phicRate < 0 || phicRate > 100) {
                    return { message: 'PhilHealth rate must be between 0 and 100.', focusId: 'pay-phic-rate' };
                }
            }

            if (document.getElementById('pay-enable-hdmf').checked) {
                var hdmfRate = toDecimal(document.getElementById('pay-hdmf-rate').value, null);
                if (hdmfRate == null || hdmfRate < 0 || hdmfRate > 100) {
                    return { message: 'Pag-IBIG rate must be between 0 and 100.', focusId: 'pay-hdmf-rate' };
                }
            }

            return null;
        }

        function applyPayConfigToForm(config) {
            if (!config) return;
            document.getElementById('pay-currency').value = 'PHP';
            document.getElementById('pay-cycle').value = config.payCycle || 'SemiMonthly';
            var compensationBasisRaw = (config.compensationBasis || 'Monthly').toString().toLowerCase();
            var compensationBasis = compensationBasisRaw === 'custom' ? 'Custom'
                : compensationBasisRaw === 'daily' ? 'Daily'
                : compensationBasisRaw === 'hourly' ? 'Hourly'
                : 'Monthly';
            document.getElementById('compensation-basis').value = compensationBasis;
            document.getElementById('custom-unit-label').value = config.customUnitLabel || '';
            document.getElementById('custom-work-hours').value = config.customWorkHours != null ? config.customWorkHours : '';
            document.getElementById('pay-hours-per-day').value = config.hoursPerDay != null ? config.hoursPerDay : 8;
            applyCutoffWindowsToForm(config.cutoffWindowsJson || '[]');
            document.getElementById('pay-lock-attendance-after-cutoff').value = String(!!config.lockAttendanceAfterCutoff);
            var thirteenthBasis = (config.thirteenthMonthBasis || 'basic').toString().toLowerCase();
            if (thirteenthBasis !== 'basic' && thirteenthBasis !== 'basic_plus_allowances' && thirteenthBasis !== 'custom') {
                thirteenthBasis = 'basic';
            }
            document.getElementById('pay-thirteenth-basis').value = thirteenthBasis;
            document.getElementById('pay-enable-bir').checked = !!config.enableBIR;
            var birPeriod = (config.birPeriod || 'semi-monthly').toString().toLowerCase();
            if (birPeriod === 'semimonthly') birPeriod = 'semi-monthly';
            if (birPeriod !== 'semi-monthly' && birPeriod !== 'monthly' && birPeriod !== 'weekly') {
                birPeriod = 'semi-monthly';
            }
            document.getElementById('pay-bir-period').value = birPeriod;
            document.getElementById('pay-bir-table-version').value = config.birTableVersion || new Date().getFullYear();
            document.getElementById('pay-enable-sss').checked = !!config.enableSSS;
            document.getElementById('pay-sss-employer').value = config.sssEmployerPercent != null ? config.sssEmployerPercent : 8.5;
            document.getElementById('pay-enable-phic').checked = !!config.enablePhilHealth;
            document.getElementById('pay-phic-rate').value = config.philHealthRate != null ? config.philHealthRate : 3;
            document.getElementById('pay-enable-hdmf').checked = !!config.enablePagIbig;
            document.getElementById('pay-hdmf-rate').value = config.pagIbigRate != null ? config.pagIbigRate : 2;
            document.getElementById('pay-tax-apply').checked = !!config.enableIncomeTax;
            document.getElementById('pay-tax-prorate-new-hire').checked = !!config.prorateNewHires;
