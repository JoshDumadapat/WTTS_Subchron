            </div>
        </div>

        <div class="flex items-center justify-end gap-3 border-t border-slate-300 bg-slate-100 px-6 py-4 dark:border-gray-700 dark:bg-gray-700/40">
            <button type="button" onclick="closeEarningRuleModal()" class="btn-secondary">Cancel</button>
            <button type="button" onclick="saveEarningRule(this)" class="btn-primary gap-1.5">Save Earning Rule</button>
        </div>
    </div>
</div>

