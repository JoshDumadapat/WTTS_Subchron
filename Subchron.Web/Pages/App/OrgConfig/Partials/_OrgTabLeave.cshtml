<div id="tab-leave" class="tab-content hidden h-full flex-col">

    <div class="flex items-center justify-between border-b border-slate-300 px-8 py-5 dark:border-gray-700">
        <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Leave Policies</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage time-off types, allowances, accrual rules, and global leave settings.</p>
        </div>
        <button onclick="openLeaveModal()" class="btn-primary gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add Leave Type
        </button>
    </div>

    <div class="flex-1 overflow-y-auto p-8">
        <div class="flex flex-col gap-8">

            @* ─── ACTIVE LEAVE POLICIES TABLE ─── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 bg-slate-200 px-6 py-4 dark:border-gray-700 dark:bg-gray-800/50">
                    <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Active Leave Types</h3>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-300 dark:divide-gray-700">
                        <thead class="bg-slate-200 dark:bg-gray-700/40">
                            <tr>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Leave Type</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Allowance</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Accrual</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Carry Over</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Flags</th>
                                <th class="px-5 py-3 text-right text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="leavePoliciesBody" class="divide-y divide-slate-300 bg-slate-50 dark:divide-gray-700 dark:bg-gray-800">

                        </tbody>
                    </table>
                </div>
            </div>

            @* ─── GENERAL LEAVE SETTINGS ─── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <h3 class="text-sm font-bold text-gray-900 dark:text-white">General Leave Settings</h3>
                    <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">Global rules that apply across all leave types.</p>
                </div>

                <div class="grid grid-cols-1 gap-0 divide-y divide-slate-300 dark:divide-gray-700 md:grid-cols-2 md:divide-x md:divide-y-0">

                    @* Left column *@
                    <div class="space-y-5 p-6">

                        @* Fiscal Year Start *@
                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Fiscal Year Start</label>
                            <div class="relative">
                            <select id="leaveFiscalYearStart" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option>January 1</option>
                                    <option>April 1</option>
                                    <option>July 1</option>
