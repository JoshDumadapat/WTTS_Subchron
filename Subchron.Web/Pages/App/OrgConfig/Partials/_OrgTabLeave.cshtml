        function renderLeavePoliciesTable() {
            const tbody = document.getElementById('leavePoliciesBody');
            if (!tbody) return;

            const perPage = leaveRowsPerPage || leaveRowsOptions[0];
            const total = leaveTypeList.length;
            const totalPages = total === 0 ? 1 : Math.ceil(total / perPage);

            if (total === 0) {
                leaveCurrentPage = 1;
            } else if (leaveCurrentPage > totalPages) {
                leaveCurrentPage = totalPages;
            } else if (leaveCurrentPage < 1) {
                leaveCurrentPage = 1;
            }

            const startIndex = total === 0 ? 0 : (leaveCurrentPage - 1) * perPage;
            const pageItems = total === 0 ? [] : leaveTypeList.slice(startIndex, startIndex + perPage);

            tbody.innerHTML = '';
            if (pageItems.length === 0) {
                const emptyRow = document.createElement('tr');
                emptyRow.innerHTML = `<td colspan="6" class="px-5 py-12 text-center text-sm text-gray-500 dark:text-gray-400">No leave types configured yet. Click "Add Leave Type" to begin.</td>`;
                tbody.appendChild(emptyRow);
            } else {
                pageItems.forEach(item => tbody.appendChild(createLeaveTypeRow(item)));
            }

            const rangeEl = document.getElementById('leavePaginationRange');
            if (rangeEl) {
                rangeEl.textContent = pageItems.length === 0
                    ? '0'
                    : `${startIndex + 1}-${startIndex + pageItems.length}`;
            }

            const totalEl = document.getElementById('leavePaginationTotal');
            if (totalEl) totalEl.textContent = total;

            const select = document.getElementById('leaveRowsPerPage');
            if (select && select.value !== String(perPage)) {
                select.value = String(perPage);
            }

            const badge = document.getElementById('leaveRowsPerPageBadge');
            if (badge) badge.textContent = String(perPage);

            renderLeavePaginationNumbers(totalPages);
        }

        function renderLeavePaginationNumbers(totalPages) {
            const container = document.getElementById('leavePaginationNumbers');
            const pages = Math.max(1, totalPages);

            if (container) {
                container.innerHTML = '';
                for (let i = 1; i <= pages; i++) {
                    const btn = document.createElement('button');
                    btn.type = 'button';
                    btn.className = i === leaveCurrentPage
                        ? 'h-9 min-w-[38px] rounded-md border border-emerald-200 bg-emerald-50 px-3 text-sm font-semibold text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-900/20 dark:text-emerald-200'
                        : 'h-9 min-w-[38px] rounded-md border border-slate-300 bg-white px-3 text-sm font-semibold text-gray-600 hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 dark:hover:bg-gray-800';
                    btn.textContent = i;
                    btn.addEventListener('click', () => {
                        if (leaveCurrentPage === i) return;
                        leaveCurrentPage = i;
                        renderLeavePoliciesTable();
                    });
                    container.appendChild(btn);
                }
            }

            const prevBtn = document.getElementById('leavePaginationPrev');
            if (prevBtn) {
                prevBtn.disabled = leaveCurrentPage <= 1 || leaveTypeList.length === 0;
                prevBtn.classList.toggle('opacity-40', prevBtn.disabled);
            }

            const nextBtn = document.getElementById('leavePaginationNext');
            if (nextBtn) {
                nextBtn.disabled = leaveCurrentPage >= pages || leaveTypeList.length === 0;
                nextBtn.classList.toggle('opacity-40', nextBtn.disabled);
            }
        }

        function replaceLeaveTypes(items) {
            leaveTypeStore.clear();
            leaveTypeList = [];
            (items || []).forEach(item => {
                if (!item) return;
                leaveTypeStore.set(item.leaveTypeID, item);
                leaveTypeList.push(item);
            });
            leaveCurrentPage = 1;
            renderLeavePoliciesTable();
        }

        function upsertLeaveTypeRecord(item, shouldRender = true) {
            if (!item) return;
            leaveTypeStore.set(item.leaveTypeID, item);
            const idStr = String(item.leaveTypeID);
            const idx = leaveTypeList.findIndex(entry => String(entry.leaveTypeID) === idStr);
            if (idx >= 0) {
                leaveTypeList[idx] = item;
            } else {
                leaveTypeList.push(item);
            }
            if (shouldRender) renderLeavePoliciesTable();
        }

        function removeLeaveTypeRecord(id, shouldRender = true) {
            const idStr = String(id);
            leaveTypeStore.delete(id);
            const idx = leaveTypeList.findIndex(entry => String(entry.leaveTypeID) === idStr);
            if (idx >= 0) leaveTypeList.splice(idx, 1);
            const pages = Math.max(1, Math.ceil((leaveTypeList.length || 0) / (leaveRowsPerPage || 1)));
            if (leaveCurrentPage > pages) leaveCurrentPage = pages;
            if (shouldRender) renderLeavePoliciesTable();
        }

        function bindLeaveTableControls() {
            const rowsSelect = document.getElementById('leaveRowsPerPage');
            if (rowsSelect && rowsSelect.dataset.bound !== 'true') {
                rowsSelect.dataset.bound = 'true';
                rowsSelect.addEventListener('change', (e) => {
                    const value = parseInt(e.target.value, 10);
                    if (!leaveRowsOptions.includes(value)) return;
                    leaveRowsPerPage = value;
                    leaveCurrentPage = 1;
                    renderLeavePoliciesTable();
                });
            }

            const prevBtn = document.getElementById('leavePaginationPrev');
            if (prevBtn && prevBtn.dataset.bound !== 'true') {
                prevBtn.dataset.bound = 'true';
                prevBtn.addEventListener('click', () => {
                    if (leaveCurrentPage > 1) {
                        leaveCurrentPage -= 1;
                        renderLeavePoliciesTable();
                    }
                });
            }

            const nextBtn = document.getElementById('leavePaginationNext');
            if (nextBtn && nextBtn.dataset.bound !== 'true') {
                nextBtn.dataset.bound = 'true';
                nextBtn.addEventListener('click', () => {
                    const pages = Math.max(1, Math.ceil((leaveTypeList.length || 0) / (leaveRowsPerPage || 1)));
                    if (leaveCurrentPage < pages) {
                        leaveCurrentPage += 1;
                        renderLeavePoliciesTable();
                    }
                });
            }

            const rowsBtn = document.getElementById('leaveRowsPerPageBtn');
            const rowsMenu = document.getElementById('leaveRowsPerPageMenu');

            if (rowsBtn && rowsBtn.dataset.bound !== 'true') {
                rowsBtn.dataset.bound = 'true';
                rowsBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    if (!rowsMenu) return;
                    rowsMenu.classList.toggle('hidden');
                    const isOpen = !rowsMenu.classList.contains('hidden');
                    rowsBtn.setAttribute('aria-expanded', String(isOpen));
                });
            }

            if (rowsMenu && rowsMenu.dataset.bound !== 'true') {
                rowsMenu.dataset.bound = 'true';
                rowsMenu.addEventListener('click', (e) => {
                    const option = e.target.closest('button.leave-rows-option');
                    if (!option) return;
                    const value = parseInt(option.dataset.value || option.value, 10);
                    if (!leaveRowsOptions.includes(value)) return;
                    leaveRowsPerPage = value;
                    leaveCurrentPage = 1;
                    const select = document.getElementById('leaveRowsPerPage');
                    if (select) select.value = String(value);
                    rowsMenu.classList.add('hidden');
                    rowsBtn?.setAttribute('aria-expanded', 'false');
                    renderLeavePoliciesTable();
                });
            }

            if (!document.body.dataset.leaveRowsMenuListener) {
                document.body.dataset.leaveRowsMenuListener = 'true';
                document.addEventListener('click', (e) => {
                    const menu = document.getElementById('leaveRowsPerPageMenu');
                    const btn = document.getElementById('leaveRowsPerPageBtn');
                    if (!menu || !btn) return;
                    if (menu.classList.contains('hidden')) return;
                    if (!menu.contains(e.target) && !btn.contains(e.target)) {
                        menu.classList.add('hidden');
                        btn.setAttribute('aria-expanded', 'false');
                    }
                });
            }
        }

        async function deleteLeaveType(id) {
            const item = leaveTypeStore.get(id);
            if (item?.isSystemProtected) {
                window.showToast?.('Protected leave templates cannot be deleted in this UI flow.', false);
                return;
            }

            if (String(id).startsWith('-') || usingDemoTemplates) {
                removeLeaveTypeRecord(id);
                window.showToast?.('Leave type removed from demo UI.', true);
                return;
            }

            try {
                const res = await apiFetch(`/api/leave-types/${id}`, { method: 'DELETE' });
                if (!res.ok) {
                    console.warn('Failed to delete leave type');
                    return;
                }

                removeLeaveTypeRecord(id);
            } catch (err) {
                console.warn('Failed to delete leave type', err);
            }
        }

        function setLeaveModalSaving(isSaving) {
            const btn = document.getElementById('leaveModalSaveBtn');
            const spinner = document.getElementById('leaveModalSaveSpinner');
            const icon = document.getElementById('leaveModalSaveIcon');
            const text = document.getElementById('leaveModalSaveText');
            if (!btn || !spinner || !icon || !text) return;

            if (isSaving) {
                btn.disabled = true;
                btn.classList.add('opacity-70', 'cursor-not-allowed');
                spinner.classList.remove('hidden');
                icon.classList.add('hidden');
                text.textContent = currentEditLeaveTypeId ? 'Updating...' : 'Saving...';
            } else {
                btn.disabled = false;
                btn.classList.remove('opacity-70', 'cursor-not-allowed');
                spinner.classList.add('hidden');
                icon.classList.remove('hidden');
                text.textContent = currentEditLeaveTypeId ? 'Update Leave Type' : 'Save Leave Type';
            }
        }

        function buildPayloadFromForm(existing = null) {
            const typeSelect = document.getElementById('leaveTypeSelect');
            const categorySelect = document.getElementById('leaveCategory');
            const compensationSelect = document.getElementById('leaveCompensationSource');
            const paidStatusSelect = document.getElementById('leavePaidStatus');
            const systemProtectedToggle = document.getElementById('flagSystemProtected');

            const typeVal = typeSelect?.value || 'sick';
            const typeName = typeVal === 'custom'
                ? (document.getElementById('customLeaveName')?.value.trim() || 'Custom Leave')
                : (leaveTypeLabels[typeVal] || 'Leave');

            const allowance = document.getElementById('leaveAllowance')?.value || 0;
            const accrualVal = document.getElementById('leaveAccrual')?.value || 'lump';
            const carryNone = document.querySelector('input[name="carry_over"]:checked')?.value === 'none';
            const carryMax = carryNone ? null : (document.getElementById('carryOverMaxDaysInput')?.value || 0);

            const needApproval = !!document.getElementById('flagApproval')?.checked;
            const needDoc = !!document.getElementById('flagDoc')?.checked;
            const allowNegative = !!document.getElementById('flagNegative')?.checked;

            const appliesToLabel = document.getElementById('leaveAppliesTo')?.value || 'All Employees';
            const leaveCategory = categorySelect?.value || 'company';
            const compensationSource = compensationSelect?.value || 'company_paid';
            const paidStatus = paidStatusSelect?.value || 'paid';
            const statutoryCode = document.getElementById('leaveStatutoryCode')?.value || 'NONE';

            const advanceFilingDays = Number(document.getElementById('leaveAdvanceFiling')?.value || 0);
            const allowRetroactiveFiling = !!document.getElementById('flagRetroactive')?.checked;
            const maxConsecutiveDays = Number(document.getElementById('leaveMaxConsecutive')?.value || 0);
            const filingUnit = document.getElementById('leaveFilingUnit')?.value || 'full_day';
            const deductionTiming = document.getElementById('leaveDeductionTiming')?.value || 'approval';
            const approverRole = document.getElementById('leaveApproverRole')?.value || 'supervisor';
            const expiryRule = document.getElementById('leaveExpiryRule')?.value || 'never';
            const expiryCustomMonths = Number(document.getElementById('leaveExpiryCustomMonths')?.value || 0);
            const allowLeaveOnRestDay = !!document.getElementById('flagAllowRestDay')?.checked;
            const allowLeaveOnHoliday = !!document.getElementById('flagAllowHoliday')?.checked;

            const minServiceMonths = Number(document.getElementById('leaveMinServiceMonths')?.value || 0);
            const requiresLegalQualification = !!document.getElementById('flagLegalQualification')?.checked;
            const requiresHrValidation = !!document.getElementById('flagHrValidation')?.checked;
            const canOrgOverride = !!document.getElementById('flagCanOrgOverride')?.checked;
            const isSystemProtected = !!systemProtectedToggle?.checked;

            return {
                leaveTypeName: typeName,
                defaultDaysPerYear: Number(allowance || 0),
                isPaid: paidStatus === 'paid',
                isActive: existing ? existing.isActive : true,
                accrualType: accrualEnumMap[accrualVal] || 1,
                carryOverType: carryOverEnumMap[carryNone ? 'none' : 'max'],
                carryOverMaxDays: carryNone ? null : Number(carryMax || 0),
                appliesTo: appliesToEnumMap[appliesToLabel] || 1,
                requireApproval: needApproval,
                requireDocument: needDoc,
                allowNegativeBalance: allowNegative,

                advanceFilingDays: advanceFilingDays,
                allowRetroactiveFiling: allowRetroactiveFiling,
                maxConsecutiveDays: maxConsecutiveDays,
                filingUnit: filingUnitEnumMap[filingUnit] || 1,
                deductBalanceOn: deductionTimingEnumMap[deductionTiming] || 1,
                approverRole: needApproval ? (approverRoleEnumMap[approverRole] || 1) : 4,
                leaveExpiryRule: expiryRuleEnumMap[expiryRule] || 1,
                leaveExpiryCustomMonths: expiryRule === 'custom_months' ? expiryCustomMonths : null,
                allowLeaveOnRestDay: allowLeaveOnRestDay,
                allowLeaveOnHoliday: allowLeaveOnHoliday,

                leaveCategory: leaveCategoryEnumMap[leaveCategory] || 2,
                statutoryCode: statutoryCodeEnumMap[statutoryCode] || 0,
                compensationSource: compensationSourceEnumMap[compensationSource] || 1,
                paidStatus: paidStatusEnumMap[paidStatus] || 1,
                minServiceMonths: minServiceMonths,
                requiresLegalQualification: requiresLegalQualification,
                requiresHrValidation: requiresHrValidation,
                canOrgOverride: canOrgOverride,
                isSystemProtected: isSystemProtected
            };
        }

        async function saveLeavePolicy() {
            if (isSavingLeaveType) return;

            isSavingLeaveType = true;
            setLeaveModalSaving(true);

            const existing = currentEditLeaveTypeId ? leaveTypeStore.get(currentEditLeaveTypeId) : null;
            const payload = buildPayloadFromForm(existing);

            const isDemoMode = usingDemoTemplates || !apiBase || String(currentEditLeaveTypeId || '').startsWith('-');

            if (isDemoMode) {
                const record = {
                    ...(existing || {}),
                    ...payload,
                    leaveTypeID: currentEditLeaveTypeId || nextDemoId--
                };

                upsertLeaveTypeRecord(record);
                closeLeaveModal();
                isSavingLeaveType = false;
                setLeaveModalSaving(false);
                window.showToast?.(currentEditLeaveTypeId ? 'Leave type updated in demo UI.' : 'Leave type added to demo UI.', true);
                return;
            }

            const url = currentEditLeaveTypeId ? `/api/leave-types/${currentEditLeaveTypeId}` : '/api/leave-types';
            const method = currentEditLeaveTypeId ? 'PUT' : 'POST';

            try {
                const res = await apiFetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!res.ok) {
                    console.warn('Failed to save leave type');
                    return;
                }

                const created = await res.json();
                upsertLeaveTypeRecord(created);
                closeLeaveModal();
            } catch (err) {
                console.error('Failed to save leave type', err);
            } finally {
                isSavingLeaveType = false;
                setLeaveModalSaving(false);
            }
        }

        async function saveLeaveSettings() {
            const fiscalLabel = document.getElementById('leaveFiscalYearStart')?.value || 'January 1';
            const resetLabel = document.getElementById('leaveResetRule')?.value || 'Reset on Fiscal Year Start';
            const prorated = document.getElementById('leaveProrated')?.checked ?? true;

            const payload = {
                fiscalYearStart: fiscalYearEnumMap[fiscalLabel] || 1,
                balanceResetRule: resetRuleEnumMap[resetLabel] || 1,
                proratedForNewHires: prorated
            };

            if (usingDemoTemplates || !apiBase) {
                window.showToast?.('General leave settings saved in demo UI.', true);
                return;
            }

            try {
                const res = await apiFetch('/api/org-leave-settings/current', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await res.json().catch(() => null);
                if (!res.ok) {
                    const message = data?.message || 'Failed to save leave settings';
                    window.showToast?.(message, false);
                    return;
                }

                const persisted = data?.persisted !== false;
                const toastMessage = data?.message
                    || (persisted ? 'Leave settings updated.' : 'Leave settings saved locally and will sync once reconnected.');
                window.showToast?.(toastMessage, persisted);
            } catch (err) {
                window.showToast?.('Unable to save leave settings.', false);
            }
        }

        function resetLeaveModal() {
            currentEditLeaveTypeId = null;

            document.getElementById('leaveModalTitle').textContent = 'New Leave Type';
            document.getElementById('leaveModalSaveText').textContent = 'Save Leave Type';

            document.getElementById('leaveTypeSelect').value = 'sil';
            document.getElementById('customLeaveName').value = '';
            document.getElementById('customNameField').classList.add('hidden');

            document.querySelector('input[name="carry_over"][value="none"]').checked = true;
            toggleCarryOverInput(false);
            document.getElementById('carryOverMaxDaysInput').value = 5;

            document.getElementById('leaveAdvanceFiling').value = 0;
            document.getElementById('flagRetroactive').checked = false;
            document.getElementById('leaveMaxConsecutive').value = 0;
            document.getElementById('leaveFilingUnit').value = 'full_day';
            document.getElementById('leaveDeductionTiming').value = 'approval';

            document.getElementById('leaveExpiryRule').value = 'never';
            document.getElementById('leaveExpiryCustomMonths').value = 12;
            toggleLeaveExpiryCustomMonths(false);

            document.getElementById('flagAllowRestDay').checked = false;
            document.getElementById('flagAllowHoliday').checked = false;

            document.getElementById('flagApproval').checked = true;
            document.getElementById('leaveApproverRole').value = 'supervisor';
            document.getElementById('approverRoleContainer').classList.remove('hidden');

            document.getElementById('flagDoc').checked = false;
            document.getElementById('flagNegative').checked = false;

            document.getElementById('flagLegalQualification').checked = false;
            document.getElementById('flagHrValidation').checked = false;
            document.getElementById('flagCanOrgOverride').checked = true;
            document.getElementById('flagSystemProtected').checked = false;

            applyTemplateToForm('sil');
            setLeaveModalSaving(false);
        }

        function openEditLeaveType(id) {
            const item = leaveTypeStore.get(id);
            if (!item) return;

            currentEditLeaveTypeId = id;
            document.getElementById('leaveModalTitle').textContent = 'Edit Leave Type';
            document.getElementById('leaveModalSaveText').textContent = 'Update Leave Type';

            const presetKey = inferTypeKeyFromName(item.leaveTypeName);
            document.getElementById('leaveTypeSelect').value = presetKey === 'custom' ? 'custom' : presetKey;

            if (presetKey === 'custom') {
                document.getElementById('customNameField').classList.remove('hidden');
                document.getElementById('customLeaveName').value = item.leaveTypeName || '';
            } else {
                document.getElementById('customNameField').classList.add('hidden');
                document.getElementById('customLeaveName').value = '';
            }

            document.getElementById('leaveCategory').value = item.leaveCategory === 1 ? 'statutory' : item.leaveCategory === 3 ? 'unpaid_admin' : 'company';
            document.getElementById('leaveCompensationSource').value =
                item.compensationSource === 2 ? 'government_benefit'
                : item.compensationSource === 3 ? 'unpaid'
                : item.compensationSource === 4 ? 'mixed'
                : 'company_paid';

            document.getElementById('leavePaidStatus').value =
                item.paidStatus === 2 ? 'unpaid'
                : item.paidStatus === 3 ? 'conditional'
                : 'paid';

            document.getElementById('leaveStatutoryCode').value = getStatutoryCodeLabel(item.statutoryCode);
            document.getElementById('leaveAllowance').value = item.defaultDaysPerYear ?? 0;
            document.getElementById('leaveAccrual').value = item.accrualType === 2 ? 'monthly' : item.accrualType === 3 ? 'perperiod' : 'lump';
            document.getElementById('leaveMinServiceMonths').value = item.minServiceMonths ?? 0;

            if (item.carryOverType === 2) {
                document.querySelector('input[name="carry_over"][value="max"]').checked = true;
                toggleCarryOverInput(true);
                document.getElementById('carryOverMaxDaysInput').value = item.carryOverMaxDays ?? 0;
            } else {
                document.querySelector('input[name="carry_over"][value="none"]').checked = true;
                toggleCarryOverInput(false);
                document.getElementById('carryOverMaxDaysInput').value = 5;
            }

            document.getElementById('leaveAppliesTo').value = getAppliesToLabel(item.appliesTo);
            document.getElementById('leaveAdvanceFiling').value = item.advanceFilingDays ?? 0;
            document.getElementById('flagRetroactive').checked = !!item.allowRetroactiveFiling;
            document.getElementById('leaveMaxConsecutive').value = item.maxConsecutiveDays ?? 0;

            document.getElementById('leaveFilingUnit').value =
                item.filingUnit === 2 ? 'half_day'
                : item.filingUnit === 3 ? 'hourly'
                : 'full_day';

            document.getElementById('leaveDeductionTiming').value = item.deductBalanceOn === 2 ? 'leave_date' : 'approval';

            document.getElementById('leaveExpiryRule').value =
                item.leaveExpiryRule === 2 ? 'fiscal_year_end'
                : item.leaveExpiryRule === 3 ? 'custom_months'
                : 'never';

            document.getElementById('leaveExpiryCustomMonths').value = item.leaveExpiryCustomMonths ?? 12;
            toggleLeaveExpiryCustomMonths(document.getElementById('leaveExpiryRule').value === 'custom_months');

            document.getElementById('flagAllowRestDay').checked = !!item.allowLeaveOnRestDay;
            document.getElementById('flagAllowHoliday').checked = !!item.allowLeaveOnHoliday;

            document.getElementById('flagLegalQualification').checked = !!item.requiresLegalQualification;
            document.getElementById('flagHrValidation').checked = !!item.requiresHrValidation;
            document.getElementById('flagCanOrgOverride').checked = item.canOrgOverride !== false;
            document.getElementById('flagSystemProtected').checked = !!item.isSystemProtected;

            document.getElementById('flagApproval').checked = !!item.requireApproval;
            document.getElementById('flagDoc').checked = !!item.requireDocument;
            document.getElementById('flagNegative').checked = !!item.allowNegativeBalance;

            document.getElementById('leaveApproverRole').value =
                item.approverRole === 2 ? 'manager'
                : item.approverRole === 3 ? 'hr'
                : item.approverRole === 4 ? 'auto'
                : 'supervisor';

            document.getElementById('approverRoleContainer').classList.toggle('hidden', !item.requireApproval);
            applyProtectedMode(!!item.isSystemProtected);
            setLeaveModalSaving(false);

            const m = document.getElementById('leaveModal');
            m.classList.remove('hidden');
            m.classList.add('flex');
        }

        function attachLeaveModalDismiss() {
            const modal = document.getElementById('leaveModal');
            if (!modal || modal.dataset.leaveModalBound === 'true') return;

            modal.dataset.leaveModalBound = 'true';
            modal.addEventListener('click', function (e) {
                if (e.target === this) closeLeaveModal();
            });
        }

        function bindLeaveEvents() {
            const approvalToggle = document.getElementById('flagApproval');
            if (approvalToggle && approvalToggle.dataset.bound !== 'true') {
                approvalToggle.dataset.bound = 'true';
                approvalToggle.addEventListener('change', (e) => {
                    document.getElementById('approverRoleContainer')?.classList.toggle('hidden', !e.target.checked);
                });
            }

            const compensationSelect = document.getElementById('leaveCompensationSource');
            if (compensationSelect && compensationSelect.dataset.bound !== 'true') {
                compensationSelect.dataset.bound = 'true';
                compensationSelect.addEventListener('change', syncPaidFromCompensation);
            }

            if (!document.body.dataset.leaveFlagsBound) {
                document.body.dataset.leaveFlagsBound = 'true';

                document.addEventListener('click', (e) => {
                    if (!e.target.closest('.leave-flag-trigger') && !e.target.closest('.leave-flags-dropdown')) {
                        closeAllLeaveFlagsDropdowns();
                    }
                });
            }
        }

        function init() {
            currentEditLeaveTypeId = null;
            isSavingLeaveType = false;
            leaveTypeStore.clear();
             leaveTypeList = [];
             leaveCurrentPage = 1;
            refreshApiContext();
            ensureFieldDecorations();
            attachLeaveModalDismiss();
            bindLeaveEvents();
            bindLeaveTableControls();
            loadLeaveTypes();
            loadLeaveSettings();
        }

        window.openLeaveModal = openLeaveModal;
        window.closeLeaveModal = closeLeaveModal;
        window.onLeaveTypeChange = onLeaveTypeChange;
        window.toggleCarryOverInput = toggleCarryOverInput;
        window.toggleLeaveExpiryCustomMonths = toggleLeaveExpiryCustomMonths;
        window.syncPaidFromCompensation = syncPaidFromCompensation;
        window.toggleLeaveFlagsDropdown = toggleLeaveFlagsDropdown;
        window.saveLeavePolicy = saveLeavePolicy;
        window.saveLeaveSettings = saveLeaveSettings;
        window.deleteLeaveType = deleteLeaveType;
        window.openEditLeaveType = openEditLeaveType;

        return { init };
    })();

    window.SubchronOrgTabLeave.init();
</script>
