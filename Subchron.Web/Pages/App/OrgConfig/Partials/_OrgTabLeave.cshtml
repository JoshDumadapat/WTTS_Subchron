                            </div>
                            <label class="relative inline-flex cursor-pointer items-center">
                                <input type="checkbox" id="leaveProrated" checked class="peer sr-only">
                                <div class="h-6 w-11 rounded-full bg-gray-300 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-400 after:bg-white after:transition-all after:content-['']
                                            peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                            peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-emerald-500/30
                                            dark:bg-gray-600"></div>
                            </label>
                        </div>

                    </div>

                </div>

                <div class="flex items-center justify-end border-t border-slate-300 bg-slate-200 px-6 py-4 dark:border-gray-700 dark:bg-gray-700/40">
                    <button onclick="saveLeaveSettings()" class="btn-primary gap-1.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                        Save General Settings
                    </button>
                </div>
            </div>

        </div>
    </div>

</div>

@* ─── ADD LEAVE TYPE MODAL ─── *@
<div id="leaveModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4 backdrop-blur-sm">
