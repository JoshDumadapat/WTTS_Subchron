        async function loadLeaveTypes() {
            replaceLeaveTypes([]);

            try {
                const res = await apiFetch('/api/leave-types');
                if (!res.ok) {
                    usingDemoTemplates = true;
                    replaceLeaveTypes(getDefaultDemoTemplates());
                    return;
                }

                const items = await res.json();
                const activeItems = Array.isArray(items) ? items.filter(item => item.isActive) : [];
                usingDemoTemplates = activeItems.length === 0;

                if (usingDemoTemplates) {
                    replaceLeaveTypes(getDefaultDemoTemplates());
                    return;
                }

                const hydratedItems = activeItems.map(item => {
                    if (typeof item.leaveCategory === 'undefined') {
                        const inferredKey = inferTypeKeyFromName(item.leaveTypeName);
                        const template = phLeaveTemplates[inferredKey];
                        if (template) {
                            item.leaveCategory = leaveCategoryEnumMap[template.leaveCategory] || 2;
                            item.statutoryCode = statutoryCodeEnumMap[template.statutoryCode] || 0;
                            item.compensationSource = compensationSourceEnumMap[template.compensationSource] || 1;
                            item.paidStatus = paidStatusEnumMap[template.paidStatus] || 1;
                            item.minServiceMonths = template.minServiceMonths || 0;
                            item.requiresLegalQualification = template.requiresLegalQualification || false;
                            item.requiresHrValidation = template.requiresHrValidation || false;
                            item.canOrgOverride = template.canOrgOverride ?? true;
                            item.isSystemProtected = template.isSystemProtected || false;
                        }
                    }
                    return item;
                });

                const displayItems = [...hydratedItems];
                const existingNames = new Set(hydratedItems.map(x => (x.leaveTypeName || '').trim().toLowerCase()));
                ['sil', 'maternity', 'paternity', 'solo_parent', 'vawc', 'special_women'].forEach((key, idx) => {
                    const template = phLeaveTemplates[key];
                    if (!existingNames.has(template.leaveTypeName.toLowerCase())) {
                        displayItems.push(templateToRecord(key, -200 - idx));
                    }
                });

                replaceLeaveTypes(displayItems);
            } catch (err) {
                usingDemoTemplates = true;
                replaceLeaveTypes(getDefaultDemoTemplates());
            }
        }

        async function loadLeaveSettings() {
            try {
                const res = await apiFetch('/api/org-leave-settings/current');
                if (!res.ok) return;

                const data = await res.json();
                const fiscalSelect = document.getElementById('leaveFiscalYearStart');
                const resetSelect = document.getElementById('leaveResetRule');
                const proratedToggle = document.getElementById('leaveProrated');

                if (fiscalSelect) {
                    const fiscalLabel = data.fiscalYearStart === 1 ? 'January 1'
                        : data.fiscalYearStart === 2 ? 'April 1'
                        : data.fiscalYearStart === 3 ? 'July 1'
                        : 'Employee Hire Date';
                    fiscalSelect.value = fiscalLabel;
                }

                if (resetSelect) {
                    const resetLabel = data.balanceResetRule === 1 ? 'Reset on Fiscal Year Start'
                        : data.balanceResetRule === 2 ? 'Reset on Employee Anniversary'
                        : 'No Reset (Cumulative)';
                    resetSelect.value = resetLabel;
                }

                if (proratedToggle) {
                    proratedToggle.checked = !!data.proratedForNewHires;
                }
            } catch (err) {
                console.warn('Failed to load leave settings', err);
            }
        }

