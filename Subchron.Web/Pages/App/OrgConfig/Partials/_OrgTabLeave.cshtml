                    <label class="relative inline-flex cursor-pointer items-center">
                        <input type="checkbox" id="flagApproval" checked class="peer sr-only">
                        <div class="h-6 w-11 rounded-full bg-gray-200 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-300 after:bg-white after:transition-all after:content-['']
                                    peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                    peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-emerald-500/30 dark:bg-gray-600"></div>
                    </label>
                </div>

                <div class="flex items-center justify-between border-b border-slate-300 px-4 py-3 dark:border-gray-700">
                    <div>
                        <span class="text-sm font-semibold text-gray-800 dark:text-white">Require Document</span>
                        <p class="text-xs text-gray-400 dark:text-gray-500">Employee must upload supporting document (e.g. medical cert).</p>
                    </div>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input type="checkbox" id="flagDoc" class="peer sr-only">
                        <div class="h-6 w-11 rounded-full bg-gray-200 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-300 after:bg-white after:transition-all after:content-['']
                                    peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                    peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-emerald-500/30 dark:bg-gray-600"></div>
                    </label>
                </div>

                <div class="flex items-center justify-between px-4 py-3">
                    <div>
                        <span class="text-sm font-semibold text-gray-800 dark:text-white">Allow Negative Balance</span>
                        <p class="text-xs text-gray-400 dark:text-gray-500">Allow employee to go below zero leave credits.</p>
                    </div>
                    <label class="relative inline-flex cursor-pointer items-center">
                        <input type="checkbox" id="flagNegative" class="peer sr-only">
                        <div class="h-6 w-11 rounded-full bg-gray-200 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-300 after:bg-white after:transition-all after:content-['']
                                    peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
