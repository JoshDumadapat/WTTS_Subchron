</div>

<script>
    let currentEditLeaveTypeId = null;
    let isSavingLeaveType = false;
    const leaveTypeStore = new Map();
    const appRoot = document.getElementById('appRoot');
    const apiBase = (appRoot?.getAttribute('data-api-base') || appRoot?.dataset?.apiBase || '').trim().replace(/\/$/, '');
    const apiToken = appRoot?.getAttribute('data-access-token') || appRoot?.dataset?.accessToken || '';

    const buildApiUrl = (path) => {
        if (!path) return apiBase;
        if (/^https?:/i.test(path)) return path;
        const normalized = path.startsWith('/') ? path : `/${path}`;
        return apiBase ? `${apiBase}${normalized}` : normalized;
    };

    const apiFetch = (path, options = {}) => {
        const url = buildApiUrl(path);
        const headers = { ...(options.headers || {}) };
        if (apiToken && !headers.Authorization) {
            headers.Authorization = `Bearer ${apiToken}`;
        }
        return fetch(url, { ...options, headers });
    };

    if (!apiBase) {
        console.warn('Org Leave tab: API base URL missing on #appRoot. Calls will target current origin.');
    }
    if (!apiToken) {
        console.warn('Org Leave tab: access token missing. Leave API calls may fail with 401.');
    }

    function openLeaveModal() {
        resetLeaveModal();
        const m = document.getElementById('leaveModal');
        m.classList.remove('hidden');
        m.classList.add('flex');
    }
    function closeLeaveModal() {
        const m = document.getElementById('leaveModal');
        m.classList.add('hidden');
        m.classList.remove('flex');
    }
    function onLeaveTypeChange(sel) {
        document.getElementById('customNameField').classList.toggle('hidden', sel.value !== 'custom');
    }
    function toggleCarryOverInput(show) {
        document.getElementById('carryOverInput').classList.toggle('hidden', !show);
    }

    const leaveTypeLabels = { sick: 'Sick Leave', vacation: 'Vacation Leave', emergency: 'Emergency Leave', unpaid: 'Unpaid Leave', custom: '' };
    const leaveTypeColors = {
        sick:      'bg-rose-100 text-rose-600 dark:bg-rose-900/30 dark:text-rose-400',
        vacation:  'bg-blue-100 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400',
        emergency: 'bg-orange-100 text-orange-600 dark:bg-orange-900/30 dark:text-orange-400',
        unpaid:    'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400',
        custom:    'bg-violet-100 text-violet-600 dark:bg-violet-900/30 dark:text-violet-400'
    };

    const accrualLabels = { lump: 'Lump Sum', monthly: 'Monthly', perperiod: 'Per Period' };
    const accrualEnumMap = { lump: 1, monthly: 2, perperiod: 3 };
    const carryOverEnumMap = { none: 1, max: 2 };
    const appliesToEnumMap = {
        'All Employees': 1,
        'Full-Time Only': 2,
        'Part-Time Only': 3,
        'Probationary Only': 4,
        'Regular Only': 5
    };
    const fiscalYearEnumMap = {
        'January 1': 1,
        'April 1': 2,
        'July 1': 3,
        'Employee Hire Date': 4
    };
    const resetRuleEnumMap = {
        'Reset on Fiscal Year Start': 1,
        'Reset on Employee Anniversary': 2,
        'No Reset (Cumulative)': 3
    };

    async function loadLeaveTypes() {
        const tbody = document.getElementById('leavePoliciesBody');
        tbody.innerHTML = '';
        const res = await apiFetch('/api/leave-types');
        if (!res.ok) {
            console.warn('Failed to load leave types');
            return;
        }
        const items = await res.json();
        items.filter(item => item.isActive).forEach(renderLeaveTypeRow);
    }

    async function loadLeaveSettings() {
        const res = await apiFetch('/api/org-leave-settings/current');
        if (!res.ok) {
            console.warn('Failed to load leave settings');
            return;
        }
        const data = await res.json();
        const fiscalSelect = document.getElementById('leaveFiscalYearStart');
        const resetSelect = document.getElementById('leaveResetRule');
        const proratedToggle = document.getElementById('leaveProrated');

        if (fiscalSelect) {
            const fiscalLabel = data.fiscalYearStart === 1 ? 'January 1'
                : data.fiscalYearStart === 2 ? 'April 1'
                : data.fiscalYearStart === 3 ? 'July 1'
                : 'Employee Hire Date';
            fiscalSelect.value = fiscalLabel;
        }

        if (resetSelect) {
            const resetLabel = data.balanceResetRule === 1 ? 'Reset on Fiscal Year Start'
                : data.balanceResetRule === 2 ? 'Reset on Employee Anniversary'
                : 'No Reset (Cumulative)';
            resetSelect.value = resetLabel;
        }

        if (proratedToggle) {
            proratedToggle.checked = !!data.proratedForNewHires;
        }
    }

    function renderLeaveTypeRow(item) {
        leaveTypeStore.set(item.leaveTypeID, item);
        const tbody = document.getElementById('leavePoliciesBody');
        const row = document.createElement('tr');
        row.dataset.leaveTypeId = item.leaveTypeID;
        row.className = 'leave-row group transition-colors hover:bg-emerald-50/40 dark:hover:bg-emerald-900/10';

        const lowerName = (item.leaveTypeName || '').toLowerCase();
        const typeKey = lowerName.includes('sick') ? 'sick'
            : lowerName.includes('vacation') ? 'vacation'
            : lowerName.includes('emergency') ? 'emergency'
            : lowerName.includes('unpaid') ? 'unpaid'
            : 'custom';
        const typeColor = leaveTypeColors[typeKey] || leaveTypeColors.custom;
        const accrual = item.accrualType === 1 ? 'Lump Sum'
            : item.accrualType === 2 ? 'Monthly'
            : 'Per Period';
        const carryHtml = item.carryOverType === 2
            ? `<span class="flex items-center gap-1 text-xs text-emerald-600 dark:text-emerald-400">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>Max ${item.carryOverMaxDays ?? 0} days</span>`
            : `<span class="flex items-center gap-1 text-xs text-gray-400 dark:text-gray-500">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>None</span>`;

        const flags = [
            item.requireApproval ? `<span class="inline-flex items-center rounded-full bg-amber-50 px-2 py-0.5 text-[10px] font-medium text-amber-700 ring-1 ring-amber-500/20 dark:bg-amber-900/20 dark:text-amber-400">Approval</span>` : '',
            item.requireDocument ? `<span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-0.5 text-[10px] font-medium text-blue-700 ring-1 ring-blue-500/20 dark:bg-blue-900/20 dark:text-blue-400">Doc</span>` : '',
            item.allowNegativeBalance ? `<span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-700 ring-1 ring-gray-400/30 dark:bg-gray-700 dark:text-gray-300">Negative</span>` : ''
        ].filter(Boolean).join('') || '<span class="text-xs text-gray-400">-</span>';

        const trashSvg = '<path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />';
        const editSvg  = '<path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />';

        row.innerHTML = `
            <td class="px-5 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                    <div class="flex h-8 w-8 items-center justify-center rounded-lg ${typeColor}">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                    </div>
                    <div>
                        <div class="text-sm font-semibold text-gray-900 dark:text-white">${item.leaveTypeName}</div>
                        <div class="text-xs text-gray-400 dark:text-gray-500">${item.appliesTo === 1 ? 'All Employees' : item.appliesTo === 2 ? 'Full-Time Only' : item.appliesTo === 3 ? 'Part-Time Only' : item.appliesTo === 4 ? 'Probationary Only' : 'Regular Only'}</div>
                    </div>
                </div>
            </td>
            <td class="px-5 py-4 whitespace-nowrap">
                <span class="inline-flex items-center rounded-md bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700 dark:bg-gray-700 dark:text-gray-300">${item.defaultDaysPerYear} days / yr</span>
            </td>
            <td class="px-5 py-4 whitespace-nowrap text-xs text-gray-500 dark:text-gray-400">${accrual}</td>
            <td class="px-5 py-4 whitespace-nowrap">${carryHtml}</td>
            <td class="px-5 py-4 whitespace-nowrap"><div class="flex gap-1.5 flex-wrap">${flags}</div></td>
            <td class="px-5 py-4 whitespace-nowrap text-right">
                <div class="flex items-center justify-end gap-1">
                    <button onclick="openEditLeaveType(${item.leaveTypeID})" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-700 dark:hover:text-gray-300">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">${editSvg}</svg>
                    </button>
                    <button onclick="deleteLeaveType(${item.leaveTypeID})" class="rounded-lg p-1.5 text-gray-400 hover:bg-red-50 hover:text-red-500 dark:hover:bg-red-900/20 dark:hover:text-red-400">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">${trashSvg}</svg>
                    </button>
                </div>
            </td>`;

        tbody.appendChild(row);
    }

    async function deleteLeaveType(id) {
        const res = await apiFetch(`/api/leave-types/${id}`, { method: 'DELETE' });
        if (!res.ok) {
            console.warn('Failed to delete leave type');
            return;
        }
        const row = document.querySelector(`tr[data-leave-type-id="${id}"]`);
        if (row) row.remove();
        leaveTypeStore.delete(id);
    }

    function setLeaveModalSaving(isSaving) {
        const btn = document.getElementById('leaveModalSaveBtn');
        const spinner = document.getElementById('leaveModalSaveSpinner');
        const icon = document.getElementById('leaveModalSaveIcon');
        const text = document.getElementById('leaveModalSaveText');
        if (!btn || !spinner || !icon || !text) return;

        if (isSaving) {
            btn.disabled = true;
            btn.classList.add('opacity-70', 'cursor-not-allowed');
            spinner.classList.remove('hidden');
            icon.classList.add('hidden');
            text.textContent = currentEditLeaveTypeId ? 'Updating...' : 'Saving...';
        } else {
            btn.disabled = false;
            btn.classList.remove('opacity-70', 'cursor-not-allowed');
            spinner.classList.add('hidden');
            icon.classList.remove('hidden');
            text.textContent = currentEditLeaveTypeId ? 'Update Leave Type' : 'Save Leave Type';
        }
    }

    async function saveLeavePolicy() {
        if (isSavingLeaveType) return;
        isSavingLeaveType = true;
        setLeaveModalSaving(true);
        const typeVal   = document.getElementById('leaveTypeSelect').value;
        const typeName  = typeVal === 'custom'
            ? (document.getElementById('customLeaveName').value.trim() || 'Custom Leave')
            : leaveTypeLabels[typeVal];
        const allowance = document.getElementById('leaveAllowance').value;
        const accrualVal = document.getElementById('leaveAccrual').value;
        const carryNone = document.querySelector('input[name="carry_over"]:checked').value === 'none';
        const carryMax  = carryNone ? null : document.querySelector('#carryOverInput input').value;
        const needApproval = document.getElementById('flagApproval').checked;
        const needDoc      = document.getElementById('flagDoc').checked;
        const allowNegative = document.getElementById('flagNegative').checked;
        const appliesToLabel = document.getElementById('leaveAppliesTo')?.value || 'All Employees';
        const appliesToValue = appliesToEnumMap[appliesToLabel] || 1;

        const existing = currentEditLeaveTypeId ? leaveTypeStore.get(currentEditLeaveTypeId) : null;
        const payload = {
            leaveTypeName: typeName,
            defaultDaysPerYear: Number(allowance || 0),
            isPaid: existing ? existing.isPaid : true,
            isActive: existing ? existing.isActive : true,
            accrualType: accrualEnumMap[accrualVal] || 1,
            carryOverType: carryOverEnumMap[carryNone ? 'none' : 'max'],
            carryOverMaxDays: carryNone ? null : Number(carryMax || 0),
            appliesTo: appliesToValue,
            requireApproval: needApproval,
            requireDocument: needDoc,
            allowNegativeBalance: allowNegative
        };

        const url = currentEditLeaveTypeId ? `/api/leave-types/${currentEditLeaveTypeId}` : '/api/leave-types';
        const method = currentEditLeaveTypeId ? 'PUT' : 'POST';
        try {
            const res = await apiFetch(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            if (!res.ok) {
                console.warn('Failed to save leave type');
                return;
            }
            const created = await res.json();
            const existingRow = document.querySelector(`tr[data-leave-type-id="${created.leaveTypeID}"]`);
            if (existingRow) existingRow.remove();
            renderLeaveTypeRow(created);
            closeLeaveModal();
        } catch (err) {
            console.error('Failed to save leave type', err);
        } finally {
            isSavingLeaveType = false;
            setLeaveModalSaving(false);
        }
        return;

    }

    async function saveLeaveSettings() {
        const fiscalLabel = document.getElementById('leaveFiscalYearStart')?.value || 'January 1';
        const resetLabel = document.getElementById('leaveResetRule')?.value || 'Reset on Fiscal Year Start';
        const prorated = document.getElementById('leaveProrated')?.checked ?? true;

        const payload = {
            fiscalYearStart: fiscalYearEnumMap[fiscalLabel] || 1,
            balanceResetRule: resetRuleEnumMap[resetLabel] || 1,
            proratedForNewHires: prorated
        };

        try {
            const res = await apiFetch('/api/org-leave-settings/current', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const data = await res.json().catch(() => null);
            if (!res.ok) {
                const message = data?.message || 'Failed to save leave settings';
                console.warn(message);
                window.showToast?.(message, false);
                return;
            }

            const persisted = data?.persisted !== false;
            const toastMessage = data?.message
                || (persisted ? 'Leave settings updated.' : 'Leave settings saved locally and will sync once reconnected.');
            window.showToast?.(toastMessage, persisted);
        } catch (err) {
            console.warn('Failed to save leave settings', err);
            window.showToast?.('Unable to save leave settings.', false);
        }
    }

    function resetLeaveModal() {
        currentEditLeaveTypeId = null;
        document.getElementById('leaveModalTitle').textContent = 'New Leave Type';
        document.getElementById('leaveModalSaveText').textContent = 'Save Leave Type';
        document.getElementById('leaveTypeSelect').value = 'sick';
        document.getElementById('customLeaveName').value = '';
        document.getElementById('customNameField').classList.add('hidden');
        document.getElementById('leaveAllowance').value = 15;
        document.getElementById('leaveAccrual').value = 'lump';
        document.querySelector('input[name="carry_over"][value="none"]').checked = true;
        toggleCarryOverInput(false);
        document.querySelector('#carryOverInput input').value = 5;
        document.getElementById('leaveAppliesTo').value = 'All Employees';
        document.getElementById('flagApproval').checked = true;
        document.getElementById('flagDoc').checked = false;
        document.getElementById('flagNegative').checked = false;
        setLeaveModalSaving(false);
    }

    function openEditLeaveType(id) {
        const item = leaveTypeStore.get(id);
        if (!item) return;

        currentEditLeaveTypeId = id;
        document.getElementById('leaveModalTitle').textContent = 'Edit Leave Type';
        document.getElementById('leaveModalSaveText').textContent = 'Update Leave Type';

        const nameLower = (item.leaveTypeName || '').toLowerCase();
        const presetKey = nameLower.includes('sick') ? 'sick'
            : nameLower.includes('vacation') ? 'vacation'
            : nameLower.includes('emergency') ? 'emergency'
            : nameLower.includes('unpaid') ? 'unpaid'
            : 'custom';

        document.getElementById('leaveTypeSelect').value = presetKey;
        if (presetKey === 'custom') {
            document.getElementById('customNameField').classList.remove('hidden');
            document.getElementById('customLeaveName').value = item.leaveTypeName || '';
        } else {
            document.getElementById('customNameField').classList.add('hidden');
            document.getElementById('customLeaveName').value = '';
        }

        document.getElementById('leaveAllowance').value = item.defaultDaysPerYear ?? 0;
        document.getElementById('leaveAccrual').value = item.accrualType === 2 ? 'monthly' : item.accrualType === 3 ? 'perperiod' : 'lump';

        if (item.carryOverType === 2) {
            document.querySelector('input[name="carry_over"][value="max"]').checked = true;
            toggleCarryOverInput(true);
            document.querySelector('#carryOverInput input').value = item.carryOverMaxDays ?? 0;
        } else {
            document.querySelector('input[name="carry_over"][value="none"]').checked = true;
            toggleCarryOverInput(false);
            document.querySelector('#carryOverInput input').value = 5;
        }

        const appliesLabel = item.appliesTo === 2 ? 'Full-Time Only'
            : item.appliesTo === 3 ? 'Part-Time Only'
            : item.appliesTo === 4 ? 'Probationary Only'
            : item.appliesTo === 5 ? 'Regular Only'
            : 'All Employees';
        document.getElementById('leaveAppliesTo').value = appliesLabel;

        document.getElementById('flagApproval').checked = !!item.requireApproval;
        document.getElementById('flagDoc').checked = !!item.requireDocument;
        document.getElementById('flagNegative').checked = !!item.allowNegativeBalance;
        setLeaveModalSaving(false);

        const m = document.getElementById('leaveModal');
        m.classList.remove('hidden');
        m.classList.add('flex');
    }

        document.getElementById('leaveModal').addEventListener('click', function(e) {
            if (e.target === this) closeLeaveModal();
        });

    document.addEventListener('DOMContentLoaded', () => {
        loadLeaveTypes();
        loadLeaveSettings();
    });
</script>
