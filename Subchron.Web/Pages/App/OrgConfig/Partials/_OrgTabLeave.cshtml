<div id="tab-leave" class="tab-content hidden h-full flex-col">

    <div class="flex items-center justify-between border-b border-slate-300 px-8 py-5 dark:border-gray-700">
        <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Leave Policies</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Manage statutory and company leave types, allowances, filing rules, and organization-wide leave settings.</p>
        </div>
        <button onclick="openLeaveModal()" class="btn-primary gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add Leave Type
        </button>
    </div>

    <div class="flex-1 overflow-y-auto p-8">
        <div class="flex flex-col gap-8">

            @* ─── ACTIVE LEAVE POLICIES TABLE ─── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 bg-slate-200 px-6 py-4 dark:border-gray-700 dark:bg-gray-800/50">
                    <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Active Leave Types</h3>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full table-fixed divide-y divide-slate-300 dark:divide-gray-700">
                        <thead class="bg-slate-200 dark:bg-gray-700/40">
                            <tr>
                                <th class="w-[26%] px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Leave Type</th>
                                <th class="w-[18%] px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Category</th>
                                <th class="w-[22%] px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Entitlement</th>
                                <th class="w-[18%] px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Usage Rules</th>
                                <th class="w-[10%] px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Flags</th>
                                <th class="w-[6%] px-5 py-3 text-right text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="leavePoliciesBody" class="divide-y divide-slate-300 bg-slate-50 dark:divide-gray-700 dark:bg-gray-800">
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-col gap-4 border-t border-slate-200 bg-white/80 px-6 py-4 dark:border-gray-700 dark:bg-gray-900/20 sm:flex-row sm:items-center sm:justify-between">
                    <div class="flex flex-wrap items-center gap-4">
                        <div class="text-sm text-gray-500 dark:text-gray-400">
                            Showing <span id="leavePaginationRange" class="font-semibold text-gray-900 dark:text-white">0</span> of <span id="leavePaginationTotal" class="font-semibold text-gray-900 dark:text-white">0</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="hidden text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500 sm:inline">Rows</span>
                            <select id="leaveRowsPerPage" class="hidden h-9 rounded-lg border border-slate-300 bg-white px-2 text-sm font-medium text-slate-600 focus:border-emerald-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-gray-200 sm:inline-block">
                                <option value="3">3</option>
                                <option value="5" selected>5</option>
                                <option value="7">7</option>
                                <option value="10">10</option>
                            </select>
                            <div class="relative inline-flex sm:hidden">
                                <button id="leaveRowsPerPageBtn" type="button" class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-3 py-2 text-xs font-semibold text-gray-600 transition hover:bg-gray-50 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100" aria-haspopup="true" aria-expanded="false">
                                    <span>Rows: <span id="leaveRowsPerPageBadge">5</span></span>
                                    <svg class="h-3.5 w-3.5 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 011.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                                <div id="leaveRowsPerPageMenu" class="absolute right-0 top-full z-20 mt-2 hidden min-w-[120px] rounded-xl border border-slate-200 bg-white p-1 shadow-xl dark:border-gray-700 dark:bg-gray-900">
                                    <button type="button" class="leave-rows-option w-full rounded-md px-3 py-2 text-left text-sm font-medium text-gray-600 hover:bg-slate-50 dark:text-gray-200 dark:hover:bg-gray-800" data-value="3">3 rows</button>
                                    <button type="button" class="leave-rows-option w-full rounded-md px-3 py-2 text-left text-sm font-medium text-gray-600 hover:bg-slate-50 dark:text-gray-200 dark:hover:bg-gray-800" data-value="5">5 rows</button>
                                    <button type="button" class="leave-rows-option w-full rounded-md px-3 py-2 text-left text-sm font-medium text-gray-600 hover:bg-slate-50 dark:text-gray-200 dark:hover:bg-gray-800" data-value="7">7 rows</button>
                                    <button type="button" class="leave-rows-option w-full rounded-md px-3 py-2 text-left text-sm font-medium text-gray-600 hover:bg-slate-50 dark:text-gray-200 dark:hover:bg-gray-800" data-value="10">10 rows</button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-center sm:justify-end">
                        <nav class="isolate inline-flex -space-x-px rounded-md shadow-sm" aria-label="Leave pagination">
                            <button id="leavePaginationPrev" type="button" class="inline-flex items-center rounded-l-md border border-slate-300 bg-white px-2.5 py-2 text-gray-500 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300 dark:hover:bg-gray-800">
                                <span class="sr-only">Previous</span>
                                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                                </svg>
                            </button>
                            <div id="leavePaginationNumbers" class="inline-flex gap-1 px-2"></div>
                            <button id="leavePaginationNext" type="button" class="inline-flex items-center rounded-r-md border border-slate-300 bg-white px-2.5 py-2 text-gray-500 transition hover:bg-gray-50 disabled:cursor-not-allowed disabled:opacity-40 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300 dark:hover:bg-gray-800">
                                <span class="sr-only">Next</span>
                                <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                                </svg>
                            </button>
                        </nav>
                    </div>
                </div>
            </div>

            @* ─── GENERAL LEAVE SETTINGS ─── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <h3 class="text-sm font-bold text-gray-900 dark:text-white">General Leave Settings</h3>
                    <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">Global rules that apply across all leave types.</p>
                </div>

                <div class="grid grid-cols-1 gap-0 divide-y divide-slate-300 dark:divide-gray-700 md:grid-cols-2 md:divide-x md:divide-y-0">

                    @* Left column *@
                    <div class="space-y-5 p-6">

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Fiscal Year Start</label>
                            <div class="relative">
                                <select id="leaveFiscalYearStart" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option>January 1</option>
                                    <option>April 1</option>
                                    <option>July 1</option>
                                    <option>Employee Hire Date</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                    <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Leave Balance Reset Rule</label>
                            <div class="relative">
                                <select id="leaveResetRule" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option>Reset on Fiscal Year Start</option>
                                    <option>Reset on Employee Anniversary</option>
                                    <option>No Reset (Cumulative)</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                    <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                                </div>
                            </div>
                        </div>

                    </div>

                    @* Right column *@
                    <div class="space-y-0 divide-y divide-slate-300 dark:divide-gray-700">

                        <div class="flex items-center justify-between px-6 py-4">
                            <div>
                                <span class="block text-sm font-semibold text-gray-800 dark:text-white">Prorated Leave for New Hires</span>
                                <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">Calculate leave based on months worked in first year.</p>
                            </div>
                            <label class="relative inline-flex cursor-pointer items-center">
                                <input type="checkbox" id="leaveProrated" checked class="peer sr-only">
                                <div class="h-6 w-11 rounded-full bg-gray-300 after:absolute after:top-[2px] after:left-[2px] after:h-5 after:w-5 after:rounded-full after:border after:border-gray-400 after:bg-white after:transition-all after:content-['']
                                            peer-checked:bg-emerald-500 peer-checked:after:translate-x-full peer-checked:after:border-white
                                            peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-emerald-500/30
                                            dark:bg-gray-600"></div>
                            </label>
                        </div>

                    </div>

                </div>

                <div class="flex items-center justify-end border-t border-slate-300 bg-slate-200 px-6 py-4 dark:border-gray-700 dark:bg-gray-700/40">
                    <button onclick="saveLeaveSettings()" class="btn-primary gap-1.5">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                        Save General Settings
                    </button>
                </div>
            </div>

        </div>
    </div>

</div>

@* ─── ADD LEAVE TYPE MODAL ─── *@
<div id="leaveModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4 backdrop-blur-sm">
    <div class="leave-modal-panel w-full max-w-2xl overflow-hidden rounded-2xl bg-slate-50 shadow-xl dark:bg-gray-800">

        <div class="flex items-center justify-between border-b border-slate-300 px-6 py-4 dark:border-gray-700">
            <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                    <h3 id="leaveModalTitle" class="text-base font-bold text-gray-900 dark:text-white">New Leave Type</h3>
                    <span id="leaveProtectedBadge" class="hidden inline-flex items-center rounded-full bg-purple-50 px-2.5 py-0.5 text-[11px] font-semibold text-purple-700 ring-1 ring-purple-500/20 dark:bg-purple-900/20 dark:text-purple-300">Statutory</span>
                    <span id="leaveLockedBadge" class="hidden inline-flex items-center rounded-full bg-slate-100 px-2.5 py-0.5 text-[11px] font-semibold text-slate-700 ring-1 ring-slate-400/30 dark:bg-slate-700 dark:text-slate-200">Protected</span>
                </div>
                <p id="leaveModalSubtitle" class="mt-1 text-xs text-gray-500 dark:text-gray-400">Configure leave rules for your organization.</p>
            </div>
            <button onclick="closeLeaveModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-700">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>

        <div id="leaveProtectedBanner" class="hidden border-b border-amber-200 bg-amber-50 px-6 py-3 text-sm text-amber-800 dark:border-amber-500/30 dark:bg-amber-900/20 dark:text-amber-200">
            This is a statutory leave template protected by Philippine labor rules. Core legal identity fields are read-only, while workflow and filing settings remain editable.
        </div>

        <div class="leave-modal-body max-h-[72vh] overflow-y-auto space-y-5 px-6 py-5">

            <div id="leaveLockedLegalIdentity" class="hidden overflow-hidden rounded-xl border border-slate-300 bg-slate-100/70 dark:border-gray-700 dark:bg-gray-900/40">
                <div class="border-b border-slate-300 px-4 py-3 dark:border-gray-700">
                    <h4 class="text-sm font-semibold text-gray-800 dark:text-white">Legal Identity (Protected)</h4>
                    <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">These fields define the legal identity of the leave type and cannot be edited while this leave is protected.</p>
                </div>
                <div class="px-4 py-3 text-xs text-gray-500 dark:text-gray-400">
                    You may still edit filing rules, approval flow, document requirements, and internal organization workflow settings below.
                </div>
            </div>

            @* Leave Type *@
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Leave Template</label>
                    <div class="relative">
                        <select id="leaveTypeSelect" onchange="onLeaveTypeChange(this)" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                            <optgroup label="Philippine Statutory Leaves">
                                <option value="sil">Service Incentive Leave</option>
                                <option value="maternity">Maternity Leave</option>
                                <option value="paternity">Paternity Leave</option>
                                <option value="solo_parent">Solo Parent Leave</option>
                                <option value="vawc">VAWC Leave</option>
                                <option value="special_women">Special Leave for Women</option>
                            </optgroup>
                            <optgroup label="Company Policy Leaves">
                                <option value="sick">Sick Leave</option>
                                <option value="vacation">Vacation Leave</option>
                                <option value="emergency">Emergency Leave</option>
                                <option value="unpaid">Unpaid Leave</option>
                                <option value="custom">Custom</option>
                            </optgroup>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Leave Category</label>
                    <div class="relative">
                        <select id="leaveCategory" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                            <option value="statutory">Statutory</option>
                            <option value="company">Company Policy</option>
                            <option value="unpaid_admin">Unpaid / Administrative</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                        </div>
                    </div>
                </div>
            </div>

            <div id="customNameField" class="hidden">
                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Custom Leave Name</label>
                <input type="text" id="customLeaveName" placeholder="e.g. Bereavement Leave, Study Leave..." maxlength="60"
                       class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
            </div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Compensation Source</label>
                    <div class="relative">
                        <select id="leaveCompensationSource" onchange="syncPaidFromCompensation()" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                            <option value="company_paid">Company Paid</option>
                            <option value="government_benefit">Government Benefit</option>
                            <option value="unpaid">Unpaid</option>
                            <option value="mixed">Mixed / Conditional</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Paid Status</label>
                    <div class="relative">
                        <select id="leavePaidStatus" class="block w-full appearance-none rounded-lg border-0 bg-slate-200 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                            <option value="paid">Paid</option>
                            <option value="unpaid">Unpaid</option>
                            <option value="conditional">Conditional</option>
                        </select>
                        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                            <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 3a1 1 0 01.707.293l3 3a1 1 0 01-1.414 1.414L10 5.414 7.707 7.707a1 1 0 01-1.414-1.414l3-3A1 1 0 0110 3zm-3.707 9.293a1 1 0 011.414 0L10 14.586l2.293-2.293a1 1 0 011.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Statutory Code</label>
                    <input type="text" id="leaveStatutoryCode" readonly
                           class="block w-full rounded-lg border-0 bg-slate-100 py-2 px-3 text-sm text-gray-700 ring-1 ring-inset ring-gray-300 dark:bg-gray-900 dark:text-gray-300 dark:ring-gray-600">
                </div>
            </div>

            @* Allowance *@
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Allowance (Days / Year)</label>
                    <input type="number" id="leaveAllowance" min="0" max="365" value="15"
                           class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                </div>
                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Accrual Type</label>
                    <div class="relative">
