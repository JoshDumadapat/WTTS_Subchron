        function inferTypeKeyFromName(name) {
            const lower = (name || '').toLowerCase();
            if (lower.includes('service incentive')) return 'sil';
            if (lower.includes('maternity')) return 'maternity';
            if (lower.includes('paternity')) return 'paternity';
            if (lower.includes('solo')) return 'solo_parent';
            if (lower.includes('vawc')) return 'vawc';
            if (lower.includes('special leave for women')) return 'special_women';
            if (lower.includes('sick')) return 'sick';
            if (lower.includes('vacation')) return 'vacation';
            if (lower.includes('emergency')) return 'emergency';
            if (lower.includes('unpaid')) return 'unpaid';
            return 'custom';
        }

        function getAppliesToLabel(value) {
            switch (value) {
                case 2: return 'Full-Time Only';
                case 3: return 'Part-Time Only';
                case 4: return 'Probationary Only';
                case 5: return 'Regular Only';
                case 6: return 'Female Employees Only';
                case 7: return 'Male Employees Only';
                default: return 'All Employees';
            }
        }

        function getCategoryLabel(value) {
            return value === 1 ? 'Statutory' : value === 3 ? 'Unpaid/Admin' : 'Company';
        }

        function getCompensationSourceLabel(value) {
            return value === 2 ? 'Govt Benefit' : value === 3 ? 'Unpaid' : value === 4 ? 'Mixed' : 'Company Paid';
        }

        function getPaidStatusLabel(value) {
            return value === 2 ? 'Unpaid' : value === 3 ? 'Conditional' : 'Paid';
        }

        function getStatutoryCodeLabel(value) {
            switch (value) {
                case 1: return 'SIL';
                case 2: return 'MATERNITY';
                case 3: return 'PATERNITY';
                case 4: return 'SOLO_PARENT';
                case 5: return 'VAWC';
                case 6: return 'SPECIAL_LEAVE_WOMEN';
                default: return 'NONE';
            }
        }

        function getProtectedInputWrapper(fieldId) {
            const field = document.getElementById(fieldId);
            return field?.closest('.protected-input-wrap') || null;
        }

        function ensureFieldDecorations() {
            const addLockChip = (fieldId) => {
                const field = document.getElementById(fieldId);
                if (!field) return;
                let wrapper = field.closest('.protected-input-wrap');

                if (!wrapper) {
                    wrapper = document.createElement('div');
                    wrapper.className = 'protected-input-wrap';
                    field.parentNode.insertBefore(wrapper, field);
                    wrapper.appendChild(field);
                }

                if (!wrapper.querySelector('.lock-chip')) {
                    const chip = document.createElement('span');
                    chip.className = 'lock-chip';
                    chip.innerHTML = `
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-1.5 0h12A1.5 1.5 0 0119.5 12v7.5A1.5 1.5 0 0118 21H6a1.5 1.5 0 01-1.5-1.5V12A1.5 1.5 0 016 10.5z" />
                        </svg>
                        Locked
                    `;
                    wrapper.appendChild(chip);
                }
            };

            [...protectedDisabledSelectIds, ...protectedReadonlyInputIds].forEach(addLockChip);

            Object.entries(fieldLockNotesMap).forEach(([fieldId, note]) => {
                const field = document.getElementById(fieldId);
                if (!field) return;
                const parent = field.closest('.protected-input-wrap') || field.parentElement;
                if (!parent) return;

                let noteEl = parent.parentElement?.querySelector(`.field-lock-note[data-for="${fieldId}"]`);
                if (!noteEl) {
                    noteEl = document.createElement('div');
                    noteEl.className = 'field-lock-note';
                    noteEl.dataset.for = fieldId;
                    noteEl.textContent = note;
                    parent.parentElement?.appendChild(noteEl);
                }
            });

            protectedToggleIds.forEach((fieldId) => {
                const field = document.getElementById(fieldId);
                if (!field) return;
                const host = field.closest('label')?.parentElement;
                if (!host) return;

                let noteEl = host.querySelector(`.field-lock-note[data-for="${fieldId}"]`);
                if (!noteEl) {
                    noteEl = document.createElement('div');
                    noteEl.className = 'field-lock-note';
                    noteEl.dataset.for = fieldId;
                    noteEl.textContent = fieldLockNotesMap[fieldId] || 'Protected field';
                    noteEl.style.marginTop = '0.25rem';
                    host.appendChild(noteEl);
                }
            });
        }

        function syncPaidFromCompensation() {
            const compensation = document.getElementById('leaveCompensationSource')?.value;
            const paidStatus = document.getElementById('leavePaidStatus');
            if (!paidStatus || paidStatus.disabled) return;

            if (compensation === 'unpaid') {
                paidStatus.value = 'unpaid';
            } else if (compensation === 'mixed') {
                paidStatus.value = 'conditional';
            } else {
                paidStatus.value = 'paid';
            }
        }

        function applyProtectedMode(isProtected) {
            const protectedBanner = document.getElementById('leaveProtectedBanner');
            const protectedBadge = document.getElementById('leaveProtectedBadge');
            const lockedBadge = document.getElementById('leaveLockedBadge');
            const subtitle = document.getElementById('leaveModalSubtitle');
            const legalIdentityBox = document.getElementById('leaveLockedLegalIdentity');

            protectedBanner?.classList.toggle('hidden', !isProtected);
            protectedBadge?.classList.toggle('hidden', !isProtected);
            lockedBadge?.classList.toggle('hidden', !isProtected);
            legalIdentityBox?.classList.toggle('hidden', !isProtected);

            if (subtitle) {
                subtitle.textContent = isProtected
                    ? 'Protected statutory template with editable workflow settings.'
                    : 'Configure leave rules for your organization.';
            }

            protectedDisabledSelectIds.forEach((fieldId) => {
                const field = document.getElementById(fieldId);
                const wrapper = getProtectedInputWrapper(fieldId);
                const note = document.querySelector(`.field-lock-note[data-for="${fieldId}"]`);
                if (!field) return;

                field.disabled = !!isProtected;
                field.classList.toggle('protected-field', !!isProtected);
                wrapper?.classList.toggle('is-locked', !!isProtected);
                note?.classList.toggle('is-visible', !!isProtected);
            });

            protectedReadonlyInputIds.forEach((fieldId) => {
                const field = document.getElementById(fieldId);
                const wrapper = getProtectedInputWrapper(fieldId);
                const note = document.querySelector(`.field-lock-note[data-for="${fieldId}"]`);
                if (!field) return;

                field.readOnly = !!isProtected;
                field.classList.toggle('protected-field', !!isProtected);
                wrapper?.classList.toggle('is-locked', !!isProtected);
                note?.classList.toggle('is-visible', !!isProtected);
            });

            protectedToggleIds.forEach((fieldId) => {
                const field = document.getElementById(fieldId);
                const note = document.querySelector(`.field-lock-note[data-for="${fieldId}"]`);
                if (!field) return;

                field.disabled = !!isProtected;
                note?.classList.toggle('is-visible', !!isProtected);

                const host = field.closest('label')?.parentElement;
                host?.classList.toggle('opacity-80', !!isProtected);
            });
        }

        function closeAllLeaveFlagsDropdowns(exceptId = null) {
            document.querySelectorAll('[id^="leaveFlagsDropdown-"]').forEach(el => {
                if (exceptId && el.id === exceptId) return;
                el.classList.add('hidden');
            });
        }

        function toggleLeaveFlagsDropdown(event, leaveTypeId) {
            event.stopPropagation();
            const dropdownId = `leaveFlagsDropdown-${leaveTypeId}`;
            const dropdown = document.getElementById(dropdownId);
            if (!dropdown) return;

            const willOpen = dropdown.classList.contains('hidden');
            closeAllLeaveFlagsDropdowns(willOpen ? dropdownId : null);
            dropdown.classList.toggle('hidden', !willOpen);
        }

        function openLeaveModal() {
            resetLeaveModal();
            const m = document.getElementById('leaveModal');
            if (!m) return;
            m.classList.remove('hidden');
            m.classList.add('flex');
        }

        function closeLeaveModal() {
            const m = document.getElementById('leaveModal');
            if (!m) return;
            m.classList.add('hidden');
            m.classList.remove('flex');
        }

        function applyTemplateToForm(templateKey) {
            const t = phLeaveTemplates[templateKey];
            if (!t) return;

            document.getElementById('customNameField')?.classList.toggle('hidden', templateKey !== 'custom');

            if (templateKey === 'custom') {
                document.getElementById('leaveCategory').value = 'company';
                document.getElementById('leaveCompensationSource').value = 'company_paid';
                document.getElementById('leavePaidStatus').value = 'paid';
                document.getElementById('leaveStatutoryCode').value = 'NONE';
                document.getElementById('leaveAllowance').value = 1;
                document.getElementById('leaveAccrual').value = 'lump';
                document.getElementById('leaveMinServiceMonths').value = 0;
                document.getElementById('leaveAppliesTo').value = 'All Employees';
                document.getElementById('flagLegalQualification').checked = false;
                document.getElementById('flagHrValidation').checked = false;
                document.getElementById('flagCanOrgOverride').checked = true;
                document.getElementById('flagSystemProtected').checked = false;
                applyProtectedMode(false);
                return;
            }

            document.getElementById('leaveCategory').value = t.leaveCategory;
            document.getElementById('leaveCompensationSource').value = t.compensationSource;
            document.getElementById('leavePaidStatus').value = t.paidStatus;
            document.getElementById('leaveStatutoryCode').value = t.statutoryCode;
            document.getElementById('leaveAllowance').value = t.defaultDaysPerYear;
            document.getElementById('leaveAccrual').value = t.accrualType;
            document.getElementById('leaveMinServiceMonths').value = t.minServiceMonths;
            document.getElementById('leaveAppliesTo').value = t.appliesTo;

            if (t.carryOverType === 'max') {
                document.querySelector('input[name="carry_over"][value="max"]').checked = true;
                toggleCarryOverInput(true);
                document.getElementById('carryOverMaxDaysInput').value = t.carryOverMaxDays ?? 5;
            } else {
                document.querySelector('input[name="carry_over"][value="none"]').checked = true;
                toggleCarryOverInput(false);
                document.getElementById('carryOverMaxDaysInput').value = 5;
            }

            document.getElementById('leaveAdvanceFiling').value = t.advanceFilingDays;
            document.getElementById('flagRetroactive').checked = t.allowRetroactiveFiling;
            document.getElementById('leaveMaxConsecutive').value = t.maxConsecutiveDays;
            document.getElementById('leaveFilingUnit').value = t.filingUnit;
            document.getElementById('leaveDeductionTiming').value = t.deductBalanceOn;
            document.getElementById('leaveExpiryRule').value = t.leaveExpiryRule;
            document.getElementById('leaveExpiryCustomMonths').value = t.leaveExpiryCustomMonths ?? 12;
            toggleLeaveExpiryCustomMonths(t.leaveExpiryRule === 'custom_months');
            document.getElementById('flagAllowRestDay').checked = t.allowLeaveOnRestDay;
            document.getElementById('flagAllowHoliday').checked = t.allowLeaveOnHoliday;

            document.getElementById('flagLegalQualification').checked = t.requiresLegalQualification;
            document.getElementById('flagHrValidation').checked = t.requiresHrValidation;
            document.getElementById('flagCanOrgOverride').checked = t.canOrgOverride;
            document.getElementById('flagSystemProtected').checked = t.isSystemProtected;

            document.getElementById('flagApproval').checked = t.requireApproval;
            document.getElementById('leaveApproverRole').value = t.approverRole;
            document.getElementById('approverRoleContainer').classList.toggle('hidden', !t.requireApproval);
            document.getElementById('flagDoc').checked = t.requireDocument;
            document.getElementById('flagNegative').checked = t.allowNegativeBalance;

            applyProtectedMode(!!t.isSystemProtected);
        }

        function onLeaveTypeChange(sel) {
            const value = sel.value;
            document.getElementById('customNameField')?.classList.toggle('hidden', value !== 'custom');
            applyTemplateToForm(value);
        }

        function toggleCarryOverInput(show) {
            document.getElementById('carryOverInput')?.classList.toggle('hidden', !show);
        }

        function toggleLeaveExpiryCustomMonths(show) {
            document.getElementById('leaveExpiryCustomMonthsWrap')?.classList.toggle('hidden', !show);
