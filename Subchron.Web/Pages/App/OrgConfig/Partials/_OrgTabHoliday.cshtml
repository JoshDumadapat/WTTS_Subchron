            }
        }

        function getTypeDotClass(type) {
            switch (type) {
                case 'RegularHoliday': return 'holiday-type-dot-regular';
                case 'SpecialNonWorkingHoliday': return 'holiday-type-dot-special-nonworking';
                case 'SpecialWorkingHoliday': return 'holiday-type-dot-special-working';
                case 'DoubleHoliday': return 'holiday-type-dot-double';
                case 'CompanyHoliday': return 'holiday-type-dot-company';
                case 'LocalHoliday': return 'holiday-type-dot-local';
                default: return 'holiday-type-dot-company';
            }
        }

        function getDefaultClassificationConfig(type) {
            switch (type) {
                case 'RegularHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'RegularHoliday',
                        restDayClassification: 'RestDayRegularHoliday',
                        payrollClassification: 'RegularHoliday',
                        restDayPayrollClassification: 'RestDayRegularHoliday',
                        paidWhenUnworked: true
                    };
                case 'SpecialNonWorkingHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'SpecialNonWorkingHoliday',
                        restDayClassification: 'RestDaySpecialNonWorkingHoliday',
                        payrollClassification: 'SpecialNonWorkingHoliday',
                        restDayPayrollClassification: 'RestDaySpecialNonWorkingHoliday',
                        paidWhenUnworked: false
                    };
                case 'SpecialWorkingHoliday':
                    return {
                        nonWorkingDay: false,
                        allowWork: true,
                        attendanceClassification: 'SpecialWorkingHoliday',
                        restDayClassification: 'RestDaySpecialWorkingHoliday',
                        payrollClassification: 'SpecialWorkingHoliday',
                        restDayPayrollClassification: 'RestDaySpecialWorkingHoliday',
                        paidWhenUnworked: false
                    };
                case 'DoubleHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'DoubleHoliday',
                        restDayClassification: 'RestDayDoubleHoliday',
                        payrollClassification: 'DoubleHoliday',
                        restDayPayrollClassification: 'RestDayDoubleHoliday',
                        paidWhenUnworked: true
                    };
                case 'LocalHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'LocalHoliday',
                        restDayClassification: 'RestDayLocalHoliday',
                        payrollClassification: 'LocalHoliday',
                        restDayPayrollClassification: 'RestDayLocalHoliday',
                        paidWhenUnworked: false
                    };
                case 'CompanyHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'CompanyHoliday',
