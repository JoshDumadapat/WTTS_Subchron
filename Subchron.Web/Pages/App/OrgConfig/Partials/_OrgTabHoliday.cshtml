        background: rgba(139, 92, 246, 0.18);
        color: rgb(221, 214, 254);
        box-shadow: inset 0 0 0 1px rgba(139, 92, 246, 0.28);
    }
</style>

<script>
    window.SubchronOrgTabHoliday = window.SubchronOrgTabHoliday || (() => {
        const monthNames = [
            'January', 'February', 'March', 'April', 'May', 'June',
            'July', 'August', 'September', 'October', 'November', 'December'
        ];

        const selectors = {
            yearSelect: 'holidayYearSelect',
            typeFilter: 'holidayTypeFilter',
            scopeFilter: 'holidayScopeFilter',
            tableBody: 'holidayRulesTableBody',
            grid: 'holidayCalendarGrid',
            title: 'holidayCalendarTitle',
            modal: 'holidayModal',
            deleteButton: 'holidayDeleteButton',
            summaryYear: 'holidaySummaryYear',
            summaryCount: 'holidaySummaryCount',
            summaryCoverage: 'holidaySummaryCoverage',
            summarySync: 'holidaySummarySync'
        };

        const appRoot = document.getElementById('appRoot');
        const apiBase = (appRoot?.getAttribute('data-api-base') || '').trim().replace(/\/$/, '');
        const accessToken = appRoot?.getAttribute('data-access-token') || '';

        const resolvedApiBase = apiBase || window.location.origin;

        function buildApiUrl(path) {
            if (!path) return resolvedApiBase;
            if (!resolvedApiBase) return path;
            return `${resolvedApiBase}${path.startsWith('/') ? path : `/${path}`}`;
        }

        const state = {
            currentDate: new Date(),
            selectedYear: new Date().getFullYear(),
            selectedMonth: new Date().getMonth(),
            selectedHolidayType: 'all',
            selectedScopeType: 'all',
            editingHolidayId: null,
            holidays: [],
            payrollRules: [],
            isLoading: false
        };

        const api = {
            holidays: buildApiUrl('/api/orgconfig/holidays'),
            holidaySync: buildApiUrl('/api/orgconfig/holidays/sync'),
            payrollRules: buildApiUrl('/api/orgconfig/payroll/holiday-rules')
        };

        function $(id) {
            return document.getElementById(id);
        }

        function escapeHtml(value) {
            const div = document.createElement('div');
            div.textContent = value == null ? '' : String(value);
            return div.innerHTML;
        }

        function parseCsv(value) {
            return (value || '')
                .split(',')
                .map(x => x.trim())
                .filter(Boolean);
        }

        function boolToStatus(value) {
            return value ? 'Active' : 'Inactive';
        }

        function getTypeLabel(type) {
            switch (type) {
                case 'RegularHoliday': return 'Regular Holiday';
                case 'SpecialNonWorkingHoliday': return 'Special Non-working Holiday';
                case 'SpecialWorkingHoliday': return 'Special Working Holiday';
                case 'DoubleHoliday': return 'Double Holiday';
                case 'CompanyHoliday': return 'Company Holiday';
                case 'LocalHoliday': return 'Local Holiday';
                default: return 'Holiday';
            }
        }

        function getScopeLabel(scopeType) {
            switch (scopeType) {
                case 'Nationwide': return 'Nationwide';
                case 'Region': return 'Region';
                case 'Province': return 'Province';
                case 'CityMunicipality': return 'City / Municipality';
                case 'Barangay': return 'Barangay';
                case 'Site': return 'Site / Branch';
                case 'Department': return 'Department';
                case 'EmployeeGroup': return 'Employee Group';
                case 'CompanyWide': return 'Company-wide';
                default: return 'Scope';
            }
        }

        function getSourceTagLabel(value) {
            switch (value) {
                case 'Official': return 'Official / Government';
                case 'LocalOrdinance': return 'Local Ordinance';
                case 'CompanyPolicy': return 'Company Policy';
                case 'ManualEntry': return 'Manual Entry';
                case 'Imported': return 'Imported';
                default: return value || '—';
            }
        }

        function getTypeClass(type) {
            switch (type) {
                case 'RegularHoliday': return 'holiday-type-regular';
                case 'SpecialNonWorkingHoliday': return 'holiday-type-special-nonworking';
                case 'SpecialWorkingHoliday': return 'holiday-type-special-working';
                case 'DoubleHoliday': return 'holiday-type-double';
                case 'CompanyHoliday': return 'holiday-type-company';
                case 'LocalHoliday': return 'holiday-type-local';
                default: return 'holiday-type-company';
            }
        }

        function getTypeDotClass(type) {
            switch (type) {
                case 'RegularHoliday': return 'holiday-type-dot-regular';
                case 'SpecialNonWorkingHoliday': return 'holiday-type-dot-special-nonworking';
                case 'SpecialWorkingHoliday': return 'holiday-type-dot-special-working';
                case 'DoubleHoliday': return 'holiday-type-dot-double';
                case 'CompanyHoliday': return 'holiday-type-dot-company';
                case 'LocalHoliday': return 'holiday-type-dot-local';
                default: return 'holiday-type-dot-company';
            }
        }

        function getDefaultClassificationConfig(type) {
            switch (type) {
                case 'RegularHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'RegularHoliday',
                        restDayClassification: 'RestDayRegularHoliday',
                        payrollClassification: 'RegularHoliday',
                        restDayPayrollClassification: 'RestDayRegularHoliday',
                        paidWhenUnworked: true
                    };
                case 'SpecialNonWorkingHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'SpecialNonWorkingHoliday',
                        restDayClassification: 'RestDaySpecialNonWorkingHoliday',
                        payrollClassification: 'SpecialNonWorkingHoliday',
                        restDayPayrollClassification: 'RestDaySpecialNonWorkingHoliday',
                        paidWhenUnworked: false
                    };
                case 'SpecialWorkingHoliday':
                    return {
                        nonWorkingDay: false,
                        allowWork: true,
                        attendanceClassification: 'SpecialWorkingHoliday',
                        restDayClassification: 'RestDaySpecialWorkingHoliday',
                        payrollClassification: 'SpecialWorkingHoliday',
                        restDayPayrollClassification: 'RestDaySpecialWorkingHoliday',
                        paidWhenUnworked: false
                    };
                case 'DoubleHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'DoubleHoliday',
                        restDayClassification: 'RestDayDoubleHoliday',
                        payrollClassification: 'DoubleHoliday',
                        restDayPayrollClassification: 'RestDayDoubleHoliday',
                        paidWhenUnworked: true
                    };
                case 'LocalHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'LocalHoliday',
                        restDayClassification: 'RestDayLocalHoliday',
                        payrollClassification: 'LocalHoliday',
                        restDayPayrollClassification: 'RestDayLocalHoliday',
                        paidWhenUnworked: false
                    };
                case 'CompanyHoliday':
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'CompanyHoliday',
                        restDayClassification: 'RestDayCompanyHoliday',
                        payrollClassification: 'CompanyHoliday',
                        restDayPayrollClassification: 'RestDayCompanyHoliday',
                        paidWhenUnworked: false
                    };
                default:
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'Holiday',
                        restDayClassification: '',
                        payrollClassification: 'RegularHoliday',
                        restDayPayrollClassification: '',
                        paidWhenUnworked: false
                    };
            }
        }

        function formatDate(dateObj) {
            const y = dateObj.getFullYear();
            const m = String(dateObj.getMonth() + 1).padStart(2, '0');
            const d = String(dateObj.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function formatDateDisplay(dateString) {
            if (!dateString) return '—';
            const d = new Date(dateString + 'T00:00:00');
            return `${monthNames[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
        }

        function normalizeHoliday(raw) {
            const scopeValues = Array.isArray(raw.scopeValues)
                ? raw.scopeValues
                : parseCsv(raw.scopeValues);

            const employeeGroupScope = Array.isArray(raw.employeeGroupScope)
                ? raw.employeeGroupScope
                : parseCsv(raw.employeeGroupScope);

            return {
                id: raw.id ?? raw.holidayId ?? null,
                orgId: raw.orgId ?? raw.organizationId ?? null,
                date: raw.date ?? raw.holidayDate ?? '',
                name: raw.name ?? raw.holidayName ?? '',
                type: raw.type ?? raw.holidayType ?? 'RegularHoliday',
                scopeType: raw.scopeType ?? 'Nationwide',
                scopeValues,
                sourceTag: raw.sourceTag ?? 'ManualEntry',
                isActive: raw.isActive !== false,
                includeAttendance: raw.includeAttendance !== false,
                nonWorkingDay: raw.nonWorkingDay !== false,
                allowWork: raw.allowWork !== false,
                applyRestDayRules: raw.applyRestDayRules !== false,
                attendanceClassification: raw.attendanceClassification ?? 'Holiday',
                restDayClassification: raw.restDayClassification ?? '',
                includePayroll: raw.includePayroll !== false,
                usePayRules: raw.usePayRules !== false,
                paidWhenUnworked: raw.paidWhenUnworked !== false,
                payrollClassification: raw.payrollClassification ?? (raw.type ?? 'RegularHoliday'),
                restDayPayrollClassification: raw.restDayPayrollClassification ?? '',
                payrollRuleId: raw.payrollRuleId ?? '',
                restDayPayrollRuleId: raw.restDayPayrollRuleId ?? '',
                payrollNotes: raw.payrollNotes ?? '',
                referenceNo: raw.referenceNo ?? '',
                referenceUrl: raw.referenceUrl ?? '',
                officialTag: raw.officialTag ?? '',
                overlapStrategy: raw.overlapStrategy ?? 'HighestPrecedence',
                precedence: Number(raw.precedence ?? 100),
                employeeGroupScope,
                notes: raw.notes ?? '',
                createdAt: raw.createdAt ?? null,
                updatedAt: raw.updatedAt ?? null,
                isSynced: !!raw.isSynced
            };
        }

        async function apiRequest(url, options = {}) {
            const headers = new Headers(options.headers || {});
            if (!headers.has('Content-Type')) headers.set('Content-Type', 'application/json');
            headers.set('X-Requested-With', 'XMLHttpRequest');
            if (accessToken) headers.set('Authorization', `Bearer ${accessToken}`);

            try {
                const response = await fetch(url, {
                    ...options,
                    headers,
                    mode: 'cors',
                    credentials: 'omit'
                });

                if (!response.ok) {
                    let message = `Request failed (${response.status}).`;
                    try {
                        const error = await response.json();
                        message = error.message || error.title || error.error || message;
                    } catch {
                        try {
                            const text = await response.text();
                            if (text) message = text;
                        } catch { }
                    }

                    throw new Error(message);
                }

                if (response.status === 204) return null;

                const contentType = response.headers.get('content-type') || '';
                if (contentType.includes('application/json')) {
                    return await response.json();
                }

                return await response.text();
            }
            catch (err) {
                if (err instanceof TypeError || err?.message?.includes('Failed to fetch')) {
                    const target = apiBase || 'the Subchron API';
                    throw new Error(`Unable to reach ${target}. Ensure the Subchron.API service is running.`);
                }
                throw err;
            }
        }

        function getFilteredHolidays() {
            return state.holidays
                .filter(x => {
                    const year = new Date(x.date + 'T00:00:00').getFullYear();
                    return year === state.selectedYear;
                })
                .filter(x => state.selectedHolidayType === 'all' || x.type === state.selectedHolidayType)
                .filter(x => state.selectedScopeType === 'all' || x.scopeType === state.selectedScopeType);
        }

        function getAllHolidaysByDate(dateString) {
            return state.holidays.filter(x => x.date === dateString);
        }

        function getVisibleHolidaysByDate(dateString) {
            return getFilteredHolidays().filter(x => x.date === dateString);
        }

        function renderSummary() {
            const visible = getFilteredHolidays();
            const coverageSet = new Set(
                state.holidays
                    .filter(x => new Date(x.date + 'T00:00:00').getFullYear() === state.selectedYear)
                    .filter(x => x.isActive)
                    .map(x => x.type)
            );

            if ($(selectors.summaryYear)) $(selectors.summaryYear).textContent = String(state.selectedYear);
            if ($(selectors.summaryCount)) $(selectors.summaryCount).textContent = String(visible.length);
            if ($(selectors.summaryCoverage)) $(selectors.summaryCoverage).textContent = `${coverageSet.size}/6`;
            if ($(selectors.summarySync)) $(selectors.summarySync).textContent = 'Org + Official Template';
        }

        function renderHolidayCalendar() {
            const title = $(selectors.title);
            const grid = $(selectors.grid);
            if (!title || !grid) return;

            title.textContent = `${monthNames[state.selectedMonth]} ${state.selectedYear}`;
            grid.innerHTML = '';

            const firstDayOfMonth = new Date(state.selectedYear, state.selectedMonth, 1);
            const mondayBasedStart = (firstDayOfMonth.getDay() + 6) % 7;
            const startDate = new Date(firstDayOfMonth);
            startDate.setDate(firstDayOfMonth.getDate() - mondayBasedStart);
            const todayString = formatDate(new Date());

            for (let i = 0; i < 42; i++) {
                const cellDate = new Date(startDate);
                cellDate.setDate(startDate.getDate() + i);

                const dateString = formatDate(cellDate);
                const isCurrentMonth = cellDate.getMonth() === state.selectedMonth;
                const isToday = dateString === todayString;
                const visibleHolidays = getVisibleHolidaysByDate(dateString);
                const allHolidays = getAllHolidaysByDate(dateString);

                const cell = document.createElement('button');
                cell.type = 'button';
                cell.className = [
                    'holiday-day-cell flex flex-col items-start text-left',
                    !isCurrentMonth ? 'is-outside' : '',
                    isToday ? 'is-today' : ''
                ].join(' ').trim();

                let holidayContent = '';
                visibleHolidays.slice(0, 2).forEach(h => {
                    const scopeText = h.scopeType === 'Nationwide'
                        ? 'Nationwide'
                        : `${getScopeLabel(h.scopeType)}${h.scopeValues?.length ? ` • ${h.scopeValues[0]}` : ''}`;
                    const ruleText = `${h.nonWorkingDay ? 'Non-working' : 'Working'} • ${h.includePayroll ? 'Payroll' : 'No payroll'}`;

                    holidayContent += `
                        <div class="mt-1.5 w-full">
                            <div class="line-clamp-2 text-[12px] font-semibold leading-4 text-slate-800 dark:text-white">${escapeHtml(h.name)}</div>
                            <div class="mt-0.5 line-clamp-1 text-[10px] text-slate-500 dark:text-slate-300">${escapeHtml(getTypeLabel(h.type))} • ${escapeHtml(scopeText)}</div>
                            <div class="mt-0.5 line-clamp-1 text-[10px] text-slate-400 dark:text-slate-400">${escapeHtml(ruleText)}</div>
                        </div>
                    `;
                });

                if (visibleHolidays.length > 2) {
                    holidayContent += `<div class="mt-1.5 text-[11px] font-medium text-slate-500 dark:text-slate-300">+${visibleHolidays.length - 2} more</div>`;
                } else if (!visibleHolidays.length && allHolidays.length > 0) {
                    holidayContent += `<div class="mt-1.5 text-[11px] font-medium text-slate-400 dark:text-slate-500">${allHolidays.length} hidden by filter</div>`;
                }

                cell.innerHTML = `
                    ${visibleHolidays.length > 0 ? `<span class="holiday-corner-indicator ${getTypeDotClass(visibleHolidays[0].type)}"></span>` : ''}
                    <div class="holiday-day-number">${cellDate.getDate()}</div>
                    <div class="mt-1.5 w-full">
                        ${holidayContent}
                    </div>
                `;

                cell.addEventListener('click', function () {
                    if (visibleHolidays.length > 0) {
                        openHolidayModal(visibleHolidays[0].id);
                    } else if (allHolidays.length > 0) {
                        openHolidayModal(allHolidays[0].id);
                    } else {
                        openHolidayModal(null, dateString);
                    }
                });

                grid.appendChild(cell);
            }
        }

        function renderHolidayTable() {
            const tbody = $(selectors.tableBody);
            if (!tbody) return;

            const rows = getFilteredHolidays().sort((a, b) => {
                const byDate = a.date.localeCompare(b.date);
                if (byDate !== 0) return byDate;
                return (b.precedence || 0) - (a.precedence || 0);
            });

            tbody.innerHTML = '';

            if (!rows.length) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="9" class="px-5 py-10 text-center text-sm text-gray-500 dark:text-gray-400">
                            No holiday rules found for this year and filter combination.
                        </td>
                    </tr>
                `;
                renderSummary();
                return;
            }

            rows.forEach(item => {
                const tr = document.createElement('tr');

                const scopeValues = item.scopeValues?.length ? item.scopeValues.join(', ') : 'All';
                const referenceText = item.referenceNo || item.officialTag || getSourceTagLabel(item.sourceTag);
                const payrollRule = state.payrollRules.find(x => String(x.id) === String(item.payrollRuleId));
                const payrollRuleName = payrollRule?.name || item.payrollClassification || '—';

                tr.innerHTML = `
                    <td class="px-5 py-4 text-sm text-gray-700 dark:text-gray-200">${escapeHtml(formatDateDisplay(item.date))}</td>
                    <td class="px-5 py-4">
                        <div class="text-sm font-semibold text-gray-900 dark:text-white">${escapeHtml(item.name)}</div>
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">${escapeHtml(getSourceTagLabel(item.sourceTag))}</div>
                    </td>
                    <td class="px-5 py-4">
                        <div class="inline-flex items-center gap-2 text-sm text-gray-700 dark:text-gray-200">
                            <span class="holiday-type-dot ${getTypeDotClass(item.type)}"></span>
                            <span>${escapeHtml(getTypeLabel(item.type))}</span>
                        </div>
                    </td>
                    <td class="px-5 py-4 text-xs text-gray-600 dark:text-gray-300">
                        <div class="font-semibold text-gray-700 dark:text-gray-200">${escapeHtml(getScopeLabel(item.scopeType))}</div>
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">${escapeHtml(scopeValues)}</div>
                    </td>
                    <td class="px-5 py-4 text-xs text-gray-600 dark:text-gray-300">
                        ${item.includeAttendance ? 'Included' : 'Ignored'}
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">
                            ${item.nonWorkingDay ? 'Non-working' : 'Working'} • ${item.allowWork ? 'Work allowed' : 'Work blocked'}
                        </div>
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">
                            ${escapeHtml(item.attendanceClassification || 'Holiday')}
                        </div>
                    </td>
                    <td class="px-5 py-4 text-xs text-gray-600 dark:text-gray-300">
                        ${item.includePayroll ? 'Included' : 'Ignored'}
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">
                            ${item.usePayRules ? escapeHtml(payrollRuleName) : 'Manual / no pay rule'}
                        </div>
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">
                            ${escapeHtml(item.restDayPayrollClassification || 'No rest day override')}
                        </div>
                    </td>
                    <td class="px-5 py-4 text-xs text-gray-600 dark:text-gray-300">
                        <div class="font-semibold text-gray-700 dark:text-gray-200">${escapeHtml(referenceText || '—')}</div>
                        <div class="mt-1 text-[11px] text-gray-400 dark:text-gray-500">
                            ${escapeHtml(item.referenceUrl || item.overlapStrategy || '—')}
                        </div>
                    </td>
                    <td class="px-5 py-4 text-xs">
                        <span class="${item.isActive ? 'text-emerald-600 dark:text-emerald-400' : 'text-gray-500 dark:text-gray-400'} font-semibold">
                            ${escapeHtml(boolToStatus(item.isActive))}
                        </span>
                    </td>
                    <td class="px-5 py-4 text-right">
                        <div class="inline-flex items-center gap-2">
                            <button type="button" onclick="window.SubchronOrgTabHoliday.openHolidayModal(${item.id})" class="rounded-lg px-2.5 py-1.5 text-xs font-semibold text-gray-500 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700">
                                Edit
                            </button>
                        </div>
                    </td>
                `;

                tbody.appendChild(tr);
            });

            renderSummary();
        }

        function fillYearOptions() {
            const select = $(selectors.yearSelect);
            if (!select) return;

            select.innerHTML = '';
            const current = new Date().getFullYear();

            for (let y = current - 10; y <= current + 10; y++) {
                const option = document.createElement('option');
                option.value = y;
                option.textContent = y;
                if (y === state.selectedYear) option.selected = true;
                select.appendChild(option);
            }

            if (select.dataset.bound !== 'true') {
                select.dataset.bound = 'true';
                select.addEventListener('change', async function () {
                    state.selectedYear = parseInt(this.value, 10);
                    state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
                    await loadHolidayData(state.selectedYear);
                });
            }
        }

        function bindFilters() {
            const typeFilter = $(selectors.typeFilter);
            const scopeFilter = $(selectors.scopeFilter);

            if (typeFilter && typeFilter.dataset.bound !== 'true') {
                typeFilter.dataset.bound = 'true';
                typeFilter.addEventListener('change', function () {
                    state.selectedHolidayType = this.value;
                    renderHolidayCalendar();
                    renderHolidayTable();
                });
            }

            if (scopeFilter && scopeFilter.dataset.bound !== 'true') {
                scopeFilter.dataset.bound = 'true';
                scopeFilter.addEventListener('change', function () {
                    state.selectedScopeType = this.value;
                    renderHolidayCalendar();
                    renderHolidayTable();
                });
            }
        }

        function bindModalDismiss() {
            const modal = $(selectors.modal);
            if (!modal || modal.dataset.bound === 'true') return;

            modal.dataset.bound = 'true';
            modal.addEventListener('click', function (e) {
                if (e.target === this) closeHolidayModal();
            });
        }

        function bindHolidayTypeAutoMapping() {
            const holidayType = $('holidayType');
            if (!holidayType || holidayType.dataset.bound === 'true') return;

            holidayType.dataset.bound = 'true';
            holidayType.addEventListener('change', function () {
                applyDefaultConfigForType(this.value);
            });
        }

        function applyDefaultConfigForType(type) {
            const config = getDefaultClassificationConfig(type);

            if ($('holidayNonWorkingDay')) $('holidayNonWorkingDay').checked = !!config.nonWorkingDay;
            if ($('holidayAllowWork')) $('holidayAllowWork').checked = !!config.allowWork;
            if ($('holidayAttendanceClassification')) $('holidayAttendanceClassification').value = config.attendanceClassification || 'Holiday';
            if ($('holidayRestDayClassification')) $('holidayRestDayClassification').value = config.restDayClassification || '';
            if ($('holidayPayrollClassification')) $('holidayPayrollClassification').value = config.payrollClassification || 'RegularHoliday';
            if ($('holidayRestDayPayrollClassification')) $('holidayRestDayPayrollClassification').value = config.restDayPayrollClassification || '';
            if ($('holidayPaidWhenUnworked')) $('holidayPaidWhenUnworked').checked = !!config.paidWhenUnworked;

            if (type === 'LocalHoliday' && $('holidayScopeType') && $('holidayScopeType').value === 'Nationwide') {
                $('holidayScopeType').value = 'CityMunicipality';
            }

            if (type === 'CompanyHoliday' && $('holidayScopeType') && $('holidayScopeType').value === 'Nationwide') {
                $('holidayScopeType').value = 'CompanyWide';
            }

            suggestPayrollRuleSelection();
        }

        function suggestPayrollRuleSelection() {
            const usePayRules = $('holidayUsePayRules')?.checked;
            const payrollClassification = $('holidayPayrollClassification')?.value || '';
            const restDayPayrollClassification = $('holidayRestDayPayrollClassification')?.value || '';

            if (usePayRules && $('holidayPayrollRuleId') && !$('holidayPayrollRuleId').value) {
                const match = state.payrollRules.find(x => String(x.classification || '') === String(payrollClassification));
                if (match) $('holidayPayrollRuleId').value = String(match.id);
            }

            if (usePayRules && $('holidayRestDayPayrollRuleId') && restDayPayrollClassification && !$('holidayRestDayPayrollRuleId').value) {
                const restMatch = state.payrollRules.find(x => String(x.classification || '') === String(restDayPayrollClassification));
                if (restMatch) $('holidayRestDayPayrollRuleId').value = String(restMatch.id);
            }
        }

        async function loadPayrollRules() {
            try {
                const data = await apiRequest(api.payrollRules, { method: 'GET' });
                const list = Array.isArray(data) ? data : (data?.items || data?.data || []);
                state.payrollRules = list.map(x => ({
                    id: x.id ?? x.payrollRuleId ?? '',
                    name: x.name ?? x.ruleName ?? x.displayName ?? `Rule ${x.id ?? ''}`.trim(),
                    classification: x.classification ?? x.holidayClassification ?? ''
                }));
            } catch {
                state.payrollRules = [
                    { id: 'regular', name: 'Regular Holiday Rule', classification: 'RegularHoliday' },
                    { id: 'special-nonworking', name: 'Special Non-working Rule', classification: 'SpecialNonWorkingHoliday' },
                    { id: 'special-working', name: 'Special Working Rule', classification: 'SpecialWorkingHoliday' },
                    { id: 'double-holiday', name: 'Double Holiday Rule', classification: 'DoubleHoliday' },
                    { id: 'restday-regular', name: 'Rest Day + Regular Holiday Rule', classification: 'RestDayRegularHoliday' },
                    { id: 'restday-special-nonworking', name: 'Rest Day + Special Non-working Rule', classification: 'RestDaySpecialNonWorkingHoliday' },
                    { id: 'restday-special-working', name: 'Rest Day + Special Working Rule', classification: 'RestDaySpecialWorkingHoliday' },
                    { id: 'restday-double', name: 'Rest Day + Double Holiday Rule', classification: 'RestDayDoubleHoliday' },
                    { id: 'local-holiday', name: 'Local Holiday Rule', classification: 'LocalHoliday' },
                    { id: 'company-holiday', name: 'Company Holiday Rule', classification: 'CompanyHoliday' }
                ];
            }

            populatePayrollRuleOptions();
        }

        function populatePayrollRuleOptions() {
            const selects = ['holidayPayrollRuleId', 'holidayRestDayPayrollRuleId'];

            selects.forEach(id => {
                const select = $(id);
                if (!select) return;

                const currentValue = select.value || '';
                const firstLabel = id === 'holidayPayrollRuleId' ? 'Select payroll rule' : 'Optional rest day rule override';
                select.innerHTML = `<option value="">${firstLabel}</option>`;

                state.payrollRules.forEach(rule => {
                    const option = document.createElement('option');
                    option.value = String(rule.id);
                    option.textContent = rule.classification
                        ? `${rule.name} (${rule.classification})`
                        : rule.name;
                    if (String(rule.id) === String(currentValue)) option.selected = true;
                    select.appendChild(option);
                });
            });
        }

        async function loadHolidayData(year) {
            try {
                state.isLoading = true;
                const data = await apiRequest(`${api.holidays}?year=${encodeURIComponent(year)}`, { method: 'GET' });
                const list = Array.isArray(data) ? data : (data?.items || data?.data || []);
                state.holidays = list.map(normalizeHoliday);
            } catch (error) {
                state.holidays = [];
                window.showToast?.(`Unable to load holidays. ${error.message}`, false);
            } finally {
                state.isLoading = false;
                renderHolidayCalendar();
                renderHolidayTable();
                updateYearSelect();
            }
        }

        function updateYearSelect() {
            fillYearOptions();
            const select = $(selectors.yearSelect);
            if (select) select.value = String(state.selectedYear);
        }

        function resetHolidayModal(prefillDate = null) {
            state.editingHolidayId = null;

            $('holidayRecordId').value = '';
            $('holidayModalTitle').textContent = 'Configure Holiday Rule';
            $('holidayName').value = '';
            $('holidayDate').value = prefillDate || '';
            $('holidayType').value = 'RegularHoliday';
            $('holidayActive').value = 'true';
            $('holidayScopeType').value = 'Nationwide';
            $('holidayScopeValues').value = '';
            $('holidaySourceTag').value = 'ManualEntry';
            $('holidayPrecedence').value = '100';

            $('holidayReferenceNo').value = '';
            $('holidayReferenceUrl').value = '';
            $('holidayOfficialTag').value = '';
            $('holidayOverlapStrategy').value = 'HighestPrecedence';

            $('holidayIncludeAttendance').checked = true;
            $('holidayNonWorkingDay').checked = true;
            $('holidayAllowWork').checked = true;
            $('holidayApplyRestDayRules').checked = true;
            $('holidayAttendanceClassification').value = 'RegularHoliday';
            $('holidayRestDayClassification').value = 'RestDayRegularHoliday';
            $('holidayEmployeeGroupScope').value = '';

            $('holidayIncludePayroll').checked = true;
            $('holidayUsePayRules').checked = true;
            $('holidayPaidWhenUnworked').checked = true;
            $('holidayPayrollClassification').value = 'RegularHoliday';
            $('holidayRestDayPayrollClassification').value = 'RestDayRegularHoliday';
            $('holidayPayrollRuleId').value = '';
            $('holidayRestDayPayrollRuleId').value = '';
            $('holidayPayrollNotes').value = '';
            $('holidayNotes').value = '';

            suggestPayrollRuleSelection();
            $('holidayDeleteButton').classList.add('hidden');
        }

        function fillHolidayModal(item) {
            state.editingHolidayId = item.id;

            $('holidayRecordId').value = item.id ?? '';
            $('holidayModalTitle').textContent = 'Edit Holiday Rule';
            $('holidayName').value = item.name || '';
            $('holidayDate').value = item.date || '';
            $('holidayType').value = item.type || 'RegularHoliday';
            $('holidayActive').value = String(!!item.isActive);
            $('holidayScopeType').value = item.scopeType || 'Nationwide';
            $('holidayScopeValues').value = (item.scopeValues || []).join(', ');
            $('holidaySourceTag').value = item.sourceTag || 'ManualEntry';
            $('holidayPrecedence').value = String(item.precedence ?? 100);

            $('holidayReferenceNo').value = item.referenceNo || '';
            $('holidayReferenceUrl').value = item.referenceUrl || '';
            $('holidayOfficialTag').value = item.officialTag || '';
            $('holidayOverlapStrategy').value = item.overlapStrategy || 'HighestPrecedence';

            $('holidayIncludeAttendance').checked = !!item.includeAttendance;
            $('holidayNonWorkingDay').checked = !!item.nonWorkingDay;
            $('holidayAllowWork').checked = !!item.allowWork;
            $('holidayApplyRestDayRules').checked = !!item.applyRestDayRules;
            $('holidayAttendanceClassification').value = item.attendanceClassification || 'Holiday';
            $('holidayRestDayClassification').value = item.restDayClassification || '';
            $('holidayEmployeeGroupScope').value = (item.employeeGroupScope || []).join(', ');

            $('holidayIncludePayroll').checked = !!item.includePayroll;
            $('holidayUsePayRules').checked = !!item.usePayRules;
            $('holidayPaidWhenUnworked').checked = !!item.paidWhenUnworked;
            $('holidayPayrollClassification').value = item.payrollClassification || 'RegularHoliday';
            $('holidayRestDayPayrollClassification').value = item.restDayPayrollClassification || '';
            $('holidayPayrollRuleId').value = item.payrollRuleId || '';
            $('holidayRestDayPayrollRuleId').value = item.restDayPayrollRuleId || '';
            $('holidayPayrollNotes').value = item.payrollNotes || '';
            $('holidayNotes').value = item.notes || '';

            $('holidayDeleteButton').classList.remove('hidden');
        }

        function openHolidayModal(id = null, prefillDate = null) {
            const modal = $(selectors.modal);
            if (!modal) return;

            populatePayrollRuleOptions();

            if (id == null) {
                resetHolidayModal(prefillDate);
                if (prefillDate) {
                    const d = new Date(prefillDate + 'T00:00:00');
                    if (d.getFullYear() !== state.selectedYear) {
                        state.selectedYear = d.getFullYear();
                    }
                }
            } else {
                const item = state.holidays.find(x => String(x.id) === String(id));
                if (!item) {
                    window.showToast?.('Holiday record not found.', false);
                    return;
                }

                fillHolidayModal(item);
            }

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeHolidayModal() {
            const modal = $(selectors.modal);
            if (!modal) return;
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function validateHolidayPayload(payload) {
            if (!payload.name) return 'Holiday name is required.';
            if (!payload.date) return 'Holiday date is required.';
            if (!payload.type) return 'Holiday classification is required.';
            if (!payload.scopeType) return 'Scope type is required.';
            if (payload.scopeType !== 'Nationwide' && payload.scopeType !== 'CompanyWide' && (!payload.scopeValues || !payload.scopeValues.length)) {
                return 'Scope values are required for the selected scope type.';
            }
            if (payload.includePayroll && payload.usePayRules && !payload.payrollRuleId) {
                return 'Please select a payroll rule when "Use Holiday Pay Rules" is enabled.';
            }

            const sameDateOverlaps = state.holidays.filter(x =>
                String(x.id) !== String(payload.id || '') &&
                x.date === payload.date &&
                x.scopeType === payload.scopeType &&
                JSON.stringify([...(x.scopeValues || [])].sort()) === JSON.stringify([...(payload.scopeValues || [])].sort())
            );

            if (sameDateOverlaps.length > 0 && payload.overlapStrategy === 'ManualResolution') {
                return 'An overlapping holiday already exists for this date and scope. Choose a different overlap strategy or adjust precedence.';
            }

            return null;
        }

        function collectHolidayPayload() {
            return {
                id: $('holidayRecordId').value ? $('holidayRecordId').value : null,
                date: $('holidayDate').value,
                name: ($('holidayName').value || '').trim(),
                type: $('holidayType').value,
                isActive: $('holidayActive').value === 'true',
                scopeType: $('holidayScopeType').value,
                scopeValues: parseCsv($('holidayScopeValues').value),
                sourceTag: $('holidaySourceTag').value,
                includeAttendance: $('holidayIncludeAttendance').checked,
                nonWorkingDay: $('holidayNonWorkingDay').checked,
                allowWork: $('holidayAllowWork').checked,
                applyRestDayRules: $('holidayApplyRestDayRules').checked,
                attendanceClassification: $('holidayAttendanceClassification').value,
                restDayClassification: $('holidayRestDayClassification').value,
                employeeGroupScope: parseCsv($('holidayEmployeeGroupScope').value),
                includePayroll: $('holidayIncludePayroll').checked,
                usePayRules: $('holidayUsePayRules').checked,
                paidWhenUnworked: $('holidayPaidWhenUnworked').checked,
                payrollClassification: $('holidayPayrollClassification').value,
                restDayPayrollClassification: $('holidayRestDayPayrollClassification').value,
                payrollRuleId: $('holidayPayrollRuleId').value,
                restDayPayrollRuleId: $('holidayRestDayPayrollRuleId').value,
                payrollNotes: ($('holidayPayrollNotes').value || '').trim(),
                referenceNo: ($('holidayReferenceNo').value || '').trim(),
                referenceUrl: ($('holidayReferenceUrl').value || '').trim(),
                officialTag: ($('holidayOfficialTag').value || '').trim(),
                overlapStrategy: $('holidayOverlapStrategy').value,
                precedence: Number($('holidayPrecedence').value || 100),
                notes: $('holidayNotes').value || ''
            };
        }

        async function saveHolidayRule() {
            const payload = collectHolidayPayload();
            const validationError = validateHolidayPayload(payload);
            if (validationError) {
                window.showToast?.(validationError, false);
                return;
            }

            try {
                const isEdit = !!payload.id;
                const url = isEdit ? `${api.holidays}/${encodeURIComponent(payload.id)}` : api.holidays;
                const method = isEdit ? 'PUT' : 'POST';

                const result = await apiRequest(url, {
                    method,
                    body: JSON.stringify(payload)
                });

                const saved = normalizeHoliday(result?.data || result || payload);
                const existingIndex = state.holidays.findIndex(x => String(x.id) === String(saved.id));

                if (existingIndex >= 0) {
                    state.holidays.splice(existingIndex, 1, saved);
                } else {
                    state.holidays.push(saved);
                }

                closeHolidayModal();
                renderHolidayCalendar();
                renderHolidayTable();
                window.showToast?.(`Holiday rule ${isEdit ? 'updated' : 'created'} successfully.`, true);
            } catch (error) {
                window.showToast?.(`Unable to save holiday rule. ${error.message}`, false);
            }
        }

        async function deleteHolidayRule() {
            const id = $('holidayRecordId').value;
            if (!id) return;

            const confirmed = window.confirm('Delete this holiday rule?');
            if (!confirmed) return;

            try {
                await apiRequest(`${api.holidays}/${encodeURIComponent(id)}`, { method: 'DELETE' });
                state.holidays = state.holidays.filter(x => String(x.id) !== String(id));
                closeHolidayModal();
                renderHolidayCalendar();
                renderHolidayTable();
                window.showToast?.('Holiday rule deleted successfully.', true);
            } catch (error) {
                window.showToast?.(`Unable to delete holiday rule. ${error.message}`, false);
            }
        }

        async function syncHolidayYear(showToast = true) {
            try {
                const result = await apiRequest(`${api.holidaySync}?year=${encodeURIComponent(state.selectedYear)}`, {
                    method: 'POST'
                });

                const list = Array.isArray(result) ? result : (result?.items || result?.data || null);
                if (Array.isArray(list)) {
                    state.holidays = list.map(normalizeHoliday);
                } else {
                    await loadHolidayData(state.selectedYear);
                }

                renderHolidayCalendar();
                renderHolidayTable();
                if (showToast) window.showToast?.(`Holiday template synced for ${state.selectedYear}.`, true);
            } catch (error) {
                if (showToast) window.showToast?.(`Unable to sync holidays. ${error.message}`, false);
                throw error;
            }
        }

        function goToPreviousMonth() {
            if (state.selectedMonth === 0) {
                state.selectedMonth = 11;
                state.selectedYear -= 1;
            } else {
                state.selectedMonth -= 1;
            }

            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
            updateYearSelect();
            renderHolidayCalendar();
            renderHolidayTable();
        }

        function goToNextMonth() {
            if (state.selectedMonth === 11) {
                state.selectedMonth = 0;
                state.selectedYear += 1;
            } else {
                state.selectedMonth += 1;
            }

            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
            updateYearSelect();
            renderHolidayCalendar();
            renderHolidayTable();
        }

        function goToToday() {
            const now = new Date();
            state.selectedYear = now.getFullYear();
            state.selectedMonth = now.getMonth();
            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
            updateYearSelect();
            loadHolidayData(state.selectedYear);
        }

        async function init() {
            if (!accessToken) {
                console.warn('OrgTabHoliday: access token missing.');
                window.showToast?.('Cannot load holidays because the API session token is missing. Refresh the page and sign in again.', false);
                return;
            }
            if (!apiBase) {
                console.warn('OrgTabHoliday: ApiBaseUrl not configured. Falling back to same origin.');
            }
            const now = new Date();
            state.selectedYear = now.getFullYear();
            state.selectedMonth = now.getMonth();
            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);

            fillYearOptions();
            bindFilters();
            bindModalDismiss();
            bindHolidayTypeAutoMapping();
            updateYearSelect();
            await loadPayrollRules();
            try {
                await syncHolidayYear(false);
            } catch {
                await loadHolidayData(state.selectedYear);
            }
        }

        return {
            init,
            openHolidayModal,
            closeHolidayModal,
            saveHolidayRule,
            deleteHolidayRule,
            goToPreviousMonth,
            goToNextMonth,
            goToToday,
            syncHolidayYear
        };
    })();

    window.SubchronOrgTabHoliday.init();
</script>
