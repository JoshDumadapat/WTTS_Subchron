                        restDayPayrollClassification: 'RestDayCompanyHoliday',
                        paidWhenUnworked: false
                    };
                default:
                    return {
                        nonWorkingDay: true,
                        allowWork: true,
                        attendanceClassification: 'Holiday',
                        restDayClassification: '',
                        payrollClassification: 'RegularHoliday',
                        restDayPayrollClassification: '',
                        paidWhenUnworked: false
                    };
            }
        }

        function formatDate(dateObj) {
            const y = dateObj.getFullYear();
            const m = String(dateObj.getMonth() + 1).padStart(2, '0');
            const d = String(dateObj.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function formatDateDisplay(dateString) {
            if (!dateString) return '—';
            const d = new Date(dateString + 'T00:00:00');
            return `${monthNames[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;
        }

        function computeRuleConfiguredFallback(raw) {
            const scopeType = raw.scopeType ?? 'Nationwide';
            const scopeValues = Array.isArray(raw.scopeValues) ? raw.scopeValues : parseCsv(raw.scopeValues);
            const groupScope = Array.isArray(raw.employeeGroupScope) ? raw.employeeGroupScope : parseCsv(raw.employeeGroupScope);
            return scopeType !== 'Nationwide'
                || scopeValues.length > 0
                || groupScope.length > 0
                || (raw.overlapStrategy ?? 'HighestPrecedence') !== 'HighestPrecedence'
                || Number(raw.precedence ?? 100) !== 100
                || raw.includeAttendance === false
                || raw.applyRestDayRules === false
                || raw.includePayroll === false
                || raw.usePayRules === false
                || !!(raw.payrollRuleId)
                || !!(raw.restDayPayrollRuleId)
                || !!(raw.restDayClassification)
                || !!(raw.restDayPayrollClassification);
        }

        function normalizeHoliday(raw) {
            const scopeValues = Array.isArray(raw.scopeValues)
                ? raw.scopeValues
                : parseCsv(raw.scopeValues);

            const employeeGroupScope = Array.isArray(raw.employeeGroupScope)
                ? raw.employeeGroupScope
                : parseCsv(raw.employeeGroupScope);

            return {
                id: raw.id ?? raw.holidayId ?? null,
                orgId: raw.orgId ?? raw.organizationId ?? null,
                date: raw.date ?? raw.holidayDate ?? '',
                name: raw.name ?? raw.holidayName ?? '',
                type: raw.type ?? raw.holidayType ?? 'RegularHoliday',
                scopeType: raw.scopeType ?? 'Nationwide',
                scopeValues,
                sourceTag: raw.sourceTag ?? 'ManualEntry',
                isActive: raw.isActive !== false,
                includeAttendance: raw.includeAttendance !== false,
                nonWorkingDay: raw.nonWorkingDay !== false,
                allowWork: raw.allowWork !== false,
                applyRestDayRules: raw.applyRestDayRules !== false,
                attendanceClassification: raw.attendanceClassification ?? 'Holiday',
                restDayClassification: raw.restDayClassification ?? raw.restDayAttendanceClassification ?? '',
                includePayroll: raw.includePayroll !== false,
                usePayRules: raw.usePayRules !== false,
                paidWhenUnworked: raw.paidWhenUnworked !== false,
                payrollClassification: raw.payrollClassification ?? (raw.type ?? 'RegularHoliday'),
                restDayPayrollClassification: raw.restDayPayrollClassification ?? '',
                payrollRuleId: raw.payrollRuleId ?? '',
                restDayPayrollRuleId: raw.restDayPayrollRuleId ?? '',
                payrollNotes: raw.payrollNotes ?? '',
                referenceNo: raw.referenceNo ?? '',
                referenceUrl: raw.referenceUrl ?? '',
                officialTag: raw.officialTag ?? '',
                overlapStrategy: raw.overlapStrategy ?? 'HighestPrecedence',
                precedence: Number(raw.precedence ?? 100),
                employeeGroupScope,
                notes: raw.notes ?? '',
                hasRuleConfigured: raw.hasRuleConfigured === true || raw.HasRuleConfigured === true || computeRuleConfiguredFallback(raw),
                createdAt: raw.createdAt ?? null,
                updatedAt: raw.updatedAt ?? null,
                isSynced: !!raw.isSynced
            };
        }

        async function apiRequest(url, options = {}) {
            const headers = new Headers(options.headers || {});
            if (!headers.has('Content-Type')) headers.set('Content-Type', 'application/json');
            headers.set('X-Requested-With', 'XMLHttpRequest');
            if (accessToken) headers.set('Authorization', `Bearer ${accessToken}`);

            try {
                const response = await fetch(url, {
                    ...options,
                    headers,
                    mode: 'cors',
                    credentials: 'omit'
                });

                if (!response.ok) {
                    let message = `Request failed (${response.status}).`;
                    try {
                        const error = await response.json();
                        message = error.message || error.title || error.error || message;
                    } catch {
                        try {
                            const text = await response.text();
                            if (text) message = text;
                        } catch { }
                    }

                    throw new Error(message);
                }

                if (response.status === 204) return null;

                const contentType = response.headers.get('content-type') || '';
                if (contentType.includes('application/json')) {
                    return await response.json();
                }

                return await response.text();
            }
            catch (err) {
                if (err instanceof TypeError || err?.message?.includes('Failed to fetch')) {
                    const target = apiBase || 'the Subchron API';
                    throw new Error(`Unable to reach ${target}. Ensure the Subchron.API service is running.`);
                }
                throw err;
            }
        }

        function getFilteredHolidays() {
            return state.configuredHolidays
                .filter(x => {
                    const year = new Date(x.date + 'T00:00:00').getFullYear();
                    return year === state.selectedYear;
                })
                .filter(x => state.selectedHolidayType === 'all' || x.type === state.selectedHolidayType)
                .filter(x => state.selectedScopeType === 'all' || x.scopeType === state.selectedScopeType);
        }

        function getCalendarFilteredHolidays() {
            return state.holidays
                .filter(x => {
                    const year = new Date(x.date + 'T00:00:00').getFullYear();
                    return year === state.selectedYear;
                })
                .filter(x => state.selectedHolidayType === 'all' || x.type === state.selectedHolidayType)
                .filter(x => state.selectedScopeType === 'all' || x.scopeType === state.selectedScopeType);
        }

        function getAllHolidaysByDate(dateString) {
            return state.holidays.filter(x => x.date === dateString);
        }

        function getVisibleHolidaysByDate(dateString) {
            return getCalendarFilteredHolidays().filter(x => x.date === dateString);
        }

        function buildHolidayKey(item) {
            const date = item?.date || '';
            const name = (item?.name || '').trim().toLowerCase();
            return `${date}|${name}`;
        }

        function mergeCalendarHolidays() {
            const merged = new Map();
            state.defaultHolidays.forEach(item => merged.set(buildHolidayKey(item), item));
            state.configuredHolidays.forEach(item => merged.set(buildHolidayKey(item), { ...item, hasRuleConfigured: true }));
            state.holidays = [...merged.values()];
        }

        function renderSummary() {
            const visible = getCalendarFilteredHolidays();
            const coverageSet = new Set(
                state.holidays
                    .filter(x => new Date(x.date + 'T00:00:00').getFullYear() === state.selectedYear)
                    .filter(x => x.isActive)
                    .map(x => x.type)
            );

            if ($(selectors.summaryYear)) $(selectors.summaryYear).textContent = String(state.selectedYear);
            if ($(selectors.summaryCount)) $(selectors.summaryCount).textContent = String(visible.length);
            if ($(selectors.summaryCoverage)) $(selectors.summaryCoverage).textContent = `${coverageSet.size}/6`;
            if ($(selectors.summarySync)) $(selectors.summarySync).textContent = 'Org + Official Template';
        }

        function renderHolidayCalendar() {
            const title = $(selectors.title);
            const grid = $(selectors.grid);
            if (!title || !grid) return;

            title.textContent = `${monthNames[state.selectedMonth]} ${state.selectedYear}`;
            grid.innerHTML = '';

            const firstDayOfMonth = new Date(state.selectedYear, state.selectedMonth, 1);
            const mondayBasedStart = (firstDayOfMonth.getDay() + 6) % 7;
            const startDate = new Date(firstDayOfMonth);
            startDate.setDate(firstDayOfMonth.getDate() - mondayBasedStart);
            const todayString = formatDate(new Date());

            for (let i = 0; i < 42; i++) {
                const cellDate = new Date(startDate);
                cellDate.setDate(startDate.getDate() + i);

                const dateString = formatDate(cellDate);
                const isCurrentMonth = cellDate.getMonth() === state.selectedMonth;
                const isToday = dateString === todayString;
                const visibleHolidays = getVisibleHolidaysByDate(dateString);
                const allHolidays = getAllHolidaysByDate(dateString);

                const cell = document.createElement('button');
                cell.type = 'button';
                cell.className = [
                    'holiday-day-cell flex flex-col items-start text-left',
                    !isCurrentMonth ? 'is-outside' : '',
                    isToday ? 'is-today' : ''
                ].join(' ').trim();

                let holidayContent = '';
                visibleHolidays.slice(0, 2).forEach(h => {
                    const scopeText = h.scopeType === 'Nationwide'
                        ? 'Nationwide'
                        : `${getScopeLabel(h.scopeType)}${h.scopeValues?.length ? ` • ${h.scopeValues[0]}` : ''}`;
                    const ruleText = `${h.nonWorkingDay ? 'Non-working' : 'Working'} • ${h.includePayroll ? 'Payroll' : 'No payroll'}`;

                    holidayContent += `
                        <div class="mt-1.5 w-full">
                            <div class="line-clamp-2 text-[12px] font-semibold leading-4 text-slate-800 dark:text-white">${escapeHtml(h.name)}</div>
                            <div class="mt-0.5 line-clamp-1 text-[10px] text-slate-500 dark:text-slate-300">${escapeHtml(getTypeLabel(h.type))} • ${escapeHtml(scopeText)}</div>
                            <div class="mt-0.5 line-clamp-1 text-[10px] text-slate-400 dark:text-slate-400">${escapeHtml(ruleText)}</div>
                        </div>
                    `;
                });

                if (visibleHolidays.length > 2) {
                    holidayContent += `<div class="mt-1.5 text-[11px] font-medium text-slate-500 dark:text-slate-300">+${visibleHolidays.length - 2} more</div>`;
                } else if (!visibleHolidays.length && allHolidays.length > 0) {
                    holidayContent += `<div class="mt-1.5 text-[11px] font-medium text-slate-400 dark:text-slate-500">${allHolidays.length} hidden by filter</div>`;
                }

                const hasCustomRules = visibleHolidays.some(h => h.hasRuleConfigured);

                cell.innerHTML = `
                    ${visibleHolidays.length > 0 ? `<span class="holiday-corner-indicator ${getTypeDotClass(visibleHolidays[0].type)}"></span>` : ''}
                    ${hasCustomRules ? `<span class="holiday-rule-flag" title="Holiday has custom rule configuration"></span>` : ''}
                    <div class="holiday-day-number">${cellDate.getDate()}</div>
                    <div class="mt-1.5 w-full">
                        ${holidayContent}
                    </div>
                    ${hasCustomRules ? `<span class="pointer-events-none absolute bottom-1 left-1 rounded bg-emerald-100 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">Configured</span>` : ''}
                `;

                cell.addEventListener('click', function () {
                    if (visibleHolidays.length > 0) {
                        const first = visibleHolidays[0];
                        if (first.id) {
                            openHolidayModal(first.id);
                        } else {
                            openHolidayModal(null, dateString, first);
                        }
                    } else if (allHolidays.length > 0) {
                        const first = allHolidays[0];
                        if (first.id) {
                            openHolidayModal(first.id);
                        } else {
                            openHolidayModal(null, dateString, first);
                        }
                    } else {
                        openHolidayModal(null, dateString);
                    }
                });

                grid.appendChild(cell);
            }
        }

        function renderHolidayTable() {
            const tbody = $(selectors.tableBody);
            if (!tbody) return;

            const sorted = getFilteredHolidays().sort((a, b) => {
                const byDate = a.date.localeCompare(b.date);
                if (byDate !== 0) return byDate;
                return (b.precedence || 0) - (a.precedence || 0);
            });

            const tableQuery = (state.tableSearchQuery || '').trim().toLowerCase();
            const filtered = sorted.filter(item => {
                const status = boolToStatus(item.isActive);
                if (state.tableStatusFilter !== 'all' && status !== state.tableStatusFilter) return false;
                if (!tableQuery) return true;

                const haystack = [
                    item.name,
                    item.type,
                    item.scopeType,
                    (item.scopeValues || []).join(', '),
                    item.referenceNo,
                    item.referenceUrl,
                    item.officialTag,
                    item.notes,
                    status
                ].join(' ').toLowerCase();

                return haystack.includes(tableQuery);
            });

            const total = filtered.length;
            const perPage = Math.max(1, Number(state.tableRowsPerPage || 10));
            const totalPages = Math.max(1, Math.ceil(total / perPage));
            if (state.tablePage > totalPages) state.tablePage = totalPages;
            if (state.tablePage < 1) state.tablePage = 1;

            const from = total === 0 ? 0 : ((state.tablePage - 1) * perPage) + 1;
            const to = total === 0 ? 0 : Math.min(state.tablePage * perPage, total);
            const rows = filtered.slice(from > 0 ? from - 1 : 0, to);

            tbody.innerHTML = '';

            if (!rows.length) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="9" class="px-5 py-10 text-center text-sm text-gray-500 dark:text-gray-400">
                            No holiday rules found for this year and filter combination.
                        </td>
                    </tr>
                `;
                updateHolidayTablePagination(total, from, to, totalPages);
                renderSummary();
                return;
            }

            rows.forEach(item => {
                const tr = document.createElement('tr');

                const scopeValues = item.scopeValues?.length ? item.scopeValues.join(', ') : 'All';
                const referenceText = item.referenceNo || item.officialTag || getSourceTagLabel(item.sourceTag);
                const payrollRule = state.payrollRules.find(x => String(x.id) === String(item.payrollRuleId));
                const payrollRuleName = payrollRule?.name || item.payrollClassification || '—';

                tr.innerHTML = `
                    <td class="px-3 py-3 text-sm text-gray-700 dark:text-gray-200 whitespace-nowrap">${escapeHtml(formatDateDisplay(item.date))}</td>
                    <td class="px-3 py-3">
                        <div class="truncate text-sm font-semibold text-gray-900 dark:text-white" title="${escapeHtml(item.name)}">${escapeHtml(item.name)}</div>
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${escapeHtml(getSourceTagLabel(item.sourceTag))}">${escapeHtml(getSourceTagLabel(item.sourceTag))}</div>
                    </td>
                    <td class="px-3 py-3">
                        <div class="flex items-start gap-2 text-sm text-gray-700 dark:text-gray-200" title="${escapeHtml(getTypeLabel(item.type))}">
                            <span class="holiday-type-dot ${getTypeDotClass(item.type)}"></span>
                            <span class="whitespace-normal break-words leading-4">${escapeHtml(getTypeLabel(item.type))}</span>
                        </div>
                    </td>
                    <td class="px-3 py-3 text-xs text-gray-600 dark:text-gray-300">
                        <div class="truncate font-semibold text-gray-700 dark:text-gray-200" title="${escapeHtml(getScopeLabel(item.scopeType))}">${escapeHtml(getScopeLabel(item.scopeType))}</div>
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${escapeHtml(scopeValues)}">${escapeHtml(scopeValues)}</div>
                    </td>
                    <td class="px-3 py-3 text-xs text-gray-600 dark:text-gray-300">
                        ${item.includeAttendance ? 'Included' : 'Ignored'}
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${escapeHtml(item.nonWorkingDay ? 'Non-working' : 'Working')} • ${escapeHtml(item.allowWork ? 'Work allowed' : 'Work blocked')}">
                            ${item.nonWorkingDay ? 'Non-working' : 'Working'} • ${item.allowWork ? 'Work allowed' : 'Work blocked'}
                        </div>
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${escapeHtml(item.attendanceClassification || 'Holiday')}">
                            ${escapeHtml(item.attendanceClassification || 'Holiday')}
                        </div>
                    </td>
                    <td class="px-3 py-3 text-xs text-gray-600 dark:text-gray-300">
                        ${item.includePayroll ? 'Included' : 'Ignored'}
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${item.usePayRules ? escapeHtml(payrollRuleName) : 'Manual / no pay rule'}">
                            ${item.usePayRules ? escapeHtml(payrollRuleName) : 'Manual / no pay rule'}
                        </div>
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${escapeHtml(item.restDayPayrollClassification || 'No rest day override')}">
