<script>
    window.SubchronOrgTabHoliday = window.SubchronOrgTabHoliday || (() => {
        const monthNames = [
            'January', 'February', 'March', 'April', 'May', 'June',
            'July', 'August', 'September', 'October', 'November', 'December'
        ];

        const selectors = {
            yearSelect: 'holidayYearSelect',
            typeFilter: 'holidayTypeFilter',
            scopeFilter: 'holidayScopeFilter',
            tableBody: 'holidayRulesTableBody',
            tableSearch: 'holidayTableSearch',
            tableStatusFilter: 'holidayTableStatusFilter',
            tableRowsPerPage: 'holidayTableRowsPerPage',
            tablePrevPage: 'holidayTablePrevPage',
            tableNextPage: 'holidayTableNextPage',
            tablePaginationInfo: 'holidayTablePaginationInfo',
            statusModal: 'holidayStatusModal',
            grid: 'holidayCalendarGrid',
            title: 'holidayCalendarTitle',
            modal: 'holidayModal',
            deleteButton: 'holidayDeleteButton',
            summaryYear: 'holidaySummaryYear',
            summaryCount: 'holidaySummaryCount',
            summaryCoverage: 'holidaySummaryCoverage',
            summarySync: 'holidaySummarySync'
        };

        const appRoot = document.getElementById('appRoot');
        const apiBase = (appRoot?.getAttribute('data-api-base') || '').trim().replace(/\/$/, '');
        const accessToken = appRoot?.getAttribute('data-access-token') || '';

        const resolvedApiBase = apiBase || window.location.origin;

        function buildApiUrl(path) {
            if (!path) return resolvedApiBase;
            if (!resolvedApiBase) return path;
            return `${resolvedApiBase}${path.startsWith('/') ? path : `/${path}`}`;
        }

        const state = {
            currentDate: new Date(),
            selectedYear: new Date().getFullYear(),
            selectedMonth: new Date().getMonth(),
            selectedHolidayType: 'all',
            selectedScopeType: 'all',
            editingHolidayId: null,
            holidays: [],
            configuredHolidays: [],
            defaultHolidays: [],
            tableSearchQuery: '',
            tableStatusFilter: 'all',
            tablePage: 1,
            tableRowsPerPage: 10,
            statusTargetId: null,
            statusTargetActive: true,
            payrollRules: [],
            isLoading: false
        };

        const api = {
            holidays: buildApiUrl('/api/orgconfig/holidays'),
            holidaySync: buildApiUrl('/api/orgconfig/holidays/sync'),
            payrollRules: buildApiUrl('/api/orgconfig/payroll/holiday-rules')
        };

        function $(id) {
            return document.getElementById(id);
        }

        function escapeHtml(value) {
            const div = document.createElement('div');
            div.textContent = value == null ? '' : String(value);
            return div.innerHTML;
        }

        function parseCsv(value) {
            return (value || '')
                .split(',')
                .map(x => x.trim())
                .filter(Boolean);
        }

        function updateHolidayStatusReasonCounter() {
            const input = $('holidayStatusReason');
            const counter = $('holidayStatusReasonCount');
            if (!input || !counter) return;
            counter.textContent = `${input.value.length}/60`;
        }

        function setHolidayStatusSaving(isSaving) {
            const btn = $('holidayStatusConfirmBtn');
            const spinner = $('holidayStatusConfirmSpinner');
            if (!btn || !spinner) return;

            btn.disabled = !!isSaving;
            btn.classList.toggle('opacity-70', !!isSaving);
            btn.classList.toggle('cursor-not-allowed', !!isSaving);
            spinner.classList.toggle('hidden', !isSaving);
        }

        function extractTaggedReason(notes, tag) {
            const prefix = `[${tag}] `;
            const line = (notes || '').split('\n').find(x => x.startsWith(prefix));
            return line ? line.slice(prefix.length).trim() : '';
        }

        function mergeReactivationReason(existingNotes, reason) {
            const cleanReason = (reason || '').trim();
            const reactivationPrefix = '[Reactivation Reason] ';
            const lines = (existingNotes || '')
                .split('\n')
                .filter(x => x && !x.startsWith(reactivationPrefix));
            if (cleanReason) lines.push(`${reactivationPrefix}${cleanReason}`);
            return lines.join('\n').trim();
        }

        function openHolidayStatusModal(id) {
            const item = state.configuredHolidays.find(x => String(x.id) === String(id));
            if (!item) {
                window.showToast?.('Holiday record not found.', false);
                return;
            }

            state.statusTargetId = item.id;
            state.statusTargetActive = !!item.isActive;

            const title = $('holidayStatusModalTitle');
            const msg = $('holidayStatusModalMessage');
            const reasonGroup = $('holidayStatusReasonGroup');
            const reasonInput = $('holidayStatusReason');
            const reasonLabel = $('holidayStatusReasonLabel');
            const reasonHint = $('holidayStatusReasonHint');
            const currentReason = $('holidayStatusCurrentReason');
            const confirmBtn = $('holidayStatusConfirmBtn');

            const isDeactivate = !!item.isActive;
            if (title) title.textContent = isDeactivate ? 'Deactivate Holiday' : 'Activate Holiday';
            if (msg) msg.textContent = isDeactivate
                ? `Are you sure you want to deactivate "${item.name}"?`
                : `Are you sure you want to activate "${item.name}"?`;
            if (reasonGroup) reasonGroup.classList.remove('hidden');
            if (reasonInput) {
                reasonInput.value = '';
                reasonInput.required = isDeactivate;
                reasonInput.readOnly = false;
                reasonInput.placeholder = isDeactivate ? 'Enter reason for deactivation' : 'Optional reason for reactivation';
            }
            if (reasonLabel) reasonLabel.textContent = isDeactivate ? 'Reason for deactivation' : 'Reason for reactivation';
            if (reasonHint) reasonHint.textContent = isDeactivate ? 'Required when deactivating. Max 60 characters.' : 'Optional when activating. Max 60 characters.';
            const lastDeactivation = extractTaggedReason(item.notes, 'Deactivation Reason');
            if (currentReason) {
                if (!isDeactivate && lastDeactivation) {
                    currentReason.classList.remove('hidden');
                    currentReason.innerHTML = `<span class="font-semibold">Reason of its deactivation:</span> ${escapeHtml(lastDeactivation)}`;
                } else {
                    currentReason.classList.add('hidden');
                    currentReason.textContent = '';
                }
            }
            updateHolidayStatusReasonCounter();
            setHolidayStatusSaving(false);

            if (confirmBtn) {
                confirmBtn.textContent = isDeactivate ? 'Deactivate' : 'Activate';
                confirmBtn.classList.remove('bg-emerald-600', 'hover:bg-emerald-700', 'focus:ring-emerald-300', 'dark:bg-emerald-500', 'dark:hover:bg-emerald-400', 'bg-red-500', 'hover:bg-red-600', 'focus:ring-red-300', 'dark:bg-red-600', 'dark:hover:bg-red-500');
                if (isDeactivate) {
                    confirmBtn.classList.add('bg-red-500', 'hover:bg-red-600', 'focus:ring-red-300', 'dark:bg-red-600', 'dark:hover:bg-red-500');
                } else {
                    confirmBtn.classList.add('bg-emerald-600', 'hover:bg-emerald-700', 'focus:ring-emerald-300', 'dark:bg-emerald-500', 'dark:hover:bg-emerald-400');
                }
            }

            const modal = $(selectors.statusModal);
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
        }

        function closeHolidayStatusModal() {
            state.statusTargetId = null;
            state.statusTargetActive = true;
            const input = $('holidayStatusReason');
            if (input) {
                input.value = '';
                input.required = false;
                input.readOnly = false;
            }
            $('holidayStatusCurrentReason')?.classList.add('hidden');
            if ($('holidayStatusCurrentReason')) $('holidayStatusCurrentReason').textContent = '';
            updateHolidayStatusReasonCounter();
            setHolidayStatusSaving(false);
            const modal = $(selectors.statusModal);
            modal?.classList.add('hidden');
            modal?.classList.remove('flex');
        }

        function mergeDeactivationReason(existingNotes, reason) {
            const cleanReason = (reason || '').trim();
            if (!cleanReason) return existingNotes || '';
            const notePrefix = '[Deactivation Reason] ';
            const current = (existingNotes || '').trim();
            const lines = current.split('\n').filter(x => !x.startsWith(notePrefix));
            lines.push(`${notePrefix}${cleanReason}`);
            return lines.join('\n').trim();
        }

        async function confirmHolidayStatusChange() {
            if (!state.statusTargetId) return;

            const item = state.configuredHolidays.find(x => String(x.id) === String(state.statusTargetId));
            if (!item) {
                closeHolidayStatusModal();
                return;
            }

            const isDeactivate = !!item.isActive;
            const reason = ($('holidayStatusReason')?.value || '').trim();
            if (isDeactivate && !reason) {
                $('holidayStatusReason')?.focus();
                window.showToast?.('Please provide a reason for deactivation.', false);
                return;
            }
            if (reason.length > 60) {
                $('holidayStatusReason')?.focus();
                window.showToast?.('Reason must be 60 characters or fewer.', false);
                return;
            }

            const payload = {
                date: item.date,
                name: item.name,
                type: item.type,
                isActive: !item.isActive,
                scopeType: item.scopeType,
                scopeValues: item.scopeValues || [],
                sourceTag: item.sourceTag || 'ManualEntry',
                includeAttendance: !!item.includeAttendance,
                nonWorkingDay: !!item.nonWorkingDay,
                allowWork: !!item.allowWork,
                applyRestDayRules: !!item.applyRestDayRules,
                attendanceClassification: item.attendanceClassification || 'Holiday',
                restDayAttendanceClassification: item.restDayClassification || '',
                employeeGroupScope: item.employeeGroupScope || [],
                includePayroll: !!item.includePayroll,
                usePayRules: !!item.usePayRules,
                paidWhenUnworked: !!item.paidWhenUnworked,
                payrollClassification: item.payrollClassification || item.type,
                restDayPayrollClassification: item.restDayPayrollClassification || '',
                payrollRuleId: item.payrollRuleId || '',
                restDayPayrollRuleId: item.restDayPayrollRuleId || '',
                payrollNotes: item.payrollNotes || '',
                referenceNo: item.referenceNo || '',
                referenceUrl: item.referenceUrl || '',
                officialTag: item.officialTag || '',
                overlapStrategy: item.overlapStrategy || 'HighestPrecedence',
                precedence: Number(item.precedence || 100),
                notes: isDeactivate ? mergeDeactivationReason(item.notes, reason) : mergeReactivationReason(item.notes, reason)
            };

            try {
                setHolidayStatusSaving(true);
                const result = await apiRequest(`${api.holidays}/${encodeURIComponent(item.id)}`, {
                    method: 'PUT',
                    body: JSON.stringify(payload)
                });

                const saved = normalizeHoliday(result?.data || result || payload);
                const idx = state.configuredHolidays.findIndex(x => String(x.id) === String(saved.id));
                if (idx >= 0) state.configuredHolidays.splice(idx, 1, saved);
                else state.configuredHolidays.push(saved);
                mergeCalendarHolidays();
                renderHolidayCalendar();
                renderHolidayTable();
                closeHolidayStatusModal();
                window.showToast?.(`Holiday ${isDeactivate ? 'deactivated' : 'activated'} successfully.`, true);
            } catch (error) {
                window.showToast?.(`Unable to update holiday status. ${error.message}`, false);
            } finally {
                setHolidayStatusSaving(false);
            }
        }

        function setHolidaySaving(isSaving) {
            const btn = $('holidaySaveButton');
            const spinner = $('holidaySaveSpinner');
            const icon = $('holidaySaveIcon');
            const text = $('holidaySaveText');
            if (!btn || !spinner || !icon || !text) return;

            btn.disabled = !!isSaving;
            btn.classList.toggle('opacity-70', !!isSaving);
            btn.classList.toggle('cursor-not-allowed', !!isSaving);
            spinner.classList.toggle('hidden', !isSaving);
            icon.classList.toggle('hidden', !!isSaving);
            text.textContent = isSaving ? 'Saving...' : 'Save Holiday Rule';
        }

        function clearHolidayValidationErrors() {
            const ids = [
                'holidayName', 'holidayDate', 'holidayType', 'holidayScopeType', 'holidayScopeValues',
                'holidayPayrollRuleId', 'holidayRestDayPayrollRuleId', 'holidayReferenceUrl',
                'holidayOverlapStrategy', 'holidayIncludePayroll', 'holidayUsePayRules', 'holidayAllowWork', 'holidayNonWorkingDay'
            ];

            ids.forEach(id => {
                const field = $(id);
                if (!field) return;
                field.classList.remove('ring-red-400', 'focus:ring-red-500');
                const existing = document.getElementById(`${id}Error`);
                existing?.remove();
            });
        }

        function setHolidayFieldError(fieldId, message) {
            const field = $(fieldId);
            if (!field) return;

            field.classList.add('ring-red-400', 'focus:ring-red-500');

            const existing = document.getElementById(`${fieldId}Error`);
            existing?.remove();

            const error = document.createElement('p');
            error.id = `${fieldId}Error`;
            error.className = 'holiday-field-error';
            error.textContent = message;

            const host = field.closest('.relative')?.parentElement || field.parentElement;
            host?.appendChild(error);
        }

        function scrollToHolidayField(fieldId) {
            const field = $(fieldId);
            if (!field) return;
            field.scrollIntoView({ behavior: 'smooth', block: 'center' });
            try { field.focus({ preventScroll: true }); } catch { field.focus(); }
        }

        function makeScopeKey(scopeValues) {
            return JSON.stringify([...(scopeValues || [])].map(x => String(x).trim().toLowerCase()).filter(Boolean).sort());
        }

        function validateHolidayPayloadDetailed(payload) {
            const errors = [];
            const add = (fieldId, message) => errors.push({ fieldId, message });

            if (!payload.name) add('holidayName', 'Holiday name is required.');
            if (!payload.date) add('holidayDate', 'Holiday date is required.');
            if (!payload.type) add('holidayType', 'Holiday classification is required.');
            if (!payload.scopeType) add('holidayScopeType', 'Scope type is required.');

            if (payload.scopeType !== 'Nationwide' && payload.scopeType !== 'CompanyWide' && (!payload.scopeValues || !payload.scopeValues.length)) {
                add('holidayScopeValues', 'Scope values are required for this scope type.');
            }

            if (payload.referenceUrl) {
                try {
                    new URL(payload.referenceUrl);
                } catch {
                    add('holidayReferenceUrl', 'Reference URL must be a valid URL (include https://).');
                }
            }

            if (!payload.includePayroll && payload.usePayRules) {
                add('holidayUsePayRules', 'Use Pay Rules cannot be enabled when Include Payroll is disabled.');
            }

            if (payload.includePayroll && payload.usePayRules && !payload.payrollRuleId) {
                add('holidayPayrollRuleId', 'Please select a payroll rule when Use Holiday Pay Rules is enabled.');
            }

            if (payload.applyRestDayRules && payload.includePayroll && payload.usePayRules && payload.restDayPayrollClassification && !payload.restDayPayrollRuleId) {
                add('holidayRestDayPayrollRuleId', 'Select a rest day payroll rule for the selected rest day payroll classification.');
            }

            if (!payload.nonWorkingDay && !payload.allowWork) {
                add('holidayAllowWork', 'Invalid setup: working day cannot be blocked from work.');
            }

            const sameDateOverlaps = state.holidays.filter(x =>
                String(x.id) !== String(payload.id || '') &&
                x.date === payload.date &&
                x.scopeType === payload.scopeType &&
                makeScopeKey(x.scopeValues) === makeScopeKey(payload.scopeValues)
            );

            if (sameDateOverlaps.length > 0 && payload.overlapStrategy === 'ManualResolution') {
                add('holidayOverlapStrategy', 'An overlapping holiday exists for this date/scope. Choose another overlap strategy or change precedence.');
            }

            return {
                isValid: errors.length === 0,
                errors,
                firstErrorFieldId: errors.length ? errors[0].fieldId : null
            };
        }

        function autoFillComplianceFields() {
            const sourceTag = $('holidaySourceTag')?.value || 'ManualEntry';
            const type = $('holidayType')?.value || 'RegularHoliday';
            const scopeType = $('holidayScopeType')?.value || 'Nationwide';
            const holidayDate = $('holidayDate')?.value || '';

            const officialTagInput = $('holidayOfficialTag');
            const referenceNoInput = $('holidayReferenceNo');
            const referenceUrlInput = $('holidayReferenceUrl');

            if (officialTagInput && !officialTagInput.value.trim()) {
                if (scopeType === 'CompanyWide' || type === 'CompanyHoliday') officialTagInput.value = 'Company';
                else if (type === 'LocalHoliday') officialTagInput.value = 'Local';
                else if (sourceTag === 'Imported') officialTagInput.value = 'Imported';
                else if (sourceTag === 'Official') officialTagInput.value = 'Nationwide';
            }

            if (referenceNoInput && !referenceNoInput.value.trim()) {
                if (sourceTag === 'Official') referenceNoInput.value = 'Proclamation No. ____';
                else if (sourceTag === 'Imported' && holidayDate) referenceNoInput.value = `HolidayAPI-${holidayDate.slice(0, 4)}`;
                else if (sourceTag === 'CompanyPolicy') referenceNoInput.value = 'Policy Ref. ____';
            }

            if (referenceUrlInput && !referenceUrlInput.value.trim()) {
                if (sourceTag === 'Official') referenceUrlInput.value = 'https://www.officialgazette.gov.ph/';
                else if (sourceTag === 'Imported') referenceUrlInput.value = 'https://holidayapi.com/';
            }
        }

        function boolToStatus(value) {
            return value ? 'Active' : 'Inactive';
        }

        function getTypeLabel(type) {
            switch (type) {
                case 'RegularHoliday': return 'Regular Holiday';
                case 'SpecialNonWorkingHoliday': return 'Special Non-working Holiday';
                case 'SpecialWorkingHoliday': return 'Special Working Holiday';
                case 'DoubleHoliday': return 'Double Holiday';
                case 'CompanyHoliday': return 'Company Holiday';
                case 'LocalHoliday': return 'Local Holiday';
                default: return 'Holiday';
            }
        }

        function getScopeLabel(scopeType) {
            switch (scopeType) {
                case 'Nationwide': return 'Nationwide';
                case 'Region': return 'Region';
                case 'Province': return 'Province';
                case 'CityMunicipality': return 'City / Municipality';
                case 'Barangay': return 'Barangay';
                case 'Site': return 'Site / Branch';
                case 'Department': return 'Department';
                case 'EmployeeGroup': return 'Employee Group';
                case 'CompanyWide': return 'Company-wide';
                default: return 'Scope';
            }
        }

        function getSourceTagLabel(value) {
            switch (value) {
                case 'Official': return 'Official / Government';
                case 'LocalOrdinance': return 'Local Ordinance';
                case 'CompanyPolicy': return 'Company Policy';
                case 'ManualEntry': return 'Manual Entry';
                case 'Imported': return 'Imported';
                default: return value || '—';
            }
        }

        function getTypeClass(type) {
            switch (type) {
                case 'RegularHoliday': return 'holiday-type-regular';
                case 'SpecialNonWorkingHoliday': return 'holiday-type-special-nonworking';
                case 'SpecialWorkingHoliday': return 'holiday-type-special-working';
                case 'DoubleHoliday': return 'holiday-type-double';
                case 'CompanyHoliday': return 'holiday-type-company';
                case 'LocalHoliday': return 'holiday-type-local';
