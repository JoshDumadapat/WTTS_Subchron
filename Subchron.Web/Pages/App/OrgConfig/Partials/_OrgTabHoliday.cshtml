                    </td>
                    <td class="px-3 py-3 text-xs text-gray-600 dark:text-gray-300">
                        <div class="truncate font-semibold text-gray-700 dark:text-gray-200" title="${escapeHtml(referenceText || '—')}">${escapeHtml(referenceText || '—')}</div>
                        <div class="mt-1 truncate text-[11px] text-gray-400 dark:text-gray-500" title="${escapeHtml(item.referenceUrl || item.overlapStrategy || '—')}">
                            ${escapeHtml(item.referenceUrl || item.overlapStrategy || '—')}
