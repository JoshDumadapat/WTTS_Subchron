@* ─── HOLIDAY CONFIGURATION TAB ─── *@
<div id="tab-holiday" class="tab-content hidden h-full flex-col">

    <div class="flex items-center justify-between border-b border-slate-300 px-8 py-5 dark:border-gray-700">
        <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Holiday Calendar</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
                Configure Philippine holiday rules, scopes, payroll mappings, and org-specific overrides.
            </p>
        </div>
    </div>

    <div class="flex-1 overflow-y-auto p-8">
        <div class="space-y-8">

            @* ─── SUMMARY / COMPLIANCE PANEL ─── *@
            <div class="grid grid-cols-1 gap-4 xl:grid-cols-4">
                <div class="rounded-2xl border border-slate-300 bg-slate-100 p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Selected Year</p>
                    <p id="holidaySummaryYear" class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">2026</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Calendar currently being managed</p>
                </div>

                <div class="rounded-2xl border border-slate-300 bg-slate-100 p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Active Holidays</p>
                    <p id="holidaySummaryCount" class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">0</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Visible under the current year and filters</p>
                </div>

                <div class="rounded-2xl border border-slate-300 bg-slate-100 p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">PH Classification Coverage</p>
                    <p id="holidaySummaryCoverage" class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">—</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Regular, Special Non-working, Special Working, Double, Local, Company</p>
                </div>

                <div class="rounded-2xl border border-slate-300 bg-slate-100 p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800">
                    <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">Sync Source</p>
                    <p id="holidaySummarySync" class="mt-2 text-base font-bold text-gray-900 dark:text-white">Org + Official Template</p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Manual entries can coexist with synced records</p>
                </div>
            </div>

            @* ─── CALENDAR PANEL ─── *@
            <div class="overflow-hidden rounded-2xl border border-slate-300 bg-slate-100 shadow-md dark:border-gray-700 dark:bg-gray-800">

                @* Top toolbar *@
                <div class="flex flex-col gap-4 border-b border-slate-300 bg-slate-200 px-6 py-5 dark:border-gray-700 dark:bg-gray-900/40">
                    <div class="flex items-center justify-between">
                        <h3 id="holidayCalendarTitle" class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">January 2026</h3>
                    </div>

                    <div class="grid grid-cols-1 gap-3 xl:grid-cols-[auto_auto_auto_auto_auto_1fr]">
                        <div class="inline-flex items-center overflow-hidden rounded-xl border border-slate-300 bg-slate-50 shadow-sm dark:border-gray-700 dark:bg-gray-900">
                            <button type="button" onclick="window.SubchronOrgTabHoliday.goToPreviousMonth()" class="inline-flex h-11 w-11 items-center justify-center text-gray-500 transition hover:bg-slate-100 hover:text-gray-700 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white" title="Previous Month">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
                                </svg>
                            </button>

                            <button type="button" onclick="window.SubchronOrgTabHoliday.goToToday()" class="border-x border-slate-300 px-5 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-slate-100 dark:border-gray-700 dark:text-gray-100 dark:hover:bg-gray-800">
                                Today
                            </button>

                            <button type="button" onclick="window.SubchronOrgTabHoliday.goToNextMonth()" class="inline-flex h-11 w-11 items-center justify-center text-gray-500 transition hover:bg-slate-100 hover:text-gray-700 dark:text-gray-300 dark:hover:bg-gray-800 dark:hover:text-white" title="Next Month">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                                </svg>
                            </button>
                        </div>

                        <div class="relative min-w-[120px]">
                            <label for="holidayYearSelect" class="sr-only">Year</label>
                            <select id="holidayYearSelect" class="block h-11 w-full appearance-none rounded-xl border border-slate-300 bg-slate-50 py-2.5 pr-10 pl-4 text-sm font-medium text-gray-700 shadow-sm ring-0 transition focus:border-emerald-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-white">
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                </svg>
                            </div>
                        </div>

                        <div class="relative min-w-[180px]">
                            <label for="holidayTypeFilter" class="sr-only">Filter by Classification</label>
                            <select id="holidayTypeFilter" class="block h-11 w-full appearance-none rounded-xl border border-slate-300 bg-slate-50 py-2.5 pr-10 pl-4 text-sm font-medium text-gray-700 shadow-sm ring-0 transition focus:border-emerald-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-white">
                                <option value="all">All Classifications</option>
                                <option value="RegularHoliday">Regular Holiday</option>
                                <option value="SpecialNonWorkingHoliday">Special Non-working Holiday</option>
                                <option value="SpecialWorkingHoliday">Special Working Holiday</option>
                                <option value="DoubleHoliday">Double Holiday / Overlap</option>
                                <option value="LocalHoliday">Local Holiday</option>
                                <option value="CompanyHoliday">Company Holiday</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                </svg>
                            </div>
                        </div>

                        <div class="relative min-w-[150px]">
                            <label for="holidayScopeFilter" class="sr-only">Filter by Scope</label>
                            <select id="holidayScopeFilter" class="block h-11 w-full appearance-none rounded-xl border border-slate-300 bg-slate-50 py-2.5 pr-10 pl-4 text-sm font-medium text-gray-700 shadow-sm ring-0 transition focus:border-emerald-500 focus:outline-none dark:border-gray-700 dark:bg-gray-900 dark:text-white">
                                <option value="all">All Scopes</option>
                                <option value="Nationwide">Nationwide</option>
                                <option value="Region">Region</option>
                                <option value="Province">Province</option>
                                <option value="CityMunicipality">City / Municipality</option>
                                <option value="Barangay">Barangay</option>
                                <option value="Site">Site / Branch</option>
                                <option value="Department">Department</option>
                                <option value="EmployeeGroup">Employee Group</option>
                                <option value="CompanyWide">Company-wide</option>
                            </select>
                            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                </svg>
                            </div>
                        </div>

                        <button type="button" onclick="window.SubchronOrgTabHoliday.syncHolidayYear()" class="btn-secondary gap-1.5 whitespace-nowrap">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992V4.356m-1.636 13.288A9 9 0 015.106 5.106L3 7.212m0 0V3.22m0 3.992h4.992" />
                            </svg>
                            Sync Holidays
                        </button>

                    </div>
                </div>

                @* Legend *@
                <div class="border-b border-slate-300 bg-slate-50 px-6 py-3 dark:border-gray-700 dark:bg-gray-900/20">
                    <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
                        <div class="inline-flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300">
                            <span class="h-2.5 w-2.5 rounded-full bg-red-500"></span>
                            Regular Holiday
                        </div>
                        <div class="inline-flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300">
                            <span class="h-2.5 w-2.5 rounded-full bg-amber-500"></span>
                            Special Non-working
                        </div>
                        <div class="inline-flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300">
                            <span class="h-2.5 w-2.5 rounded-full bg-lime-500"></span>
                            Special Working
                        </div>
                        <div class="inline-flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300">
                            <span class="h-2.5 w-2.5 rounded-full bg-fuchsia-500"></span>
                            Double Holiday
                        </div>
                        <div class="inline-flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300">
                            <span class="h-2.5 w-2.5 rounded-full bg-violet-500"></span>
                            Local Holiday
                        </div>
                        <div class="inline-flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300">
                            <span class="h-2.5 w-2.5 rounded-full bg-blue-500"></span>
                            Company Holiday
                        </div>
                    </div>
                </div>

                @* Calendar *@
                <div class="overflow-x-auto bg-slate-200 dark:bg-[#08152f]">
                    <div class="min-w-[860px] w-full">
                        <div class="grid grid-cols-7 border-b border-slate-300 dark:border-slate-700/60">
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Mon</div>
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Tue</div>
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Wed</div>
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Thu</div>
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Fri</div>
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Sat</div>
                            <div class="px-2 py-3 text-center text-sm font-semibold text-slate-700 dark:text-slate-100">Sun</div>
                        </div>

                        <div id="holidayCalendarGrid" class="grid grid-cols-7"></div>
                    </div>
                </div>
            </div>

            @* ─── HOLIDAY TABLE ─── *@
            <div class="overflow-hidden rounded-xl border border-slate-300 bg-slate-100 shadow-md dark:border-gray-700 dark:bg-gray-800">
                <div class="flex items-center justify-between border-b border-slate-300 px-6 py-4 dark:border-gray-700">
                    <div>
                        <h3 class="text-xs font-bold tracking-wider text-gray-500 uppercase dark:text-gray-400">Holiday Rules</h3>
                        <p class="mt-0.5 text-xs text-gray-400 dark:text-gray-500">
                            Org-scoped holiday records for the selected year, including PH classifications, scope, payroll rule linkages, and references.
                        </p>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-300 dark:divide-gray-700">
                        <thead class="bg-slate-200 dark:bg-gray-700/40">
                            <tr>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Date</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Holiday</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Classification</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Scope</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Attendance</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Payroll</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Reference</th>
                                <th class="px-5 py-3 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Status</th>
                                <th class="px-5 py-3 text-right text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Actions</th>
                            </tr>
                        </thead>
                        <tbody id="holidayRulesTableBody" class="divide-y divide-slate-300 bg-slate-50 dark:divide-gray-700 dark:bg-gray-800">
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

@* ─── HOLIDAY MODAL ─── *@
<div id="holidayModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 px-4 backdrop-blur-sm">
    <div class="w-full max-w-6xl overflow-hidden rounded-2xl border border-slate-300 bg-slate-50 shadow-xl dark:border-gray-700 dark:bg-gray-800">
        <div class="flex items-center justify-between border-b border-slate-300 px-6 py-4 dark:border-gray-700">
            <div>
                <h3 id="holidayModalTitle" class="text-base font-bold text-gray-900 dark:text-white">Configure Holiday Rule</h3>
                <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">
                    Define PH-compliant classification, scope, attendance behavior, payroll linkage, and audit references.
                </p>
            </div>
            <button type="button" onclick="window.SubchronOrgTabHoliday.closeHolidayModal()" class="rounded-lg p-1.5 text-gray-400 hover:bg-gray-100 hover:text-gray-600 dark:hover:bg-gray-700">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="max-h-[78vh] overflow-y-auto px-6 py-5">
            <input type="hidden" id="holidayRecordId" value="" />

            <div class="space-y-6">
                @* Core Details *@
                <div class="rounded-2xl border border-slate-300 dark:border-gray-700">
                <div class="border-b border-slate-300 px-4 py-3 dark:border-gray-700">
                    <div class="holiday-section-heading">
                        <span class="holiday-step-badge">1</span>
                        <div>
                            <h4 class="text-sm font-semibold text-gray-800 dark:text-white">Core Details</h4>
                            <p class="text-xs text-gray-500 dark:text-gray-400">PH-compliant basics: name, date, classification, activation status.</p>
                        </div>
                    </div>
                </div>

                    <div class="grid grid-cols-1 gap-4 p-4 md:grid-cols-2 xl:grid-cols-4">
                        <div class="xl:col-span-2">
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Holiday Name</label>
                            <input type="text" id="holidayName" placeholder="e.g. Independence Day"
                                   class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Holiday Date</label>
                            <input type="date" id="holidayDate"
                                   class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                        </div>

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Status</label>
                            <div class="relative">
                                <select id="holidayActive"
                                        class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option value="true">Active</option>
                                    <option value="false">Inactive</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                    <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Holiday Classification</label>
                            <div class="relative">
                                <select id="holidayType"
                                        class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option value="RegularHoliday">Regular Holiday</option>
                                    <option value="SpecialNonWorkingHoliday">Special Non-working Holiday</option>
                                    <option value="SpecialWorkingHoliday">Special Working Holiday</option>
                                    <option value="DoubleHoliday">Double Holiday / Overlap</option>
                                    <option value="LocalHoliday">Local Holiday</option>
                                    <option value="CompanyHoliday">Company Holiday</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                    <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Scope Type</label>
                            <div class="relative">
                                <select id="holidayScopeType"
                                        class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option value="Nationwide">Nationwide</option>
                                    <option value="Region">Region</option>
                                    <option value="Province">Province</option>
                                    <option value="CityMunicipality">City / Municipality</option>
                                    <option value="Barangay">Barangay</option>
                                    <option value="Site">Site / Branch</option>
                                    <option value="Department">Department</option>
                                    <option value="EmployeeGroup">Employee Group</option>
                                    <option value="CompanyWide">Company-wide</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                    <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div class="xl:col-span-2">
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Scope Values</label>
                            <input type="text" id="holidayScopeValues" placeholder="Comma-separated values. Example: NCR, Cebu City, Makati Branch, Production"
                                   class="block w-full rounded-lg border-0 py-2.5 px-3 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600" />
                            <p class="mt-1 text-[11px] text-gray-500 dark:text-gray-400">Used when the holiday is not nationwide. Values are stored as an array.</p>
                        </div>

                        <div>
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Source Tag</label>
                            <div class="relative">
                                <select id="holidaySourceTag"
                                        class="block w-full appearance-none rounded-lg border-0 bg-slate-100 py-2.5 pr-10 pl-4 text-sm text-gray-900 ring-1 ring-inset ring-gray-300 focus:bg-white focus:ring-2 focus:ring-emerald-500 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-gray-600">
                                    <option value="Official">Official / Government</option>
                                    <option value="LocalOrdinance">Local Ordinance</option>
                                    <option value="CompanyPolicy">Company Policy</option>
                                    <option value="ManualEntry">Manual Entry</option>
                                    <option value="Imported">Imported</option>
                                </select>
                                <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-3">
                                    <svg class="h-4 w-4 text-gray-400" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 10.94l3.71-3.71a.75.75 0 111.08 1.04l-4.24 4.25a.75.75 0 01-1.08 0L5.23 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
                                    </svg>
                                </div>
                            </div>
                        </div>

                        <div>
