                    </td>
                    <td class="px-3 py-3 text-xs">
                        <button type="button" onclick="window.SubchronOrgTabHoliday.openHolidayStatusModal(${item.id})" class="inline-flex items-center rounded-full px-2.5 py-0.5 font-semibold ring-1 transition ${item.isActive ? 'bg-emerald-50 text-emerald-700 ring-emerald-600/20 hover:bg-emerald-100 dark:bg-emerald-900/25 dark:text-emerald-300 dark:ring-emerald-500/30' : 'bg-rose-50 text-rose-700 ring-rose-600/20 hover:bg-rose-100 dark:bg-rose-900/25 dark:text-rose-300 dark:ring-rose-500/30'}" title="Click to ${item.isActive ? 'deactivate' : 'activate'}">
                            ${escapeHtml(boolToStatus(item.isActive))}
                        </button>
                    </td>
                    <td class="px-3 py-3 text-right">
                        <div class="inline-flex items-center gap-2">
                            <button type="button" onclick="window.SubchronOrgTabHoliday.openHolidayModal(${item.id})" class="rounded-lg px-2.5 py-1.5 text-xs font-semibold text-gray-500 hover:bg-gray-100 dark:text-gray-300 dark:hover:bg-gray-700">
                                Edit
                            </button>
                        </div>
                    </td>
                `;

                tbody.appendChild(tr);
            });

            updateHolidayTablePagination(total, from, to, totalPages);
            renderSummary();
        }

        function updateHolidayTablePagination(total, from, to, totalPages) {
            const info = $(selectors.tablePaginationInfo);
            const prev = $(selectors.tablePrevPage);
            const next = $(selectors.tableNextPage);

            if (info) {
                info.textContent = total === 0
                    ? 'Showing 0 of 0'
                    : `Showing ${from}-${to} of ${total} (Page ${state.tablePage}/${totalPages})`;
            }

            if (prev) prev.disabled = state.tablePage <= 1 || total === 0;
            if (next) next.disabled = state.tablePage >= totalPages || total === 0;
        }

        function fillYearOptions() {
            const select = $(selectors.yearSelect);
            if (!select) return;

            select.innerHTML = '';
            const current = new Date().getFullYear();

            for (let y = current - 10; y <= current + 10; y++) {
                const option = document.createElement('option');
                option.value = y;
                option.textContent = y;
                if (y === state.selectedYear) option.selected = true;
                select.appendChild(option);
            }

            if (select.dataset.bound !== 'true') {
                select.dataset.bound = 'true';
                select.addEventListener('change', async function () {
                    state.selectedYear = parseInt(this.value, 10);
                    state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
                    await loadHolidayData(state.selectedYear);
                    await syncHolidayYear(false).catch(() => { });
                });
            }
        }

        function bindFilters() {
            const typeFilter = $(selectors.typeFilter);
            const scopeFilter = $(selectors.scopeFilter);

            if (typeFilter && typeFilter.dataset.bound !== 'true') {
                typeFilter.dataset.bound = 'true';
                typeFilter.addEventListener('change', function () {
                    state.selectedHolidayType = this.value;
                    state.tablePage = 1;
                    renderHolidayCalendar();
                    renderHolidayTable();
                });
            }

            if (scopeFilter && scopeFilter.dataset.bound !== 'true') {
                scopeFilter.dataset.bound = 'true';
                scopeFilter.addEventListener('change', function () {
                    state.selectedScopeType = this.value;
                    state.tablePage = 1;
                    renderHolidayCalendar();
                    renderHolidayTable();
                });
            }
        }

        function bindHolidayTableControls() {
            const search = $(selectors.tableSearch);
            const status = $(selectors.tableStatusFilter);
            const rowsPerPage = $(selectors.tableRowsPerPage);
            const prev = $(selectors.tablePrevPage);
            const next = $(selectors.tableNextPage);

            if (search && search.dataset.bound !== 'true') {
                search.dataset.bound = 'true';
                search.addEventListener('input', function () {
                    state.tableSearchQuery = this.value || '';
                    state.tablePage = 1;
                    renderHolidayTable();
                });
            }

            if (status && status.dataset.bound !== 'true') {
                status.dataset.bound = 'true';
                status.addEventListener('change', function () {
                    state.tableStatusFilter = this.value || 'all';
                    state.tablePage = 1;
                    renderHolidayTable();
                });
            }

            if (rowsPerPage && rowsPerPage.dataset.bound !== 'true') {
                rowsPerPage.dataset.bound = 'true';
                rowsPerPage.addEventListener('change', function () {
                    state.tableRowsPerPage = Number(this.value || 10);
                    state.tablePage = 1;
                    renderHolidayTable();
                });
            }

            if (prev && prev.dataset.bound !== 'true') {
                prev.dataset.bound = 'true';
                prev.addEventListener('click', function () {
                    if (state.tablePage <= 1) return;
                    state.tablePage -= 1;
                    renderHolidayTable();
                });
            }

            if (next && next.dataset.bound !== 'true') {
                next.dataset.bound = 'true';
                next.addEventListener('click', function () {
                    state.tablePage += 1;
                    renderHolidayTable();
                });
            }
        }

        function bindModalDismiss() {
            const modal = $(selectors.modal);
            if (!modal || modal.dataset.bound === 'true') return;

            modal.dataset.bound = 'true';
            modal.addEventListener('click', function (e) {
                if (e.target === this) closeHolidayModal();
            });

            const statusModal = $(selectors.statusModal);
            if (statusModal && statusModal.dataset.bound !== 'true') {
                statusModal.dataset.bound = 'true';
                statusModal.addEventListener('click', function (e) {
                    if (e.target === this) closeHolidayStatusModal();
                });
            }
        }

        function bindHolidayTypeAutoMapping() {
            const holidayType = $('holidayType');
            if (!holidayType || holidayType.dataset.bound === 'true') return;

            holidayType.dataset.bound = 'true';
            holidayType.addEventListener('change', function () {
                applyDefaultConfigForType(this.value);
                autoFillComplianceFields();
            });
        }

        function bindHolidayValidationAndAutomation() {
            const fieldIds = [
                'holidayName', 'holidayDate', 'holidayType', 'holidayScopeType', 'holidayScopeValues',
                'holidayPayrollRuleId', 'holidayRestDayPayrollRuleId', 'holidayReferenceUrl',
                'holidayOverlapStrategy', 'holidayIncludePayroll', 'holidayUsePayRules', 'holidayAllowWork', 'holidayNonWorkingDay',
                'holidaySourceTag', 'holidayReferenceNo', 'holidayOfficialTag'
            ];

            fieldIds.forEach(id => {
                const field = $(id);
                if (!field || field.dataset.validateBound === 'true') return;
                field.dataset.validateBound = 'true';

                const eventName = field.tagName === 'INPUT' && field.type !== 'checkbox' ? 'input' : 'change';
                field.addEventListener(eventName, () => {
                    field.classList.remove('ring-red-400', 'focus:ring-red-500');
                    document.getElementById(`${id}Error`)?.remove();

                    if (id === 'holidaySourceTag' || id === 'holidayType' || id === 'holidayScopeType' || id === 'holidayDate') {
                        autoFillComplianceFields();
                    }
                });
            });

            const statusReason = $('holidayStatusReason');
            if (statusReason && statusReason.dataset.bound !== 'true') {
                statusReason.dataset.bound = 'true';
                statusReason.addEventListener('input', updateHolidayStatusReasonCounter);
                updateHolidayStatusReasonCounter();
            }
        }

        function applyDefaultConfigForType(type) {
            const config = getDefaultClassificationConfig(type);

            if ($('holidayNonWorkingDay')) $('holidayNonWorkingDay').checked = !!config.nonWorkingDay;
            if ($('holidayAllowWork')) $('holidayAllowWork').checked = !!config.allowWork;
            if ($('holidayAttendanceClassification')) $('holidayAttendanceClassification').value = config.attendanceClassification || 'Holiday';
            if ($('holidayRestDayClassification')) $('holidayRestDayClassification').value = config.restDayClassification || '';
            if ($('holidayPayrollClassification')) $('holidayPayrollClassification').value = config.payrollClassification || 'RegularHoliday';
            if ($('holidayRestDayPayrollClassification')) $('holidayRestDayPayrollClassification').value = config.restDayPayrollClassification || '';
            if ($('holidayPaidWhenUnworked')) $('holidayPaidWhenUnworked').checked = !!config.paidWhenUnworked;

            if (type === 'LocalHoliday' && $('holidayScopeType') && $('holidayScopeType').value === 'Nationwide') {
                $('holidayScopeType').value = 'CityMunicipality';
            }

            if (type === 'CompanyHoliday' && $('holidayScopeType') && $('holidayScopeType').value === 'Nationwide') {
                $('holidayScopeType').value = 'CompanyWide';
            }

            suggestPayrollRuleSelection();
        }

        function suggestPayrollRuleSelection() {
            const usePayRules = $('holidayUsePayRules')?.checked;
            const payrollClassification = $('holidayPayrollClassification')?.value || '';
            const restDayPayrollClassification = $('holidayRestDayPayrollClassification')?.value || '';

            if (usePayRules && $('holidayPayrollRuleId') && !$('holidayPayrollRuleId').value) {
                const match = state.payrollRules.find(x => String(x.classification || '') === String(payrollClassification));
                if (match) $('holidayPayrollRuleId').value = String(match.id);
            }

            if (usePayRules && $('holidayRestDayPayrollRuleId') && restDayPayrollClassification && !$('holidayRestDayPayrollRuleId').value) {
                const restMatch = state.payrollRules.find(x => String(x.classification || '') === String(restDayPayrollClassification));
                if (restMatch) $('holidayRestDayPayrollRuleId').value = String(restMatch.id);
            }
        }

        async function loadPayrollRules() {
            try {
                const data = await apiRequest(api.payrollRules, { method: 'GET' });
                const list = Array.isArray(data) ? data : (data?.items || data?.data || []);
                state.payrollRules = list.map(x => ({
                    id: x.id ?? x.payrollRuleId ?? '',
                    name: x.name ?? x.ruleName ?? x.displayName ?? `Rule ${x.id ?? ''}`.trim(),
                    classification: x.classification ?? x.holidayClassification ?? ''
                }));
            } catch {
                state.payrollRules = [
                    { id: 'regular', name: 'Regular Holiday Rule', classification: 'RegularHoliday' },
                    { id: 'special-nonworking', name: 'Special Non-working Rule', classification: 'SpecialNonWorkingHoliday' },
                    { id: 'special-working', name: 'Special Working Rule', classification: 'SpecialWorkingHoliday' },
                    { id: 'double-holiday', name: 'Double Holiday Rule', classification: 'DoubleHoliday' },
                    { id: 'restday-regular', name: 'Rest Day + Regular Holiday Rule', classification: 'RestDayRegularHoliday' },
                    { id: 'restday-special-nonworking', name: 'Rest Day + Special Non-working Rule', classification: 'RestDaySpecialNonWorkingHoliday' },
                    { id: 'restday-special-working', name: 'Rest Day + Special Working Rule', classification: 'RestDaySpecialWorkingHoliday' },
                    { id: 'restday-double', name: 'Rest Day + Double Holiday Rule', classification: 'RestDayDoubleHoliday' },
                    { id: 'local-holiday', name: 'Local Holiday Rule', classification: 'LocalHoliday' },
                    { id: 'company-holiday', name: 'Company Holiday Rule', classification: 'CompanyHoliday' }
                ];
            }

            populatePayrollRuleOptions();
        }

        function populatePayrollRuleOptions() {
            const selects = ['holidayPayrollRuleId', 'holidayRestDayPayrollRuleId'];

            selects.forEach(id => {
                const select = $(id);
                if (!select) return;

                const currentValue = select.value || '';
                const firstLabel = id === 'holidayPayrollRuleId' ? 'Select payroll rule' : 'Optional rest day rule override';
                select.innerHTML = `<option value="">${firstLabel}</option>`;

                state.payrollRules.forEach(rule => {
                    const option = document.createElement('option');
                    option.value = String(rule.id);
                    option.textContent = rule.classification
                        ? `${rule.name} (${rule.classification})`
                        : rule.name;
                    if (String(rule.id) === String(currentValue)) option.selected = true;
                    select.appendChild(option);
                });
            });
        }

        async function loadHolidayData(year) {
            try {
                state.isLoading = true;
                const data = await apiRequest(`${api.holidays}?year=${encodeURIComponent(year)}`, { method: 'GET' });
                const list = Array.isArray(data) ? data : (data?.items || data?.data || []);
                state.configuredHolidays = list.map(normalizeHoliday);
                mergeCalendarHolidays();
            } catch (error) {
                state.configuredHolidays = [];
                mergeCalendarHolidays();
                window.showToast?.(`Unable to load holidays. ${error.message}`, false);
            } finally {
                state.isLoading = false;
                renderHolidayCalendar();
                renderHolidayTable();
                updateYearSelect();
            }
        }

        function updateYearSelect() {
            fillYearOptions();
            const select = $(selectors.yearSelect);
            if (select) select.value = String(state.selectedYear);
        }

        function resetHolidayModal(prefillDate = null) {
            state.editingHolidayId = null;
            clearHolidayValidationErrors();
            setHolidaySaving(false);

            $('holidayRecordId').value = '';
            $('holidayModalTitle').textContent = 'Configure Holiday Rule';
            $('holidayName').value = '';
            $('holidayDate').value = prefillDate || '';
            $('holidayType').value = 'RegularHoliday';
            $('holidayActive').value = 'true';
            $('holidayScopeType').value = 'Nationwide';
            $('holidayScopeValues').value = '';
            $('holidaySourceTag').value = 'ManualEntry';
            $('holidayPrecedence').value = '100';

            $('holidayReferenceNo').value = '';
            $('holidayReferenceUrl').value = '';
            $('holidayOfficialTag').value = '';
            $('holidayOverlapStrategy').value = 'HighestPrecedence';

            $('holidayIncludeAttendance').checked = true;
            $('holidayNonWorkingDay').checked = true;
            $('holidayAllowWork').checked = true;
            $('holidayApplyRestDayRules').checked = true;
            $('holidayAttendanceClassification').value = 'RegularHoliday';
            $('holidayRestDayClassification').value = 'RestDayRegularHoliday';
            $('holidayEmployeeGroupScope').value = '';

            $('holidayIncludePayroll').checked = true;
            $('holidayUsePayRules').checked = true;
            $('holidayPaidWhenUnworked').checked = true;
            $('holidayPayrollClassification').value = 'RegularHoliday';
            $('holidayRestDayPayrollClassification').value = 'RestDayRegularHoliday';
            $('holidayPayrollRuleId').value = '';
            $('holidayRestDayPayrollRuleId').value = '';
            $('holidayPayrollNotes').value = '';
            $('holidayNotes').value = '';

            suggestPayrollRuleSelection();
            autoFillComplianceFields();
            $('holidayDeleteButton').classList.add('hidden');
        }

        function fillHolidayModal(item) {
            state.editingHolidayId = item.id;
            clearHolidayValidationErrors();
            setHolidaySaving(false);

            $('holidayRecordId').value = item.id ?? '';
            $('holidayModalTitle').textContent = 'Edit Holiday Rule';
            $('holidayName').value = item.name || '';
            $('holidayDate').value = item.date || '';
            $('holidayType').value = item.type || 'RegularHoliday';
            $('holidayActive').value = String(!!item.isActive);
            $('holidayScopeType').value = item.scopeType || 'Nationwide';
            $('holidayScopeValues').value = (item.scopeValues || []).join(', ');
            $('holidaySourceTag').value = item.sourceTag || 'ManualEntry';
            $('holidayPrecedence').value = String(item.precedence ?? 100);

            $('holidayReferenceNo').value = item.referenceNo || '';
            $('holidayReferenceUrl').value = item.referenceUrl || '';
            $('holidayOfficialTag').value = item.officialTag || '';
            $('holidayOverlapStrategy').value = item.overlapStrategy || 'HighestPrecedence';

            $('holidayIncludeAttendance').checked = !!item.includeAttendance;
            $('holidayNonWorkingDay').checked = !!item.nonWorkingDay;
            $('holidayAllowWork').checked = !!item.allowWork;
            $('holidayApplyRestDayRules').checked = !!item.applyRestDayRules;
            $('holidayAttendanceClassification').value = item.attendanceClassification || 'Holiday';
            $('holidayRestDayClassification').value = item.restDayClassification || '';
            $('holidayEmployeeGroupScope').value = (item.employeeGroupScope || []).join(', ');

            $('holidayIncludePayroll').checked = !!item.includePayroll;
            $('holidayUsePayRules').checked = !!item.usePayRules;
            $('holidayPaidWhenUnworked').checked = !!item.paidWhenUnworked;
            $('holidayPayrollClassification').value = item.payrollClassification || 'RegularHoliday';
            $('holidayRestDayPayrollClassification').value = item.restDayPayrollClassification || '';
            $('holidayPayrollRuleId').value = item.payrollRuleId || '';
            $('holidayRestDayPayrollRuleId').value = item.restDayPayrollRuleId || '';
            $('holidayPayrollNotes').value = item.payrollNotes || '';
            $('holidayNotes').value = item.notes || '';

            autoFillComplianceFields();
            $('holidayDeleteButton').classList.remove('hidden');
        }

        function prefillHolidayModalFromTemplate(item, prefillDate = null) {
            resetHolidayModal(prefillDate || item?.date || null);
            if (!item) return;

            $('holidayName').value = item.name || '';
            $('holidayDate').value = prefillDate || item.date || '';
            $('holidayType').value = item.type || 'RegularHoliday';
            $('holidayScopeType').value = item.scopeType || 'Nationwide';
            $('holidayScopeValues').value = (item.scopeValues || []).join(', ');
            $('holidaySourceTag').value = item.sourceTag || 'Imported';
            $('holidayOfficialTag').value = item.officialTag || 'HolidayApi';
            $('holidayReferenceUrl').value = item.referenceUrl || 'https://holidayapi.com/';

            applyDefaultConfigForType($('holidayType').value);
            suggestPayrollRuleSelection();
            autoFillComplianceFields();
        }

        function openHolidayModal(id = null, prefillDate = null, prefillTemplate = null) {
            const modal = $(selectors.modal);
            if (!modal) return;

            populatePayrollRuleOptions();

            if (id == null) {
                if (prefillTemplate) {
                    prefillHolidayModalFromTemplate(prefillTemplate, prefillDate);
                } else {
                    resetHolidayModal(prefillDate);
                }
                if (prefillDate) {
                    const d = new Date(prefillDate + 'T00:00:00');
                    if (d.getFullYear() !== state.selectedYear) {
                        state.selectedYear = d.getFullYear();
                    }
                }
            } else {
                const item = state.holidays.find(x => String(x.id) === String(id));
                if (!item) {
                    window.showToast?.('Holiday record not found.', false);
                    return;
                }

                fillHolidayModal(item);
            }

            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeHolidayModal() {
            const modal = $(selectors.modal);
            if (!modal) return;
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function validateHolidayPayload(payload) {
            if (!payload.name) return 'Holiday name is required.';
            if (!payload.date) return 'Holiday date is required.';
            if (!payload.type) return 'Holiday classification is required.';
            if (!payload.scopeType) return 'Scope type is required.';
            if (payload.scopeType !== 'Nationwide' && payload.scopeType !== 'CompanyWide' && (!payload.scopeValues || !payload.scopeValues.length)) {
                return 'Scope values are required for the selected scope type.';
            }
            if (payload.includePayroll && payload.usePayRules && !payload.payrollRuleId) {
                return 'Please select a payroll rule when "Use Holiday Pay Rules" is enabled.';
            }

            const sameDateOverlaps = state.holidays.filter(x =>
                String(x.id) !== String(payload.id || '') &&
                x.date === payload.date &&
                x.scopeType === payload.scopeType &&
                JSON.stringify([...(x.scopeValues || [])].sort()) === JSON.stringify([...(payload.scopeValues || [])].sort())
            );

            if (sameDateOverlaps.length > 0 && payload.overlapStrategy === 'ManualResolution') {
                return 'An overlapping holiday already exists for this date and scope. Choose a different overlap strategy or adjust precedence.';
            }

            return null;
        }

        function collectHolidayPayload() {
            return {
                id: $('holidayRecordId').value ? $('holidayRecordId').value : null,
                date: $('holidayDate').value,
                name: ($('holidayName').value || '').trim(),
                type: $('holidayType').value,
                isActive: $('holidayActive').value === 'true',
                scopeType: $('holidayScopeType').value,
                scopeValues: parseCsv($('holidayScopeValues').value),
                sourceTag: $('holidaySourceTag').value,
                includeAttendance: $('holidayIncludeAttendance').checked,
                nonWorkingDay: $('holidayNonWorkingDay').checked,
                allowWork: $('holidayAllowWork').checked,
                applyRestDayRules: $('holidayApplyRestDayRules').checked,
                attendanceClassification: $('holidayAttendanceClassification').value,
                restDayAttendanceClassification: $('holidayRestDayClassification').value,
                employeeGroupScope: parseCsv($('holidayEmployeeGroupScope').value),
                includePayroll: $('holidayIncludePayroll').checked,
                usePayRules: $('holidayUsePayRules').checked,
                paidWhenUnworked: $('holidayPaidWhenUnworked').checked,
                payrollClassification: $('holidayPayrollClassification').value,
                restDayPayrollClassification: $('holidayRestDayPayrollClassification').value,
                payrollRuleId: $('holidayPayrollRuleId').value,
                restDayPayrollRuleId: $('holidayRestDayPayrollRuleId').value,
                payrollNotes: ($('holidayPayrollNotes').value || '').trim(),
                referenceNo: ($('holidayReferenceNo').value || '').trim(),
                referenceUrl: ($('holidayReferenceUrl').value || '').trim(),
                officialTag: ($('holidayOfficialTag').value || '').trim(),
                overlapStrategy: $('holidayOverlapStrategy').value,
                precedence: Number($('holidayPrecedence').value || 100),
                notes: $('holidayNotes').value || ''
            };
        }

        async function saveHolidayRule() {
            clearHolidayValidationErrors();
            const payload = collectHolidayPayload();

            const validation = validateHolidayPayloadDetailed(payload);
            if (!validation.isValid) {
                validation.errors.forEach(err => setHolidayFieldError(err.fieldId, err.message));
                if (validation.firstErrorFieldId) {
                    scrollToHolidayField(validation.firstErrorFieldId);
                }
                window.showToast?.('Please fix the highlighted fields before saving.', false);
                return;
            }

            try {
                setHolidaySaving(true);
                const isEdit = !!payload.id;
                const url = isEdit ? `${api.holidays}/${encodeURIComponent(payload.id)}` : api.holidays;
                const method = isEdit ? 'PUT' : 'POST';

                const result = await apiRequest(url, {
                    method,
                    body: JSON.stringify(payload)
                });

                const saved = normalizeHoliday(result?.data || result || payload);
                const existingIndex = state.configuredHolidays.findIndex(x => String(x.id) === String(saved.id));

                if (existingIndex >= 0) {
                    state.configuredHolidays.splice(existingIndex, 1, saved);
                } else {
                    state.configuredHolidays.push(saved);
                }

                mergeCalendarHolidays();

                closeHolidayModal();
                renderHolidayCalendar();
                renderHolidayTable();
                window.showToast?.(`Holiday rule ${isEdit ? 'updated' : 'created'} successfully.`, true);
            } catch (error) {
                window.showToast?.(`Unable to save holiday rule. ${error.message}`, false);
            } finally {
                setHolidaySaving(false);
            }
        }

        async function deleteHolidayRule() {
            const id = $('holidayRecordId').value;
            if (!id) return;

            const confirmed = window.confirm('Delete this holiday rule?');
            if (!confirmed) return;

            try {
                await apiRequest(`${api.holidays}/${encodeURIComponent(id)}`, { method: 'DELETE' });
                state.configuredHolidays = state.configuredHolidays.filter(x => String(x.id) !== String(id));
                mergeCalendarHolidays();
                closeHolidayModal();
                renderHolidayCalendar();
                renderHolidayTable();
                window.showToast?.('Holiday rule deleted successfully.', true);
            } catch (error) {
                window.showToast?.(`Unable to delete holiday rule. ${error.message}`, false);
            }
        }

        async function syncHolidayYear(showToast = true) {
            try {
                const result = await apiRequest(`${api.holidaySync}?year=${encodeURIComponent(state.selectedYear)}`, {
                    method: 'POST'
                });

                const list = Array.isArray(result) ? result : (result?.items || result?.data || null);
                if (Array.isArray(list)) {
                    state.defaultHolidays = list.map(normalizeHoliday);
                    mergeCalendarHolidays();
                } else {
                    await loadHolidayData(state.selectedYear);
                }

                renderHolidayCalendar();
                renderHolidayTable();
                if (showToast) window.showToast?.(`Holiday template synced for ${state.selectedYear}.`, true);
            } catch (error) {
                if (showToast) window.showToast?.(`Unable to sync holidays. ${error.message}`, false);
                throw error;
            }
        }

        function goToPreviousMonth() {
            if (state.selectedMonth === 0) {
                state.selectedMonth = 11;
                state.selectedYear -= 1;
            } else {
                state.selectedMonth -= 1;
            }

            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
            updateYearSelect();
            renderHolidayCalendar();
            renderHolidayTable();
        }

        function goToNextMonth() {
            if (state.selectedMonth === 11) {
                state.selectedMonth = 0;
                state.selectedYear += 1;
            } else {
                state.selectedMonth += 1;
            }

            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
            updateYearSelect();
            renderHolidayCalendar();
            renderHolidayTable();
        }

        function goToToday() {
            const now = new Date();
            state.selectedYear = now.getFullYear();
            state.selectedMonth = now.getMonth();
            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);
            updateYearSelect();
            loadHolidayData(state.selectedYear);
            syncHolidayYear(false).catch(() => { });
        }

        async function init() {
            if (!accessToken) {
                console.warn('OrgTabHoliday: access token missing.');
                window.showToast?.('Cannot load holidays because the API session token is missing. Refresh the page and sign in again.', false);
                return;
            }
            if (!apiBase) {
                console.warn('OrgTabHoliday: ApiBaseUrl not configured. Falling back to same origin.');
            }
            const now = new Date();
            state.selectedYear = now.getFullYear();
            state.selectedMonth = now.getMonth();
            state.currentDate = new Date(state.selectedYear, state.selectedMonth, 1);

            fillYearOptions();
            bindFilters();
            bindHolidayTableControls();
            bindModalDismiss();
            bindHolidayTypeAutoMapping();
            bindHolidayValidationAndAutomation();
            state.tableSearchQuery = $(selectors.tableSearch)?.value || '';
            state.tableStatusFilter = $(selectors.tableStatusFilter)?.value || 'all';
            state.tableRowsPerPage = Number($(selectors.tableRowsPerPage)?.value || 10);
            updateYearSelect();
            await loadPayrollRules();
            await loadHolidayData(state.selectedYear);
            await syncHolidayYear(false).catch(() => { });
        }

        return {
            init,
            openHolidayModal,
            closeHolidayModal,
            openHolidayStatusModal,
            closeHolidayStatusModal,
            confirmHolidayStatusChange,
            saveHolidayRule,
            deleteHolidayRule,
            goToPreviousMonth,
            goToNextMonth,
            goToToday,
            syncHolidayYear
        };
    })();

    window.SubchronOrgTabHoliday.init();
</script>
