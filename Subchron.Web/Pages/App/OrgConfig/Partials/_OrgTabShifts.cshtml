            fixed: 'Fixed: strict start and end times each shift.',
            flexible: 'Flexible: employees pick a start within an allowed window.',
            open: 'Open: no clock window — just total weekly hours.'
        };

        const TYPE_META = {
            Fixed: {
                label: 'Fixed', accent: 'emerald',
                border: 'border-emerald-200 dark:border-emerald-800/60', bar: 'bg-emerald-500',
                detailBg: 'bg-emerald-50/70 dark:bg-emerald-900/10',
                iconWrapper: 'bg-emerald-100 text-emerald-600 dark:bg-emerald-900/40 dark:text-emerald-400',
                badge: 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20 dark:bg-emerald-900/30 dark:text-emerald-400 dark:ring-emerald-500/30',
                icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />'
            },
            Flexible: {
                label: 'Flexible', accent: 'blue',
                border: 'border-blue-200 dark:border-blue-800/60', bar: 'bg-blue-500',
                detailBg: 'bg-blue-50/70 dark:bg-blue-900/10',
                iconWrapper: 'bg-blue-100 text-blue-600 dark:bg-blue-900/40 dark:text-blue-400',
                badge: 'bg-blue-50 text-blue-700 ring-1 ring-blue-600/20 dark:bg-blue-900/30 dark:text-blue-400 dark:ring-blue-500/30',
                icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />'
            },
            Open: {
                label: 'Open', accent: 'violet',
                border: 'border-violet-200 dark:border-violet-800/60', bar: 'bg-violet-500',
                detailBg: 'bg-violet-50/70 dark:bg-violet-900/10',
                iconWrapper: 'bg-violet-100 text-violet-600 dark:bg-violet-900/40 dark:text-violet-400',
                badge: 'bg-violet-50 text-violet-700 ring-1 ring-violet-600/20 dark:bg-violet-900/30 dark:text-violet-400 dark:ring-violet-500/30',
                icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />'
            }
        };

        const appRoot = document.getElementById('appRoot');
        const apiBase = (appRoot?.getAttribute('data-api-base') || appRoot?.dataset?.apiBase || '').trim().replace(/\/$/, '');
        const token = appRoot?.getAttribute('data-api-token') || appRoot?.dataset?.apiToken || '';

        const refs = {
            listEl: document.getElementById('shiftsList'),
            emptyStateEl: document.getElementById('shiftsEmptyState'),
            loadingStateEl: document.getElementById('shiftsLoadingState'),
            addModal: document.getElementById('addShiftModal'),
            addSaveBtn: document.getElementById('addShiftSaveBtn'),
            addSaveIdle: document.getElementById('addShiftSaveIdle'),
            addSaveLoading: document.getElementById('addShiftSaveLoading'),
            editModal: document.getElementById('editShiftModal'),
            deleteModal: document.getElementById('deleteShiftModal'),
            deleteNameEl: document.getElementById('deleteShiftName'),
            deleteTitleEl: document.getElementById('deleteShiftModalTitle'),
            deleteMessageEl: document.getElementById('deleteShiftModalMessage'),
            deleteHintEl: document.getElementById('deleteShiftModalHint'),
            deleteConfirmBtnEl: document.getElementById('deleteShiftConfirmBtn'),
            disableReasonGroupEl: document.getElementById('disableReasonGroup'),
            disableReasonInputEl: document.getElementById('disableShiftReason'),
            disableReasonCountEl: document.getElementById('disableShiftReasonCount')
        };

        if (!refs.listEl) return;

        const state = {
            templates: [],
            editingCode: null,
            deleteCode: null,
            deleteTargetActive: true,
            isSaving: false,
            isLoading: false,
            multipleBreakCounter: 0,
            lastLoadTime: 0,
            loadCacheDuration: 30000 // Cache for 30 seconds
        };

        const authHeaders = () => {
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['Authorization'] = `Bearer ${token}`;
            return headers;
        };

        const showToast = (message, success = true) => {
            if (typeof window.showToast === 'function') window.showToast(message, success);
        };

        const canCallApi = () => {
            if (!apiBase || !token) {
                console.warn('Shift tab: missing API base or token.');
                return false;
            }
            return true;
        };

        const diffMinutes = (start, end) => {
            if (!start || !end) return 0;
            const startDate = new Date(`1970-01-01T${start}:00`);
            const endDate = new Date(`1970-01-01T${end}:00`);
            if (Number.isNaN(startDate.getTime()) || Number.isNaN(endDate.getTime())) return 0;
            let diff = endDate - startDate;
            if (diff < 0) diff += 24 * 60 * 60 * 1000;
            return Math.round(diff / 60000);
        };

        const formatMinutes = (minutes) => {
            if (!Number.isFinite(minutes) || minutes <= 0) return '0m';
            const hrs = Math.floor(minutes / 60);
            const mins = minutes % 60;
            if (hrs && mins) return `${hrs}h ${mins}m`;
            if (hrs) return `${hrs}h`;
            return `${mins}m`;
        };

        const formatTime = (value) => {
            if (!value) return '—';
            const [h, m] = value.split(':');
            if (h === undefined || m === undefined) return value;
            const hour = Number(h);
            const minute = Number(m);
            if (Number.isNaN(hour) || Number.isNaN(minute)) return value;
            const suffix = hour >= 12 ? 'PM' : 'AM';
            const normalizedHour = hour % 12 || 12;
            return `${normalizedHour}:${String(minute).padStart(2, '0')} ${suffix}`;
        };

        const escapeHtml = (value) => {
            return (value ?? '').toString()
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');
        };

        const getTemplateBreaks = (template) => {
            const breaks = template?.Breaks || template?.breaks || [];
            return Array.isArray(breaks) ? breaks : [];
        };

        const normalizeBreak = (item, index) => ({
            Name: (item?.Name || item?.name || `Break ${index + 1}`).toString(),
            StartTime: (item?.StartTime || item?.startTime || item?.BreakStart || item?.breakStart || '').toString(),
            EndTime: (item?.EndTime || item?.endTime || item?.BreakEnd || item?.breakEnd || '').toString(),
            IsPaid: !!(item?.IsPaid ?? item?.isPaid)
        });

        const normalizeShiftType = (value) => {
            const raw = (value || 'Fixed').toString().trim().toLowerCase();
            if (raw === 'flex' || raw === 'flexible') return 'Flexible';
            if (raw === 'open') return 'Open';
            return 'Fixed';
        };

        const unwrapTemplate = (raw) => {
            if (!raw || typeof raw !== 'object') return raw;
            if (raw.Template && typeof raw.Template === 'object') return raw.Template;
            if (raw.template && typeof raw.template === 'object') return raw.template;
            if (raw.Value && typeof raw.Value === 'object') return raw.Value;
            if (raw.value && typeof raw.value === 'object') return raw.value;
            return raw;
        };

        const normalizeTemplate = (raw) => {
            const source = unwrapTemplate(raw) || {};
            const fixed = source?.Fixed || source?.fixed || source?.FixedSettings || source?.fixedSettings || null;
            const flexible = source?.Flexible || source?.flexible || source?.FlexibleSettings || source?.flexibleSettings || null;
            const open = source?.Open || source?.open || source?.OpenSettings || source?.openSettings || null;
            const workDaysRaw = source?.WorkDays || source?.workDays || [];
            const breaksRaw = source?.Breaks || source?.breaks || [];
            const dayOverridesRaw = source?.DayOverrides || source?.dayOverrides || [];
            const code = (source?.Code || source?.code || source?.ShiftCode || source?.shiftCode || '').toString();
            const name = (source?.Name || source?.name || source?.ShiftName || source?.shiftName || '').toString();

            return {
                Code: code,
                Name: name || code,
                Type: normalizeShiftType(source?.Type || source?.type || source?.ShiftType || source?.shiftType),
                WorkDays: Array.isArray(workDaysRaw)
                    ? workDaysRaw.map(d => {
                        if (typeof d === 'string') return d;
                        return d?.Day || d?.day || d?.DayCode || d?.dayCode || '';
                    }).map(d => d?.toString?.() || '').filter(Boolean)
                    : [],
                IsActive: typeof source?.IsActive === 'boolean' ? source.IsActive : (typeof source?.isActive === 'boolean' ? source.isActive : true),
                DisabledReason: (source?.DisabledReason || source?.disabledReason || source?.DisableReason || source?.disableReason || '').toString(),
                Fixed: fixed ? {
                    StartTime: fixed?.StartTime || fixed?.startTime || null,
                    EndTime: fixed?.EndTime || fixed?.endTime || null,
                    RequiredHours: fixed?.RequiredHours ?? fixed?.requiredHours ?? null,
                    BreakMinutes: fixed?.BreakMinutes ?? fixed?.breakMinutes ?? null,
                    GraceMinutes: fixed?.GraceMinutes ?? fixed?.graceMinutes ?? null
                } : null,
                Flexible: flexible ? {
                    EarliestStart: flexible?.EarliestStart || flexible?.earliestStart || null,
                    LatestEnd: flexible?.LatestEnd || flexible?.latestEnd || null,
                    RequiredDailyHours: flexible?.RequiredDailyHours ?? flexible?.requiredDailyHours ?? null,
                    MaxDailyHours: flexible?.MaxDailyHours ?? flexible?.maxDailyHours ?? null
                } : null,
                Open: open ? {
                    RequiredWeeklyHours: open?.RequiredWeeklyHours ?? open?.requiredWeeklyHours ?? null
                } : null,
                Breaks: Array.isArray(breaksRaw) ? breaksRaw.map(normalizeBreak) : [],
                DayOverrides: Array.isArray(dayOverridesRaw) ? dayOverridesRaw : []
            };
        };

        const getTemplateIsActive = (template) => {
            if (typeof template?.IsActive === 'boolean') return template.IsActive;
            if (typeof template?.isActive === 'boolean') return template.isActive;
            return true;
        };

        const setAddSaveLoading = (isLoading) => {
            if (refs.addSaveBtn) refs.addSaveBtn.disabled = isLoading;
            if (refs.addSaveIdle) refs.addSaveIdle.classList.toggle('hidden', isLoading);
            if (refs.addSaveLoading) refs.addSaveLoading.classList.toggle('hidden', !isLoading);
        };

        const setShiftLoadingState = (isLoading) => {
            refs.loadingStateEl?.classList.toggle('hidden', !isLoading);
            if (isLoading) {
                refs.listEl?.classList.add('hidden');
                refs.emptyStateEl?.classList.add('hidden');
            } else {
                refs.listEl?.classList.remove('hidden');
            }
        };

        const updateDisableReasonCounter = () => {
            if (!refs.disableReasonInputEl || !refs.disableReasonCountEl) return;
            refs.disableReasonCountEl.textContent = `${refs.disableReasonInputEl.value.length}/60`;
        };

        const toggleDayButton = (btn, theme) => {
            const active = btn.getAttribute('data-active') === 'true';
            btn.setAttribute('data-active', active ? 'false' : 'true');
            applyDayButtonClass(btn, !active, theme);
        };

        const applyDayButtonClass = (btn, active, theme) => {
            const baseClass = btn.classList.contains('edit-day-btn') ? 'edit-day-btn' : 'modal-day-btn';
            if (active) {
                btn.className = `${baseClass} flex h-10 w-10 items-center justify-center rounded-lg bg-${theme}-500 text-xs font-bold text-white shadow-sm transition-all`;
            } else {
                btn.className = `${baseClass} flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-xs font-bold text-gray-400 transition-all hover:border-${theme}-300 hover:text-${theme}-500 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-500`;
            }
        };

        const toggleDayButtons = (container, selector, activeDays) => {
            if (!container) return;
            container.querySelectorAll(selector).forEach(btn => {
                const day = btn.getAttribute('data-day');
                const shouldBeActive = activeDays.has(day);
                btn.setAttribute('data-active', shouldBeActive ? 'true' : 'false');
                applyDayButtonClass(btn, shouldBeActive, selector.includes('modal') ? 'emerald' : 'amber');
            });
        };

        const collectActiveDays = (container, selector) => {
            const days = [];
            container?.querySelectorAll(selector).forEach(btn => {
                if (btn.getAttribute('data-active') === 'true') {
                    const day = btn.getAttribute('data-day');
                    if (day) days.push(day);
                }
            });
            return days;
        };

        const setShiftType = (mode, type) => {
            const normalized = (type || 'fixed').toLowerCase();
            const prefix = mode === 'edit' ? 'edit-fields-' : 'fields-';
            ['fixed', 'flexible', 'open'].forEach(t => {
                const el = document.getElementById(prefix + t);
                if (el) el.classList.toggle('hidden', t !== normalized);
            });
            const hint = document.getElementById(mode === 'edit' ? 'editShiftTypeHint' : 'shiftTypeHint');
            if (hint) hint.textContent = SHIFT_HINTS[normalized] || '';
        };

        const onBreakRuleChange = (type, mode) => {
            const prefix = mode === 'edit' ? 'edit' : 'add';
            const single = document.getElementById(`${prefix}-break-rule-single`);
            const multiple = document.getElementById(`${prefix}-break-rule-multiple`);
            if (single) single.classList.toggle('hidden', type !== 'single');
            if (multiple) multiple.classList.toggle('hidden', type !== 'multiple');
        };

        const setBreakRuleType = (mode, type) => {
            const groupName = mode === 'edit' ? 'edit_break_rule_type' : 'break_rule_type';
            document.querySelectorAll(`input[name="${groupName}"]`).forEach(radio => {
                radio.checked = radio.value === type;
            });
            onBreakRuleChange(type, mode);
        };

        const clearMultipleBreakRows = (mode) => {
            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (container) container.innerHTML = '';
        };

        const addMultipleBreakRow = (mode, breakData = null) => {
            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (!container) return;
            state.multipleBreakCounter += 1;
            const accent = mode === 'add' ? 'emerald' : 'amber';
            const id = state.multipleBreakCounter;
            const nameValue = (breakData?.name || breakData?.Name || '').trim();
            const startValue = (breakData?.startTime || breakData?.StartTime || '').trim();
            const endValue = (breakData?.endTime || breakData?.EndTime || '').trim();
            const isPaid = !!(breakData?.isPaid ?? breakData?.IsPaid);
            const row = document.createElement('tr');
            row.id = `multiple-break-row-${mode}-${id}`;
            row.innerHTML = `
                <td class="px-3 py-2 align-top"><input type="text" data-break-name placeholder="e.g. Lunch" value="${nameValue}" class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500"></td>
                <td class="px-3 py-2 align-top"><input type="time" data-break-start value="${startValue}" onchange="window.SubchronOrgTabShifts.calculateDuration('${mode}', ${id})" class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500"></td>
                <td class="px-3 py-2 align-top"><input type="time" data-break-end value="${endValue}" onchange="window.SubchronOrgTabShifts.calculateDuration('${mode}', ${id})" class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500"></td>
                <td class="px-3 py-2 align-top"><input type="text" id="multiple-break-duration-${mode}-${id}" readonly class="block w-20 text-sm rounded-md border-0 py-1.5 px-2 bg-slate-100 ring-1 ring-inset ring-gray-300 dark:bg-gray-700/60 dark:ring-gray-600"></td>
                <td class="px-3 py-2 align-top">
                    <select data-break-paid class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500">
                        <option value="unpaid" ${isPaid ? '' : 'selected'}>Unpaid</option>
                        <option value="paid" ${isPaid ? 'selected' : ''}>Paid</option>
                    </select>
                </td>
                <td class="px-3 py-2 align-top">
                    <select class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500">
                        <option value="yes">Yes</option>
                        <option value="no">No</option>
                    </select>
                </td>
                <td class="px-3 py-2 align-top">
                    <button type="button" onclick="window.SubchronOrgTabShifts.removeMultipleBreakRow('${mode}', ${id})" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 p-1">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" /></svg>
                    </button>
                </td>`;
            container.appendChild(row);
            calculateDuration(mode, id);
        };

        const removeMultipleBreakRow = (mode, id) => {
            document.getElementById(`multiple-break-row-${mode}-${id}`)?.remove();
        };

        const calculateDuration = (mode, id) => {
            const row = document.getElementById(`multiple-break-row-${mode}-${id}`);
            if (!row) return;
            const startEl = row.querySelector('[data-break-start]');
            const endEl = row.querySelector('[data-break-end]');
            if (!startEl || !endEl) return;
            const minutes = diffMinutes(startEl.value, endEl.value);
            const target = document.getElementById(`multiple-break-duration-${mode}-${id}`);
            if (target) target.value = formatMinutes(minutes);
        };

        const calculateSingleBreakDuration = (mode) => {
            const prefix = mode === 'edit' ? 'edit' : 'add';
            const startEl = document.getElementById(`${prefix}SingleBreakStart`);
            const endEl = document.getElementById(`${prefix}SingleBreakEnd`);
            const displayEl = document.getElementById(`${prefix}SingleBreakDuration`);
            if (!startEl || !endEl || !displayEl) return 0;
            const minutes = diffMinutes(startEl.value, endEl.value);
            displayEl.value = formatMinutes(minutes);
            return minutes;
        };

        const computeBreakMinutes = (mode) => {
            const type = getBreakRuleType(mode);
            if (type === 'multiple') {
                return sumMultipleBreakMinutes(mode);
            }
            return calculateSingleBreakDuration(mode);
        };

        const getBreakRuleType = (mode) => {
            const name = mode === 'edit' ? 'edit_break_rule_type' : 'break_rule_type';
            return document.querySelector(`input[name="${name}"]:checked`)?.value || 'single';
        };

        const sumMultipleBreakMinutes = (mode) => {
            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (!container) return 0;
            let total = 0;
            container.querySelectorAll('tr').forEach(row => {
                const startEl = row.querySelector('[data-break-start]');
                const endEl = row.querySelector('[data-break-end]');
                if (startEl && endEl) total += diffMinutes(startEl.value, endEl.value);
            });
            return total;
        };

        const collectBreaks = (mode) => {
            const type = getBreakRuleType(mode);
            if (type === 'single') {
                const prefix = mode === 'edit' ? 'edit' : 'add';
                const start = document.getElementById(`${prefix}SingleBreakStart`)?.value || '';
                const end = document.getElementById(`${prefix}SingleBreakEnd`)?.value || '';
                if (!start || !end) return [];
                const paidName = mode === 'edit' ? 'edit_single_break_type' : 'add_single_break_type';
                const paidValue = document.querySelector(`input[name="${paidName}"]:checked`)?.value || 'unpaid';
                return [{
                    name: 'Break 1',
                    startTime: start,
                    endTime: end,
                    isPaid: paidValue === 'paid'
                }];
            }

            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (!container) return [];
            const breaks = [];
            container.querySelectorAll('tr').forEach((row, index) => {
                const name = (row.querySelector('[data-break-name]')?.value || '').trim();
                const start = row.querySelector('[data-break-start]')?.value || '';
                const end = row.querySelector('[data-break-end]')?.value || '';
                const paid = row.querySelector('[data-break-paid]')?.value === 'paid';
                if (!start || !end) return;
                breaks.push({
                    name: name || `Break ${index + 1}`,
                    startTime: start,
                    endTime: end,
                    isPaid: paid
                });
            });
            return breaks;
        };

        const resetAddForm = () => {
            const defaults = new Set(['Mon','Tue','Wed','Thu','Fri']);
            toggleDayButtons(refs.addModal, '.modal-day-btn', defaults);
            const nameInput = document.getElementById('shiftName');
            if (nameInput) nameInput.value = '';
            const fixedRadio = document.querySelector('input[name="shift_type"][value="fixed"]');
            if (fixedRadio) fixedRadio.checked = true;
            setShiftType('add', 'fixed');
            document.getElementById('addFixedStart').value = '09:00';
            document.getElementById('addFixedEnd').value = '18:00';
            document.getElementById('addFixedRequiredHours').value = '8';
            document.getElementById('addFixedGrace').value = '15';
            document.getElementById('addFlexEarliest').value = '06:00';
            document.getElementById('addFlexLatest').value = '22:00';
            document.getElementById('addFlexReqHrs').value = '8';
            document.getElementById('addFlexMaxHrs').value = '10';
            document.getElementById('addOpenWeekHrs').value = '40';
            const breakStart = document.getElementById('addSingleBreakStart');
            const breakEnd = document.getElementById('addSingleBreakEnd');
            if (breakStart) breakStart.value = '12:00';
            if (breakEnd) breakEnd.value = '13:00';
            setBreakRuleType('add', 'single');
            document.querySelectorAll('input[name="add_single_break_type"]').forEach(radio => radio.checked = radio.value === 'unpaid');
            clearMultipleBreakRows('add');
            calculateSingleBreakDuration('add');
        };

        const openAddShiftModal = () => {
            state.editingCode = null;
            resetAddForm();
            refs.addModal?.classList.remove('hidden');
        };

        const closeAddShiftModal = () => {
            refs.addModal?.classList.add('hidden');
        };

        const openEditModal = (code) => {
            if (!code) return;
            const template = state.templates.find(t => stringEquals(t.Code, code));
            if (!template) {
                showToast('Shift template not found.', false);
                return;
            }
            state.editingCode = template.Code || null;
            
            // Set basic fields
            const nameEl = document.getElementById('editShiftName');
            if (nameEl) nameEl.value = template.Name || '';
            
            const type = (template.Type || 'Fixed').toLowerCase();
            const radio = document.querySelector(`input[name="edit_shift_type"][value="${type}"]`);
            if (radio) radio.checked = true;
            setShiftType('edit', type);
            
            // Set work days
            toggleDayButtons(refs.editModal, '.edit-day-btn', new Set(template.WorkDays || ['Mon','Tue','Wed','Thu','Fri']));
            
            // Set fixed shift fields
            const fixedStartEl = document.getElementById('editFixedStart');
            const fixedEndEl = document.getElementById('editFixedEnd');
            const fixedReqEl = document.getElementById('editFixedRequiredHours');
            const fixedGraceEl = document.getElementById('editFixedGrace');
            const existingBreaks = getTemplateBreaks(template);
            const existingBreakMinutes = existingBreaks.length
                ? existingBreaks.reduce((total, item) => total + diffMinutes(item.StartTime || item.startTime, item.EndTime || item.endTime), 0)
                : (template.Fixed?.BreakMinutes || 0);
            const totalShiftMinutes = diffMinutes(template.Fixed?.StartTime, template.Fixed?.EndTime);
            const derivedRequiredHours = totalShiftMinutes > 0
                ? Math.max(0, (totalShiftMinutes - existingBreakMinutes) / 60)
                : null;
            
            if (fixedStartEl) fixedStartEl.value = template.Fixed?.StartTime || '09:00';
            if (fixedEndEl) fixedEndEl.value = template.Fixed?.EndTime || '18:00';
            if (fixedReqEl) fixedReqEl.value = (template.Fixed?.RequiredHours ?? (derivedRequiredHours != null ? Number(derivedRequiredHours.toFixed(2)) : null))?.toString() || '8';
            if (fixedGraceEl) fixedGraceEl.value = template.Fixed?.GraceMinutes?.toString() || '15';
            
            // Set flexible shift fields
            const flexEarliestEl = document.getElementById('editFlexEarliest');
            const flexLatestEl = document.getElementById('editFlexLatest');
            const flexReqEl = document.getElementById('editFlexReqHrs');
            const flexMaxEl = document.getElementById('editFlexMaxHrs');
            
            if (flexEarliestEl) flexEarliestEl.value = template.Flexible?.EarliestStart || '06:00';
            if (flexLatestEl) flexLatestEl.value = template.Flexible?.LatestEnd || '22:00';
            if (flexReqEl) flexReqEl.value = template.Flexible?.RequiredDailyHours?.toString() || '8';
            if (flexMaxEl) flexMaxEl.value = template.Flexible?.MaxDailyHours?.toString() || '10';
            
            // Set open shift fields
            const openWeekEl = document.getElementById('editOpenWeekHrs');
            if (openWeekEl) openWeekEl.value = template.Open?.RequiredWeeklyHours?.toString() || '40';
            
            // Set break configuration
            clearMultipleBreakRows('edit');
            const breakStartEl = document.getElementById('editSingleBreakStart');
            const breakEndEl = document.getElementById('editSingleBreakEnd');

            if (existingBreaks.length > 1) {
                setBreakRuleType('edit', 'multiple');
                existingBreaks.forEach(item => addMultipleBreakRow('edit', item));
            } else {
                const singleBreak = existingBreaks[0] || null;
                setBreakRuleType('edit', 'single');
                if (breakStartEl) breakStartEl.value = singleBreak?.StartTime || singleBreak?.startTime || '12:00';
                if (breakEndEl) breakEndEl.value = singleBreak?.EndTime || singleBreak?.endTime || '13:00';
                const paid = !!(singleBreak?.IsPaid ?? singleBreak?.isPaid);
                document.querySelectorAll('input[name="edit_single_break_type"]').forEach(radio => {
                    radio.checked = paid ? radio.value === 'paid' : radio.value === 'unpaid';
                });
                calculateSingleBreakDuration('edit');
            }
            
            // Ensure modal is visible
            if (refs.editModal) {
                refs.editModal.classList.remove('hidden');
                // Force a reflow to ensure the modal displays
                refs.editModal.style.display = 'none';
                setTimeout(() => {
                    refs.editModal.style.display = '';
                }, 0);
            }
        };

        const closeEditShiftModal = () => {
            state.editingCode = null;
            refs.editModal?.classList.add('hidden');
        };

        const openDeleteModal = (code) => {
            if (!code) return;
            const template = state.templates.find(t => stringEquals(t.Code, code));
            state.deleteCode = code;
            const isActive = getTemplateIsActive(template);
            state.deleteTargetActive = isActive;
            const targetName = template ? `"${template.Name}"` : 'this shift';
            if (refs.deleteNameEl) refs.deleteNameEl.textContent = targetName;
            if (refs.deleteTitleEl) refs.deleteTitleEl.textContent = isActive ? 'Disable Shift Template' : 'Enable Shift Template';
            if (refs.deleteMessageEl) refs.deleteMessageEl.innerHTML = isActive
                ? `Are you sure you want to disable <span class="font-semibold text-gray-900 dark:text-white">${targetName}</span>?`
                : `Are you sure you want to enable <span class="font-semibold text-gray-900 dark:text-white">${targetName}</span>?`;
            if (refs.deleteHintEl) refs.deleteHintEl.textContent = isActive
                ? 'Disabled templates stay in the list but can no longer be used for new assignments.'
                : 'Enabled templates become available for new assignments and selection.';
            if (refs.disableReasonGroupEl) refs.disableReasonGroupEl.classList.toggle('hidden', !isActive);
            if (refs.disableReasonInputEl) {
                refs.disableReasonInputEl.value = isActive ? '' : (template?.DisabledReason || '');
                refs.disableReasonInputEl.required = isActive;
                refs.disableReasonInputEl.readOnly = !isActive;
            }
            updateDisableReasonCounter();
            if (refs.deleteConfirmBtnEl) {
                refs.deleteConfirmBtnEl.textContent = isActive ? 'Disable Template' : 'Enable Template';
                refs.deleteConfirmBtnEl.classList.toggle('bg-red-500', isActive);
                refs.deleteConfirmBtnEl.classList.toggle('hover:bg-red-600', isActive);
                refs.deleteConfirmBtnEl.classList.toggle('dark:bg-red-600', isActive);
                refs.deleteConfirmBtnEl.classList.toggle('dark:hover:bg-red-500', isActive);
                refs.deleteConfirmBtnEl.classList.toggle('bg-emerald-500', !isActive);
                refs.deleteConfirmBtnEl.classList.toggle('hover:bg-emerald-600', !isActive);
                refs.deleteConfirmBtnEl.classList.toggle('dark:bg-emerald-500', !isActive);
                refs.deleteConfirmBtnEl.classList.toggle('dark:hover:bg-emerald-400', !isActive);
            }
            refs.deleteModal?.classList.remove('hidden');
        };

        const closeDeleteShiftModal = () => {
            state.deleteCode = null;
            state.deleteTargetActive = true;
            if (refs.disableReasonInputEl) {
                refs.disableReasonInputEl.value = '';
                refs.disableReasonInputEl.required = false;
                refs.disableReasonInputEl.readOnly = false;
            }
            updateDisableReasonCounter();
            refs.disableReasonGroupEl?.classList.remove('hidden');
            refs.deleteModal?.classList.add('hidden');
        };

        const stringEquals = (a, b) => {
            if (typeof a !== 'string' || typeof b !== 'string') return a === b;
            return a.toLowerCase() === b.toLowerCase();
        };

        const buildPayloadFromForm = (mode) => {
            const isEdit = mode === 'edit';
            const nameInput = document.getElementById(isEdit ? 'editShiftName' : 'shiftName');
            const name = nameInput?.value.trim();
            if (!name) {
                nameInput?.focus();
                return null;
            }
            const typeValue = document.querySelector(isEdit ? 'input[name="edit_shift_type"]:checked' : 'input[name="shift_type"]:checked')?.value || 'fixed';
            const type = typeValue.charAt(0).toUpperCase() + typeValue.slice(1);
            const days = collectActiveDays(isEdit ? refs.editModal : refs.addModal, isEdit ? '.edit-day-btn' : '.modal-day-btn');
            if (!days.length) {
                showToast('Select at least one work day.', false);
                return null;
            }

            const payload = {
                code: isEdit ? state.editingCode : undefined,
                name,
                type,
                workDays: days,
                breaks: collectBreaks(isEdit ? 'edit' : 'add'),
                dayOverrides: [],
                isActive: isEdit
                    ? getTemplateIsActive(state.templates.find(t => stringEquals(t.Code, state.editingCode)))
                    : true,
                disabledReason: isEdit
                    ? (state.templates.find(t => stringEquals(t.Code, state.editingCode))?.DisabledReason || '')
                    : '',
                fixed: null,
                flexible: null,
                open: null
            };

            if (type === 'Fixed') {
                const prefix = isEdit ? 'edit' : 'add';
                const startEl = document.getElementById(`${prefix}FixedStart`);
                const endEl = document.getElementById(`${prefix}FixedEnd`);
                const reqHoursEl = document.getElementById(`${prefix}FixedRequiredHours`);
                const graceEl = document.getElementById(`${prefix}FixedGrace`);
                
                if (!startEl || !endEl) {
                    showToast('Required time fields are missing.', false);
                    return null;
                }
                
                payload.fixed = {
                    startTime: startEl.value,
                    endTime: endEl.value,
                    requiredHours: parseFloat(reqHoursEl?.value || '0') || 0,
                    breakMinutes: payload.breaks.reduce((total, item) => total + diffMinutes(item.startTime, item.endTime), 0),
                    graceMinutes: parseInt(graceEl?.value || '0', 10) || 0
                };
            } else if (type === 'Flexible') {
                const prefix = isEdit ? 'edit' : 'add';
                const earliestEl = document.getElementById(`${prefix}FlexEarliest`);
                const latestEl = document.getElementById(`${prefix}FlexLatest`);
                const reqHrsEl = document.getElementById(`${prefix}FlexReqHrs`);
                const maxHrsEl = document.getElementById(`${prefix}FlexMaxHrs`);
                
                if (!earliestEl || !latestEl) {
                    showToast('Required time window fields are missing.', false);
                    return null;
                }
                
                payload.flexible = {
                    earliestStart: earliestEl.value,
                    latestEnd: latestEl.value,
                    requiredDailyHours: parseFloat(reqHrsEl?.value || '0') || 0,
                    maxDailyHours: parseFloat(maxHrsEl?.value || '0') || 0
                };
            } else {
                const prefix = isEdit ? 'edit' : 'add';
                const weekHrsEl = document.getElementById(`${prefix}OpenWeekHrs`);
                
                payload.open = {
                    requiredWeeklyHours: parseFloat(weekHrsEl?.value || '0') || 0
                };
            }

            return payload;
        };

        const saveShiftTemplate = async () => {
            if (state.isSaving || !canCallApi()) return;
            try {
                const payload = buildPayloadFromForm('add');
                if (!payload) return;
                state.isSaving = true;
                setAddSaveLoading(true);
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current`, {
                    method: 'POST',
                    headers: authHeaders(),
                    body: JSON.stringify(payload)
                });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to save shift template.');
                showToast('Shift template added.');
                closeAddShiftModal();
                await loadShiftTemplates(true); // Force refresh after save
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : 'Unable to save shift template.', false);
            } finally {
                state.isSaving = false;
            }
        };

        const saveEditShiftTemplate = async () => {
            if (!state.editingCode || state.isSaving || !canCallApi()) return;
            try {
                const payload = buildPayloadFromForm('edit');
                if (!payload) return;
                state.isSaving = true;
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current/${encodeURIComponent(state.editingCode)}`, {
                    method: 'PUT',
                    headers: authHeaders(),
                    body: JSON.stringify(payload)
                });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to update shift template.');
                showToast('Shift template updated.');
                closeEditShiftModal();
                await loadShiftTemplates(true); // Force refresh after save
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : 'Unable to update shift template.', false);
            } finally {
                state.isSaving = false;
            }
        };

        const confirmDeleteShift = async () => {
            if (!state.deleteCode || state.isSaving || !canCallApi()) return;
            try {
                const template = state.templates.find(t => stringEquals(t.Code, state.deleteCode));
                if (!template) throw new Error('Shift template not found.');
                const disableReason = (refs.disableReasonInputEl?.value || '').trim();
                if (state.deleteTargetActive && !disableReason) {
                    refs.disableReasonInputEl?.focus();
                    showToast('Please provide a reason for disabling this shift template.', false);
                    return;
                }
                if (disableReason.length > 60) {
                    refs.disableReasonInputEl?.focus();
                    showToast('Disable reason must be 60 characters or fewer.', false);
                    return;
                }

                const payload = {
                    code: template.Code || template.code,
                    name: template.Name || template.name || '',
                    type: template.Type || template.type || 'Fixed',
                    workDays: template.WorkDays || template.workDays || [],
                    fixed: template.Fixed || template.fixed || null,
                    flexible: template.Flexible || template.flexible || null,
                    open: template.Open || template.open || null,
                    breaks: getTemplateBreaks(template).map((item, index) => ({
                        name: item.Name || item.name || `Break ${index + 1}`,
                        startTime: item.StartTime || item.startTime || '',
                        endTime: item.EndTime || item.endTime || '',
                        isPaid: !!(item.IsPaid ?? item.isPaid)
                    })),
                    dayOverrides: template.DayOverrides || template.dayOverrides || [],
                    isActive: !state.deleteTargetActive,
                    disabledReason: state.deleteTargetActive ? disableReason : ''
                };

                state.isSaving = true;
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current/${encodeURIComponent(state.deleteCode)}`, {
                    method: 'PUT',
                    headers: authHeaders(),
                    body: JSON.stringify(payload)
                });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || `Unable to ${state.deleteTargetActive ? 'disable' : 'enable'} shift template.`);
                showToast(`Shift template ${state.deleteTargetActive ? 'disabled' : 'enabled'}.`);
                closeDeleteShiftModal();
                await loadShiftTemplates(true);
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : `Unable to ${state.deleteTargetActive ? 'disable' : 'enable'} shift template.`, false);
            } finally {
                state.isSaving = false;
                setAddSaveLoading(false);
            }
        };

        const DISABLED_META = {
            accent: 'slate',
            border: 'border-slate-300 dark:border-slate-700',
            bar: 'bg-slate-400',
            detailBg: 'bg-slate-100/90 dark:bg-slate-800/80',
            iconWrapper: 'bg-slate-200 text-slate-600 dark:bg-slate-700 dark:text-slate-300',
            badge: 'bg-slate-100 text-slate-700 ring-1 ring-slate-400/30 dark:bg-slate-700 dark:text-slate-300 dark:ring-slate-500/30'
        };

        const loadShiftTemplates = async (forceRefresh = false) => {
            if (!canCallApi()) return;
            
            // Use cache if available and not forced refresh
            const now = Date.now();
            if (!forceRefresh && state.templates.length > 0 && (now - state.lastLoadTime) < state.loadCacheDuration) {
                renderTemplateCards();
                return;
            }
            
            if (state.isLoading) return; // Prevent duplicate requests
            
            try {
                state.isLoading = true;
                setShiftLoadingState(true);
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current`, { headers: authHeaders() });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to load shift templates.');
                const rawTemplates =
                    data?.templates ||
                    data?.Templates ||
                    data?.data?.templates ||
                    data?.data?.Templates ||
                    data?.result?.templates ||
                    data?.result?.Templates ||
                    [];
                if (Array.isArray(rawTemplates)) {
                    state.templates = rawTemplates.map(normalizeTemplate);
                } else if (rawTemplates && typeof rawTemplates === 'object') {
                    state.templates = [normalizeTemplate(rawTemplates)];
                } else {
                    state.templates = [];
                }
                state.lastLoadTime = Date.now();
                renderTemplateCards();
            } catch (err) {
                console.error(err);
                state.templates = [];
                renderTemplateCards();
                showToast(err instanceof Error ? err.message : 'Unable to load shift templates.', false);
            } finally {
                state.isLoading = false;
                setShiftLoadingState(false);
            }
        };

        const renderTemplateCards = () => {
            refs.listEl.innerHTML = '';
            if (!state.templates.length) {
                refs.emptyStateEl?.classList.remove('hidden');
                return;
            }
            refs.emptyStateEl?.classList.add('hidden');
            const sortedTemplates = [...state.templates].sort((a, b) => {
                const activeA = getTemplateIsActive(a) ? 1 : 0;
                const activeB = getTemplateIsActive(b) ? 1 : 0;
                if (activeA !== activeB) return activeB - activeA;
                return (a?.Name || '').localeCompare(b?.Name || '');
            });

            sortedTemplates.forEach(template => {
                const meta = TYPE_META[template.Type ?? 'Fixed'] || TYPE_META.Fixed;
                const isActive = getTemplateIsActive(template);
                const viewMeta = isActive ? meta : { ...meta, ...DISABLED_META };
                const card = document.createElement('div');
                card.className = `shift-card overflow-hidden rounded-2xl border ${viewMeta.border} ${isActive ? 'bg-slate-50 dark:bg-gray-800' : 'bg-slate-100/80 dark:bg-slate-900/70'} shadow-sm`;
                card.dataset.shiftCode = template.Code || '';
                card.innerHTML = `
                    <div class="h-1.5 w-full ${viewMeta.bar}"></div>
                    <div class="px-5 pt-4 pb-4">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl ${viewMeta.iconWrapper}">
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">${meta.icon}</svg>
                                </div>
                                <div>
                                    <span class="block text-sm font-bold text-gray-900 dark:text-white">${template.Name || 'Untitled Shift'}</span>
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ${viewMeta.badge}">${meta.label}</span>
                                    <span class="ml-2 inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ${isActive ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20 dark:bg-emerald-900/30 dark:text-emerald-300 dark:ring-emerald-500/30' : 'bg-rose-50 text-rose-700 ring-1 ring-rose-600/20 dark:bg-rose-900/30 dark:text-rose-300 dark:ring-rose-500/30'}">${isActive ? 'Active' : 'Disabled'}</span>
                                </div>
                            </div>
                            <div class="flex shrink-0 items-center gap-2">
                                <button type="button" class="rounded-lg p-2 ${isActive ? 'text-amber-400 hover:bg-amber-50 hover:text-amber-600 dark:text-amber-500 dark:hover:bg-amber-900/20' : 'text-slate-300 dark:text-slate-600 cursor-not-allowed'}" data-action="edit" title="${isActive ? 'Edit' : 'Disabled shifts cannot be edited'}" ${isActive ? '' : 'disabled'}>
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
                                </button>
                                <button type="button" class="rounded-lg p-2 ${isActive ? 'text-red-500 hover:bg-red-50 hover:text-red-700 dark:text-red-500 dark:hover:bg-red-900/20' : 'text-emerald-600 hover:bg-emerald-50 hover:text-emerald-700 dark:text-emerald-400 dark:hover:bg-emerald-900/20'}" data-action="delete" title="${isActive ? 'Disable' : 'Enable'}">
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="${isActive ? 'M9.75 9.75L14.25 14.25M14.25 9.75L9.75 14.25M21 12a9 9 0 11-18 0 9 9 0 0118 0z' : 'M9 12.75l2.25 2.25L15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z'}" /></svg>
                                </button>
                            </div>
                        </div>
                        <div class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 rounded-xl ${viewMeta.detailBg} px-4 py-3 sm:grid-cols-4">
                            ${buildDetailCells(template, viewMeta)}
                        </div>
                        ${buildBreakDetails(template, viewMeta)}
                        ${buildDisabledReasonBlock(template)}
                    </div>`;
                card.querySelector('[data-action="edit"]')?.addEventListener('click', () => openEditModal(template.Code));
                card.querySelector('[data-action="delete"]').addEventListener('click', () => openDeleteModal(template.Code));
                refs.listEl.appendChild(card);
            });
        };

        const buildDisabledReasonBlock = (template) => {
            if (getTemplateIsActive(template)) return '';
            const reason = escapeHtml(template.DisabledReason || template.disabledReason || 'No reason provided.');
            return `
                <div class="mt-3 rounded-lg border border-slate-300 bg-slate-100/90 px-3 py-2 dark:border-slate-600 dark:bg-slate-800/90">
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-slate-600 dark:text-slate-300">Disabled Reason</p>
                    <p class="mt-1 text-xs text-slate-700 dark:text-slate-200">${reason}</p>
                </div>`;
        };

        const buildBreakDetails = (template, meta) => {
            const accent = meta.accent;
            const breaks = getTemplateBreaks(template);

            if (!breaks.length) {
                if (template.Fixed?.BreakMinutes) {
                    return `<div class="mt-3 rounded-lg border border-dashed border-slate-300 px-3 py-2 text-xs text-slate-600 dark:border-slate-600 dark:text-slate-300">Break Details: Total break is configured as ${template.Fixed.BreakMinutes} min.</div>`;
                }
                return `<div class="mt-3 rounded-lg border border-dashed border-slate-300 px-3 py-2 text-xs text-slate-600 dark:border-slate-600 dark:text-slate-300">Break Details: No break windows configured.</div>`;
            }

            const items = breaks.map((item, index) => {
                const name = escapeHtml(item.Name || item.name || `Break ${index + 1}`);
                const start = formatTime(item.StartTime || item.startTime);
                const end = formatTime(item.EndTime || item.endTime);
                const paid = (item.IsPaid ?? item.isPaid) ? 'Paid' : 'Unpaid';
                return `<li class="flex items-center justify-between gap-3 rounded-md bg-white/70 px-2 py-1.5 dark:bg-gray-900/40"><span class="truncate font-medium text-gray-800 dark:text-gray-100">${name}</span><span class="shrink-0 text-gray-600 dark:text-gray-300">${start} - ${end} (${paid})</span></li>`;
            });

            const firstItem = items[0];
            const remaining = items.slice(1);

            let detailsMarkup = `<ul class="mt-1.5 space-y-1 text-xs">${firstItem}</ul>`;
            if (remaining.length > 0) {
                detailsMarkup += `
                    <details class="mt-2 group">
                        <summary class="cursor-pointer select-none text-xs font-semibold text-${accent}-700 hover:text-${accent}-800 dark:text-${accent}-400 dark:hover:text-${accent}-300">
                            View ${remaining.length} more break${remaining.length > 1 ? 's' : ''}
                        </summary>
                        <ul class="mt-2 space-y-1 text-xs">${remaining.join('')}</ul>
                    </details>`;
            }

            return `
                <div class="mt-3 rounded-lg border border-${accent}-200/70 bg-${accent}-50/40 px-3 py-2 dark:border-${accent}-900/40 dark:bg-${accent}-900/10">
                    <p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-700 dark:text-${accent}-400">Break Details</p>
                    ${detailsMarkup}
                </div>`;
        };

        const buildDetailCells = (template, meta) => {
            const days = template.WorkDays?.length ? template.WorkDays.join(', ') : 'No days set';
            const accent = meta.accent;
            const type = (template.Type ?? 'Fixed').toLowerCase();
            const breaks = getTemplateBreaks(template);
            const breakTotal = breaks.reduce((total, item) => total + diffMinutes(item.StartTime || item.startTime, item.EndTime || item.endTime), 0);
            const breakSummary = breaks.length === 0
                ? (template.Fixed?.BreakMinutes ? `${template.Fixed.BreakMinutes} min total` : 'None')
                : `${breaks.length > 1 ? 'Multiple' : 'Single'} (${breaks.length}) - ${breakTotal} min total`;

            if (type === 'flexible') {
                const earliest = formatTime(template.Flexible?.EarliestStart);
                const latest = formatTime(template.Flexible?.LatestEnd);
                const req = template.Flexible?.RequiredDailyHours ? `${template.Flexible.RequiredDailyHours} hrs` : '—';
                const max = template.Flexible?.MaxDailyHours ? `${template.Flexible.MaxDailyHours} hrs` : '—';
                return `
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Window</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${earliest} – ${latest}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Work Days</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${days}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Required Daily</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${req}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Breaks</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${breakSummary}</p></div>`;
            }

            if (type === 'open') {
                const weekly = template.Open?.RequiredWeeklyHours ? `${template.Open.RequiredWeeklyHours} hrs` : '—';
                return `
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Schedule</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">No strict window</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Work Days</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${days}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Required Weekly</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${weekly}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Breaks</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${breakSummary}</p></div>`;
            }

            const start = formatTime(template.Fixed?.StartTime);
            const end = formatTime(template.Fixed?.EndTime);
            const graceText = template.Fixed?.GraceMinutes ? `${template.Fixed.GraceMinutes} min` : '—';

            return `
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Time</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${start} – ${end}</p></div>
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Work Days</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${days}</p></div>
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Breaks</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${breakSummary}</p></div>
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Grace</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${graceText}</p></div>`;
        };

        const attachModalDismissHandlers = () => {
            [
                { el: refs.addModal, close: closeAddShiftModal },
                { el: refs.editModal, close: closeEditShiftModal },
                { el: refs.deleteModal, close: closeDeleteShiftModal }
            ].forEach(({ el, close }) => {
                if (!el || el.dataset.dismissBound === 'true') return;
                el.dataset.dismissBound = 'true';
                el.addEventListener('click', evt => {
                    if (evt.target === el) close();
                });
            });
        };

        const initShiftTab = () => {
            resetAddForm();
            calculateSingleBreakDuration('add');
            setAddSaveLoading(false);
            updateDisableReasonCounter();
            refs.disableReasonInputEl?.addEventListener('input', updateDisableReasonCounter);
            attachModalDismissHandlers();
            loadShiftTemplates();
            const shiftsTab = document.getElementById('tab-shifts');
            shiftsTab?.addEventListener('org-shifts-tab-shown', () => {
                if (!state.templates.length) loadShiftTemplates();
            });
        };

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initShiftTab, { once: true });
        } else {
            initShiftTab();
        }

        const api = {
            openAddShiftModal,
            closeAddShiftModal,
            onShiftTypeChange: (type) => setShiftType('add', type),
            toggleModalDay: (btn) => toggleDayButton(btn, 'emerald'),
            onBreakRuleChange,
            calculateSingleBreakDuration,
            addMultipleBreakRow,
            removeMultipleBreakRow,
            calculateDuration,
            saveShiftTemplate,
            openEditShiftModal: (target) => {
                const code = typeof target === 'string' ? target : target?.dataset?.shiftCode;
                openEditModal(code);
            },
            closeEditShiftModal,
            onEditShiftTypeChange: (type) => setShiftType('edit', type),
            toggleEditDay: (btn) => toggleDayButton(btn, 'amber'),
            saveEditShiftTemplate,
            openDeleteShiftModal: (target) => {
                const code = typeof target === 'string' ? target : target?.dataset?.shiftCode;
                openDeleteModal(code);
            },
            closeDeleteShiftModal,
            confirmDeleteShift
        };

        window.SubchronOrgTabShifts = api;
        [
            'openAddShiftModal','closeAddShiftModal','onShiftTypeChange','toggleModalDay','onBreakRuleChange',
            'calculateSingleBreakDuration','addMultipleBreakRow','removeMultipleBreakRow','calculateDuration',
            'saveShiftTemplate','openEditShiftModal','closeEditShiftModal','onEditShiftTypeChange','toggleEditDay',
            'saveEditShiftTemplate','openDeleteShiftModal','closeDeleteShiftModal','confirmDeleteShift'
        ].forEach(name => {
            window[name] = api[name];
        });
    })();
</script>
