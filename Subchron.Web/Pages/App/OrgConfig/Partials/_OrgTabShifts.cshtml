                detailBg: 'bg-violet-50/70 dark:bg-violet-900/10',
                iconWrapper: 'bg-violet-100 text-violet-600 dark:bg-violet-900/40 dark:text-violet-400',
                badge: 'bg-violet-50 text-violet-700 ring-1 ring-violet-600/20 dark:bg-violet-900/30 dark:text-violet-400 dark:ring-violet-500/30',
                icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />'
            }
        };

        const appRoot = document.getElementById('appRoot');
        const apiBase = (appRoot?.getAttribute('data-api-base') || appRoot?.dataset?.apiBase || '').trim().replace(/\/$/, '');
        const token = appRoot?.getAttribute('data-api-token') || appRoot?.dataset?.apiToken || '';

        const refs = {
            listEl: document.getElementById('shiftsList'),
            emptyStateEl: document.getElementById('shiftsEmptyState'),
            addModal: document.getElementById('addShiftModal'),
            editModal: document.getElementById('editShiftModal'),
            deleteModal: document.getElementById('deleteShiftModal'),
            deleteNameEl: document.getElementById('deleteShiftName')
        };

        if (!refs.listEl) return;

        const state = {
            templates: [],
            editingCode: null,
            deleteCode: null,
            isSaving: false,
            multipleBreakCounter: 0
        };

        const authHeaders = () => {
            const headers = { 'Content-Type': 'application/json' };
            if (token) headers['Authorization'] = `Bearer ${token}`;
            return headers;
        };

        const showToast = (message, success = true) => {
            if (typeof window.showToast === 'function') window.showToast(message, success);
        };

        const canCallApi = () => {
            if (!apiBase || !token) {
                console.warn('Shift tab: missing API base or token.');
                return false;
            }
            return true;
        };

        const diffMinutes = (start, end) => {
            if (!start || !end) return 0;
            const startDate = new Date(`1970-01-01T${start}:00`);
            const endDate = new Date(`1970-01-01T${end}:00`);
            if (Number.isNaN(startDate.getTime()) || Number.isNaN(endDate.getTime())) return 0;
            let diff = endDate - startDate;
            if (diff < 0) diff += 24 * 60 * 60 * 1000;
            return Math.round(diff / 60000);
        };

        const formatMinutes = (minutes) => {
            if (!Number.isFinite(minutes) || minutes <= 0) return '0m';
            const hrs = Math.floor(minutes / 60);
            const mins = minutes % 60;
            if (hrs && mins) return `${hrs}h ${mins}m`;
            if (hrs) return `${hrs}h`;
            return `${mins}m`;
        };

        const formatTime = (value) => {
            if (!value) return '—';
            const [h, m] = value.split(':');
            if (h === undefined || m === undefined) return value;
            const hour = Number(h);
            const minute = Number(m);
            if (Number.isNaN(hour) || Number.isNaN(minute)) return value;
            const suffix = hour >= 12 ? 'PM' : 'AM';
            const normalizedHour = hour % 12 || 12;
            return `${normalizedHour}:${String(minute).padStart(2, '0')} ${suffix}`;
        };

        const toggleDayButton = (btn, theme) => {
            const active = btn.getAttribute('data-active') === 'true';
            btn.setAttribute('data-active', active ? 'false' : 'true');
            applyDayButtonClass(btn, !active, theme);
        };

        const applyDayButtonClass = (btn, active, theme) => {
            const baseClass = btn.classList.contains('edit-day-btn') ? 'edit-day-btn' : 'modal-day-btn';
            if (active) {
                btn.className = `${baseClass} flex h-10 w-10 items-center justify-center rounded-lg bg-${theme}-500 text-xs font-bold text-white shadow-sm transition-all`;
            } else {
                btn.className = `${baseClass} flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-xs font-bold text-gray-400 transition-all hover:border-${theme}-300 hover:text-${theme}-500 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-500`;
            }
        };

        const toggleDayButtons = (container, selector, activeDays) => {
            if (!container) return;
            container.querySelectorAll(selector).forEach(btn => {
                const day = btn.getAttribute('data-day');
                const shouldBeActive = activeDays.has(day);
                btn.setAttribute('data-active', shouldBeActive ? 'true' : 'false');
                applyDayButtonClass(btn, shouldBeActive, selector.includes('modal') ? 'emerald' : 'amber');
            });
        };

        const collectActiveDays = (container, selector) => {
            const days = [];
            container?.querySelectorAll(selector).forEach(btn => {
                if (btn.getAttribute('data-active') === 'true') {
                    const day = btn.getAttribute('data-day');
                    if (day) days.push(day);
                }
            });
            return days;
        };

        const setShiftType = (mode, type) => {
            const normalized = (type || 'fixed').toLowerCase();
            const prefix = mode === 'edit' ? 'edit-fields-' : 'fields-';
            ['fixed', 'flexible', 'open'].forEach(t => {
                const el = document.getElementById(prefix + t);
                if (el) el.classList.toggle('hidden', t !== normalized);
            });
            const hint = document.getElementById(mode === 'edit' ? 'editShiftTypeHint' : 'shiftTypeHint');
            if (hint) hint.textContent = SHIFT_HINTS[normalized] || '';
        };

        const onBreakRuleChange = (type, mode) => {
            const prefix = mode === 'edit' ? 'edit' : 'add';
            const single = document.getElementById(`${prefix}-break-rule-single`);
            const multiple = document.getElementById(`${prefix}-break-rule-multiple`);
            if (single) single.classList.toggle('hidden', type !== 'single');
            if (multiple) multiple.classList.toggle('hidden', type !== 'multiple');
        };

        const clearMultipleBreakRows = (mode) => {
            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (container) container.innerHTML = '';
        };

        const addMultipleBreakRow = (mode) => {
            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (!container) return;
            state.multipleBreakCounter += 1;
            const accent = mode === 'add' ? 'emerald' : 'amber';
            const id = state.multipleBreakCounter;
            const row = document.createElement('tr');
            row.id = `multiple-break-row-${id}`;
            row.innerHTML = `
                <td class="px-3 py-2 align-top"><input type="text" placeholder="e.g. Lunch" class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500"></td>
                <td class="px-3 py-2 align-top"><input type="time" onchange="window.SubchronOrgTabShifts.calculateDuration(${id})" class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500"></td>
                <td class="px-3 py-2 align-top"><input type="time" onchange="window.SubchronOrgTabShifts.calculateDuration(${id})" class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500"></td>
                <td class="px-3 py-2 align-top"><input type="text" id="multiple-break-duration-${id}" readonly class="block w-20 text-sm rounded-md border-0 py-1.5 px-2 bg-slate-100 ring-1 ring-inset ring-gray-300 dark:bg-gray-700/60 dark:ring-gray-600"></td>
                <td class="px-3 py-2 align-top">
                    <select class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500">
                        <option value="unpaid">Unpaid</option>
                        <option value="paid">Paid</option>
                    </select>
                </td>
                <td class="px-3 py-2 align-top">
                    <select class="block w-full text-sm rounded-md border-0 py-1.5 px-2 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-${accent}-500 dark:bg-gray-900 dark:ring-gray-600 dark:focus:ring-${accent}-500">
                        <option value="yes">Yes</option>
                        <option value="no">No</option>
                    </select>
                </td>
                <td class="px-3 py-2 align-top">
                    <button type="button" onclick="window.SubchronOrgTabShifts.removeMultipleBreakRow(${id})" class="text-red-500 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300 p-1">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 12H6" /></svg>
                    </button>
                </td>`;
            container.appendChild(row);
        };

        const removeMultipleBreakRow = (id) => {
            document.getElementById(`multiple-break-row-${id}`)?.remove();
        };

        const calculateDuration = (id) => {
            const row = document.getElementById(`multiple-break-row-${id}`);
            if (!row) return;
            const times = row.querySelectorAll('input[type="time"]');
            if (times.length < 2) return;
            const minutes = diffMinutes(times[0].value, times[1].value);
            const target = document.getElementById(`multiple-break-duration-${id}`);
            if (target) target.value = formatMinutes(minutes);
        };

        const calculateSingleBreakDuration = (mode) => {
            const prefix = mode === 'edit' ? 'edit' : 'add';
            const startEl = document.getElementById(`${prefix}SingleBreakStart`);
            const endEl = document.getElementById(`${prefix}SingleBreakEnd`);
            const displayEl = document.getElementById(`${prefix}SingleBreakDuration`);
            if (!startEl || !endEl || !displayEl) return 0;
            const minutes = diffMinutes(startEl.value, endEl.value);
            displayEl.value = formatMinutes(minutes);
            return minutes;
        };

        const computeBreakMinutes = (mode) => {
            const type = getBreakRuleType(mode);
            if (type === 'multiple') {
                return sumMultipleBreakMinutes(mode);
            }
            return calculateSingleBreakDuration(mode);
        };

        const getBreakRuleType = (mode) => {
            const name = mode === 'edit' ? 'edit_break_rule_type' : 'break_rule_type';
            return document.querySelector(`input[name="${name}"]:checked`)?.value || 'single';
        };

        const sumMultipleBreakMinutes = (mode) => {
            const container = document.getElementById(`${mode}-multiple-breaks-container`);
            if (!container) return 0;
            let total = 0;
            container.querySelectorAll('tr').forEach(row => {
                const times = row.querySelectorAll('input[type="time"]');
                if (times.length >= 2) total += diffMinutes(times[0].value, times[1].value);
            });
            return total;
        };

        const resetAddForm = () => {
            const defaults = new Set(['Mon','Tue','Wed','Thu','Fri']);
            toggleDayButtons(refs.addModal, '.modal-day-btn', defaults);
            const nameInput = document.getElementById('shiftName');
            if (nameInput) nameInput.value = '';
            const fixedRadio = document.querySelector('input[name="shift_type"][value="fixed"]');
            if (fixedRadio) fixedRadio.checked = true;
            setShiftType('add', 'fixed');
            document.getElementById('addFixedStart').value = '09:00';
            document.getElementById('addFixedEnd').value = '18:00';
            document.getElementById('addFixedRequiredHours').value = '8';
            document.getElementById('addFixedGrace').value = '15';
            document.getElementById('addFlexEarliest').value = '06:00';
            document.getElementById('addFlexLatest').value = '22:00';
            document.getElementById('addFlexReqHrs').value = '8';
            document.getElementById('addFlexMaxHrs').value = '10';
            document.getElementById('addOpenWeekHrs').value = '40';
            const breakStart = document.getElementById('addSingleBreakStart');
            const breakEnd = document.getElementById('addSingleBreakEnd');
            if (breakStart) breakStart.value = '12:00';
            if (breakEnd) breakEnd.value = '13:00';
            document.querySelectorAll('input[name="break_rule_type"]').forEach(radio => radio.checked = radio.value === 'single');
            document.querySelectorAll('input[name="add_single_break_type"]').forEach(radio => radio.checked = radio.value === 'unpaid');
            clearMultipleBreakRows('add');
            onBreakRuleChange('single', 'add');
            calculateSingleBreakDuration('add');
        };

        const openAddShiftModal = () => {
            state.editingCode = null;
            resetAddForm();
            refs.addModal?.classList.remove('hidden');
        };

        const closeAddShiftModal = () => {
            refs.addModal?.classList.add('hidden');
        };

        const openEditModal = (code) => {
            if (!code) return;
            const template = state.templates.find(t => stringEquals(t.Code, code));
            if (!template) {
                showToast('Shift template not found.', false);
                return;
            }
            state.editingCode = template.Code || null;
            document.getElementById('editShiftName').value = template.Name || '';
            const type = (template.Type || 'Fixed').toLowerCase();
            const radio = document.querySelector(`input[name="edit_shift_type"][value="${type}"]`);
            if (radio) radio.checked = true;
            setShiftType('edit', type);
            toggleDayButtons(refs.editModal, '.edit-day-btn', new Set(template.WorkDays || ['Mon','Tue','Wed','Thu','Fri']));
            document.getElementById('editFixedStart').value = template.Fixed?.StartTime || '09:00';
            document.getElementById('editFixedEnd').value = template.Fixed?.EndTime || '18:00';
            document.getElementById('editFixedRequiredHours').value = template.Fixed?.RequiredHours?.toString() || '8';
            document.getElementById('editFixedGrace').value = template.Fixed?.GraceMinutes?.toString() || '15';
            document.getElementById('editFlexEarliest').value = template.Flexible?.EarliestStart || '06:00';
            document.getElementById('editFlexLatest').value = template.Flexible?.LatestEnd || '22:00';
            document.getElementById('editFlexReqHrs').value = template.Flexible?.RequiredDailyHours?.toString() || '8';
            document.getElementById('editFlexMaxHrs').value = template.Flexible?.MaxDailyHours?.toString() || '10';
            document.getElementById('editOpenWeekHrs').value = template.Open?.RequiredWeeklyHours?.toString() || '40';
            clearMultipleBreakRows('edit');
            onBreakRuleChange('single', 'edit');
            document.querySelectorAll('input[name="edit_break_rule_type"]').forEach(radio => radio.checked = radio.value === 'single');
            document.querySelectorAll('input[name="edit_single_break_type"]').forEach(radio => radio.checked = radio.value === 'unpaid');

            const breakMinutes = template.Fixed?.BreakMinutes ?? 60;
            const start = document.getElementById('editSingleBreakStart');
            const end = document.getElementById('editSingleBreakEnd');
            if (start) start.value = '12:00';
            if (end) {
                const total = 12 * 60 + breakMinutes;
                const hour = Math.floor(total / 60) % 24;
                const minute = total % 60;
                end.value = `${String(hour).padStart(2,'0')}:${String(minute).padStart(2,'0')}`;
            }
            calculateSingleBreakDuration('edit');
            refs.editModal?.classList.remove('hidden');
        };

        const closeEditShiftModal = () => {
            state.editingCode = null;
            refs.editModal?.classList.add('hidden');
        };

        const openDeleteModal = (code) => {
            if (!code) return;
            const template = state.templates.find(t => stringEquals(t.Code, code));
            state.deleteCode = code;
            if (refs.deleteNameEl) refs.deleteNameEl.textContent = template ? `"${template.Name}"` : 'this shift';
            refs.deleteModal?.classList.remove('hidden');
        };

        const closeDeleteShiftModal = () => {
            state.deleteCode = null;
            refs.deleteModal?.classList.add('hidden');
        };

        const stringEquals = (a, b) => {
            if (typeof a !== 'string' || typeof b !== 'string') return a === b;
            return a.toLowerCase() === b.toLowerCase();
        };

        const buildPayloadFromForm = (mode) => {
            const isEdit = mode === 'edit';
            const nameInput = document.getElementById(isEdit ? 'editShiftName' : 'shiftName');
            const name = nameInput?.value.trim();
            if (!name) {
                nameInput?.focus();
                return null;
            }
            const typeValue = document.querySelector(isEdit ? 'input[name="edit_shift_type"]:checked' : 'input[name="shift_type"]:checked')?.value || 'fixed';
            const type = typeValue.charAt(0).toUpperCase() + typeValue.slice(1);
            const days = collectActiveDays(isEdit ? refs.editModal : refs.addModal, isEdit ? '.edit-day-btn' : '.modal-day-btn');
            if (!days.length) {
                showToast('Select at least one work day.', false);
                return null;
            }

            const payload = {
                code: isEdit ? state.editingCode : undefined,
                name,
                type,
                workDays: days,
                breaks: [],
                dayOverrides: [],
                isActive: true,
                fixed: null,
                flexible: null,
                open: null
            };

            if (type === 'Fixed') {
                const prefix = isEdit ? 'edit' : 'add';
                payload.fixed = {
                    startTime: document.getElementById(`${prefix}FixedStart`).value,
                    endTime: document.getElementById(`${prefix}FixedEnd`).value,
                    requiredHours: parseFloat(document.getElementById(`${prefix}FixedRequiredHours`).value || '0') || 0,
                    breakMinutes: computeBreakMinutes(isEdit ? 'edit' : 'add'),
                    graceMinutes: parseInt(document.getElementById(`${prefix}FixedGrace`).value || '0', 10) || 0
                };
            } else if (type === 'Flexible') {
                const prefix = isEdit ? 'edit' : 'add';
                payload.flexible = {
                    earliestStart: document.getElementById(`${prefix}FlexEarliest`).value,
                    latestEnd: document.getElementById(`${prefix}FlexLatest`).value,
                    requiredDailyHours: parseFloat(document.getElementById(`${prefix}FlexReqHrs`).value || '0') || 0,
                    maxDailyHours: parseFloat(document.getElementById(`${prefix}FlexMaxHrs`).value || '0') || 0
                };
            } else {
                const prefix = isEdit ? 'edit' : 'add';
                payload.open = {
                    requiredWeeklyHours: parseFloat(document.getElementById(`${prefix}OpenWeekHrs`).value || '0') || 0
                };
            }

            return payload;
        };

        const saveShiftTemplate = async () => {
            if (state.isSaving || !canCallApi()) return;
            try {
                const payload = buildPayloadFromForm('add');
                if (!payload) return;
                state.isSaving = true;
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current`, {
                    method: 'POST',
                    headers: authHeaders(),
                    body: JSON.stringify(payload)
                });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to save shift template.');
                showToast('Shift template added.');
                closeAddShiftModal();
                await loadShiftTemplates();
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : 'Unable to save shift template.', false);
            } finally {
                state.isSaving = false;
            }
        };

        const saveEditShiftTemplate = async () => {
            if (!state.editingCode || state.isSaving || !canCallApi()) return;
            try {
                const payload = buildPayloadFromForm('edit');
                if (!payload) return;
                state.isSaving = true;
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current/${encodeURIComponent(state.editingCode)}`, {
                    method: 'PUT',
                    headers: authHeaders(),
                    body: JSON.stringify(payload)
                });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to update shift template.');
                showToast('Shift template updated.');
                closeEditShiftModal();
                await loadShiftTemplates();
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : 'Unable to update shift template.', false);
            } finally {
                state.isSaving = false;
            }
        };

        const confirmDeleteShift = async () => {
            if (!state.deleteCode || state.isSaving || !canCallApi()) return;
            try {
                state.isSaving = true;
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current/${encodeURIComponent(state.deleteCode)}`, {
                    method: 'DELETE',
                    headers: authHeaders()
                });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to delete shift template.');
                showToast('Shift template deleted.');
                closeDeleteShiftModal();
                await loadShiftTemplates();
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : 'Unable to delete shift template.', false);
            } finally {
                state.isSaving = false;
            }
        };

        const loadShiftTemplates = async () => {
            if (!canCallApi()) return;
            try {
                const resp = await fetch(`${apiBase}/api/org-shift-templates/current`, { headers: authHeaders() });
                const data = await resp.json().catch(() => null);
                if (!resp.ok) throw new Error(data?.message || 'Unable to load shift templates.');
                state.templates = data?.templates || [];
                renderTemplateCards();
            } catch (err) {
                console.error(err);
                showToast(err instanceof Error ? err.message : 'Unable to load shift templates.', false);
            }
        };

        const renderTemplateCards = () => {
            refs.listEl.innerHTML = '';
            if (!state.templates.length) {
                refs.emptyStateEl?.classList.remove('hidden');
                return;
            }
            refs.emptyStateEl?.classList.add('hidden');
            state.templates.forEach(template => {
                const meta = TYPE_META[template.Type ?? 'Fixed'] || TYPE_META.Fixed;
                const card = document.createElement('div');
                card.className = `shift-card overflow-hidden rounded-2xl border ${meta.border} bg-slate-50 shadow-sm dark:bg-gray-800`;
                card.dataset.shiftCode = template.Code || '';
                card.innerHTML = `
                    <div class="h-1.5 w-full ${meta.bar}"></div>
                    <div class="px-5 pt-4 pb-4">
                        <div class="flex items-start justify-between gap-4">
                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl ${meta.iconWrapper}">
                                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">${meta.icon}</svg>
                                </div>
                                <div>
                                    <span class="block text-sm font-bold text-gray-900 dark:text-white">${template.Name || 'Untitled Shift'}</span>
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold ${meta.badge}">${meta.label}</span>
                                </div>
                            </div>
                            <div class="flex shrink-0 items-center gap-1">
                                <button type="button" class="rounded-lg p-1.5 text-amber-400 hover:bg-amber-50 hover:text-amber-600 dark:text-amber-500 dark:hover:bg-amber-900/20" data-action="edit" title="Edit">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
                                </button>
                                <button type="button" class="rounded-lg p-1.5 text-red-400 hover:bg-red-50 hover:text-red-600 dark:text-red-500 dark:hover:bg-red-900/20" data-action="delete" title="Delete">
                                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
                                </button>
                            </div>
                        </div>
                        <div class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 rounded-xl ${meta.detailBg} px-4 py-3 sm:grid-cols-4">
                            ${buildDetailCells(template, meta)}
                        </div>
                    </div>`;
                card.querySelector('[data-action="edit"]').addEventListener('click', () => openEditModal(template.Code));
                card.querySelector('[data-action="delete"]').addEventListener('click', () => openDeleteModal(template.Code));
                refs.listEl.appendChild(card);
            });
        };

        const buildDetailCells = (template, meta) => {
            const days = template.WorkDays?.length ? template.WorkDays.join(', ') : 'No days set';
            const accent = meta.accent;
            const type = (template.Type ?? 'Fixed').toLowerCase();

            if (type === 'flexible') {
                const earliest = formatTime(template.Flexible?.EarliestStart);
                const latest = formatTime(template.Flexible?.LatestEnd);
                const req = template.Flexible?.RequiredDailyHours ? `${template.Flexible.RequiredDailyHours} hrs` : '—';
                const max = template.Flexible?.MaxDailyHours ? `${template.Flexible.MaxDailyHours} hrs` : '—';
                return `
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Window</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${earliest} – ${latest}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Work Days</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${days}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Required Daily</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${req}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Max Daily</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${max}</p></div>`;
            }

            if (type === 'open') {
                const weekly = template.Open?.RequiredWeeklyHours ? `${template.Open.RequiredWeeklyHours} hrs` : '—';
                return `
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Schedule</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">No strict window</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Work Days</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${days}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Required Weekly</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${weekly}</p></div>
                    <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Basis</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">Hours only</p></div>`;
            }

            const start = formatTime(template.Fixed?.StartTime);
            const end = formatTime(template.Fixed?.EndTime);
            const breakText = template.Fixed?.BreakMinutes ? `${template.Fixed.BreakMinutes} min` : '—';
            const graceText = template.Fixed?.GraceMinutes ? `${template.Fixed.GraceMinutes} min` : '—';

            return `
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Time</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${start} – ${end}</p></div>
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Work Days</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${days}</p></div>
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Break</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${breakText}</p></div>
                <div><p class="text-[10px] font-semibold uppercase tracking-wider text-${accent}-600 dark:text-${accent}-500">Grace</p><p class="mt-0.5 text-xs font-medium text-gray-800 dark:text-gray-200">${graceText}</p></div>`;
        };

        const attachModalDismissHandlers = () => {
            [
                { el: refs.addModal, close: closeAddShiftModal },
                { el: refs.editModal, close: closeEditShiftModal },
                { el: refs.deleteModal, close: closeDeleteShiftModal }
            ].forEach(({ el, close }) => {
                if (!el || el.dataset.dismissBound === 'true') return;
                el.dataset.dismissBound = 'true';
                el.addEventListener('click', evt => {
                    if (evt.target === el) close();
                });
            });
        };

        document.addEventListener('DOMContentLoaded', () => {
            resetAddForm();
            calculateSingleBreakDuration('add');
            attachModalDismissHandlers();
            loadShiftTemplates();
        });

        const api = {
            openAddShiftModal,
            closeAddShiftModal,
            onShiftTypeChange: (type) => setShiftType('add', type),
            toggleModalDay: (btn) => toggleDayButton(btn, 'emerald'),
            onBreakRuleChange,
            calculateSingleBreakDuration,
            addMultipleBreakRow,
            removeMultipleBreakRow,
            calculateDuration,
            saveShiftTemplate,
            openEditShiftModal: (target) => {
                const code = typeof target === 'string' ? target : target?.dataset?.shiftCode;
                openEditModal(code);
            },
            closeEditShiftModal,
            onEditShiftTypeChange: (type) => setShiftType('edit', type),
            toggleEditDay: (btn) => toggleDayButton(btn, 'amber'),
            saveEditShiftTemplate,
            openDeleteShiftModal: (target) => {
                const code = typeof target === 'string' ? target : target?.dataset?.shiftCode;
                openDeleteModal(code);
            },
            closeDeleteShiftModal,
            confirmDeleteShift
        };

        window.SubchronOrgTabShifts = api;
        [
            'openAddShiftModal','closeAddShiftModal','onShiftTypeChange','toggleModalDay','onBreakRuleChange',
            'calculateSingleBreakDuration','addMultipleBreakRow','removeMultipleBreakRow','calculateDuration',
            'saveShiftTemplate','openEditShiftModal','closeEditShiftModal','onEditShiftTypeChange','toggleEditDay',
            'saveEditShiftTemplate','openDeleteShiftModal','closeDeleteShiftModal','confirmDeleteShift'
        ].forEach(name => {
            window[name] = api[name];
        });
    })();
</script>
