<div id="tab-shifts" class="tab-content hidden h-full flex-col">

    <div class="flex items-center justify-between border-b border-slate-200 px-8 py-5 dark:border-gray-700">
        <div>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Shift Configuration</h2>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Define shift templates for your organization. Assign them to employees later.</p>
        </div>
        <button onclick="openAddShiftModal()" class="btn-primary gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Add Shift Template
        </button>
    </div>

    <div class="flex-1 overflow-y-auto p-8">
        <div class="space-y-6">

            @* ── SHIFT TEMPLATE CARDS LIST ── *@
            <div id="shiftsList" class="space-y-4"></div>
            <div id="shiftsEmptyState" class="rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-10 text-center text-sm text-gray-500 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400">
                No shift templates yet. Create your first template to get started.
            </div>
        </div>
    </div>

</div>

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 50;
        padding: 1rem;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .modal-overlay:not(.hidden) {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .modal-shell {
        display: flex;
        flex-direction: column;
        width: 100%;
        max-height: calc(100vh - 2rem);
        overflow: hidden;
        scrollbar-width: none;
        -ms-overflow-style: none;
        margin: auto;
    }

    .modal-body {
        flex: 1 1 auto;
        min-height: 0;
        overflow-y: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

        .modal-shell::-webkit-scrollbar,
        .modal-overlay::-webkit-scrollbar,
        .modal-table::-webkit-scrollbar,
        .modal-body::-webkit-scrollbar {
            display: none;
        }

    .modal-table {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

        .modal-table table {
            min-width: 960px;
        }
</style>

@* ─── EDIT SHIFT MODAL ─── *@
<div id="editShiftModal" class="modal-overlay hidden bg-black/50 px-4 backdrop-blur-sm">
    <div class="modal-shell w-full max-w-5xl rounded-2xl border border-slate-200 bg-white shadow-xl dark:border-gray-700 dark:bg-gray-800">

        <div class="h-1.5 w-full bg-amber-400"></div>
        <div class="flex items-center justify-between border-b border-amber-200 bg-amber-50/60 px-6 py-4 dark:border-amber-900/40 dark:bg-amber-900/10">
            <div class="flex items-center gap-2.5">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-100 text-amber-600 dark:bg-amber-900/40 dark:text-amber-400">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
                    </svg>
                </div>
                <h3 class="text-base font-bold text-amber-900 dark:text-amber-200">Edit Shift Template</h3>
            </div>
            <button onclick="closeEditShiftModal()" class="rounded-lg p-1.5 text-amber-400 hover:bg-amber-100 hover:text-amber-600 dark:hover:bg-amber-900/30">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="modal-body px-6 py-5 space-y-5">

            <div>
                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Shift Name</label>
                <input type="text" id="editShiftName" maxlength="60"
                       class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 placeholder:text-gray-400 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50 dark:placeholder:text-gray-500">
            </div>

            <div>
                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Shift Type</label>
                <div class="grid grid-cols-3 gap-2">
                    <label class="group cursor-pointer">
                        <input type="radio" name="edit_shift_type" value="fixed" class="peer sr-only" onchange="onEditShiftTypeChange('fixed')">
                        <div class="flex flex-col items-center gap-1 rounded-xl border border-slate-200 bg-slate-50 p-3 text-center transition-all shadow-sm
                                    peer-checked:border-amber-400 peer-checked:bg-amber-50 peer-checked:ring-1 peer-checked:ring-amber-300
                                    hover:border-amber-300 hover:shadow-md dark:border-gray-600 dark:bg-gray-700 dark:peer-checked:border-amber-500 dark:peer-checked:bg-amber-900/20">
                            <svg class="h-5 w-5 text-gray-400 group-has-[input:checked]:text-amber-600 dark:group-has-[input:checked]:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <span class="text-xs font-semibold text-gray-700 group-has-[input:checked]:text-amber-700 dark:text-gray-300 dark:group-has-[input:checked]:text-amber-400">Fixed</span>
                            <span class="text-[10px] text-gray-400 dark:text-gray-500">Strict times</span>
                        </div>
                    </label>

                    <label class="group cursor-pointer">
                        <input type="radio" name="edit_shift_type" value="flexible" class="peer sr-only" onchange="onEditShiftTypeChange('flexible')">
                        <div class="flex flex-col items-center gap-1 rounded-xl border border-slate-200 bg-slate-50 p-3 text-center transition-all shadow-sm
                                    peer-checked:border-amber-400 peer-checked:bg-amber-50 peer-checked:ring-1 peer-checked:ring-amber-300
                                    hover:border-amber-300 hover:shadow-md dark:border-gray-600 dark:bg-gray-700 dark:peer-checked:border-amber-500 dark:peer-checked:bg-amber-900/20">
                            <svg class="h-5 w-5 text-gray-400 group-has-[input:checked]:text-amber-600 dark:group-has-[input:checked]:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                            </svg>
                            <span class="text-xs font-semibold text-gray-700 group-has-[input:checked]:text-amber-700 dark:text-gray-300 dark:group-has-[input:checked]:text-amber-400">Flexible</span>
                            <span class="text-[10px] text-gray-400 dark:text-gray-500">Allowed window</span>
                        </div>
                    </label>

                    <label class="group cursor-pointer">
                        <input type="radio" name="edit_shift_type" value="open" class="peer sr-only" onchange="onEditShiftTypeChange('open')">
                        <div class="flex flex-col items-center gap-1 rounded-xl border border-slate-200 bg-slate-50 p-3 text-center transition-all shadow-sm
                                    peer-checked:border-amber-400 peer-checked:bg-amber-50 peer-checked:ring-1 peer-checked:ring-amber-300
                                    hover:border-amber-300 hover:shadow-md dark:border-gray-600 dark:bg-gray-700 dark:peer-checked:border-amber-500 dark:peer-checked:bg-amber-900/20">
                            <svg class="h-5 w-5 text-gray-400 group-has-[input:checked]:text-amber-600 dark:group-has-[input:checked]:text-amber-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                            </svg>
                            <span class="text-xs font-semibold text-gray-700 group-has-[input:checked]:text-amber-700 dark:text-gray-300 dark:group-has-[input:checked]:text-amber-400">Open</span>
                            <span class="text-[10px] text-gray-400 dark:text-gray-500">Hours only</span>
                        </div>
                    </label>
                </div>
                <p id="editShiftTypeHint" class="mt-2 text-xs text-amber-600 dark:text-amber-500">Fixed: strict start and end times each shift.</p>
            </div>

            <div>
                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Work Days</label>
                <div class="flex gap-2">
                    <button type="button" onclick="toggleEditDay(this)" data-day="Mon" data-active="true" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg bg-amber-400 text-xs font-bold text-white shadow-sm transition-all">M</button>
                    <button type="button" onclick="toggleEditDay(this)" data-day="Tue" data-active="true" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg bg-amber-400 text-xs font-bold text-white shadow-sm transition-all">T</button>
                    <button type="button" onclick="toggleEditDay(this)" data-day="Wed" data-active="true" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg bg-amber-400 text-xs font-bold text-white shadow-sm transition-all">W</button>
                    <button type="button" onclick="toggleEditDay(this)" data-day="Thu" data-active="true" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg bg-amber-400 text-xs font-bold text-white shadow-sm transition-all">T</button>
                    <button type="button" onclick="toggleEditDay(this)" data-day="Fri" data-active="true" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg bg-amber-400 text-xs font-bold text-white shadow-sm transition-all">F</button>
                    <button type="button" onclick="toggleEditDay(this)" data-day="Sat" data-active="false" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-xs font-bold text-gray-400 transition-all hover:border-amber-300 hover:text-amber-500 hover:shadow-sm dark:border-gray-600 dark:bg-gray-700 dark:text-gray-500">S</button>
                    <button type="button" onclick="toggleEditDay(this)" data-day="Sun" data-active="false" class="edit-day-btn flex h-10 w-10 items-center justify-center rounded-lg border border-slate-200 bg-slate-50 text-xs font-bold text-gray-400 transition-all hover:border-amber-300 hover:text-amber-500 hover:shadow-sm dark:border-gray-600 dark:bg-gray-700 dark:text-gray-500">S</button>
                </div>
            </div>

            <div id="edit-fields-fixed" class="space-y-4">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Shift Start Time</label>
                        <input type="time" id="editFixedStart" value="09:00" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Shift End Time</label>
                        <input type="time" id="editFixedEnd" value="18:00" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                    </div>
                </div>

                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Break Rules</label>
                    <div class="flex gap-4">
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="edit_break_rule_type" value="single" class="h-4 w-4 accent-amber-500" checked onchange="onBreakRuleChange('single', 'edit')">
                            <span class="text-sm text-gray-700 dark:text-gray-300">Single Break</span>
                        </label>
                        <label class="flex items-center gap-2 cursor-pointer">
                            <input type="radio" name="edit_break_rule_type" value="multiple" class="h-4 w-4 accent-amber-500" onchange="onBreakRuleChange('multiple', 'edit')">
                            <span class="text-sm text-gray-700 dark:text-gray-300">Multiple Break</span>
                        </label>
                    </div>
                </div>

                <div id="edit-break-rule-single">
                    <div class="rounded-lg border border-slate-200 bg-slate-50 p-3 dark:border-gray-700 dark:bg-gray-700/30">
                        <div class="grid grid-cols-3 gap-3">
                            <div>
                                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Break Start</label>
                                <input type="time" id="editSingleBreakStart" value="12:00" onchange="calculateSingleBreakDuration('edit')" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                            </div>
                            <div>
                                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Break End</label>
                                <input type="time" id="editSingleBreakEnd" value="13:00" onchange="calculateSingleBreakDuration('edit')" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                            </div>
                            <div>
                                <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Duration</label>
                                <input type="text" id="editSingleBreakDuration" readonly value="1h 0m" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-500 bg-slate-100 ring-1 ring-inset ring-amber-300 focus:outline-none dark:bg-gray-700 dark:text-gray-400 dark:ring-amber-700/50">
                            </div>
                        </div>
                        <div class="mt-3">
                            <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Break Type</label>
                            <div class="flex gap-4">
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="edit_single_break_type" value="paid" class="h-4 w-4 accent-amber-500">
                                    <span class="text-sm text-gray-700 dark:text-gray-300">Paid</span>
                                </label>
                                <label class="flex items-center gap-2 cursor-pointer">
                                    <input type="radio" name="edit_single_break_type" value="unpaid" class="h-4 w-4 accent-amber-500" checked>
                                    <span class="text-sm text-gray-700 dark:text-gray-300">Unpaid</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="edit-break-rule-multiple" class="hidden">
                    <div class="modal-table overflow-hidden rounded-lg border border-slate-200 dark:border-gray-700">
                        <table class="min-w-full">
                            <thead class="bg-slate-100 dark:bg-gray-700/40">
                                <tr>
                                    <th class="px-3 py-2 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Label</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Start</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">End</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Duration</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Type</th>
                                    <th class="px-3 py-2 text-left text-xs font-semibold tracking-wider text-gray-500 uppercase dark:text-gray-400">Auto-Deduct</th>
                                    <th class="w-12 px-3 py-2"></th>
                                </tr>
                            </thead>
                            <tbody id="edit-multiple-breaks-container" class="divide-y divide-slate-200 dark:divide-gray-700"></tbody>
                        </table>
                    </div>
                    <div class="text-right">
                        <button type="button" onclick="addMultipleBreakRow('edit')" class="mt-2 text-sm text-amber-600 hover:text-amber-700 font-semibold">+ Add Break Rule</button>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Required Work Hours Per Shift</label>
                        <div class="flex items-center gap-2">
                            <input type="number" id="editFixedRequiredHours" min="0" max="24" step="0.25" value="8" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                            <span class="text-xs text-gray-400 whitespace-nowrap">hours</span>
                        </div>
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Grace Period</label>
                        <div class="flex items-center gap-2">
                            <input type="number" id="editFixedGrace" min="0" max="60" value="15" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                            <span class="text-xs text-gray-400 whitespace-nowrap">min</span>
                        </div>
                    </div>
                </div>
            </div>

            <div id="edit-fields-flexible" class="hidden space-y-4">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Earliest Start</label>
                        <input type="time" id="editFlexEarliest" value="06:00" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Latest End</label>
                        <input type="time" id="editFlexLatest" value="22:00" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Required Daily Hours</label>
                        <div class="flex items-center gap-2">
                            <input type="number" id="editFlexReqHrs" min="1" max="24" value="8" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                            <span class="text-xs text-gray-400 whitespace-nowrap">hrs</span>
                        </div>
                    </div>
                    <div>
                        <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Max Hours Per Day</label>
                        <div class="flex items-center gap-2">
                            <input type="number" id="editFlexMaxHrs" min="1" max="24" value="10" class="block w-full rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                            <span class="text-xs text-gray-400 whitespace-nowrap">hrs</span>
                        </div>
                    </div>
                </div>
            </div>

            <div id="edit-fields-open" class="hidden space-y-4">
                <div class="rounded-lg bg-amber-50 px-4 py-3 text-xs text-amber-700 ring-1 ring-amber-200 dark:bg-amber-900/20 dark:text-amber-300 dark:ring-amber-500/30">
                    No strict clock-in window. Employees log total hours worked per day or week.
                </div>
                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-gray-600 dark:text-gray-400">Required Hours Per Week</label>
                    <div class="flex items-center gap-2">
                        <input type="number" id="editOpenWeekHrs" min="1" max="168" value="40" class="w-28 rounded-lg border-0 py-2 px-3 text-sm text-gray-900 ring-1 ring-inset ring-amber-300 focus:ring-2 focus:ring-amber-400 focus:outline-none dark:bg-gray-900 dark:text-white dark:ring-amber-700/50">
                        <span class="text-xs text-gray-400">hrs / week</span>
                    </div>
                </div>
            </div>

        </div>

        <div class="flex items-center justify-end gap-3 border-t border-amber-200 bg-amber-50/60 px-6 py-4 dark:border-amber-900/40 dark:bg-amber-900/10">
            <button onclick="closeEditShiftModal()" class="btn-secondary">Cancel</button>
            <button onclick="saveEditShiftTemplate()" class="inline-flex items-center gap-1.5 rounded-lg bg-amber-400 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-300 focus:ring-offset-1 transition-colors dark:bg-amber-500 dark:hover:bg-amber-400">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                Save Changes
            </button>
        </div>
    </div>
</div>

@* ─── DELETE SHIFT CONFIRMATION MODAL ─── *@
<div id="deleteShiftModal" class="modal-overlay hidden bg-black/50 px-4 backdrop-blur-sm">
    <div class="modal-shell w-full max-w-xl rounded-2xl border border-red-200 bg-white shadow-2xl dark:border-red-900/40 dark:bg-gray-800">
        <div class="h-1.5 w-full bg-red-500"></div>
        <div class="flex items-center justify-between border-b border-red-100 bg-red-50/70 px-6 py-4 dark:border-red-900/40 dark:bg-red-900/10">
            <div class="flex items-center gap-2.5 text-red-600 dark:text-red-400">
