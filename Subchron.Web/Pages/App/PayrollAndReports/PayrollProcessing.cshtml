    @* ── PAYROLL CALCULATION GUIDE ── *@
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100 text-blue-600 dark:bg-blue-900/50 dark:text-blue-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white">Payroll Calculation Guide</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Philippine labor law compliance and computation methodology</p>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-1 gap-4 p-6 md:grid-cols-2 lg:grid-cols-3">
            @* Step 1 *@
            <div class="guide-step">
                <span class="guide-step-number">1</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Basic Salary Calculation</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Monthly rate divided by number of working days in the pay period. For semi-monthly: divide by 15 or 16 days.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">₱45,000 ÷ 15 = ₱3,000/day</p>
                </div>
            </div>

            @* Step 2 *@
            <div class="guide-step">
                <span class="guide-step-number">2</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Overtime Pay (OT)</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Per DOLE, overtime beyond 8 hours should be paid at least 25% above the regular rate.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">Hourly Rate × 1.25 × OT Hours</p>
                </div>
            </div>

            @* Step 3 *@
            <div class="guide-step">
                <span class="guide-step-number">3</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Holiday Pay</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Regular holidays (10/year) paid at 100%. Special holidays at 30% if worked.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">Regular: 100% | Special: 30%</p>
                </div>
            </div>

            @* Step 4 *@
            <div class="guide-step">
                <span class="guide-step-number">4</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Night Differential</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Employees working between 10PM to 6AM should receive at least 10% additional pay.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">Hourly Rate × 0.10 × Night Hours</p>
                </div>
            </div>

            @* Step 5 *@
            <div class="guide-step">
                <span class="guide-step-number">5</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Rest Day / Sunday Work</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">At least 30% additional pay for work on rest day when it's also a regular holiday.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">Regular: +30% | w/ Holiday: +50%</p>
                </div>
            </div>

            @* Step 6 *@
            <div class="guide-step">
                <span class="guide-step-number">6</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Statutory Deductions</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">SSS, PhilHealth, and Pag-IBIG contributions based on employee compensation bracket.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">BIR Tax Table (semi-monthly)</p>
                </div>
            </div>

            @* Step 7 *@
            <div class="guide-step">
                <span class="guide-step-number">7</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">13th Month Pay</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Required under Presidential Decree No. 851. Must be given before December 24.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">Total Basic Salary ÷ 12</p>
                </div>
            </div>

            @* Step 8 *@
            <div class="guide-step">
                <span class="guide-step-number">8</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">SSS Loan Deduction</h4>
                    <p class="mt-1 text-xs text-gray-600 dark:text-gray-400">Optional. SSS salary loan amortization based on approved loan amount and term.</p>
                    <p class="mt-2 text-xs font-mono text-emerald-600 dark:text-emerald-400">Per amortization schedule</p>
                </div>
            </div>

            @* Step 9 *@
            <div class="guide-step">
                <span class="guide-step-number">9</span>
                <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white">Final Net Pay</h4>
