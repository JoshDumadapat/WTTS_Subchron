    function formatCurrency(value) {
        return new Intl.NumberFormat('en-PH', {
            style: 'currency',
            currency: 'PHP',
            minimumFractionDigits: 2
        }).format(value);
    }

    function renderBatchSummary(selectedEmployees) {
        const grossTotal = selectedEmployees.reduce((sum, employee) => sum + employee.gross, 0);
        const deductionTotal = selectedEmployees.reduce((sum, employee) => sum + employee.deductionsTotal, 0);
        const netTotal = selectedEmployees.reduce((sum, employee) => sum + employee.net, 0);

        document.getElementById('batchModalEmployeesCount').textContent = String(selectedEmployees.length);
        document.getElementById('batchModalGrossTotal').textContent = formatCurrency(grossTotal);
        document.getElementById('batchModalDeductionTotal').textContent = formatCurrency(deductionTotal);
        document.getElementById('batchModalNetTotal').textContent = formatCurrency(netTotal);
        document.getElementById('confirmBatchBtn').textContent = 'Confirm & Process All (' + selectedEmployees.length + ')';
    }

    function renderBatchPayslip(employee) {
        const initial = document.getElementById('batchPayslipInitial');
        initial.className = 'flex h-12 w-12 items-center justify-center rounded-full text-lg font-bold ' + employee.avatarClass;
        initial.textContent = employee.initial;

        document.getElementById('batchPayslipName').textContent = employee.name;
        document.getElementById('batchPayslipMeta').textContent = employee.meta;
        document.getElementById('batchPayslipNetPay').textContent = formatCurrency(employee.net);

        const earningsHtml = employee.earnings
            .map(entry => '<div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">' + entry.label + '</span><span class="font-medium text-gray-900 dark:text-white">' + formatCurrency(entry.amount) + '</span></div>')
            .join('') +
            '<div class="flex justify-between border-t border-slate-200 pt-2 text-sm font-semibold dark:border-slate-600"><span class="text-gray-900 dark:text-white">Gross Pay</span><span class="text-gray-900 dark:text-white">' + formatCurrency(employee.gross) + '</span></div>';

        const deductionsHtml = employee.deductions
            .map(entry => '<div class="flex justify-between text-sm"><span class="text-gray-600 dark:text-gray-400">' + entry.label + '</span><span class="font-medium text-gray-900 dark:text-white">' + formatCurrency(entry.amount) + '</span></div>')
            .join('') +
            '<div class="flex justify-between border-t border-slate-200 pt-2 text-sm font-semibold dark:border-slate-600"><span class="text-gray-900 dark:text-white">Total Deductions</span><span class="text-gray-900 dark:text-white">' + formatCurrency(employee.deductionsTotal) + '</span></div>';

        document.getElementById('batchPayslipEarnings').innerHTML = earningsHtml;
        document.getElementById('batchPayslipDeductions').innerHTML = deductionsHtml;
    }

    function selectBatchPayslip(employeeId) {
        const listItems = document.querySelectorAll('[data-batch-payslip-row]');
        listItems.forEach(item => item.classList.remove('active'));

        const activeItem = document.querySelector('[data-batch-payslip-row="' + employeeId + '"]');
        if (activeItem) {
            activeItem.classList.add('active');
        }

        const employee = batchPayslipData[employeeId];
        if (employee) {
            renderBatchPayslip(employee);
        }
    }

    function renderBatchPayslipList(selectedEmployees) {
        const container = document.getElementById('batchPayslipList');
        container.innerHTML = selectedEmployees
            .map(employee => {
                return '<button type="button" data-batch-payslip-row="' + employee.id + '" onclick="selectBatchPayslip(\'' + employee.id + '\')" class="batch-payslip-row w-full text-left">' +
                    '<div class="flex items-center justify-between gap-3">' +
                        '<div class="flex items-center gap-3">' +
                            '<div class="flex h-9 w-9 items-center justify-center rounded-full text-xs font-bold ' + employee.avatarClass + '">' + employee.initial + '</div>' +
                            '<div>' +
                                '<p class="text-sm font-semibold text-gray-900 dark:text-white">' + employee.name + '</p>' +
                                '<p class="text-xs text-gray-500 dark:text-gray-400">' + employee.meta + '</p>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="mt-3 grid grid-cols-3 gap-2 text-[11px]">' +
                        '<p class="text-gray-500 dark:text-gray-400">Gross: <span class="font-semibold text-gray-700 dark:text-gray-200">' + formatCurrency(employee.gross) + '</span></p>' +
                        '<p class="text-gray-500 dark:text-gray-400">Deductions: <span class="font-semibold text-gray-700 dark:text-gray-200">' + formatCurrency(employee.deductionsTotal) + '</span></p>' +
                        '<p class="text-emerald-700 dark:text-emerald-400">Net: <span class="font-semibold">' + formatCurrency(employee.net) + '</span></p>' +
                    '</div>' +
                '</button>';
            })
            .join('');

        if (selectedEmployees.length > 0) {
            selectBatchPayslip(selectedEmployees[0].id);
        }
    }

    // Batch Modal Functions
    function openBatchConfirmModal() {
        const selectedEmployeeIds = Array.from(document.querySelectorAll('.employee-checkbox:checked')).map(checkbox => checkbox.value);
        if (selectedEmployeeIds.length === 0) {
            alert('Please select at least one employee to process.');
            return;
        }

        const selectedEmployees = selectedEmployeeIds
            .map(id => batchPayslipData[id])
            .filter(Boolean);

        renderBatchSummary(selectedEmployees);
        renderBatchPayslipList(selectedEmployees);

        document.getElementById('batchConfirmModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    }

    function closeBatchConfirmModal() {
        document.getElementById('batchConfirmModal').classList.add('hidden');
        document.body.style.overflow = 'auto';
    }

    function processBatchPayroll() {
        closeBatchConfirmModal();
        const checkboxes = document.querySelectorAll('.employee-checkbox:checked');
        alert('Batch payroll processed for ' + checkboxes.length + ' employees successfully!');
    }

    function switchProcessingMode(mode) {
        currentMode = mode;
        
        const individualCard = document.getElementById('individualProcessingCard');
        const batchCard = document.getElementById('batchProcessingCard');
        const individualSection = document.getElementById('individualSection');
        const batchSection = document.getElementById('batchSection');

        if (mode === 'individual') {
            individualCard.classList.add('active');
            batchCard.classList.remove('active');
            individualSection.classList.remove('hidden');
            batchSection.classList.add('hidden');
        } else {
            individualCard.classList.remove('active');
            batchCard.classList.add('active');
            individualSection.classList.add('hidden');
            batchSection.classList.remove('hidden');
        }
    }

    function selectIndividualEmployee(id) {
        const rows = document.querySelectorAll('#individualEmployeeTable .employee-row');
        rows.forEach(row => row.classList.remove('selected'));
        event.currentTarget.classList.add('selected');
        
        const name = event.currentTarget.querySelector('.text-sm.font-medium').textContent;
        document.getElementById('individualEmployeeName').textContent = name;
    }

    function updateSelectedCount() {
        const checkboxes = document.querySelectorAll('.employee-checkbox:checked');
        document.getElementById('selectedCount').textContent = checkboxes.length + ' selected';
    }

    function toggleSelectAll() {
        const selectAllCheckbox = document.getElementById('selectAllCheckbox');
        const checkboxes = document.querySelectorAll('.employee-checkbox');
        checkboxes.forEach(cb => cb.checked = selectAllCheckbox.checked);
        updateSelectedCount();
    }

    function selectAllEmployees() {
        const checkboxes = document.querySelectorAll('.employee-checkbox');
        const allChecked = Array.from(checkboxes).every(cb => cb.checked);
        checkboxes.forEach(cb => cb.checked = !allChecked);
        document.getElementById('selectAllCheckbox').checked = !allChecked;
        updateSelectedCount();
    }

    // Search functionality for individual
    document.getElementById('individualSearchInput').addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#individualEmployeeTable .employee-row');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    // Search functionality for batch
    document.getElementById('batchSearchInput').addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#batchEmployeeTable .employee-row');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });

    // Department filter for individual
    document.getElementById('individualDepartmentFilter').addEventListener('change', function(e) {
        const dept = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#individualEmployeeTable .employee-row');
        rows.forEach(row => {
            if (!dept) {
                row.style.display = '';
            } else {
                row.style.display = row.textContent.toLowerCase().includes(dept) ? '' : 'none';
            }
        });
    });

    // Department filter for batch
    document.getElementById('batchDepartmentFilter').addEventListener('change', function(e) {
        const dept = e.target.value.toLowerCase();
        const rows = document.querySelectorAll('#batchEmployeeTable .employee-row');
        rows.forEach(row => {
            if (!dept) {
                row.style.display = '';
            } else {
                row.style.display = row.textContent.toLowerCase().includes(dept) ? '' : 'none';
            }
        });
    });
</script>
