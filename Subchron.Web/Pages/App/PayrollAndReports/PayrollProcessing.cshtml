@page
@model Subchron.Web.Pages.App.PayrollAndReports.PayrollProcessingModel
@{
    ViewData["Title"] = "Payroll Processing";
    ViewData["PageTitle"] = "Payroll Processing";
    Layout = "/Pages/App/Shared/_LayoutAdmin.cshtml";
}

<style>
    .processing-card {
        cursor: pointer;
        border-radius: 1rem;
        border: 2px solid rgb(226 232 240);
        background: rgb(248 250 252);
        padding: 1.5rem;
        transition: all 0.2s ease;
    }

    .processing-card:hover {
        border-color: rgb(52 211 153);
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.12);
    }

    .processing-card.active {
        border-color: rgb(16 185 129);
        background: rgb(236 253 245);
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
    }

    .processing-card.active .card-icon {
        background: rgb(16 185 129);
        color: white;
    }

    .card-icon {
        display: flex;
        height: 3.5rem;
        width: 3.5rem;
        align-items: center;
        justify-content: center;
        border-radius: 0.75rem;
        background: rgb(226 232 240);
        color: rgb(71 85 105);
        transition: background-color 0.2s ease, color 0.2s ease;
    }

    .summary-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        border-bottom: 1px solid rgb(241 245 249);
        padding: 0.75rem 0;
    }

    .summary-row:last-child {
        border-bottom: 0;
    }

    .guide-step {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        border: 1px solid rgb(226 232 240);
        border-radius: 0.75rem;
        background: rgb(248 250 252);
        padding: 1rem;
    }

    .guide-step-number {
        display: flex;
        height: 2rem;
        width: 2rem;
        flex-shrink: 0;
        align-items: center;
        justify-content: center;
        border-radius: 9999px;
        background: rgb(209 250 229);
        color: rgb(4 120 87);
        font-size: 0.875rem;
        font-weight: 700;
    }

    .checkbox-cell {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .custom-checkbox {
        height: 1.25rem;
        width: 1.25rem;
        cursor: pointer;
        border-radius: 0.25rem;
        border: 2px solid rgb(203 213 225);
        background: white;
        transition: all 0.2s ease;
        accent-color: rgb(16 185 129);
    }

    .employee-row:hover {
        background: rgb(248 250 252);
    }

    .employee-row.selected {
        background: rgb(236 253 245);
    }

    .dark .processing-card {
        border-color: rgb(51 65 85);
        background: rgb(30 41 59);
    }

    .dark .processing-card:hover,
    .dark .processing-card.active {
        border-color: rgb(16 185 129);
    }

    .dark .processing-card.active {
        background: rgba(6, 78, 59, 0.45);
    }

    .dark .card-icon {
        background: rgb(51 65 85);
        color: rgb(203 213 225);
    }

    .dark .summary-row {
        border-bottom-color: rgb(51 65 85);
    }

    .dark .guide-step {
        border-color: rgb(51 65 85);
        background: rgb(30 41 59);
    }

    .dark .guide-step-number {
        background: rgba(16, 185, 129, 0.25);
        color: rgb(110 231 183);
    }

    .dark .custom-checkbox {
        border-color: rgb(71 85 105);
        background: rgb(30 41 59);
    }

    .dark .employee-row:hover {
        background: rgba(51, 65, 85, 0.4);
    }

    .dark .employee-row.selected {
        background: rgba(6, 78, 59, 0.35);
    }

    .batch-payslip-row {
        border: 1px solid rgb(226 232 240);
        border-radius: 0.75rem;
        background: white;
        padding: 0.75rem;
        transition: all 0.2s ease;
    }

    .batch-payslip-row:hover {
        border-color: rgb(16 185 129);
        background: rgb(248 250 252);
    }

    .batch-payslip-row.active {
        border-color: rgb(16 185 129);
        background: rgb(236 253 245);
        box-shadow: 0 6px 14px rgba(16, 185, 129, 0.14);
    }

    .dark .batch-payslip-row {
        border-color: rgb(51 65 85);
        background: rgb(30 41 59);
    }

    .dark .batch-payslip-row:hover {
        border-color: rgb(16 185 129);
        background: rgb(15 23 42);
    }

    .dark .batch-payslip-row.active {
        border-color: rgb(16 185 129);
        background: rgba(6, 78, 59, 0.35);
    }
</style>

<div class="space-y-6">
    @* ── TOP CARD: Payroll Rules Summary ── *@
    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
            <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-100 text-emerald-600 dark:bg-emerald-900/50 dark:text-emerald-400">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white">Payroll Configuration Rules</h2>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Current organization payroll settings (read-only)</p>
                </div>
            </div>
        </div>
        <div class="grid grid-cols-1 gap-6 p-6 md:grid-cols-2 lg:grid-cols-4">
            @* Payment Cycle *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Payment Cycle</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">Semi-Monthly</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">1st-15th & 16th-EOM</p>
            </div>

            @* Work Hours *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Work Hours/Day</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">8 Hours</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">Standard work day</p>
            </div>

            @* OT Policy *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">OT Policy</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">1.25x - 2.0x</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">Regular + Holiday/Rest Day</p>
            </div>

            @* Compensation Basis *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Compensation</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">Monthly</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">PHP Currency</p>
            </div>

            @* 13th Month *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">13th Month</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">Basic Only</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">Per DOLE guidelines</p>
            </div>

            @* Tax Settings *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2zM10 8.5a.5.5 0 11-1 0 .5.5 0 011 0zm5 5a.5.5 0 11-1 0 .5.5 0 011 0z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Tax & Statutory</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">BIR + SSS + PhilHealth</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">SSS 8.5% | PhilHealth 3% | Pag-IBIG 2%</p>
            </div>

            @* Night Differential *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Night Differential</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">10%</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">10PM - 6AM</p>
            </div>

            @* Lock Attendance *@
            <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-700/30">
                <div class="mb-2 flex items-center gap-2">
                    <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                    <span class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Lock Attendance</span>
                </div>
                <p class="text-lg font-bold text-gray-900 dark:text-white">Disabled</p>
                <p class="text-xs text-slate-500 dark:text-slate-400">Manual corrections allowed</p>
            </div>
        </div>
    </div>

    @* ── PROCESSING MODE CARDS ── *@
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <div id="individualProcessingCard" class="processing-card active" onclick="switchProcessingMode('individual')">
            <div class="flex items-center gap-4">
                <div class="card-icon">
                    <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Individual Processing</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Process payroll for a single employee</p>
                </div>
            </div>
        </div>

        <div id="batchProcessingCard" class="processing-card" onclick="switchProcessingMode('batch')">
            <div class="flex items-center gap-4">
                <div class="card-icon">
                    <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white">Batch Processing</h3>
                    <p class="text-sm text-gray-500 dark:text-gray-400">Process payroll for multiple employees</p>
                </div>
            </div>
        </div>
    </div>

    @* ── INDIVIDUAL PROCESSING SECTION ── *@
    <div id="individualSection">
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
            @* Left: Employee Selection *@
            <div class="lg:col-span-2">
                <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
                    <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
                        <h3 class="text-base font-bold text-gray-900 dark:text-white">Select Employee</h3>
                    </div>
                    <div class="p-6">
                        @* Search and Filters *@
                        <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center">
                            <div class="relative flex-1">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                                    <svg class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                                    </svg>
                                </span>
                                <input type="text" id="individualSearchInput" 
                                       class="h-10 w-full rounded-xl border border-slate-200 bg-slate-50 pl-10 text-sm focus:border-emerald-500 focus:ring-2 focus:ring-emerald-500/20 dark:border-slate-700 dark:bg-slate-700/30 dark:text-white"
                                       placeholder="Search by name or employee ID...">
                            </div>
                            <select id="individualDepartmentFilter" 
                                    class="h-10 rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm font-medium text-slate-600 dark:border-slate-700 dark:bg-slate-700/30 dark:text-slate-300">
                                <option value="">All Departments</option>
                                <option value="Engineering">Engineering</option>
                                <option value="Marketing">Marketing</option>
                                <option value="Sales">Sales</option>
                                <option value="HR">Human Resources</option>
                            </select>
                            <select id="individualStatusFilter" 
                                    class="h-10 rounded-xl border border-slate-200 bg-slate-50 px-4 text-sm font-medium text-slate-600 dark:border-slate-700 dark:bg-slate-700/30 dark:text-slate-300">
                                <option value="">All Status</option>
                                <option value="Active">Active</option>
                                <option value="OnLeave">On Leave</option>
                                <option value="Probation">Probation</option>
                            </select>
                        </div>

                        @* Employee List *@
                        <div class="overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
                            <table class="min-w-full divide-y divide-slate-200 dark:divide-slate-700">
                                <thead class="bg-slate-50 dark:bg-slate-700/30">
                                    <tr>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Employee</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Department</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Position</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Status</th>
                                        <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Basic Salary</th>
                                    </tr>
                                </thead>
                                <tbody id="individualEmployeeTable" class="divide-y divide-slate-200 bg-white dark:divide-slate-700 dark:bg-slate-800">
                                    <tr class="employee-row cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50" onclick="selectIndividualEmployee('1')">
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-3">
                                                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-emerald-100 text-sm font-bold text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-400">JD</div>
                                                <div>
                                                    <p class="text-sm font-medium text-gray-900 dark:text-white">John Doe</p>
                                                    <p class="text-xs text-gray-500 dark:text-gray-400">EMP-001</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">Engineering</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">Software Engineer</td>
                                        <td class="px-4 py-3">
                                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-400">Active</span>
                                        </td>
                                        <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">₱45,000.00</td>
                                    </tr>
                                    <tr class="employee-row cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50" onclick="selectIndividualEmployee('2')">
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-3">
                                                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-sm font-bold text-blue-700 dark:bg-blue-900/50 dark:text-blue-400">AS</div>
                                                <div>
                                                    <p class="text-sm font-medium text-gray-900 dark:text-white">Alice Smith</p>
                                                    <p class="text-xs text-gray-500 dark:text-gray-400">EMP-002</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">Marketing</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">Marketing Manager</td>
                                        <td class="px-4 py-3">
                                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-400">Active</span>
                                        </td>
                                        <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">₱55,000.00</td>
                                    </tr>
                                    <tr class="employee-row cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50" onclick="selectIndividualEmployee('3')">
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-3">
                                                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-purple-100 text-sm font-bold text-purple-700 dark:bg-purple-900/50 dark:text-purple-400">RJ</div>
                                                <div>
                                                    <p class="text-sm font-medium text-gray-900 dark:text-white">Robert Johnson</p>
                                                    <p class="text-xs text-gray-500 dark:text-gray-400">EMP-003</p>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">Sales</td>
                                        <td class="px-4 py-3 text-sm text-gray-600 dark:text-gray-300">Sales Representative</td>
                                        <td class="px-4 py-3">
                                            <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700 dark:bg-emerald-900/50 dark:text-emerald-400">Active</span>
                                        </td>
                                        <td class="px-4 py-3 text-sm font-medium text-gray-900 dark:text-white">₱35,000.00</td>
                                    </tr>
                                    <tr class="employee-row cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-800/50" onclick="selectIndividualEmployee('4')">
                                        <td class="px-4 py-3">
                                            <div class="flex items-center gap-3">
                                                <div class="flex h-8 w-8 items-center justify-center rounded-full bg-orange-100 text-sm font-bold text-orange-700 dark:bg-orange-900/50 dark:text-orange-400">MW</div>
                                                <div>
                                                    <p class="text-sm font-medium text-gray-900 dark:text-white">Maria Williams</p>
                                                    <p class="text-xs text-gray-500 dark:text-gray-400">EMP-004</p>
                                                </div>
                                            </div>
                                        </td>
