@page
@model Subchron.Web.Pages.App.PayrollAndReports.PayrollModel
@{
    ViewData["Title"] = "Payroll Processing";
    ViewData["PageTitle"] = "Payroll Processing";
    Layout = "/Pages/App/Shared/_LayoutAdmin.cshtml";
}

<div class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="grid gap-4 md:grid-cols-5">
            <div>
                <label class="mb-1 block text-xs font-semibold text-slate-500 dark:text-slate-400">Mode</label>
                <select id="payrollMode" class="h-10 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm dark:border-slate-600 dark:bg-slate-700 dark:text-white">
                    <option value="batch">Batch Processing</option>
                    <option value="individual">Individual Processing</option>
                </select>
            </div>
            <div id="employeeWrap" class="hidden md:col-span-2">
                <label class="mb-1 block text-xs font-semibold text-slate-500 dark:text-slate-400">Employee</label>
                <select id="employeeId" class="h-10 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm dark:border-slate-600 dark:bg-slate-700 dark:text-white">
                    <option value="">Select employee</option>
                </select>
            </div>
            <div>
                <label class="mb-1 block text-xs font-semibold text-slate-500 dark:text-slate-400">Period Start</label>
                <input type="date" id="periodStart" class="h-10 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm dark:border-slate-600 dark:bg-slate-700 dark:text-white" />
            </div>
            <div>
                <label class="mb-1 block text-xs font-semibold text-slate-500 dark:text-slate-400">Period End</label>
                <input type="date" id="periodEnd" class="h-10 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm dark:border-slate-600 dark:bg-slate-700 dark:text-white" />
            </div>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
            <button id="btnPreview" class="btn-primary px-4 py-2">Preview Payroll</button>
            <button id="btnProcess" class="btn-secondary px-4 py-2" disabled>Process Payroll</button>
        </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-800">
        <div class="border-b border-slate-200 px-5 py-4 dark:border-slate-700">
            <h3 class="text-sm font-semibold text-slate-700 dark:text-slate-200">Processing Preview</h3>
            <p class="text-xs text-slate-500 dark:text-slate-400">Review employee payroll summary before processing.</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-slate-50 dark:bg-slate-800/70">
                    <tr>
                        <th class="px-4 py-2 text-left">Employee</th>
                        <th class="px-4 py-2 text-left">Worked Hrs</th>
                        <th class="px-4 py-2 text-left">Base</th>
                        <th class="px-4 py-2 text-left">OT</th>
                        <th class="px-4 py-2 text-left">Allowances</th>
                        <th class="px-4 py-2 text-left">Deductions</th>
                        <th class="px-4 py-2 text-left">Net</th>
                        <th class="px-4 py-2 text-right">Review</th>
                    </tr>
                </thead>
                <tbody id="previewBody" class="divide-y divide-slate-100 dark:divide-slate-700">
                    <tr><td colspan="8" class="px-4 py-8 text-center text-slate-500">No preview yet.</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <details class="rounded-2xl border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-800">
        <summary class="cursor-pointer text-sm font-semibold text-slate-700 dark:text-slate-200">Payroll Formula Breakdown</summary>
        <div class="mt-3 space-y-2 text-sm text-slate-600 dark:text-slate-300">
            <p><strong>Base Pay:</strong> Uses employee compensation basis override; if none, uses Pay tab basis.</p>
            <p><strong>Worked Hours:</strong> Sum of attendance log TimeOut - TimeIn within selected period.</p>
            <p><strong>Overtime Pay:</strong> Approved overtime hours x hourly rate x 1.25 multiplier.</p>
            <p><strong>Allowances:</strong> Active allowance rules, with attendance-dependent/proration logic applied.</p>
            <p><strong>Deductions:</strong> Employee-linked deduction rules from Pay tab; formula/percentage/fixed logic applied.</p>
            <p><strong>Net Pay:</strong> <code>Net = (Base + OT + Allowances) - Deductions</code></p>
        </div>
    </details>
</div>

<div id="reviewModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 p-4">
    <div class="w-full max-w-2xl rounded-2xl bg-white p-5 shadow-2xl dark:bg-slate-800">
        <h3 class="text-base font-semibold text-slate-800 dark:text-slate-100">Payslip Summary Review</h3>
        <div id="reviewContent" class="mt-3 space-y-1 text-sm text-slate-600 dark:text-slate-300"></div>
        <div class="mt-4 flex justify-end gap-2">
            <button id="closeReview" class="btn-secondary px-4 py-2">Close</button>
        </div>
    </div>
</div>

<div id="processModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 p-4">
    <div class="w-full max-w-lg rounded-2xl bg-white p-5 shadow-2xl dark:bg-slate-800">
        <h3 class="text-base font-semibold text-slate-800 dark:text-slate-100">Payroll Processed</h3>
        <p id="processResult" class="mt-2 text-sm text-slate-600 dark:text-slate-300"></p>
        <div class="mt-4 flex justify-end gap-2">
            <button id="downloadPayslip" class="btn-primary px-4 py-2">Download Payslip PDF</button>
            <button id="closeProcess" class="btn-secondary px-4 py-2">Close</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var payrollMode = document.getElementById('payrollMode');
    var employeeWrap = document.getElementById('employeeWrap');
    var employeeId = document.getElementById('employeeId');
    var periodStart = document.getElementById('periodStart');
    var periodEnd = document.getElementById('periodEnd');
    var btnPreview = document.getElementById('btnPreview');
    var btnProcess = document.getElementById('btnProcess');
    var previewBody = document.getElementById('previewBody');

    var reviewModal = document.getElementById('reviewModal');
    var reviewContent = document.getElementById('reviewContent');
    var closeReview = document.getElementById('closeReview');

    var processModal = document.getElementById('processModal');
    var processResult = document.getElementById('processResult');
    var closeProcess = document.getElementById('closeProcess');
    var downloadPayslip = document.getElementById('downloadPayslip');

    var previewData = null;
    var latestRunId = null;

    function setDefaultDates() {
        var today = new Date();
        var start = new Date(today.getFullYear(), today.getMonth(), 1);
        periodStart.value = start.toISOString().slice(0, 10);
        periodEnd.value = today.toISOString().slice(0, 10);
    }

    function currency(n) {
        return new Intl.NumberFormat(undefined, { style: 'currency', currency: 'PHP' }).format(Number(n || 0));
    }

    function modeChanged() {
        var individual = payrollMode.value === 'individual';
        employeeWrap.classList.toggle('hidden', !individual);
    }

    function getPayload() {
        return {
            periodStart: periodStart.value,
            periodEnd: periodEnd.value,
            mode: payrollMode.value,
            empID: payrollMode.value === 'individual' && employeeId.value ? Number(employeeId.value) : null
        };
    }

    function renderPreview(items) {
        if (!items || !items.length) {
            previewBody.innerHTML = '<tr><td colspan="8" class="px-4 py-8 text-center text-slate-500">No employees found for selected criteria.</td></tr>';
            btnProcess.disabled = true;
            return;
        }

        previewBody.innerHTML = items.map(function (x, idx) {
            return '<tr>' +
                '<td class="px-4 py-3">' + x.employeeName + ' <span class="text-xs text-slate-400">(' + x.empNumber + ')</span></td>' +
                '<td class="px-4 py-3">' + Number(x.workedHours || 0).toFixed(2) + '</td>' +
                '<td class="px-4 py-3">' + currency(x.basePay) + '</td>' +
                '<td class="px-4 py-3">' + currency(x.overtimePay) + '</td>' +
                '<td class="px-4 py-3">' + currency(x.allowances) + '</td>' +
                '<td class="px-4 py-3">' + currency(x.deductions) + '</td>' +
                '<td class="px-4 py-3 font-semibold">' + currency(x.netPay) + '</td>' +
                '<td class="px-4 py-3 text-right"><button type="button" class="rounded-lg bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700 hover:bg-slate-200 dark:bg-slate-700 dark:text-slate-100" data-review="' + idx + '">Review</button></td>' +
                '</tr>';
        }).join('');

        previewBody.querySelectorAll('[data-review]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var item = items[Number(btn.getAttribute('data-review'))];
                var lines = (item.breakdown || []).map(function (b) { return '<p>' + b.type + ': ' + b.name + ' - <strong>' + currency(b.amount) + '</strong></p>'; }).join('');
                reviewContent.innerHTML =
                    '<p><strong>' + item.employeeName + '</strong> (' + item.empNumber + ')</p>' +
                    '<p>Worked Hours: ' + Number(item.workedHours || 0).toFixed(2) + '</p>' +
                    '<p>Gross: ' + currency(item.grossPay) + '</p>' +
                    '<p>Deductions: ' + currency(item.deductions) + '</p>' +
                    '<p>Net: <strong>' + currency(item.netPay) + '</strong></p>' +
                    '<hr class="my-2 border-slate-200 dark:border-slate-700" />' + lines;
                reviewModal.classList.remove('hidden');
                reviewModal.classList.add('flex');
            });
        });

        btnProcess.disabled = false;
    }

    function loadEmployees() {
        fetch('?handler=Employees').then(function (r) { return r.json(); }).then(function (rows) {
            employeeId.innerHTML = '<option value="">Select employee</option>' +
                (rows || []).map(function (x) { return '<option value="' + x.empID + '">' + x.firstName + ' ' + x.lastName + ' (' + x.empNumber + ')</option>'; }).join('');
        });
    }

    btnPreview.addEventListener('click', function () {
        fetch('?handler=Preview', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(getPayload())
        }).then(function (r) { return r.json(); }).then(function (data) {
            previewData = data;
            renderPreview(data.items || []);
        });
    });

    btnProcess.addEventListener('click', function () {
        fetch('?handler=Process', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(getPayload())
        }).then(function (r) { return r.json(); }).then(function (res) {
            latestRunId = res.runId;
            processResult.textContent = 'Processed ' + (res.processedCount || 0) + ' employee(s). Net total: ' + currency(res.totalNet || 0);
            processModal.classList.remove('hidden');
            processModal.classList.add('flex');
        });
    });

    closeReview.addEventListener('click', function () {
        reviewModal.classList.add('hidden');
        reviewModal.classList.remove('flex');
    });

    closeProcess.addEventListener('click', function () {
        processModal.classList.add('hidden');
        processModal.classList.remove('flex');
    });

    downloadPayslip.addEventListener('click', function () {
        if (!latestRunId) return;
        window.location.href = '?handler=PayslipPdf&runId=' + latestRunId;
    });

    payrollMode.addEventListener('change', modeChanged);
    setDefaultDates();
    modeChanged();
    loadEmployees();
})();
</script>
}
